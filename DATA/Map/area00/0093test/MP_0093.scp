//	MSG_EX("#S3#C0リーゼ「奇岩城のことは……|　　　　……何か分かりましたか…………、」",-1,2)
//
////　　リーゼ、言いかけて倒れてしまう。イベントが面倒な場合は画
////　　面ブラックアウトでもいいかも。
//
//	fade_in(40)
//	wait(80)
//	set_motion("Liese","EMPTY20",10)
//	fade_in(40)
//	wait(110)
//	set_motion("Liese","EMPTY19",0)
//
////　　駆け寄るエリックとアイラ。
//
//	set_deg_EX("Erick", "Liese")
//	set_deg_EX("Ira", "Liese")
//
//	MSG_EX("#S3#C0アイラ「リーゼ様っ！！」",-1,2)
//
//	fade_out(120)
//
//	wait(10)
//
//	INIT_WALK_DST("Erick")
//	set_walk_dst("Erick", 3.35,0.00,2.74)
//	set_walk_dst("Erick", 3.26,0.00,4.04)
//	set_walk_dst("Erick", 1.94,0.50,4.78)
//	set_walk_dst("Erick", 0.06,0.50,4.69)
//	walk_pos("Erick",1,0.06)
//
//	wait(10)
//
//	INIT_WALK_DST("Ira")
//	set_walk_dst("Ira", -3.75,0.0,1.00)
//	set_walk_dst("Ira", -3.75,0.0,4.75)
//	walk_pos("Ira",1,0.05)
//
//	wait(60)
//
//	MSG_EX("#S3#C0エリック「大丈夫ですか？」",-1,2)
//
//	MSG_EX("#S3#C0リーゼ「…………………………………………」",-1,2)
//	MSG_EX("#S3#C0リーゼ「すみません、大丈夫……|　　　　少し眩暈がしただけです……」",-1,2)
//
//	MSG_EX("#S3#C0エリック「いかん、お顔の色が……」",-1,2)
//	MSG_EX("#S3#C0エリック「……騎士殿、申し訳ありませんが|　　　　　しばらく席を外していただきましょう。」",-1,2)
//
//SKIP5:
//
//	game_flag_on(3701)
//
//	ENTRY_MAP("0097_0093")
//	ret

//--------------------------------------------------------------------

TALK4:
	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump TALK4_5

	// TK 持ち物がいっぱいで破魔矢をもらえなかった
	CHECK_GAME_FLAG(3612)
	OFF_JUMP TALK4_1

	CHECK_MAX_ITEM(0)
	ON_JUMP TALK4_4
	MSG("どうぞ、これを受け取って下さい。")
	JUMP TALK4_3

TALK4_1:
	MSG("騎士殿……どうです？|ガーディアンには慣れましたか？")
	MSG("シャルさんにお聞きしました。|遺跡の調査は順調のようですね。")

	CHECK_MAX_ITEM(0)
	OFF_JUMP TALK4_2

	MSG("そうですね……。")

TALK4_4:
	MSG("お渡ししたいものがありますので|荷物を整理してきてください。")

	// TK 持ち物がいっぱいで破魔矢をもらえなかった
	GAME_FLAG_ON(3612)
	ret

TALK4_2:
	MSG("そうそう、騎士殿に|これを差し上げましょう。")

TALK4_3:
	SE("SE_GETITEM")
//	SYS("#C2リーゼの破魔矢を手に入れた。")
	sys_ex("【リーゼの破魔矢】を手に入れた。",-1,0x00000200)
	GET_ITEM(191, 1)

	MSG("大した効果はありませんが、|私が作った御守りのようなものです。")
	MSG("騎士殿を手伝うわけにはいきませんが、|せめてこれくらいなら……")
	MSG("どうかご武運を。")

	game_flag_on(3610)
	ret

TALK4_5:
	MSG("騎士殿……すっかり|ご自分を取り戻されようですね。")
	MSG("今のあなたは見ていて|とても頼もしく思えます。")
	ret

//▼トレント戦後
TALK3:
	// 3620	TK B-4b トレント戦後のリーゼ会話
	check_game_flag(3620)
	on_jump TALK3_2

TALK3_1:
	MSG("その王冠は……")
	MSG("…………とても強い力を感じます。")
	MSG("もしかしたら奇岩城や聖剣と|関係があるものかもしれません。")
	MSG("それは騎士殿が|持ち歩いていたほうがいいでしょう。")
	game_flag_on(3620)
	jump EXIT

//　　★繰り返し
TALK3_2:
	MSG("騎士殿、体の調子はどうですか？")
	MSG("確かにあなたの時間は|限られていますが、一歩ずつ|進んでいくことが大切だと思います。")
	MSG("何かあったら、すぐに知らせて下さい。")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	check_room_flag(2)
	on_jump TALK2_2

TALK2_1:
	MSG("騎士殿……体調はいかがですか？")
	MSG("調査が終わり、北の遺跡に|出入りできるようになりました。")
	MSG("残念なことに事件の|手がかりは得られませんでしたが……")
	MSG("ただ、腕が立つことから|旅行者を殺害した犯人と騎士殿が|戦った剣士は同一人物かもしれません。")
	MSG("遺跡の探索を始めるのでしたら|くれぐれも気をつけて行くのですよ。")
	room_flag_on(0)
	jump EXIT

//　　★繰り返し
TALK2_2:
	MSG("……騎士殿の体は宿している|ガーディアンを替えることができます。")
	MSG("ガーディアンのカードを見つけたら|私のところへ持ってきて下さい。")
	MSG("色々と試してみるといいでしょう。")
	jump EXIT

TALK1:
	// GF[街外れの遺跡の話を聞いた]
	CHECK_GAME_FLAG(3512)
	ON_JUMP TALK1_3

TALK1_1:
	// TK リーゼと初めて話した
	CHECK_GAME_FLAG(3515)
	ON_JUMP TALK1_2

	GAME_FLAG_ON(3515)
	MSG("あなたは……")
	MSG("騎士殿とお見受けしますが、|当精霊堂にどのような御用でしょう？")
	MSG("…………奇岩城の手がかりを？")
	MSG("申し訳ありませんが、|北の遺跡は事件があったばかりで|調査が済むまで出入りは禁止です。")
	MSG("もう少し待って頂かないと……")
	ret
//　　※以降、繰り返し

TALK1_2:
	MSG("申し訳ありませんが、|北の遺跡は事件があったばかりで|調査が済むまで出入りは禁止です。")
	MSG("もう少し待って頂かないと……")
	ret

TALK1_3:
	// TK リーゼと初めて話した
	CHECK_GAME_FLAG(3515)
	ON_JUMP TALK1_4

	MSG("あなたは……")
	MSG("奇岩城を調べに来た騎士と|研究者がいると伺いましたが|どうやら、あなたのことのようですね。")
	MSG("私はこの精霊堂を預かる祭司です。|リーゼとお呼び下さい。")
	MSG("あいにく北の遺跡は|不幸な事件があったばかりで|調査が済むまで出入り禁止ですが……")
	GAME_FLAG_ON(3515)

TALK1_4:
	CHECK_GAME_FLAG(3516)
	ON_JUMP TALK1_5

	MSG("え……街外れの遺跡に入りたい？|どうして、あの場所のことを……")
	MSG("………………………………")
	MSG("……スペンスさんですね……|あの人にも困ったものです……")
	MSG("…………仕方ありません。")
	MSG("入っても構いませんが、|中にはモンスターが巣食っています。")
	MSG("十分に準備を整えてから|調査するようにお願いします。")

TALK1_5:
	CHECK_MAX_ITEM(0)
	ON_JUMP TALK1_6

	MSG("それでは遺跡の扉を開く|鍵をお渡ししておきましょう。")

	SE("SE_GETITEM")
	SYS("#C2リーゼは『街外れの遺跡の鍵』を差し出した。")
	GET_ITEM(200, 1)
	GAME_FLAG_ON(3517)

	room_flag_on(2)
	jump TALK1_8

TALK1_6:
	GAME_FLAG_ON(3516)
	MSG("遺跡の扉を開く鍵をお渡しするので、|荷物を整理してきてください。")
	ret

TALK1_8:
	check_room_flag(2)
	on_jump TALK1_9

//▽遺跡の鍵を手に入れた後&&一度屋外マップに出た
	MSG("騎士殿、遺跡探索のほうはどうですか？")
	MSG("レベルアップした場合、|始めのうちはボーナスポイントを早めに|能力値に割り振ったほうがいいでしょう。")
	MSG("レベルアップしたら、|忘れずにこの精霊堂を訪ねなさい。")

	ret

TALK1_9:
	MSG("騎士殿のように奇岩城を|調べに来る方は後を絶ちません。")
	MSG("中には遺跡に足を踏み入れたまま、|戻ってこない方もいらっしゃいます。")
	MSG("くれぐれもお気をつけて。")


EXIT:
	ret
}

//////////////////////////////////////////////////////////////////////
