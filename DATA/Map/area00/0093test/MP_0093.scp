// ============================================================================
// 寺院（初期化）
// ============================================================================


//-- ROOM_FLAG -------------------------------------------------------
// 0 エリック会話
// 1 アイラ会話
// 2 リーゼ会話
// 3 アプサラスを選んだ
// 4 メルクリウスを選んだ
// 5 リーフェルトを選んだ
// 6  ドヴォルザーク
// 7  ガンダルチュア
// 8  シュトゥルム
// 9  ベアトリーチェ
// 10 アバターラハ
// 11 ティオバルト
// 12 
// 13 
// 14 
// 15 

///////////////
DEF("MAP")
RES("INIT")
{

	// 店員とカウンターの関連付け
	link_ev_pop("Liese2","Liese")

	// シャルは基本的にいない
	HIDE_CHR("Char")

//--------------------------------------------------------------------
	// EV C-12 聖剣の巫女姫
	CHECK_GAME_FLAG(3711)
	OFF_JUMP NEXT2

	// リーゼいない
	HIDE_CHR("Liese")

	// フローレットにかわる
	ENTRY_CHR(0, 398)
	PUT_CHR( 0, "Fleurette",    0.00,0.50,3.23, 180)
	jump EXIT
//--------------------------------------------------------------------
NEXT2:
	// EV C-11 黒き花嫁
	CHECK_GAME_FLAG(3710)
	OFF_JUMP NEXT

	ENTRY_CHR(0, 398)
	ENTRY_CHR(1,  36)
	ENTRY_CHR(2,  37)
	ENTRY_CHR(3,  38)
	ENTRY_CHR(4,  39)
	ENTRY_CHR(5,  40)
	ENTRY_CHR(6,  41)
	PUT_CHR( 0, "Fleurette",    0.00,0.70, 8.50, 180)
	PUT_CHR( 1, "Avatarlaha",   1.35,0.25, 0.75, 240)
	PUT_CHR( 6, "Beatrice",    -2.10,0.00,-0.70,  95)
	PUT_CHR( 5, "Dvorak",       2.10,0.00,-0.70, 265)
	PUT_CHR( 2, "Tiowald",     -1.35,0.25, 0.75, 120)
	PUT_CHR( 3, "Sturm",       -2.20,0.00,-2.40,  90)
	PUT_CHR( 4, "Gandaltua",    2.20,0.00,-2.40, 270)
	load_npc_eqp(7,00)
	DVORAK(0)

	// リーゼいない
	HIDE_CHR("Liese")
	//HIDE_CHR("Liese2")
	jump EXIT
//--------------------------------------------------------------------
NEXT:
	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump EXIT
	// 1		カニグモを倒したか？
	check_game_flag( 1)
	off_jump EXIT

NO_LIESE:
	HIDE_CHR("Liese")
	HIDE_CHR("Liese2")
	jump EXIT

//--------------------------------------------------------------------

EXIT:
	END

}


//////////////////////////////////////////////////////////////////////
// リーゼロットイベント

DEF("Liese")

RES("INIT")
{

	// EV 赤子を抱いた母親
	check_game_flag(3514)
	on_jump NEXT

	jump EVENT1

//--------------------------------------------------------------------

NEXT:
	jump EXIT


//-- 赤子を抱いた母親の降霊の儀式 ------------------------------------

EVENT1:
	stop_bgm(1,0)

	ENTRY_CHR(7, 534)
	PUT_CHR( 7, "Mother1",    0.00,0.50, 2, 00)
	set_pos("Mother1",0,0.5,2)
	set_deg_ex("Mother1","Liese")
	set_deg_ex("Liese","Mother1")

	STOP_PC(0)
	set_motion("PC", "STAND",-1)
	set_deg_ex("PC","Mother1")
	look_chr("PC", "Mother1")

//　　精霊堂に入ると、祭司リーゼが降霊の儀式を行っているムービー。
//　　イベント専用ＮＰＣ(赤子を抱いた母親)が祭壇の前にかがんで
//　　いて、光に包まれている。
//　　以降、降霊の儀式イベント画面へ。
//　　以前あったイベントを流用します。
//    同じカメラが続いてしまうので、こっちのは若干あっさりめにしてみました（井

	set_skip_label("SKIP3")

	// SE再生
	SE("SE_EVENT_00")

	set_motion("Liese","EMPTY4",0)
	set_motion("Liese2","EMPTY1",0)

	CINEMA_ON(0)
	permit_script_camera(1)
	set_script_camera(0.12,0.50,-4.56,  -45.5,225.0,0.0, 12, 15.0)
	move_script_look_at(0.0,0.00,5.0, 200, 1)
	wait(200)

	fade_out(60)
	wait(100)

	permit_script_camera(1)
	set_script_camera_ex("Liese",1, -5,200,0, 5, 40)
	scale_script_camera( 1.2, 380, 0 )
	fade_in(60)
	wait(300)

	cross_fade(40)
	SET_SCRIPT_CAMERA( 0.2,0.5,1,  -60,-30,0, 6, 30 )
	scale_script_camera( 0.8, 360, 0 )
	wait(300)

	fade_out(60)
	wait(60)
	STOP_ENV_SE("SE_EVENT_00", 2000)
	wait(120)

//　　儀式が終わると、基本画面に戻して
//　　以下のメッセージを表示。

	set_pos("PC",1.24,0.50,-4.52)
	set_motion("Liese2","STAND",0)
	DELETE_EFC("Liese2")
	DELETE_EFC("Liese")
	set_motion("Liese","STAND",0)

	//座り老婆と挿げ替え
	HIDE_CHR("Mother1")
	ENTRY_CHR(8, 122)
	PUT_CHR( 8, "Mother2",    0.00,0.50, 2, 00)
	set_pos("Mother2",0,0.5,2)
	set_deg_ex("Mother2","Liese")
	LOOK_CHR("Mother2","Liese")
	LOOK_CHR("PC","Mother2")

	// BGM 戻す
	bgm(-1, 0, -1)
	set_script_camera_EX("Mother2",1,-45,225.0,0.0, 12, 15.0)
	fade_in(60)
	wait(60)

	MSG_EX("#S3#C0リーゼ「……これにて降霊の儀は終わりです。」",-1,2)
	MSG_EX("#S3#C0リーゼ「カードのガーディアンは|　　　　無事お子様の体に宿りました。」",-1,2)

	LOOK_CHR("Mother2","-")
	MSG_EX("#S3#C0母親「おお、坊や……よかったわね。」",-1,2)
	MSG_EX("#S3#C0母親「リーゼ殿、どうも|　　　ありがとうございました。」",-1,2)
	set_motion("Mother2","ATTACK2",30)
	WAIT(70)

	MSG_EX("#S3#C0リーゼ「いえ……お子様が心身ともに|　　　　健やかに成長することを願っています。」",-1,2)
	MSG_EX("#S3#C0リーゼ「新しき命の灯火に|　　　　ガーディアンの加護があらんことを。」",-1,2)
	WAIT(30)

//　　イベント後、親子が退場してプレイヤーに操作許可。

	INIT_WALK_DST("Mother2")
	set_walk_dst("Mother2", 0.07,0.50,-4.40)
	walk_pos("Mother2",0,0.02)
	move_script_look_at(0.0,0.00,-5.0, 200, 1)

	wait_walk("Mother2")

	se("SE_DOOR")
	switch_on("Door1")
	wait(60)

	INIT_WALK_DST("Mother2")
	set_walk_dst("Mother2", 0.07,0.50,-7.40)
	walk_pos("Mother2",0,0.02)

	fade_out(60)
	wait(60)

SKIP3:
	// BGM 戻す
	bgm(-1, 0, -1)
//	STOP_SE(0)
	STOP_ENV_SE("SE_EVENT_00")
	HIDE_CHR("Mother1")
	HIDE_CHR("Mother2")
	LOOK_CHR("PC","-")
	set_pos("PC",1.24,0.50,-4.52)
	set_motion("Liese2","STAND",0)
	DELETE_EFC("Liese2")
	DELETE_EFC("Liese")
	set_motion("Liese","STAND",0)

	// EV 赤子を抱いた母親
	game_flag_on(3514)

	FOCUS_CHR("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)
	fade_in(60)
	switch_off("Door1")
	end

EXIT:
	END

}

RES("CLICK")
{
	MSG_EX("#S3#C0リーゼ「こちらに入られては困ります、騎士殿。」",-1,2)
	end
}



























// "ガーディアンの変更" //////////////////////////////////////////////////
@change_card
{
//	call_shop(7)
	call_shop(5)
	ret
}

// "ボーナス割り振り" //////////////////////////////////////////////////
@division_bonus
{
	call_shop(6)
	ret
}

// "レベルダウン" //////////////////////////////////////////////////
@leveldown
{
	CHECK_LEVEL(2)
	OFF_JUMP NOT_LEVEL

	MSG("騎士殿は再び修練を|積みなおしたいと申しますか……")
	MSG("武器熟練度以外のステータスが|一つ前のレベルアップ時に戻されますよ。")
	MSG("それでも構いませんね？")
	SEL("レベルダウン|#c2レベルダウンする|やっぱりやめる")
	check_select(0)
	on_jump LEVEL

	ret

LEVEL:
	LEVEL_DOWN(0)
	sys("#c2レベルが下がりました。")
	MSG("退くのにも勇気を要するもの……|騎士殿の心意気は立派です。")
	ret

NOT_LEVEL:
	MSG("これ以上、能力値の解放を行えば、|騎士殿の自我が崩壊してしまいます。")
	MSG("さらなるレベルダウンは|考え直したほうがよいでしょう……")
	ret
}




// "カードの鑑定" ////////////////////////////////////////////////////////
@analyze_card
{
	check_card(0)
	on_jump analyze
	
	sys("カードが一枚も無い。")
	ret
	
analyze:
	call_shop(9)
	ret
}

// "ガーディアンの閲覧" //////////////////////////////////////////////////
@card_library
{
	call_shop(8)
	ret
}

///////////////
//-- リーゼロットの祭壇 ----------------------------------------------
DEF("Liese2")
RES("CLICK")
{
	// EV C-12 聖剣の巫女姫
	CHECK_GAME_FLAG(3711)
	OFF_JUMP NEXT2

//-- フローレバージョン ----------------------------------------------

	set_deg_ex("Fleurette","")
	active_chr("Fleurette")
	focus_chr("Fleurette")
	set_name("Fleurette","フローレット")

SelMenuF:
	SEL("ご用件は？|#c2話す|ガーディアンの降霊|パラメータ割り振り|レベルダウン|やめる")

	check_select(0)
	on_jump TALK2
	check_select(1)
	on_jump GURDIAN2
	check_select(2)
	on_jump BONUS2
	check_select(2)
	on_jump LEVEL2

	jump EXIT

// 会話
TALK2:
	call TALK_Fleurette
	jump SelMenuF

// "ガーディアンの変更"
GURDIAN2:
	call change_card
	jump SelMenuF

// "ボーナス"
BONUS2:
	call division_bonus
	jump SelMenuF

// "レベル"
LEVEL2:
	call leveldown
	jump SelMenuF

//-- リーゼバージョン ------------------------------------------------
NEXT2:

	set_deg_ex("Liese","")
	active_chr("Liese")
	focus_chr("Liese")
	set_name("Liese","リーゼ")
//	set_motion("Liese","ATTACK1",-1)

SelMenu:

	// EV C-4 相似の二人
	check_game_flag(3703)
	on_jump SelMenu3

//	// EV C-2 リーゼが倒れる
//	check_game_flag(3701)
//	on_jump SelMenu2

	//3622	EV B-9e インフェルノ倒した後、リーゼと話した
	check_game_flag(3622)
	on_jump SelMenu2

	// EV インフェルノを倒した
	check_game_flag(4)
	on_jump TALK

	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump SelMenu2

	// EV カニグモを倒した
	check_game_flag(1)
	on_jump TALK

	// 3531	EV 降霊の儀式本編
	check_game_flag(3531)
	on_jump SelMenu2

	// TK リーゼからカギをもらった
	check_game_flag(3517)
	on_jump SelMenu1

	// GF[街外れの遺跡の話を聞いた]
	CHECK_GAME_FLAG(3512)
	ON_JUMP TALK

	// TK リーゼと初めて話した
	check_game_flag(3515)
	off_jump TALK

SelMenu1:
//	SEL("【寺院メニュー】|#c2体のことを相談する|やめる")
//	check_select(0)
//	on_jump TALK

	SEL("ご用件は？|#c2話す|パラメータ割り振り|レベルダウン|やめる")
	check_select(0)
	on_jump TALK
	check_select(1)
	on_jump BONUS
	check_select(2)
	on_jump LEVEL
	jump EXIT

SelMenu2:
	SEL("ご用件は？|#c2話す|ガーディアンの降霊|パラメータ割り振り|レベルダウン|やめる")
	jump SelMenuCheck

SelMenu3:
	SEL("ご用件は？|#c2奇岩城の石像について聞く|ガーディアンの降霊|パラメータ割り振り|レベルダウン|やめる")
	jump SelMenuCheck

SelMenuCheck:
	check_select(0)
	on_jump TALK
	check_select(1)
	on_jump GURDIAN
	check_select(2)
	on_jump BONUS
	check_select(3)
	on_jump LEVEL

	jump EXIT


// 会話
TALK:
	call TALK_Liese
	jump SelMenu

// "ガーディアンの変更"
GURDIAN:
	call change_card
	jump SelMenu

// "ボーナス"
BONUS:
	call division_bonus
	jump SelMenu

// "レベル"
LEVEL:
	call leveldown
	jump SelMenu

EXIT:
	end
}

RES("INIT")
{
	// マップの回転角度を強制変更（所要時間 1 フレームで方向 6 に回転）
	RESET_MAP_ROT_Y(1,1)
}

//////////////////////////////////////////////////////////////////////
// フローレット会話

@TALK_Fleurette
{
	check_room_flag(2)
	on_jump TALK1_2

	MSG("確かに黒き花嫁は私の実姉ですが、|討つのに一片の迷いもありません。")
	MSG("あれは討つべき敵なのです……")
	MSG("騎士殿、私や導師たちも|できる限りの協力をさせて頂きます。")
	MSG("魔王ともども、黒き花嫁を滅ぼしましょう。")
	room_flag_on(2)
	ret

//　　※繰り返し
TALK1_2:
	MSG("確かに黒き花嫁は私の実姉ですが、|討つのに一片の迷いもありません。")
	MSG("あれは討つべき敵なのです……")
	ret
}

//////////////////////////////////////////////////////////////////////
// リーゼ会話

@TALK_Liese
{
//	//▼障壁消滅後
//	check_game_flag(3710)
//	on_jump TALK7
	//▼奇岩城出現後
	check_game_flag(3702)
	on_jump TALK6
	//▼インフェルノ戦後
	check_game_flag(4)
	on_jump TALK5
	//▼カニグモ戦後
	check_game_flag(1)
	on_jump TALK4
	//▼トレント戦後
	check_game_flag(3)
	on_jump TALK3
	//▼ガーディアン取得後
	check_game_flag(3532)
	on_jump TALK2
	// TK リーゼからカギをもらった
	check_game_flag(3517)
	on_jump TALK1_8

	jump TALK1

//--------------------------------------------------------------------

//▼奇岩城出現後
TALK6:
	game_flag_on(3622)
	// 3703	EV C-4 相似の二人
	check_game_flag(3703)
	on_jump TALK6_1

	MSG("騎士殿…………|ついに奇岩城が姿を現しましたね。")
	MSG("城の中に聖剣に関する|手がかりがきっとあるはずです。")
	MSG("何とか城内に入る|手立てがあるとよいのですが……")
	ret

TALK6_1:
	check_room_flag(2)
	on_jump TALK6_2

	MSG("………………………………")
	MSG("あれは…………")
	MSG("いえ……私には何とも……")
	room_flag_on(2)
	jump EXIT

//　　★繰り返し
TALK6_2:
	MSG("………………………………")
	jump EXIT

//▼インフェルノ戦後
TALK5:
	MSG("騎士殿…………|奇岩城はいつも霧の中に彷徨っています。")
	MSG("まるで私の心のよう……")
	MSG("いつか霧が晴れるとよいのですが……")
	//3622	EV B-9e インフェルノ倒した後、リーゼと話した
	game_flag_on(3622)
	jump EXIT

////　　イーグリット山のインフェルノを倒した後、精霊堂でリーゼに話
////　　しかけると強制的に発動。
//
//	cross_fade(60)
//	permit_script_camera(1)
//	set_script_camera_EX("Liese",1,-33,225.0,0.0, 12, 15.0)
//	CINEMA_ON(0)
