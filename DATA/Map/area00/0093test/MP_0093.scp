//--------------------------------------------------------------------

//▼障壁消滅後
TALK7:
	MSG("リーゼ様…………")
	jump EXIT
//▼奇岩城出現後
TALK6:
	MSG("あれが奇岩城……")
	MSG("さすがにみんな|驚かれているようですね……")
	jump EXIT
//▼インフェルノ戦後
TALK5:
	MSG("ご存知でしょうが、|リーゼ様はとても厳しい方です。")
	MSG("でも…………")
	MSG("それは本当の優しさがあってこその|厳しさだと思うんです。")
	jump EXIT
//▼カニグモ戦後
TALK4:
	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump TALK4_5
	MSG("リーゼ様なら外を|お散歩なさっていると思いますよ。")
	MSG("この時間でしたら湖の|ほとりにいらっしゃるかもしれません。")
	jump EXIT
//▽破魔矢イベント終了後
TALK4_5:
	MSG("遺跡の先にある魔粧の森を抜けると、|霊峰ハーレック山に至るそうです。")
	MSG("しかし、あの森は人を惑わす|恐ろしい森と聞いています……")
	MSG("騎士殿にガーディアンの|加護があらんことを……")
	jump EXIT
//▼トレント戦後
TALK3:
	MSG("島の遺跡にはまだまだ|私たちが存在すら知らない|ガーディアンがいるかもしれません。")
	MSG("宿すことが出来れば|心強い味方になると思うのですが……")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	MSG("遺跡の中を探索していると|ガーディアンを封じたカードを|入手することがあると思います。")
	MSG("カードそのものは|かなり昔に作られたものですが、|きちんと宿すことができるはずです。")
	MSG("新しいカードを手に入れたら、|リーゼ様にお渡し下さいね。")
	jump EXIT

//▽遺跡の鍵を手に入れた後
TALK1_5:
	check_room_flag(1)
	on_jump TALK1_6

	MSG("《レベルダウン》とは文字通り|自分のレベルを落とすことです。")
	MSG("この場合、全てが一つ前の|レベルアップ直後の状態に戻されます。")
	MSG("ただし、武器熟練度はそのままなので|少しだけ有利にやり直すことができます。")
	MSG("レベルはいくつでも|前に戻すことができるそうです。")
	MSG("もし極端な成長をしてしまい、|やり直したい時はお勧めですよ。")
	room_flag_on(1)
	jump EXIT

//　　★繰り返し
TALK1_6:
	MSG("《レベルダウン》とは文字通り|自分のレベルを落とすことです。")
	MSG("この場合、全てが一つ前の|レベルアップ直後の状態に戻されます。")
	MSG("ただし、武器熟練度はそのままなので|少しだけ有利にやり直すことができます。")
	jump EXIT

//▼ゲーム開始直後
TALK1:
	check_room_flag(1)
	on_jump TALK1_2

TALK1_1:
	MSG("この地方に生まれた|人間は精霊堂で《ガーディアン》を|授かるのが習わしです。")
	MSG("ガーディアンって何かですって？|そうですね……")
	MSG("いわば一人一人に宿っている|守護精霊のようなものです。")
	MSG("もちろん、私やリーゼ様にも|ガーディアンが宿っているんですよ。")
	room_flag_on(1)
	jump EXIT

//　　★繰り返し
TALK1_2:
	MSG("ガーディアンとは一人一人に|宿っている精霊のようなものです。")
	MSG("この地方に生まれた|人間は精霊堂で《ガーディアン》を|授かるのが習わしなのです。")
	jump EXIT

EXIT:
	SET_MOTION("Ira","STAND",-1)
	END
}













//////////////////////////////////////////////////////////////////////
// フローレットイベント

DEF("Fleurette")
RES("INIT")
{

	// EV C-12 聖剣の巫女姫
	CHECK_GAME_FLAG(3711)
	ON_JUMP EXIT

	// EV C-11 黒き花嫁
	CHECK_GAME_FLAG(3710)
	OFF_JUMP EXIT

//--------------------------------------------------------------------

//　　奇岩城内でリーゼロットとのイベントを終えて、精霊堂に入ると
//　　イベント開始。精霊堂の中にはフローレットと六人の導師たちが
//　　全員控えている。以下のような並び順。
//　　　 祭壇
//　　　　■
//　　　　○フ
//　　ア○　○テ
//　　ベ○　○シュ
//　　ド○　○ガ

	CINEMA_ON(0)
	STOP_PC(0)
	PC_WEAPON( 0 , 1 )
	INIT_SWITCH_ON("Door1")
	SET_DEG("PC", "0")

	BGM(18, 0, -1)

	look_chr("Beatrice","PC")
	look_chr("Tiowald","PC")
	look_chr("Sturm","PC")
	look_chr("Avatarlaha","PC")
	look_chr("Gandaltua","PC")
	look_chr("Dvorak","PC")

//初期カメラ設定
	permit_script_camera(1)
	set_script_camera(-0.09,0.50,-6.30,  -50,225.0,0.0, 10, 15.0)
	fade_in(120)
	wait(120)
	move_script_look_at(0,0,7.0, 200, 1)
	set_skip_label("SKIP")
	wait(200)

//各司祭台詞
	cross_fade(60)
	set_script_camera(2,-1,0.25,  -50,225.0,0.0, 12.5, 15.0)
	wait(60)

	look_chr("PC", "Beatrice")
	SET_MOTION("Beatrice", "ATTACK1",-1)
	MSG_EX("#S3#C0ベアトリーチェ「来たわね。」",-1,2)

	look_chr("PC", "Tiowald")
	SET_MOTION("Tiowald", "ATTACK1",-1)
	MSG_EX("#S3#C0ティオバルト「ご苦労じゃったな、#N0殿。」",-1,2)

	look_chr("PC", "Sturm")
	SET_MOTION("Sturm", "ATTACK1",-1)
	MSG_EX("#S3#C0シュトゥルム「ローレライを退けた力……見事だった。」",-1,2)

	look_chr("PC", "Avatarlaha")
	SET_MOTION("Avatarlaha", "ATTACK1",-1)
	MSG_EX("#S3#C0アバターラハ「どうぞ、こちらへいらして下さい。」",-1,2)

	LOOK_CHR("PC", "")
	INIT_WALK_DST("PC")
	set_walk_dst("PC", 0.00,0.00,-2.19)
	walk_pos("PC",0,0.03)
	wait(60)

	look_chr("PC", "Gandaltua")
	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C0ガンダルチュア「まずは礼を言わせてくれ。|　　　　　　　　よく奇岩城の障壁を解除してくれた。」",-1,2)
	MSG_EX("#S3#C0ガンダルチュア「一同皆、感謝してるぜ。」",-1,2)
	MSG_EX("#S3#C0ガンダルチュア「おかげで無鉄砲な|　　　　　　　　誰かさんも命拾いしたことだしな。」",-1,2)

	look_chr("PC", "Dvorak")
	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C0ドヴォルザーク「何だ……その……感謝している。」",-1,2)

	look_chr("PC", "Gandaltua")
	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C0ガンダルチュア「奇岩城では黒き花嫁と接触したようだな。」",-1,2)
	MSG_EX("#S3#C0ガンダルチュア「ならば、話は早い。|　　　　　　　　あんたに会ってもらいたい人がいるんだ。」",-1,2)

	stop_bgm(0, 1000)
	wait(30)

//フローレット歩いてくる
	cross_fade(30)
	set_script_camera(0.0,0.25,6,  -40,200,0,  10, 15.0)
	wait(30)
	wait_walk("PC")

	BGM(03, 0, -1)

	MSG_EX("#S3#C0白ローブの女性「お初にお目にかかります、騎士殿。」",-1,2)
	INIT_WALK_DST("Fleurette")
	set_walk_dst("Fleurette", 0, 0.5, 3.23)
	walk_pos("Fleurette",0,0.022)
	move_script_look_at(0,0,-0.5, 80, 1)
	look_chr("PC", "Fleurette")

	SET_DEG_EX("Dvorak", "PC")
	SET_DEG_EX("Sturm", "PC")
	SET_DEG_EX("Avatarlaha", "PC")
	SET_DEG_EX("Gandaltua", "PC")
	SET_DEG_EX("Beatrice", "PC")
	SET_DEG_EX("Tiowald", "PC")

	look_chr("Beatrice","-")
	look_chr("Tiowald","-")
	look_chr("Sturm","-")
	look_chr("Avatarlaha","-")
	look_chr("Gandaltua","-")
	look_chr("Dvorak","-")
	wait(80)

	cross_fade(30)
	set_script_camera(0,1.4,5.3,  0,265,0,  2.5, 15.0)
	move_script_look_at(0,0.1,-0.3, 190, 1)
	blur(1)
	wait(190)


//フローレット自己紹介
	cross_fade(30)
	set_script_camera(0,1.8,3.23,  3,180,0, 3.5, 15.0)
	SCALE_SCRIPT_CAMERA( 0.9, 1000, 1)
	set_pos("Fleurette",  0.00,0.50,3.23)
	look_chr("Fleurette", "PC")
	blur(0)
	wait(120)
	
	MSG_EX("#S3#C0白ローブの女性「私はザナドゥ第十四王朝の第二王女……」",-1,2)
	MSG_EX("#S3#C0フローレット「名をフローレットと申します。|　　　　　　　以後、お見知りおきを。」",-1,2)
	wait(30)
	stop_camera(0)


//わいわいがやがや
	cross_fade(60)
	set_script_camera(2,-1,0.25,  -50,225.0,0.0, 12.5, 15.0)
	wait(60)
	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C0ガンダルチュア「はは、さすがに驚いているな。」",-1,2)
	MSG_EX("#S3#C0ガンダルチュア「どこかで見た御顔だろ？」",-1,2)
	wait(40)
	MSG_EX("#S3#C0フローレット「驚かせて、ごめんなさい。」",-1,2)
	MSG_EX("#S3#C0フローレット「リーゼロット、いえ……|　　　　　　　黒き花嫁は私の双子の姉なのです。」",-1,2)
	wait(40)
	MSG_EX("#S3#C0ガンダルチュア「しかも、遺跡を調べてるなら|　　　　　　　　もう知ってるかもしれんが……」",-1,2)
	MSG_EX("#S3#C0ガンダルチュア「フローレット姫と言やぁ、|　　　　　　　　魔王ガルシスを倒したはずの英雄だ。」",-1,2)
	wait(40)
	look_chr("Fleurette", "Gandaltua")
	MSG_EX("#S3#C0フローレット「ガルシスを倒した？　私が！？」",-1,2)

	look_chr("Gandaltua","Fleurette")
	MSG_EX("#S3#C0ガンダルチュア「はは、俺も驚きました。」",-1,2)

	look_chr("Dvorak","Gandaltua")
	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C0ドヴォルザーク「茶化すな、話がややこしくなる上に|　　　　　　　　フローレット様に失礼であろう。」",-1,2)

	look_chr("Gandaltua","-")
	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C0ガンダルチュア「おお、コワいねぇ……」",-1,2)
	look_chr("Dvorak","-")

//謎明かし。
	cross_fade(60)
	set_script_camera_EX("Fleurette",1,  -20,180.0,0.0, 8, 15.0)
	look_chr("Fleurette", "PC")
	wait(90)

	MSG_EX("#S3#C0フローレット「……どうやら伝わっている|　　　　　　　歴史と事実は異なるようですね。」",-1,2)
	MSG_EX("#S3#C0フローレット「確かに私は魔王と戦いましたが|　　　　　　　英雄などと呼ばれる程の者ではありません。」",-1,2)
	MSG_EX("#S3#C0フローレット「順を追って説明させて頂きましょう。」",-1,2)
	MSG_EX("#S3#C0フローレット「……まず、ここに控えているのは私とともに|　　　　　　　魔王や黒き花嫁と戦った者たちです。」",-1,2)

	rotate_script_camera(10,0,0, 800, 1)

	SET_MOTION("Tiowald", "ATTACK1",-1)
	MSG_EX("#S3#C0ティオバルト「わしらはザナドゥに仕える|　　　　　　　七導師と呼ばれておった者たちじゃ。」",-1,2)
	MSG_EX("#S3#C0ティオバルト「元々はフローレット様とともに|　　　　　　　魔王を結界に封じるのが役目じゃった。」",-1,2)

	SET_MOTION("Sturm", "ATTACK1",-1)
	MSG_EX("#S3#C0シュトゥルム「時はおよそ５００年前に遡る……」",-1,2)
	MSG_EX("#S3#C0シュトゥルム「あれはフローレット様が|　　　　　　　巫女に選ばれた日のことだった。」",-1,2)
	MSG_EX("#S3#C0シュトゥルム「突如、リーゼロット姫が王城に|　　　　　　　封印されていた魔王を解き放った。」",-1,2)
	MSG_EX("#S3#C0シュトゥルム「そして、あろうことか|　　　　　　　その花嫁となることを宣言したのだ……」",-1,2)

	SET_MOTION("Fleurette", "ATTACK2",-1)
	MSG_EX("#S3#C0フローレット「七導師の一人、ローレライ……」",-1,2)
	MSG_EX("#S3#C0フローレット「病弱の姉君は彼女にそそのかされて、|　　　　　　　魔王の力に魅入られたのでしょう。」",-1,2)

	SET_MOTION("Beatrice", "ATTACK1",-1)
	MSG_EX("#S3#C0ベアトリーチェ「リーゼロット姫の身分は剥奪。|　　　　　　　　ただちに国王から追討令が下ったわ。」",-1,2)
	MSG_EX("#S3#C0ベアトリーチェ「私たちは魔王と国賊である黒き花嫁を|　　　　　　　　討つべく奇岩城に攻め入ったの……」",-1,2)

	SET_MOTION("Avatarlaha", "ATTACK1",-1)
	MSG_EX("#S3#C0アバターラハ「しかし、フローレット様が聖剣で|　　　　　　　魔王ガルシスを追い詰めた瞬間……」",-1,2)
	MSG_EX("#S3#C0アバターラハ「不覚にも我々は黒き花嫁に虚を衝かれ、|　　　　　　　《時》を奪われてしまいました。」",-1,2)

	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C0ガンダルチュア「俺たちがあちこちで石化してたのは|　　　　　　　　戦ってた最中に術をかけられたからだ。」",-1,2)
//	MSG_EX("#S3#C0ガンダルチュア「……ああ、あんなポーズで|　　　　　　　　カッコ悪いったら、ありゃしねぇ。」",-1,2)

	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C0ドヴォルザーク「そして、その術が今になって|　　　　　　　　こうして解けたというわけだ。」",-1,2)

	SET_MOTION("Fleurette", "ATTACK2",-1)
	MSG_EX("#S3#C0フローレット「しかし、眠りについている魔王も|　　　　　　　今再び呼び起こされようとしています。」",-1,2)
	MSG_EX("#S3#C0フローレット「黒き花嫁はこの国にも|　　　　　　　暗黒の時代を呼び寄せる気なのでしょう。」",-1,2)
	wait(60)
	look_chr("Tiowald", "Fleurette")
	MSG_EX("#S3#C0ティオバルト「………………………………」",-1,2)
	wait(60)
	MSG_EX("#S3#C0フローレット「ザナドゥはすでに滅びましたが、|　　　　　　　今度こそ黒き花嫁と魔王を討ちます。」",-1,2)
	MSG_EX("#S3#C0フローレット「それこそが、この時代に|　　　　　　　目覚めた我々の使命なのでしょう。」",-1,2)

	wait(60)
	cross_fade(60)
	set_script_camera(0.00,-0.00,-0.39,  -55,10.0,0.0, 15.0, 15.0)
	rotate_script_camera(0,-20,0, 1500, 1)
	wait(60)

	MSG_EX("#S3#C0フローレット「そして、騎士殿……」",-1,2)
	MSG_EX("#S3#C0フローレット「どうやら、あなたにも|　　　　　　　課された役目があるようなのです。」",-1,2)
	MSG_EX("#S3#C0フローレット「あなたは聖剣ドラゴンスレイヤーを|　　　　　　　求めているそうですね。」",-1,2)
	MSG_EX("#S3#C0フローレット「封印の巫女には二つの役目があります。」",-1,2)
	MSG_EX("#S3#C0フローレット「一つは命を削って|　　　　　　　魔王ガルシスを封印し続ける役目……」",-1,2)
	MSG_EX("#S3#C0フローレット「そして、もう一つは有事の際、|　　　　　　　資格ある者に聖剣を託す役目。」",-1,2)
	MSG_EX("#S3#C0フローレット「つまり封印の巫女とは|　　　　　　　聖剣継承者の選定者でもあるのです。」",-1,2)
	MSG_EX("#S3#C0フローレット「五百年前の戦いでは継承者が現れず、|　　　　　　　私自らが聖剣を手に戦いました。」",-1,2)
	MSG_EX("#S3#C0フローレット「ですが…………」",-1,2)

	wait(60)
	cross_fade(60)
	set_script_camera_EX("Fleurette",1,  -20,180.0,0.0, 8, 15.0)
	rotate_script_camera(10,0,0, 800, 1)
	wait(60)

	look_chr("Tiowald", "-")
	wait(60)
	MSG_EX("#S3#C0ティオバルト「先だって、天空に輝く三つの|　　　　　　　シリューガの星が一つに合わさった……」",-1,2)
	MSG_EX("#S3#C0ティオバルト「古来より、それこそが聖剣の|　　　　　　　継承者が現れた証とされておるのじゃ。」",-1,2)
	wait(60)
	MSG_EX("#S3#C0フローレット「騎士殿…………」",-1,2)
	MSG_EX("#S3#C0フローレット「私はあなたを聖剣継承者に選定し、|　　　　　　　ドラゴンスレイヤーを託します。」",-1,2)
	MSG_EX("#S3#C0フローレット「それ以上の事は申しません。」",-1,2)
	MSG_EX("#S3#C0フローレット「すでにあなたは黒き花嫁と縁があり、|　　　　　　　立ち向かう運命にあるようですから。」",-1,2)

	set_deg_EX("Tiowald", "Fleurette")
	MSG_EX("#S3#C0ティオバルト「フローレット様、それでは……」",-1,2)

	look_chr("Fleurette", "Tiowald")
	wait(40)
	MSG_EX("#S3#C0フローレット「ええ……」",-1,2)
	wait(80)
//	set_deg_EX("Fleurette", "Dvorak")
	look_chr("Fleurette", "Dvorak")
	MSG_EX("#S3#C0フローレット「ドヴォルザーク、|　　　　　　　《ザクリュイレス》をここに。」",-1,2)

	set_deg_EX("Dvorak", "Fleurette")
	MSG_EX("#S3#C0ドヴォルザーク「はっ。」",-1,2)

	look_chr("Fleurette", "PC")
	MSG_EX("#S3#C0フローレット「騎士殿、三つの|　　　　　　　クラウンを持っていますね？」",-1,2)
	MSG_EX("#S3#C0フローレット「それらをここへ……」",-1,2)

	fade_out(120)
	wait(180)


//クラウン→ドラスレイベント。エフェクトとか動きとか諸々決めうちで======================================================
//作ってるので、修正要望ある時は井上まで================================================================================
//======================================================================================================================

	MSG_EX("#S3#C0フローレット「レビック、クォージィ、タイロン、|　　　　　　　そしてザクリュイレス……」",-1,2)
	MSG_EX("#S3#C0フローレット「四つのクラウンはザナドゥの象徴であり、|　　　　　　　聖剣の封印を解くための鍵でもあります。」",-1,2)
	MSG_EX("#S3#C0フローレット「そして、この地に伝わる|　　　　　　　ガーディアンを身に宿す風習……」",-1,2)
	MSG_EX("#S3#C0フローレット「これはもともと私たち巫女が|　　　　　　　自らに施す術を応用したものなのです。」",-1,2)

	//邪魔なので位置変え
	set_pos("PC",  0,0.25,-2.5)

	set_pos("Avatarlaha",   2.2,0, 0.75)
	set_pos("Tiowald",     -2.2,0, 0.75)
	set_pos("Beatrice",    -2.2,0,-0.70)
	set_pos("Sturm",       -2.2,0,-2.40)
	set_pos("Dvorak",       2.2,0,-0.70)
	set_pos("Gandaltua",    2.2,0,-2.40)
	SET_DEG_EX("Avatarlaha", "Fleurette")
	SET_DEG_EX("Tiowald",    "Fleurette")
	SET_DEG_EX("Beatrice",   "Fleurette")
	SET_DEG_EX("Sturm",      "Fleurette")
	SET_DEG_EX("Dvorak",     "Fleurette")
	SET_DEG_EX("Gandaltua",  "Fleurette")

//カメラ
	set_script_camera(0,1.5,2,  -20,180,0, 10, 15.0)
	SCALE_SCRIPT_CAMERA( 0.8, 1000, 1)
	fade_in(120)
	SET_MOTION("Fleurette", "EMPTY4",0)
	SET_MOTION("Ds", "EMPTY1",0)
	SE(SE_EVENT_36)
	MSG_EX("#S3#C0フローレット「……太祖クーブラ・カーンの末裔なる|　　　　　　　我、フローレットが願い奉る……」",-1,2)
	MSG_EX("#S3#C0フローレット「太古に果てし竜狩人の英霊よ……」",-1,2)
	MSG_EX("#S3#C0フローレット「汝、姿成し、シリューガの光に|　　　　　　　導かれし使徒の刃とならん……」",-1,2)
//	MSG_EX("#S3#C0フローレット「……古の盟約により、我、フローレットと|　　　　　　　開祖クーブラ・カーンの名のもとに願い奉る……」",-1,2)
//	MSG_EX("#S3#C0フローレット「汝、姿成し、シリューガの|　　　　　　　光に導かれし使徒の干戈とならん……」",-1,2)

//ここで暗転しつつクラウンに光収束、空中で合体
	SE(SE_EVENT_37)
	SET_MOTION("Ds", "EMPTY2",0)
	wait(120)
	SET_MOTION("Ds", "EMPTY3",0)
	wait(60)
	SET_MOTION("Ds", "EMPTY4",0)
	wait(110)
	SE(SE_EVENT_38)
	wait(60)
	SET_MOTION("Ds", "EMPTY5",0)
	MSG_EX("#S3#C0フローレット「お出でなさい、我がガーディアン……」",-1,2)
	MSG_EX("#S3#C0フローレット「……ドラゴンスレイヤー。」",-1,2)

//クラウン、ドラスレへ
	cross_fade(30)
	set_script_camera(0,2.3,1.5,  -10,182,0, 3.5, 15.0)
	rotate_script_camera(0,-4,0, 500, 1)
	DELETE_EFC("Ds")
	SE(SE_EVENT_40)
	SET_MOTION("Ds", "EMPTY6",0)
	SE(SE_EVENT_39)
	wait(250)
//	SE(SE_EVENT_39)
	FADE_OUT_EX( 120, 1,"0xffffffff",0)
	wait(120)
	STOP_ENV_SE( "SE_EVENT_36", 2000 )
	wait(240)
	SE(SE_EVENT_41)

//ＰＣ剣を取る。
	set_script_camera(0,1.5,-0.25,  -30,180,0, 8, 15.0)
	SCALE_SCRIPT_CAMERA( 0.8, 1000, 1)
	SET_MOTION("Fleurette", "STAND",0)
	SET_MOTION("Ds", "EMPTY7",0)
	DELETE_EFC("Ds")
	DELETE_EFC("Fleurette")
	SET_DEG("Avatarlaha",-90)
	SET_DEG("Tiowald",  90)
	SET_DEG("Beatrice", 90)
	SET_DEG("Sturm",  90)
	SET_DEG("Dvorak",-90)
	SET_DEG("Gandaltua", -90)
	STOP_ENV_SE( "SE_EVENT_39",2000 )
	FADE_IN_EX( 60, 1,"0xffffffff",0)
	wait(150)

	MSG_EX("#S3#C0フローレット「これこそが魔王ガルシスと|　　　　　　　黒き花嫁を滅ぼせる唯一の聖剣……」",-1,2)
	MSG_EX("#S3#C0フローレット「騎士殿、どうぞお持ち下さい。」",-1,2)
	wait(100)
	INIT_WALK_DST("PC")
	set_walk_dst("PC", 0,0,-0.6)
	walk_pos("PC",0,0.03)
	wait(120)
	SET_MOTION("PC", "EMPTY7",40)
	wait(30)
	SE(SE_EVENT_42)
	FADE_OUT_EX( 20, 1,"0xffffffff",0)
	SCALE_SCRIPT_CAMERA( 0.3, 20, 1)
	blur(10)
	wait(40)
	blur(0)

	STOP_ENV_SE( "SE_EVENT_41",2000 )
	FADE_IN_EX( 20, 1,"0xffffffff",0)
	set_script_camera(0,1.5,-3.4,  2,-10,0,  2.6, 15)
	rotate_script_camera(-20,30,0, 1000, 0)
	DELETE_EFC("Ds")
	set_pos("Ds",  0,0.25,-0.495)
	set_pos("PC",  0,0.25,-2.85)

	SET_MOTION("Ds", "EMPTY8",0)
	SET_MOTION("PC", "EMPTY9",0)
	wait(300)
	wait(300)
	fade_out(120)
	wait(150)

	// 全部の効果音を止めちゃう
	STOP_SE(0)

//=====================================================================================================
//=====================================================================================================
//=====================================================================================================
//=====================================================================================================


//ドラスレ入手後会話
	PICK_ITEM(187)
	PICK_ITEM(188)
	PICK_ITEM(189)
	PICK_ITEM(190)
	GET_ITEM(36, 1)
	//いろいろ元に戻す
	SET_MOTION("Ds", "STAND",0)
	SET_MOTION("PC", "STAND",0)
	DELETE_EFC("Ds")
	set_pos("PC",  0,0,-0.5)
	set_pos("Avatarlaha",   1.35,0.25, 0.75)
	set_pos("Tiowald",     -1.35,0.25, 0.75)
	set_pos("Beatrice",    -2.1,0,-0.70)
	set_pos("Sturm",       -2.2,0,-2.40)
	set_pos("Dvorak",       2.1,0,-0.70)
	set_pos("Gandaltua",    2.2,0,-2.40)
	SET_DEG_EX("Avatarlaha", "PC")
	SET_DEG_EX("Tiowald",    "PC")
	SET_DEG_EX("Beatrice",   "PC")
	SET_DEG_EX("Sturm",      "PC")
	SET_DEG_EX("Dvorak",     "PC")
	SET_DEG_EX("Gandaltua",  "PC")
	set_script_camera(0.0,0.25,1.5,  -40,180.0,0.0, 13, 15.0)
	fade_in(120)
	wait(150)

	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C0ドヴォルザーク「おお……」",-1,2)
	MSG_EX("#S3#C0ドヴォルザーク「聖剣に認められたようだな……|　　　　　　　　これで貴公の体も元通りというわけだ。」",-1,2)

	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C0ガンダルチュア「めでたしめでたし、とはまだ言えんがな。」",-1,2)

	SET_MOTION("Fleurette", "ATTACK2",-1)
	MSG_EX("#S3#C0フローレット「黒き花嫁は魔王を出迎えるために|　　　　　　　奇岩城の奥へ向かったと思われます。」",-1,2)
	MSG_EX("#S3#C0フローレット「騎士殿も今から後を追うといいでしょう。」",-1,2)
	MSG_EX("#S3#C0フローレット「ここで行っていた儀式は今後全て|　　　　　　　このフローレットが承りますのでご安心を。」",-1,2)
	MSG_EX("#S3#C0フローレット「騎士殿……どうかご武運を。」",-1,2)

	BGM(-1, 0, -1)

	cross_fade(80)
	FOCUS_CHR("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)
	game_flag_on(3711)
	wait(60)
	END


SKIP:
	//後処理
	blur(0)
	PICK_ITEM(187)
	PICK_ITEM(188)
	PICK_ITEM(189)
	PICK_ITEM(190)
	GET_ITEM(36, 1)
	DELETE_EFC("Ds")
	DELETE_EFC("Fleurette")
	SET_MOTION("Ds", "STAND",0)
	SET_MOTION("Fleurette", "STAND",0)
	SET_MOTION("PC", "STAND",0)
	SET_MOTION("Avatarlaha", "STAND",0)
	SET_MOTION("Tiowald", "STAND",0)
	SET_MOTION("Beatrice", "STAND",0)
	SET_MOTION("Sturm", "STAND",0)
	SET_MOTION("Dvorak", "STAND",0)
	SET_MOTION("Gandaltua", "STAND",0)
	set_pos("Fleurette",  0.00,0.50,3.23)
	SET_DEG("Avatarlaha",180)
	set_pos("PC",  0,0,-0.5)
	SET_DEG("PC", 0)
	set_pos("Avatarlaha",  -1.35,0.25, 0.75)
	SET_DEG("Avatarlaha",90)
	set_pos("Tiowald",      1.35,0.25, 0.75)
	SET_DEG("Tiowald", -90)
	set_pos("Beatrice",    -2.1,0,-0.70)
	SET_DEG("Beatrice", 90)
	set_pos("Sturm",        2.1,0,-0.70)
	SET_DEG("Sturm", -90)
	set_pos("Dvorak",      -2.2,0,-2.40)
	SET_DEG("Dvorak", 90)
	set_pos("Gandaltua",    2.2,0,-2.40)
	SET_DEG("Gandaltua", -90)

	STOP_SE(0)
	BGM(-1, 0, -1)

	CINEMA_OFF(0)
	cross_fade(80)
	permit_script_camera(0)
	FOCUS_CHR("PC")
	game_flag_on(3711)
	fade_in(60)
	wait(60)

EXIT:
END
}

RES("CLICK")
{
	MSG_EX("#S3#C0フローレット「御用でしたら正面へおまわり下さい。」",-1,2)
end
}




DEF("Dvorak")
RES("CLICK")
{
	FOCUS_CHR("Dvorak")
	SET_NAME("Dvorak", "ドヴォルザーク")
	SET_MOTION("Dvorak", "ATTACK1",-1)

	check_room_flag(6)
	on_jump TALK2

	MSG("騎士よ、成長したものだ……")
	MSG("まさか、このような|状況が訪れようとはな……")
	MSG("想像していなかったわけではない。|だが、あまりにも早い。")
	MSG("憎しみではなく、功名心でもない……|何が貴公をして戦わしめるのか？")
	MSG("いつか酒でも酌み交わしながら|ゆっくり聞かせてもらいたいものだ。")
	room_flag_on(6)
	jump EXIT

//　　※繰り返し
TALK2:
	MSG("騎士よ、成長したものだ……")
	MSG("まさか、このような|状況が訪れようとはな……")

EXIT:
	SET_MOTION("Dvorak","STAND",-1)
	END
}

DEF("Gandaltua")
RES("CLICK")
{
	FOCUS_CHR("Gandaltua")
	SET_NAME("Gandaltua", "ガンダルチュア")
	SET_MOTION("Gandaltua", "ATTACK1",-1)

	check_room_flag(7)
	on_jump TALK2

	MSG("いよいよ決戦ってワケか……")
	MSG("俺たちもあんたの後を追って|奇岩城に乗り込むつもりだ。")
	MSG("せいぜい、あんたの足を|引っ張らないよう手助けさせてもらうぜ。")
	room_flag_on(7)
	jump EXIT

//　　※繰り返し
TALK2:
	MSG("俺たちもあんたの後を追って|奇岩城に乗り込むつもりだ。")
	MSG("せいぜい、あんたの足を|引っ張らないよう手助けさせてもらうぜ。")

EXIT:
	SET_MOTION("Gandaltua","STAND",-1)
	END
}

DEF("Sturm")
RES("CLICK")
{
	FOCUS_CHR("Sturm")
	SET_NAME("Sturm", "シュトゥルム")
	SET_MOTION("Sturm", "ATTACK1",-1)
	MSG("魔王が復活するまで|そう時間は残されていないはずだ……")
	MSG("急ぐがいい……")

EXIT:
	SET_MOTION("Sturm","STAND",-1)
	END
}

DEF("Beatrice")
RES("CLICK")
{
	FOCUS_CHR("Beatrice")
	SET_NAME("Beatrice", "ベアトリーチェ")
	SET_MOTION("Beatrice", "ATTACK1",-1)
	MSG("聖剣の勇者が現れたのはジュリデン王の|治世以来ということになるわね……")
	MSG("いけるかもしれない……|今度こそガルシスと黒き花嫁を……")

EXIT:
	SET_MOTION("Beatrice","STAND",-1)
	END
}

DEF("Avatarlaha")
RES("CLICK")
{
	FOCUS_CHR("Avatarlaha")
	SET_NAME("Avatarlaha", "アバターラハ")
	SET_MOTION("Avatarlaha", "ATTACK1",-1)
	MSG("騎士殿、魔王ガルシスの居城でもある|奇岩城はかなり大きな建物です。")
	MSG("十分に装備を整えて下さい。")

EXIT:
	SET_MOTION("Avatarlaha","STAND",-1)
	END
}

DEF("Tiowald")
