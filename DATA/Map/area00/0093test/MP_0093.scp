//精霊堂内の邪魔にならない場所へ配置|

DEF("Erick")
RES("CLICK")
{
	FOCUS_CHR("Erick")
	SET_NAME("Erick", "エリック")
	SET_MOTION("Erick","ATTACK1",-1)

	//▼障壁消滅後
	check_game_flag(3710)
	on_jump TALK7
	//▼奇岩城出現後
	check_game_flag(3702)
	on_jump TALK6
	//▼インフェルノ戦後
	check_game_flag(4)
	on_jump TALK5
	//▼カニグモ戦後
	check_game_flag(1)
	on_jump TALK4
	//▼トレント戦後
	check_game_flag(3)
	on_jump TALK3
	//▼ガーディアン取得後
	check_game_flag(3532)
	on_jump TALK2
	// TK リーゼからカギをもらった
	check_game_flag(3517)
	on_jump TALK1_5
	//▼ゲーム開始直後
	jump TALK1

//--------------------------------------------------------------------

//▼障壁消滅後
TALK7:
	MSG("…………………………")
	jump EXIT
//▼奇岩城出現後
TALK6:
	MSG("始まりましたか……")
	jump EXIT
//▼インフェルノ戦後
TALK5:
	MSG("騎士殿…………")
	MSG("私たちは何があってもリーゼ様を|信じてついていきたいと思っています。")
	jump EXIT
//▼カニグモ戦後
TALK4:
	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump TALK4_5
	MSG("騎士殿、リーゼ様なら|今はお出かけになっています。")
	MSG("街の中にいらっしゃると思うのですが……")
	jump EXIT
//▽破魔矢イベント終了後
TALK4_5:
	MSG("遥か昔からイーグリット山には|巨大な火焔の魔人が棲んでいると|耳にしたことがあります。")
	MSG("魔人はその巨大な剣で|火炎や溶岩を自在に操るとか……")
	jump EXIT
//▼トレント戦後
TALK3:
	MSG("騎士殿、ガーディアンは|体に馴染んできましたか？")
	MSG("……ガーディアンを身に宿す風習は|ずいぶん昔から行われてきました。")
	MSG("そう、このレイランドが|建国される、もっと以前から……")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	MSG("レベルアップした時点で|ボーナスポイントが余っている場合、|次のレベルに持ち越すことができます。")
	MSG("もし、急いで能力値を上げる|必要がないようでしたら、|持ち越すのも一つの手段ですよ。")
	MSG("後で強化したい能力値が出てきた場合、|余っているポイントで補えますから。")
	jump EXIT

//▽遺跡の鍵を手に入れた後
TALK1_5:
	check_room_flag(0)
	on_jump TALK1_6

	MSG("この精霊堂ではレベルアップで得た|《ボーナスポイント》を《能力値》に|割り振ることができるのです。")
	MSG("能力値は次のレベルアップまで|何度でも上げ下げすることが可能です。")
	MSG("敵との戦いが苦しいようであれば、|能力値を見直すのといいでしょう。")
	MSG("ただ、レベルアップしてしまうと|能力値はその地点で固定されるので|お気をつけて下さい。")
	room_flag_on(0)
	jump EXIT

//　　★繰り返し
TALK1_6:
	MSG("この精霊堂ではレベルアップで得た|《ボーナスポイント》を《能力値》に|割り振ることができるのです。")
	MSG("能力値は次のレベルアップまで|何度でも上げ下げすることが可能です。")
	jump EXIT

//▼ゲーム開始直後
TALK1:
	MSG("ここは《洗礼》や|《降霊の儀》を執り行う精霊堂です。")
	MSG("《能力値》の割り振りや|《レベルダウン》も承っておりますので|祭壇のリーゼ様にお話しかけ下さい。")
	jump EXIT

EXIT:
	SET_MOTION("Erick","STAND",-1)
	END
}

//////////////////////////////////////////////////////////////////////
// アイラ

// 精霊堂内の邪魔にならない場所へ配置|
DEF("Ira")
RES("CLICK")
{
	//▼障壁消滅後
