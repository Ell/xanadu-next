	SET_MOTION("Erick","ATTACK1",-1)

	//▼障壁消滅後
	check_game_flag(3710)
	on_jump TALK7
	//▼奇岩城出現後
	check_game_flag(3702)
	on_jump TALK6
	//▼インフェルノ戦後
	check_game_flag(4)
	on_jump TALK5
	//▼カニグモ戦後
	check_game_flag(1)
	on_jump TALK4
	//▼トレント戦後
	check_game_flag(3)
	on_jump TALK3
	//▼ガーディアン取得後
	check_game_flag(3532)
	on_jump TALK2
	// TK リーゼからカギをもらった
	check_game_flag(3517)
	on_jump TALK1_5
	//▼ゲーム開始直後
	jump TALK1

//--------------------------------------------------------------------

//▼障壁消滅後
TALK7:
	MSG("...")
	jump EXIT
//▼奇岩城出現後
TALK6:
	MSG("So it's begun...")
	jump EXIT
//▼インフェルノ戦後
TALK5:
	MSG("Knight...")
	MSG("...")
	MSG("Regardless of what happens,|I believe in Lady Liese.|I will follow her to the end...")
	jump EXIT
//▼カニグモ戦後
TALK4:
	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump TALK4_5
	MSG("Lady Liese has stepped out for the moment,|sir.")
	MSG("Though I believe she is still in town...")
	jump EXIT
//▽破魔矢イベント終了後
TALK4_5:
	MSG("Lady Liese has finally returned.")
	MSG("It may just be me, but she seemed to take|longer than usual today to return...")
	MSG("Ordinarily, she is quite punctual|when it comes to these things.")
	jump EXIT
//▼トレント戦後
TALK3:
	MSG("Have you adjusted to having|a Guardian, sir?")
	MSG("Our people have borne Guardians ever|since days of yore.")
	MSG("In fact, these bonds between us have existed since|long before the country of Leyland was even founded...")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	MSG("As your levels increase, any Bonus Points left|over will be carried to the next level.")
	MSG("If by chance you don't need to raise your stats,|then allowing them to carry over is an option.")
	MSG("If you wish to strengthen an ability later,|you'll be able to from the leftover points.")
	jump EXIT

//▽遺跡の鍵を手に入れた後
TALK1_5:
	check_room_flag(0)
	on_jump TALK1_6

	MSG("Within the Spirit Sanctum, you may allocate|[Bonus Points] earned by leveling up to your|[Attributes].")
	MSG("Until you have leveled up once more, there is no|limit to the times you can adjust those attributes.")
	MSG("If you're having difficulty besting your enemies,|it would be best to look over your attributes.")
	MSG("Do bear in mind, however, your attributes become|locked once you've leveled once more.")
	room_flag_on(0)
	jump EXIT

//　　★繰り返し
TALK1_6:
	MSG("Within the Spirit Sanctum, you may allocate|[Bonus Points] earned by leveling up to your|[Attributes].")
	MSG("Until you have leveled up once more, there is no|limit to the times you can adjust those attributes.")
	jump EXIT

//▼ゲーム開始直後
TALK1:
	MSG("Within these walls is where we conduct|[Baptisms] or [Spiritual Ceremonies].")
	MSG("Please speak with Lady Liese at the altar if|you wish to allocate your Bonus Points or|[Level Down].")
	jump EXIT

EXIT:
	SET_MOTION("Erick","STAND",-1)
	END
}

//////////////////////////////////////////////////////////////////////
