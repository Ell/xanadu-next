//--------------------------------------------------------------------

//▼障壁消滅後
TALK7:
	MSG("Lady Liese...")
	jump EXIT
//▼奇岩城出現後
TALK6:
	MSG("So Castle Strangerock has risen from the waters...")
	MSG("It's understandable that everyone is|caught off guard.")
	jump EXIT
//▼インフェルノ戦後
TALK5:
	MSG("As might be apparent,|Lady Liese is rather strict.")
	MSG("And yet...")
	MSG("I think underneath that stern demeanor|she is truly a compassionate person.")
	MSG("I respect Lady Liese a lot, not just as a priestess|of the Spirit Sanctum, but also as a woman.")
	jump EXIT
//▼カニグモ戦後
TALK4:
	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump TALK4_5
	MSG("If you're hoping to speak with Lady Liese,|I believe she's gone out for a stroll.")
	MSG("Around this time you may find|her by the lake.")
	jump EXIT
//▽破魔矢イベント終了後
TALK4_5:
	MSG("If you pass through the Trechier Woods,|which lay at the edge of the ruins,|you'll reach the sacred Eaglet Mountain.")
	MSG("But I should warn you, Sir Knight. I've heard many|tales of that perilous forest. Those who brave its|reaches become lost and confused...")
	MSG("If you were to venture in there without the|divine protection of a Guardian, then...")
	jump EXIT
//▼トレント戦後
TALK3:
	MSG("There might be more Guardians|hidden amongst the ruins|that even WE'VE never heard of.")
	MSG("If you happen to come across one,|they might be a valuable ally...")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	MSG("While scouring the ruins you might|come across a Guardian Card|which was sealed away.")
	MSG("Even though the card might be old, I'm sure|you'd be able to find some use for it.")
	MSG("So if you find a new card,|please bring it to Lady Liese.")
	jump EXIT

//▽遺跡の鍵を手に入れた後
TALK1_5:
	check_room_flag(1)
	on_jump TALK1_6

	MSG("To [Level Down] is to reduce your|overall strength.")
	MSG("In your case, both attributes and Bonus Points|would be reverted to what they were one level ago.")
	MSG("Of note, though, your weapon skills would stay|what they were, and the needed experience to|reach the level again would be reduced by 50%.")
	MSG("It offers just a little edge|when having to do it over again.")
	MSG("You can revert back to any of your|previous levels this way.")
	MSG("If you want to truly excel,|I'd advise using this method.")
	room_flag_on(1)
	jump EXIT

//　　★繰り返し
TALK1_6:
	MSG("To [Level Down] is to reduce your|overall strength.")
	MSG("In your case, both attributes and Bonus Points|would be reverted to what they were one level ago.")
	MSG("Of note, though, your weapon skills would stay|what they were, and the needed experience to|reach the level again would be reduced by 50%.")
	jump EXIT

//▼ゲーム開始直後
TALK1:
	check_room_flag(1)
	on_jump TALK1_2

TALK1_1:
	MSG("Receiving a [Guardian] from the Spirit Sanctum|is a custom that people have followed since|this land was settled.")
	MSG("What are Guardians, you ask?|Hmm, well...")
	MSG("They're kind of like spirits which|protect each and every one of us.")
	MSG("Of course, Lady Liese and|I both have Guardians.")
	room_flag_on(1)
	jump EXIT

//　　★繰り返し
TALK1_2:
	MSG("Guardians are kind of like spirits|which protect each and every one of us.")
	MSG("Receiving a [Guardian] from the Spirit Sanctum|is a custom that people have followed since|this land was settled.")
	jump EXIT

EXIT:
	SET_MOTION("Ira","STAND",-1)
	END
}













//////////////////////////////////////////////////////////////////////
// フローレットイベント

DEF("Fleurette")
RES("INIT")
{

	// EV C-12 聖剣の巫女姫
	CHECK_GAME_FLAG(3711)
	ON_JUMP EXIT

	// EV C-11 黒き花嫁
	CHECK_GAME_FLAG(3710)
	OFF_JUMP EXIT

//--------------------------------------------------------------------

//　　奇岩城内でリーゼロットとのイベントを終えて、精霊堂に入ると
//　　イベント開始。精霊堂の中にはフローレットと六人の導師たちが
//　　全員控えている。以下のような並び順。
//　　　 祭壇
//　　　　■
//　　　　○フ
//　　ア○　○テ
//　　ベ○　○シュ
//　　ド○　○ガ

	CINEMA_ON(0)
	STOP_PC(0)
	PC_WEAPON( 0 , 1 )
	INIT_SWITCH_ON("Door1")
	SET_DEG("PC", "0")

	BGM(18, 0, -1)

	look_chr("Beatrice","PC")
	look_chr("Tiowald","PC")
	look_chr("Sturm","PC")
	look_chr("Avatarlaha","PC")
	look_chr("Gandaltua","PC")
	look_chr("Dvorak","PC")

//初期カメラ設定
	permit_script_camera(1)
	set_script_camera(-0.09,0.50,-6.30,  -50,225.0,0.0, 10, 15.0)
	fade_in(120)
	wait(120)
	move_script_look_at(0,0,7.0, 200, 1)

//ドラスレ２本ゲットを回避するために最初に取り引き
	PICK_ITEM(187)
	PICK_ITEM(188)
	PICK_ITEM(189)
	PICK_ITEM(190)
	GET_ITEM(36, 1)


	set_skip_label("SKIP")
	wait(200)

//各司祭台詞
	cross_fade(60)
	set_script_camera(2,-1,0.25,  -50,225.0,0.0, 12.5, 15.0)
	wait(60)

	look_chr("PC", "Beatrice")
	SET_MOTION("Beatrice", "ATTACK1",-1)
	MSG_EX("#S3#C3Beatrice|#C0So you've arrived.",-1,2)

	look_chr("PC", "Tiowald")
	SET_MOTION("Tiowald", "ATTACK1",-1)
	MSG_EX("#S3#C3Theobald|#C0That was quite the perilous task,|indeed, Sir #N0.",-1,2)

	look_chr("PC", "Sturm")
	SET_MOTION("Sturm", "ATTACK1",-1)
	MSG_EX("#S3#C3Sturm|#C0You had the strength to beat back Lorelei...|Simply splendid.",-1,2)

	look_chr("PC", "Avatarlaha")
	SET_MOTION("Avatarlaha", "ATTACK1",-1)
	MSG_EX("#S3#C3Abhidharma|#C0If you would, please step forward.",-1,2)

	LOOK_CHR("PC", "")
	INIT_WALK_DST("PC")
	set_walk_dst("PC", 0.00,0.00,-2.19)
	walk_pos("PC",0,0.03)
	wait(60)

	look_chr("PC", "Gandaltua")
	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C3Gandharva|#C0Allow me to first congratulate you. Splendid work|on releasing the barrier around Castle Strangerock.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0Everyone wishes to express their gratitude.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0Thanks to your actions, a certain reckless someone|was able to continue on with their life.",-1,2)

	look_chr("PC", "Dvorak")
	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C3Dvorak|#C0Come now...|I AM rather grateful.",-1,2)

	look_chr("PC", "Gandaltua")
	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C3Gandharva|#C0It seems you also came into contact with|the Black Bride while inside Castle Strangerock.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0Very well, then, I shall make this quick.|There is someone who wishes to see you.",-1,2)

	stop_bgm(0, 1000)
	wait(30)

//フローレット歩いてくる
	cross_fade(30)
	set_script_camera(0.0,0.25,6,  -40,200,0,  10, 15.0)
	wait(30)
	wait_walk("PC")

	BGM(03, 0, -1)

	MSG_EX("#S3#C3Female Voice|#C0It is a pleasure to meet you, brave knight.",-1,2)
	INIT_WALK_DST("Fleurette")
	set_walk_dst("Fleurette", 0, 0.5, 3.23)
	walk_pos("Fleurette",0,0.022)
	move_script_look_at(0,0,-0.5, 80, 1)
	look_chr("PC", "Fleurette")

	SET_DEG_EX("Dvorak", "PC")
	SET_DEG_EX("Sturm", "PC")
	SET_DEG_EX("Avatarlaha", "PC")
	SET_DEG_EX("Gandaltua", "PC")
	SET_DEG_EX("Beatrice", "PC")
	SET_DEG_EX("Tiowald", "PC")

	look_chr("Beatrice","-")
	look_chr("Tiowald","-")
	look_chr("Sturm","-")
	look_chr("Avatarlaha","-")
	look_chr("Gandaltua","-")
	look_chr("Dvorak","-")
	wait(80)

	cross_fade(30)
	set_script_camera(0,1.4,5.3,  0,265,0,  2.5, 15.0)
	move_script_look_at(0,0.1,-0.3, 190, 1)
	blur(10)
	wait(190)


//フローレット自己紹介
	cross_fade(30)
	set_script_camera(0,1.8,3.23,  3,180,0, 3.5, 15.0)
	SCALE_SCRIPT_CAMERA( 0.9, 1000, 1)
	set_pos("Fleurette",  0.00,0.50,3.23)
	look_chr("Fleurette", "PC")
	blur(0)
	wait(120)
	
	MSG_EX("#S3#C3White Robed Female|#C0I am the second princess of|the 14th Dynasty of Xanadu...",-1,2)
	MSG_EX("#S3#C3White Robed Female|#C0You may call me Fleurette.|There is no need for the formalities.",-1,2)
	wait(30)
	stop_camera(0)


//わいわいがやがや
	cross_fade(60)
	set_script_camera(2,-1,0.25,  -50,225.0,0.0, 12.5, 15.0)
	wait(60)
	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C3Gandharva|#C0Haha, you seem quite shocked.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0Have you perchance met somewhere before?",-1,2)
	wait(40)
	MSG_EX("#S3#C3Fleurette|#C0My apologizes for surprising you.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Lieselotte...the Black Bride, rather,|is my twin sister.",-1,2)
	wait(40)
	MSG_EX("#S3#C3Gandharva|#C0If you have traversed the ruins and unearthed|its secrets, then you likely already know this,|but...",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0Princess Fleurette is said to have been|the hero who defeated the devil Galsis.",-1,2)
	wait(40)
	look_chr("Fleurette", "Gandaltua")
	MSG_EX("#S3#C3Fleurette|#C0...Galsis was defeated?",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0By me?",-1,2)

	look_chr("Gandaltua","Fleurette")
	MSG_EX("#S3#C3Gandharva|#C0Haha! I share your surprise, my lady.",-1,2)

	look_chr("Dvorak","Gandaltua")
	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C3Dvorak|#C0Enough of this foolery. Allow Princess Fleurette|the courtesy of explaining.",-1,2)

	look_chr("Gandaltua","-")
	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C3Gandharva|#C0My my, how strict...",-1,2)
	look_chr("Dvorak","-")

//謎明かし。
	cross_fade(60)
	set_script_camera_EX("Fleurette",1,  -20,180.0,0.0, 8, 15.0)
	look_chr("Fleurette", "PC")
	wait(90)

	MSG_EX("#S3#C3Fleurette|#C0Ummm... It seems the truth differs|from that which was recorded in history.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0While I did do battle with the dragon,|I have no right to be called a hero.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Allow me to start from the beginning.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Firstly, all of those gathered here fought with me|against both the Black Bride and her Dragon King.",-1,2)

	rotate_script_camera(10,0,0, 800, 1)

	SET_MOTION("Tiowald", "ATTACK1",-1)
	MSG_EX("#S3#C3Theobald|#C0Hmmhmm, we live but to serve.|We were named the 'Seven Sages' by the people,|after all.",-1,2)
	MSG_EX("#S3#C3Theobald|#C0Our original role was to aid Princess Fleurette|and assist in sealing off the Dragon King.",-1,2)

	SET_MOTION("Sturm", "ATTACK1",-1)
	MSG_EX("#S3#C3Sturm|#C0This tale goes back 500 years...",-1,2)
	MSG_EX("#S3#C3Sturm|#C0That was when Princess Fleurette|was chosen to become a Sacred Maiden.",-1,2)
	MSG_EX("#S3#C3Sturm|#C0Without warning, Princess Lieselotte went|into the castle and released the seal binding|the Dragon King.",-1,2)
	MSG_EX("#S3#C3Sturm|#C0And thus, perhaps by doing so, she|came to be known as the Black Bride.",-1,2)

	SET_MOTION("Fleurette", "ATTACK2",-1)
	MSG_EX("#S3#C3Fleurette|#C0One of the Seven Sages, Lorelei...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0My beloved sister coerced her,|lost amidst the gaze of the devil's power.",-1,2)

	SET_MOTION("Beatrice", "ATTACK1",-1)
	MSG_EX("#S3#C3Beatrice|#C0Princess Lieselotte was stripped of her royal ties.|This declaration was made by the king almost immediately.",-1,2)
	MSG_EX("#S3#C3Beatrice|#C0Our mission was to breach Castle Strangerock to|kill the dragon and traitorous Black Bride both...",-1,2)

	SET_MOTION("Avatarlaha", "ATTACK1",-1)
	MSG_EX("#S3#C3Abhidharma|#C0However, the moment Galsis was cornered|and Lady Fleurette raised the Sacred Sword|to strike him down...",-1,2)
	MSG_EX("#S3#C3Abhidharma|#C0We were caught unawares by the Black Bride,|and our 'time' was stolen from us.",-1,2)

	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C3Gandharva|#C0The sorcery she cast upon us at this|crucial moment petrified us left and right.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0It was horrible. To be frozen in such a pose...|How embarrassing.",-1,2)

	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C3Dvorak|#C0It was a potent magic that lasted an age,|but over time its power dwindled and now|we are freed.",-1,2)

	SET_MOTION("Fleurette", "ATTACK2",-1)
	MSG_EX("#S3#C3Fleurette|#C0But now, though the great beast too|has been slumbering these many years,|she seeks to wake him.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0I sense that the Black Bride is trying to summon|an era of darkness upon this country, as well.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Despite Xanadu having long been laid to|ruin, that fact is unlikely to stop them.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Perhaps because of that, we were awoken|in this era to fulfill our mission.",-1,2)
	wait(60)
	look_chr("Tiowald", "Fleurette")
	MSG_EX("#S3#C3Theobald|#C0...",-1,2)
	wait(60)

	wait(60)
	cross_fade(60)
	set_script_camera(0.00,-0.00,-0.39,  -55,10.0,0.0, 15.0, 15.0)
	rotate_script_camera(0,-20,0, 1500, 1)
	wait(60)

	MSG_EX("#S3#C3Fleurette|#C0Be advised, brave knight...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0It would seem that you, too, have|an important role to play here.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Your search for the Sacred Sword,|Dragonslayer, assures us of this.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0The Maiden's Seal serves two functions.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0The first purpose is to imprison|Galsis...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Although, in troubled times it does perform one more task.|That is, to entrust a worthy person with the Sacred Sword.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0What this means is that the Maiden's Seal|serves to select the Sacred Sword's inheritor.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0No inheritor was revealed those 500 years ago,|so I took up the Sacred Sword myself.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0But, this time...",-1,2)

	wait(60)
	cross_fade(60)
	set_script_camera_EX("Fleurette",1,  -20,180.0,0.0, 8, 15.0)
	rotate_script_camera(10,0,0, 800, 1)
	wait(60)

	look_chr("Tiowald", "-")
	wait(60)
	MSG_EX("#S3#C3Theobald|#C0It is said that when the three stars of the|Dragon's Fang shine as one in the sky, a suitable|successor of the Sacred Sword will come forth...",-1,2)
	MSG_EX("#S3#C3Theobald|#C0In ancient times, this sign was the proof|that the Sacred Sword's successor had appeared.",-1,2)
	wait(60)
	MSG_EX("#S3#C3Fleurette|#C0This time a person of strength and|merit has appeared before us.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Brave knight, I...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0I wish to entrust the Dragonslayer to you,|for YOU are the rightful successor.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Nothing more needs to be said.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0You already seem destined to be the one|who shall confront the Black Bride.",-1,2)

	set_deg_EX("Tiowald", "Fleurette")
	MSG_EX("#S3#C3Theobald|#C0Princess, do you mean to say...",-1,2)

	look_chr("Fleurette", "Tiowald")
	wait(40)
	MSG_EX("#S3#C3Fleurette|#C0With certainty.",-1,2)
	wait(80)
//	set_deg_EX("Fleurette", "Dvorak")
	look_chr("Fleurette", "Dvorak")
	MSG_EX("#S3#C3Fleurette|#C0Dvorak, the [Zagreus].",-1,2)

	set_deg_EX("Dvorak", "Fleurette")
	MSG_EX("#S3#C3Dvorak|#C0Yes, milady.",-1,2)

	look_chr("Fleurette", "PC")
	MSG_EX("#S3#C3Fleurette|#C0Brave knight, have you found|the other three crowns?",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Bring them to me.",-1,2)

	fade_out(120)
	wait(180)


//クラウン→ドラスレイベント。エフェクトとか動きとか諸々決めうちで======================================================
//作ってるので、修正要望ある時は井上まで================================================================================
//======================================================================================================================

	MSG_EX("#S3#C3Fleurette|#C0Rebick, Quoxi, Tairone,|and Zagreus...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0These four crowns are the symbols of Xanadu,|and within them is hidden the key to the|Sacred Sword's seal.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0And thus, as custom requires, I shall channel|the Guardian within myself through the earth...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0The original purpose of the Sacred Maidens|was to wield this blessed magic.",-1,2)

	//邪魔なので位置変え
	set_pos("PC",  0,0.25,-2.5)

	set_pos("Avatarlaha",   2.2,0, 0.75)
	set_pos("Tiowald",     -2.2,0, 0.75)
	set_pos("Beatrice",    -2.2,0,-0.70)
	set_pos("Sturm",       -2.2,0,-2.40)
	set_pos("Dvorak",       2.2,0,-0.70)
	set_pos("Gandaltua",    2.2,0,-2.40)
	SET_DEG_EX("Avatarlaha", "Fleurette")
	SET_DEG_EX("Tiowald",    "Fleurette")
	SET_DEG_EX("Beatrice",   "Fleurette")
	SET_DEG_EX("Sturm",      "Fleurette")
	SET_DEG_EX("Dvorak",     "Fleurette")
	SET_DEG_EX("Gandaltua",  "Fleurette")

//カメラ
	set_script_camera(0,1.5,2,  -20,180,0, 10, 15.0)
	SCALE_SCRIPT_CAMERA( 0.8, 1000, 1)
	fade_in(120)
	SET_MOTION("Fleurette", "EMPTY4",0)
	SET_MOTION("Ds", "EMPTY1",0)
	SE(SE_EVENT_36)
	MSG_EX("#S3#C3Fleurette|#C0As a descendant of Kublai Khan|I, Fleurette, beseech you...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Oh ancient and immortal dragon spirit...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Appear and let thy sacred blade|be bathed in the Great Dragon's light...",-1,2)
//	MSG_EX("#S3#C0フローレット「……古の盟約により、我、フローレットと|　　　　　　　開祖クーブラ・カーンの名のもとに願い奉る……」",-1,2)
//	MSG_EX("#S3#C0フローレット「汝、姿成し、シリューガの|　　　　　　　光に導かれし使徒の干戈とならん……」",-1,2)

//ここで暗転しつつクラウンに光収束、空中で合体
	SE(SE_EVENT_37)
	SET_MOTION("Ds", "EMPTY2",0)
	wait(120)
	SET_MOTION("Ds", "EMPTY3",0)
	wait(60)
	SET_MOTION("Ds", "EMPTY4",0)
	wait(110)
	SE(SE_EVENT_38)
	wait(60)
	SET_MOTION("Ds", "EMPTY5",0)
	MSG_EX("#S3#C3Fleurette|#C0Show yourself to us, my Guardian...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0...The Dragonslayer.",-1,2)

//クラウン、ドラスレへ
	cross_fade(30)
	set_script_camera(0,2.3,1.5,  -10,182,0, 3.5, 15.0)
	rotate_script_camera(0,-4,0, 500, 1)
	DELETE_EFC("Ds")
	SE(SE_EVENT_40)
	SET_MOTION("Ds", "EMPTY6",0)
	SE(SE_EVENT_39)
	wait(250)
//	SE(SE_EVENT_39)
	FADE_OUT_EX( 120, 1,"0xffffffff",0)
	wait(120)
	STOP_ENV_SE( "SE_EVENT_36", 2000 )
	wait(240)
	SE(SE_EVENT_41)

//ＰＣ剣を取る。
	set_script_camera(0,1.5,-0.25,  -30,180,0, 8, 15.0)
	SCALE_SCRIPT_CAMERA( 0.8, 1000, 1)
	SET_MOTION("Fleurette", "STAND",0)
	SET_MOTION("Ds", "EMPTY7",0)
	DELETE_EFC("Ds")
	DELETE_EFC("Fleurette")
	SET_DEG("Avatarlaha",-90)
	SET_DEG("Tiowald",  90)
	SET_DEG("Beatrice", 90)
	SET_DEG("Sturm",  90)
	SET_DEG("Dvorak",-90)
	SET_DEG("Gandaltua", -90)
	STOP_ENV_SE( "SE_EVENT_39",2000 )
	FADE_IN_EX( 60, 1,"0xffffffff",0)
	wait(150)

	MSG_EX("#S3#C3Fleurette|#C0Only this weapon is capable of defeating|Dragon King Galsis and the Black Bride...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Brave knight, please take hold of it.",-1,2)
	wait(100)
	INIT_WALK_DST("PC")
	set_walk_dst("PC", 0,0,-0.6)
	walk_pos("PC",0,0.03)
	wait(120)
	SET_MOTION("PC", "EMPTY7",40)
	wait(30)
	SE(SE_EVENT_42)
	FADE_OUT_EX( 20, 1,"0xffffffff",0)
	SCALE_SCRIPT_CAMERA( 0.3, 20, 1)
	blur(10)
	wait(40)
	blur(0)

	STOP_ENV_SE( "SE_EVENT_41",2000 )
	FADE_IN_EX( 20, 1,"0xffffffff",0)
	set_script_camera(0,1.5,-3.4,  2,-10,0,  2.6, 15)
	rotate_script_camera(-20,30,0, 1000, 0)
	DELETE_EFC("Ds")
	set_pos("Ds",  0,0.25,-0.495)
	set_pos("PC",  0,0.25,-2.85)

	SET_MOTION("Ds", "EMPTY8",0)
	SET_MOTION("PC", "EMPTY9",0)
	wait(300)
	wait(300)
	fade_out(120)
	wait(150)

	// 全部の効果音を止めちゃう
	STOP_SE(0)

//=====================================================================================================
//=====================================================================================================
//=====================================================================================================
//=====================================================================================================


//ドラスレ入手後会話
//	PICK_ITEM(187)
//	PICK_ITEM(188)
//	PICK_ITEM(189)
//	PICK_ITEM(190)
//	GET_ITEM(36, 1)
	//いろいろ元に戻す
	SET_MOTION("Ds", "STAND",0)
	SET_MOTION("PC", "STAND",0)
	DELETE_EFC("Ds")

	set_pos("PC",  0,0,-0.5)
	set_pos("Avatarlaha",   1.35,0.25, 0.75)
	set_pos("Tiowald",     -1.35,0.25, 0.75)
	set_pos("Beatrice",    -2.1,0,-0.70)
	set_pos("Sturm",       -2.2,0,-2.40)
	set_pos("Dvorak",       2.1,0,-0.70)
	set_pos("Gandaltua",    2.2,0,-2.40)
	SET_DEG_EX("Avatarlaha", "PC")
	SET_DEG_EX("Tiowald",    "PC")
	SET_DEG_EX("Beatrice",   "PC")
	SET_DEG_EX("Sturm",      "PC")
	SET_DEG_EX("Dvorak",     "PC")
	SET_DEG_EX("Gandaltua",  "PC")

	

	set_script_camera(0.0,0.25,1.5,  -40,180.0,0.0, 13, 15.0)
	fade_in(120)
	wait(150)

	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C3Dvorak|#C0'Tis truly amazing...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0The Sacred Sword has accepted you...|Its noble form has returned at last.",-1,2)

	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C3Gandharva|#C0'Tis too early to be praising the heavens.",-1,2)

	SET_MOTION("Fleurette", "ATTACK2",-1)
	MSG_EX("#S3#C3Fleurette|#C0In order for the Black Bride to meet the|Dragon King I believe she must make for the|center of Castle Strangerock.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0If the knight gives chase now,|he may yet still catch her.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Moving forward, I shall take care of|all future ceremonies here as you need.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Well, then, brave knight...|May fortune be with you.",-1,2)

	BGM(-1, 0, -1)

	cross_fade(80)
	FOCUS_CHR("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)
	game_flag_on(3711)
	wait(60)
	END


SKIP:
	//後処理
	blur(0)
//	PICK_ITEM(187)
//	PICK_ITEM(188)
//	PICK_ITEM(189)
//	PICK_ITEM(190)
//	GET_ITEM(36, 1)
	DELETE_EFC("Ds")
	DELETE_EFC("Fleurette")
	STOP_WALK("Fleurette")
	STOP_WALK("PC")

	SET_MOTION("Ds", "STAND",0)
	SET_MOTION("Fleurette", "STAND",0)
	SET_MOTION("PC", "STAND",0)
	SET_MOTION("Avatarlaha", "STAND",0)
	SET_MOTION("Tiowald", "STAND",0)
	SET_MOTION("Beatrice", "STAND",0)
	SET_MOTION("Sturm", "STAND",0)
	SET_MOTION("Dvorak", "STAND",0)
	SET_MOTION("Gandaltua", "STAND",0)

	set_pos("Fleurette",  0.00,0.50,3.23)
	SET_DEG("Fleurette",180)
	set_pos("PC",  0,0,-0.5)
	SET_DEG("PC", 0)
	set_pos("Avatarlaha",   1.35,0.25, 0.75)
	SET_DEG("Avatarlaha",-90)
	set_pos("Tiowald",     -1.35,0.25, 0.75)
	SET_DEG("Tiowald",  90)
	set_pos("Beatrice",    -2.1,0,-0.70)
	SET_DEG("Beatrice", 90)
	set_pos("Sturm",       -2.2,0,-2.40)
	SET_DEG("Sturm",  90)
	set_pos("Dvorak",       2.1,0,-0.70)
	SET_DEG("Dvorak",-90)
	set_pos("Gandaltua",    2.2,0,-2.40)
	SET_DEG("Gandaltua", -90)

	look_chr("Fleurette", "PC")
	look_chr("Avatarlaha", "PC")
	look_chr("Tiowald", "PC")
	look_chr("Beatrice", "PC")
	look_chr("Sturm", "PC")
	look_chr("Dvorak", "PC")
	look_chr("Gandaltua", "PC")

	STOP_SE(0)
	BGM(-1, 0, -1)

	CINEMA_OFF(0)
	cross_fade(80)
	permit_script_camera(0)
	FOCUS_CHR("PC")
	game_flag_on(3711)
	fade_in(60)
	wait(60)

EXIT:
END
}

RES("CLICK")
{
	MSG_EX("#S3#C3Fleurette|#C0Please stand before me if you have a request.",-1,2)
end
}




DEF("Dvorak")
RES("CLICK")
{
	FOCUS_CHR("Dvorak")
	SET_NAME("Dvorak", "Dvorak")
	SET_MOTION("Dvorak", "ATTACK1",-1)

	check_room_flag(6)
	on_jump TALK2

	MSG("You have grown admirably, knight.")
	MSG("Who could have guessed that you|would accomplish such things...")
	MSG("Ne'er once did I imagine such an outcome.|However, 'tis still too early to celebrate.")
	MSG("A noble struggle, truly...")
	MSG("Should we survive the battle to come,|I would very much like to hear your|tale as we drink the night away.")
	room_flag_on(6)
	jump EXIT

//　　※繰り返し
TALK2:
	MSG("You have grown admirably, knight.")
	MSG("Who could have guessed that you|would accomplish such things...")

EXIT:
	SET_MOTION("Dvorak","STAND",-1)
	END
}

DEF("Gandaltua")
RES("CLICK")
{
	FOCUS_CHR("Gandaltua")
	SET_NAME("Gandaltua", "Gandharva")
	SET_MOTION("Gandaltua", "ATTACK1",-1)

	check_room_flag(7)
	on_jump TALK2

	MSG("There exists but one final battle,|it seems...")
	MSG("We too shall follow you into the haunted|halls of that cursed castle.")
	MSG("At the very least, we wish to lend you|what power we have. We will aid you in|any way we can.")
	room_flag_on(7)
	jump EXIT

//　　※繰り返し
TALK2:
	MSG("We too shall follow you into the haunted|halls of that cursed castle.")
	MSG("At the very least, we wish to lend you|what power we have. We will aid you in|any way we can.")

EXIT:
	SET_MOTION("Gandaltua","STAND",-1)
	END
}

DEF("Sturm")
RES("CLICK")
{
	FOCUS_CHR("Sturm")
	SET_NAME("Sturm", "Sturm")
	SET_MOTION("Sturm", "ATTACK1",-1)
	MSG("We know not the hour of the devil's revival.")
	MSG("We must make haste...")

EXIT:
	SET_MOTION("Sturm","STAND",-1)
	END
}

DEF("Beatrice")
RES("CLICK")
{
	FOCUS_CHR("Beatrice")
	SET_NAME("Beatrice", "Beatrice")
	SET_MOTION("Beatrice", "ATTACK1",-1)
	MSG("During the reign of King Giuliden a brave|man armed with the Sacred Sword came forth...")
	MSG("This time around, though...with opponents like|Galsis and the Black Bride, nothing is assured.")

EXIT:
	SET_MOTION("Beatrice","STAND",-1)
	END
}

DEF("Avatarlaha")
RES("CLICK")
{
	FOCUS_CHR("Avatarlaha")
	SET_NAME("Avatarlaha", "Abhidharma")
	SET_MOTION("Avatarlaha", "ATTACK1",-1)
	MSG("Knight, the castle where Galsis slumbers|is of considerable size.")
	MSG("Be sure your equipment is in order before|venturing forth.")

EXIT:
	SET_MOTION("Avatarlaha","STAND",-1)
	END
}

DEF("Tiowald")
RES("CLICK")
{
	FOCUS_CHR("Tiowald")
	SET_NAME("Tiowald", "Theobald")
	SET_MOTION("Tiowald", "ATTACK1",-1)
	MSG("Castle Strangerock has a giant tower|rising from within.")
	MSG("If you seek that spire, I believe you will|find the Dragon King at its pinnacle.")
	MSG("Reaching those heights, however...|Heh heh. Truly, it will be a trial.")

EXIT:
	SET_MOTION("Tiowald","STAND",-1)
	END
}
























//////////////////////////////////////////////////////////////////////
// 初入店時HELPメッセージ（ガーディアン降霊編）
@help1
{
	MSG_EX("#W0",70,0x00000002)
	SYS_EX("#F0#C2About the [Guardian Ceremony]",-1,0x20000400)
	SYS_EX("#F0#C2It is possible to swap Guardians at the Spirit Sanctum.",-1,0x20000400)
	SYS_EX("#F0#C2Simply click on the Guardian you wish to use from the|Guardian list on the lower left side of the screen.",-1,0x20000400)
	SYS_EX("#F0#C2There is no limit to the amount of times|you can swap Guardians.",-1,0x20000400)
}

//////////////////////////////////////////////////////////////////////
// 初入店時HELPメッセージ（ボーナス割り振り編）
@help2
{
	MSG_EX("#W0",70,0x00000002)
	SYS_EX("#F0#C2About [Allocating Bonus Points]",-1,0x20000400)
	SYS_EX("#F0#C2When you have leveled up, you can|allocate the Bonus Points you earned to|your atributes at the Spirit Sanctum.",-1,0x20000400)
	SYS_EX("#F0#C2Use the +/- buttons to allocate the points,|and then click ACCEPT when you're done.",-1,0x20000400)
	SYS_EX("#F0#C2You can always reassign your points|until you have reached the next level.",-1,0x20000400)
}
