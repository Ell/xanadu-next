// ============================================================================
// 寺院（初期化）
// ============================================================================


//-- ROOM_FLAG -------------------------------------------------------
// 0 エリック会話
// 1 アイラ会話
// 2 リーゼ会話
// 3 アプサラスを選んだ
// 4 メルクリウスを選んだ
// 5 リーフェルトを選んだ
// 6  ドヴォルザーク
// 7  ガンダルチュア
// 8  シュトゥルム
// 9  ベアトリーチェ
// 10 アバターラハ
// 11 ティオバルト
// 12 
// 13 
// 14 
// 15 

///////////////
DEF("MAP")
RES("INIT")
{
	ATTACH_EFC("EFC_99JIIN_KAGE","kage","POS")


	// 店員とカウンターの関連付け
	link_ev_pop("Liese2","Liese")

	// シャルは基本的にいない
	HIDE_CHR("Char")

//--------------------------------------------------------------------
	// EV C-12 聖剣の巫女姫
	CHECK_GAME_FLAG(3711)
	OFF_JUMP NEXT2

	// リーゼいない
	HIDE_CHR("Liese")

	// 3800	EV 祭壇の花嫁
	CHECK_GAME_FLAG(3800)
	on_jump EXIST_FLEURETTE

	// 3804	EV D-0-1 フローレットの回想
	check_game_flag(3804)
	on_jump EXIST_FLEURETTE

	// 4017	0627	ポータルエリア５、中盤　街でフローレのイベント起動にも利用します
	check_game_flag(4017)
	on_jump NO_FLEURETTE

	// フローレットにかわる
EXIST_FLEURETTE:
	ENTRY_CHR(0, 398)
	PUT_CHR( 0, "Fleurette",    0.00,0.50,3.23, 180)
	jump EXIT

NO_FLEURETTE:
	// カウンターも停止
	HIDE_CHR("Liese2")
	jump EXIT

//--------------------------------------------------------------------
NEXT2:
	// EV C-11 黒き花嫁
	CHECK_GAME_FLAG(3710)
	OFF_JUMP NEXT

	ENTRY_CHR(0, 398)
	ENTRY_CHR(1,  36)
	ENTRY_CHR(2,  37)
	ENTRY_CHR(3,  38)
	ENTRY_CHR(4,  39)
	ENTRY_CHR(5,  40)
	ENTRY_CHR(6,  41)
	PUT_CHR( 0, "Fleurette",    0.00,0.70, 8.50, 180)
	PUT_CHR( 1, "Avatarlaha",   1.35,0.25, 0.75, 240)
	PUT_CHR( 6, "Beatrice",    -2.10,0.00,-0.70,  95)
	PUT_CHR( 5, "Dvorak",       2.10,0.00,-0.70, 265)
	PUT_CHR( 2, "Tiowald",     -1.35,0.25, 0.75, 120)
	PUT_CHR( 3, "Sturm",       -2.20,0.00,-2.40,  90)
	PUT_CHR( 4, "Gandaltua",    2.20,0.00,-2.40, 270)
	load_npc_eqp(7,00)
	DVORAK(0)

	// リーゼいない
	HIDE_CHR("Liese")
	//HIDE_CHR("Liese2")
	jump EXIT
//--------------------------------------------------------------------
NEXT:
	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump EXIT
	// 1		カニグモを倒したか？
	check_game_flag( 1)
	off_jump EXIT

NO_LIESE:
	HIDE_CHR("Liese")
	HIDE_CHR("Liese2")
	jump EXIT

//--------------------------------------------------------------------

EXIT:
	END

}


//////////////////////////////////////////////////////////////////////
// リーゼロットイベント

DEF("Liese")

RES("INIT")
{

	// EV 赤子を抱いた母親
	check_game_flag(3514)
	on_jump NEXT

	jump EVENT1

//--------------------------------------------------------------------

NEXT:
	jump EXIT


//-- 赤子を抱いた母親の降霊の儀式 ------------------------------------

EVENT1:
	stop_bgm(1,1000)

	ENTRY_CHR(7, 534)
	PUT_CHR( 7, "Mother1",    0.00,0.50, 2, 00)
	set_pos("Mother1",0,0.5,2)
	set_deg_ex("Mother1","Liese")
	set_deg_ex("Liese","Mother1")

	STOP_PC(0)
	set_motion("PC", "STAND",-1)
	set_deg_ex("PC","Mother1")
	look_chr("PC", "Mother1")

//　　精霊堂に入ると、祭司リーゼが降霊の儀式を行っているムービー。
//　　イベント専用ＮＰＣ(赤子を抱いた母親)が祭壇の前にかがんで
//　　いて、光に包まれている。
//　　以降、降霊の儀式イベント画面へ。
//　　以前あったイベントを流用します。
//    同じカメラが続いてしまうので、こっちのは若干あっさりめにしてみました（井

	set_skip_label("SKIP3")

	// SE再生
	SE("SE_EVENT_00")

	set_motion("Liese","EMPTY4",0)
	set_motion("Liese2","EMPTY1",0)

	CINEMA_ON(0)
	permit_script_camera(1)
	set_script_camera(0.12,0.50,-4.56,  -45.5,225.0,0.0, 12, 15.0)
	move_script_look_at(0.0,0.00,5.0, 200, 1)
	wait(200)

	fade_out(60)
	wait(100)

	permit_script_camera(1)
	set_script_camera_ex("Liese",1, -5,200,0, 5, 40)
	scale_script_camera( 1.2, 380, 0 )
	fade_in(60)
	wait(300)

	cross_fade(40)
	SET_SCRIPT_CAMERA( 0.2,0.5,1,  -60,-30,0, 6, 30 )
	scale_script_camera( 0.8, 360, 0 )
	wait(300)

	fade_out(60)
	wait(60)
	STOP_ENV_SE("SE_EVENT_00", 2000)
	wait(120)

//　　儀式が終わると、基本画面に戻して
//　　以下のメッセージを表示。

	set_pos("PC",1.24,0.50,-4.52)
	set_motion("Liese2","STAND",0)
	DELETE_EFC("Liese2")
	DELETE_EFC("Liese")
	set_motion("Liese","STAND",0)

	//座り老婆と挿げ替え
	HIDE_CHR("Mother1")
	ENTRY_CHR(8, 122)
	PUT_CHR( 8, "Mother2",    0.00,0.50, 2, 00)
	set_pos("Mother2",0,0.5,2)
	set_deg_ex("Mother2","Liese")
	LOOK_CHR("Mother2","Liese")
	LOOK_CHR("PC","Mother2")

	// BGM 戻す
	bgm(-1, 0, -1)
	set_script_camera_EX("Mother2",1,-45,225.0,0.0, 12, 15.0)
	fade_in(60)
	wait(60)

	MSG_EX("#S3#C3Liese|#C0...And with that, the Spiritual Ceremony|is complete.",-1,2)
	MSG_EX("#S3#C3Liese|#C0The card's Guardian now rests|safely within the child's body.",-1,2)

	LOOK_CHR("Mother2","-")
	MSG_EX("#S3#C3Mother|#C0Ohhh, my sweet one... Isn't that wonderful?",-1,2)
	MSG_EX("#S3#C3Mother|#C0Lady Liese, thank you.|Thank you so very much.",-1,2)
	set_motion("Mother2","ATTACK2",30)
	WAIT(70)

	MSG_EX("#S3#C3Liese|#C0It is of no consequence... I merely wish the|child to grow up healthy in both mind and body.",-1,2)
	MSG_EX("#S3#C3Liese|#C0A newborn comes into this world lacking|the guiding lantern of a Guardian.",-1,2)
	WAIT(30)

//　　イベント後、親子が退場してプレイヤーに操作許可。

	INIT_WALK_DST("Mother2")
	set_walk_dst("Mother2", 0.07,0.50,-4.40)
	walk_pos("Mother2",0,0.02)
	move_script_look_at(0.0,0.00,-5.0, 200, 1)

	wait_walk("Mother2")

	se("SE_DOOR")
	switch_on("Door1")
	wait(60)

	INIT_WALK_DST("Mother2")
	set_walk_dst("Mother2", 0.07,0.50,-7.40)
	walk_pos("Mother2",0,0.02)

	fade_out(60)
	wait(60)

SKIP3:
	// BGM 戻す
	bgm(-1, 0, -1)
	STOP_ENV_SE("SE_EVENT_00")
	HIDE_CHR("Mother1")
	HIDE_CHR("Mother2")
	LOOK_CHR("PC","-")
	set_pos("PC",1.24,0.50,-4.52)
	set_motion("Liese2","STAND",0)
	DELETE_EFC("Liese2")
	DELETE_EFC("Liese")
	set_motion("Liese","STAND",0)

	// EV 赤子を抱いた母親
	game_flag_on(3514)

	FOCUS_CHR("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)
	fade_in(60)
	switch_off("Door1")
	end

EXIT:
	END

}

RES("CLICK")
{
	MSG_EX("#S3#C3Liese|#C0It is shameful to speak to me from there,|Sir Knight.",-1,2)
	end
}



























// "ガーディアンの変更" //////////////////////////////////////////////////
@change_card
{
//	call_shop(7)
	call_shop(5)
	ret
}

// "ボーナス割り振り" //////////////////////////////////////////////////
@division_bonus
{
	call_shop(6)
	ret
}

// "レベルダウン" //////////////////////////////////////////////////
@leveldown
{
	CHECK_LEVEL(2)
	OFF_JUMP NOT_LEVEL

	MSG("So you say you wish to train yourself anew,|Sir Knight...")
	MSG("All aspects of your training other than weapon skills|shall be returned to what they were the previous level.")
	MSG("Do you still wish to proceed?")
	SEL("#c1Level Down|#c2Go Down One Level|Never Mind")
	check_select(0)
	on_jump LEVEL

	ret

LEVEL:
	LEVEL_DOWN(0)
	sys("#c2Your level has been decreased.")
	MSG("It takes great courage to step back...|Your determination is admirable, Sir Knight.")
	ret

NOT_LEVEL:
	MSG("If you regress your abilities any further,|your consciousness shall fade away, Sir Knight.")
	MSG("I believe leveling down any further would be unwise...")
	ret
}




// "カードの鑑定" ////////////////////////////////////////////////////////
@analyze_card
{
	check_card(0)
	on_jump analyze
	
	sys("There are no cards.")
	ret
	
analyze:
	call_shop(9)
	ret
}

// "ガーディアンの閲覧" //////////////////////////////////////////////////
@card_library
{
	call_shop(8)
	ret
}

///////////////
//-- リーゼロットの祭壇 ----------------------------------------------
DEF("Liese2")
RES("CLICK")
{
	// EV C-12 聖剣の巫女姫
	CHECK_GAME_FLAG(3711)
	OFF_JUMP NEXT2

//-- フローレバージョン ----------------------------------------------

	set_deg_ex("Fleurette","")
	active_chr("Fleurette")
	focus_chr("Fleurette")
	set_name("Fleurette","Fleurette")

	// 3807	TK 祭壇の花嫁後、フローレットに話しかけた
	CHECK_GAME_FLAG(3807)
	on_jump SelMenuF

	// 3800	EV 祭壇の花嫁
	CHECK_GAME_FLAG(3800)
	on_jump TALK2

SelMenuF:
	SEL("#c1How may I assist?|#c2Talk|Guardian Ceremony|Allocate Bonus Points|Level Down|Never Mind")

	check_select(0)
	on_jump TALK2
	check_select(1)
	on_jump GURDIAN2
	check_select(2)
	on_jump BONUS2
	check_select(3)
	on_jump LEVEL2

	jump EXIT

// 会話
TALK2:
	call TALK_Fleurette
	jump SelMenuF

// "ガーディアンの変更"
GURDIAN2:
	call change_card
	jump SelMenuF

// "ボーナス"
BONUS2:
	call division_bonus
	jump SelMenuF

// "レベル"
LEVEL2:
	call leveldown
	jump SelMenuF

//-- リーゼバージョン ------------------------------------------------
NEXT2:

	set_deg_ex("Liese","")
	active_chr("Liese")
	focus_chr("Liese")
	set_name("Liese","Liese")
//	set_motion("Liese","ATTACK1",-1)

	// 初めてガーディアンカードを持ってきたときのメッセージ
	call LIESE_CARD

SelMenu:

	// EV C-4 相似の二人
	check_game_flag(3703)
	on_jump SelMenu3

//	// EV C-2 リーゼが倒れる
//	check_game_flag(3701)
//	on_jump SelMenu2

	//3622	EV B-9e インフェルノ倒した後、リーゼと話した
	check_game_flag(3622)
	on_jump SelMenu2

	// EV インフェルノを倒した
	check_game_flag(4)
	on_jump TALK

	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump SelMenu2

	// EV カニグモを倒した
	check_game_flag(1)
	on_jump TALK

	// 3531	EV 降霊の儀式本編
	check_game_flag(3531)
	on_jump SelMenu2

	// TK リーゼからカギをもらった
	check_game_flag(3517)
	on_jump SelMenu1

	// GF[街外れの遺跡の話を聞いた]
	CHECK_GAME_FLAG(3512)
	ON_JUMP TALK

	// TK リーゼと初めて話した
	check_game_flag(3515)
	off_jump TALK

SelMenu1:
//	SEL("【寺院メニュー】|#c2体のことを相談する|やめる")
//	check_select(0)
//	on_jump TALK

	SEL("#c1How may I assist?|#c2Talk|Allocate Bonus Points|Level Down|Never Mind")
	check_select(0)
	on_jump TALK
	check_select(1)
	on_jump BONUS
	check_select(2)
	on_jump LEVEL
	jump EXIT

SelMenu2:
	SEL("#c1How may I assist?|#c2Talk|Guardian Ceremony|Allocate Bonus Points|Level Down|Never Mind")
	jump SelMenuCheck

SelMenu3:
	SEL("#c1How may I assist?|#c2Ask about the statues in Castle Strangerock|Guardian Ceremony|Allocate Bonus Points|Level Down|Never Mind")
	jump SelMenuCheck

SelMenuCheck:
	check_select(0)
	on_jump TALK
	check_select(1)
	on_jump GURDIAN
	check_select(2)
	on_jump BONUS
	check_select(3)
	on_jump LEVEL

	jump EXIT


// 会話
TALK:
	call TALK_Liese
	jump SelMenu

// "ガーディアンの変更"
GURDIAN:
	////////////////////////////////////////////////////
	// ★05/09/10:ショップ説明スクリプトを入店時に再生
	check_game_flag(75)
	on_jump skip_help1
	game_flag_on(75)
	add_shop_script("help1")
skip_help1:
	////////////////////////////////////////////////////
	call change_card
	jump SelMenu

// "ボーナス"
BONUS:
	////////////////////////////////////////////////////
	// ★05/09/10:ショップ説明スクリプトを入店時に再生
	check_game_flag(76)
	on_jump skip_help2
	game_flag_on(76)
	add_shop_script("help2")
skip_help2:
	////////////////////////////////////////////////////
	call division_bonus
	jump SelMenu

// "レベル"
LEVEL:
	call leveldown
	jump SelMenu

EXIT:
	end
}

RES("INIT")
{
	// マップの回転角度を強制変更（所要時間 1 フレームで方向 6 に回転）
	RESET_MAP_ROT_Y(1,1)
}


@LIESE_CARD
{
	// 3626	TK リーゼに初めてカードを渡したときのメッセージ
	check_game_flag(3626)
	on_jump EXIT

	// デモンカッツェ
	CHECK_GAME_FLAG(701)
	on_jump CARD
	// ソーサリアン
	CHECK_GAME_FLAG(731)
	on_jump CARD
	// ベラドーナ
	CHECK_GAME_FLAG(575)
	on_jump CARD
	// デュランダル
	CHECK_GAME_FLAG(595)
	on_jump CARD
	// フリューゲル
	CHECK_GAME_FLAG(723)
	on_jump CARD
	// ヴァナポルト
	CHECK_GAME_FLAG(598)
	on_jump CARD
	// ツヴェルク
	CHECK_GAME_FLAG(583)
	on_jump CARD
	// ガーネシア
	CHECK_GAME_FLAG(822)
	on_jump CARD
	// グレイアッシュ
	CHECK_GAME_FLAG(918)
	on_jump CARD
	// セルベスク
	CHECK_GAME_FLAG(653)
	on_jump CARD
	// ベル・フロイデ　3639	アニエスシステム：霊薬を渡した
	CHECK_GAME_FLAG(3639)
	on_jump CARD

	jump EXIT

CARD:
	MSG("Sir Knight, might that be...")
	MSG("It would appear you have found|a Guardian Card.")
	MSG("I shall keep that card here.")
	MSG("Please feel free to visit the Sanctum any|time you come across other cards.")
	MSG("If you wish to change Guardians,|simply let me know.")

	sys_ex("Gave the Guardian Card to Liese."-1,0x00000200)

	// 3626	TK リーゼに初めてカードを渡したときのメッセージ
	game_flag_on(3626)
	ret

EXIT:
	ret

}


//////////////////////////////////////////////////////////////////////
// フローレット会話

@TALK_Fleurette
{
	// 3800	EV 祭壇の花嫁
	check_game_flag(3800)
	on_jump TALK3

	// 3804	EV D-0-1 フローレットの回想
	check_game_flag(3804)
	on_jump TALK2

	jump TALK1

//--------------------------------------------------------------------

TALK3:
	// 3807	TK 祭壇の花嫁後、フローレットに話しかけた
	check_game_flag(3807)
	on_jump TALK3_2

	SYS("Fleurette is having a discussion|about the sages.")

	MSG("Eh? Everyone has...?")
	MSG("Once Abhidharma has returned, I too shall|make my way to Castle Strangerock.")
	MSG("This is quickly becoming|a decisive battle...")
	MSG("Please lend us your power, brave knight.|This time it is Galsis and the Black Bride...")
	// 3807	TK 祭壇の花嫁後、フローレットに話しかけた
	game_flag_on(3807)
	jump EXIT

//　　☆以降、繰り返し
TALK3_2:
	MSG("Once Abhidharma has returned, I too shall|make my way to Castle Strangerock.")
	MSG("This is quickly becoming|a decisive battle...")
	jump EXIT

TALK2:
	MSG("Brave knight...")
	MSG("I have something I wish to unburden myself of,|something that must be kept private from the sages.")
	MSG("My...nature rebels at sealing such secrets within.")
	jump EXIT

TALK1:
	check_room_flag(2)
	on_jump TALK1_2

	MSG("While the Black Bride IS my sister,|I have no misgivings about bringing|around her downfall.")
	MSG("She is a threat who should|have perished long ago...")
	MSG("Brave knight, allow me, along with the sages,|to aid you in this dread task.")
	MSG("Together, we shall destroy the Dragon King|and his Black Bride.")
	room_flag_on(2)
	jump EXIT

//　　※繰り返し
TALK1_2:
	MSG("While the Black Bride IS my sister,|I have no misgivings about bringing|around her downfall.")
	MSG("She is a threat who should|have perished long ago...")
	jump EXIT

EXIT:
	ret
}

//////////////////////////////////////////////////////////////////////
// リーゼ会話

@TALK_Liese
{
//	//▼障壁消滅後
//	check_game_flag(3710)
//	on_jump TALK7
	//▼奇岩城出現後
	check_game_flag(3702)
	on_jump TALK6
	//▼インフェルノ戦後
	check_game_flag(4)
	on_jump TALK5
	//▼カニグモ戦後
	check_game_flag(1)
	on_jump TALK4
	//▼トレント戦後
	check_game_flag(3)
	on_jump TALK3
	//▼ガーディアン取得後
	check_game_flag(3532)
	on_jump TALK2
	// TK リーゼからカギをもらった
	check_game_flag(3517)
	on_jump TALK1_8

	jump TALK1

//--------------------------------------------------------------------

//▼奇岩城出現後
TALK6:
	game_flag_on(3622)
	// 3703	EV C-4 相似の二人
	check_game_flag(3703)
	on_jump TALK6_1

	MSG("Sir Knight...|Castle Strangerock has finally appeared.")
	MSG("I am sure that somewhere within those haunted halls|are the clues to finding the Sacred Sword.")
	MSG("There must be some way to gain passage into|the castle...")
	ret

TALK6_1:
	check_room_flag(2)
	on_jump TALK6_2

	MSG("...")
	MSG("That's...")
	MSG("Forgive me...|It's nothing...")
	room_flag_on(2)
	jump EXIT

//　　★繰り返し
TALK6_2:
	MSG("...")
	jump EXIT

//▼インフェルノ戦後
TALK5:
	MSG("Sir Knight, you seem to have grown greatly in|confidence of late.")
	MSG("I believe you have the will now to realize your|goal and return to normal.")
	MSG("Without a doubt, the Sacred Sword will|choose a man such as yourself...")
	MSG("I can sense it.")
	//3622	EV B-9e インフェルノ倒した後、リーゼと話した
	game_flag_on(3622)
	jump EXIT

//--------------------------------------------------------------------

TALK4:
	MSG("...Sometimes I find myself gazing|out over the lake.")
	MSG("I feel a great unease of late, I must confess.")
	MSG("For I have seen what appears to be|Castle Strangerock.")
	MSG("I wonder what ill omen that bodes...")
	ret

//▼トレント戦後
TALK3:
	// 3620	TK B-4b トレント戦後のリーゼ会話
	check_game_flag(3620)
	on_jump TALK3_1

	MSG("Sir Knight, what is that crown...?")
	MSG("I sense a great power emanating from it.")
	MSG("Neither bright nor dim...|Neither warm nor cold...")
	MSG("A strange power encompasses it,|shifting between light and darkness...")
	MSG("It may bear some relation to the Sacred Sword|or Castle Strangerock.")
	MSG("Be sure to carry it with you, Sir Knight.")
	game_flag_on(3620)
	jump EXIT

TALK3_1:
	check_room_flag(2)
	on_jump TALK3_2

	MSG("Sir Knight...")
	MSG("You may not know, but a Guardian grows|with its host.")
	MSG("Did you notice the effigy of a Sacred|Maiden amongst the ruins?")
	MSG("In ancient times, that statue was believed|to give shape to a Guardian's essence.")
	MSG("They are also able to lend assistance|to a bonded Guardian, if desired.")
	MSG("Should you happen upon one whilst exploring,|it might be worthwhile to accept its blessing.")
	MSG("...Your time is limited, Sir Knight.|Each step you now take holds a great|deal of importance.")
	room_flag_on(2)
	jump EXIT

//　　★繰り返し
TALK3_2:
	MSG("Sir Knight, did you notice the effigy|of a Sacred Maiden amongst the ruins?")
	MSG("They are able to lend assistance|to a bonded Guardian, if desired.")
	MSG("Should you happen upon one whilst exploring,|it might be worthwhile to accept its blessing.")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	check_room_flag(2)
	on_jump TALK2_2

TALK2_1:
	MSG("Sir Knight...|How do you fare?")
	MSG("The investigation has concluded.|You may now travel freely and explore|the ruins to the north, if you wish.")
	MSG("Most regrettably, no clues to the incident|were found...")
	MSG("The murder of the traveler does bear some resemblance to the|attack on your person, however. The culprit may be the same.")
	MSG("I beg you take care as you begin your search in the ruins.")
	room_flag_on(2)
	jump EXIT

//　　★繰り返し
TALK2_2:
	MSG("...Due to the nature of your 'rebirth',|you are able to exchange Guardians.")
	MSG("If you chance upon a Guardian Card,|please bring it to me.")
	MSG("They each have their own merits.")
	jump EXIT

TALK1:
	// GF[街外れの遺跡の話を聞いた]
	CHECK_GAME_FLAG(3512)
	ON_JUMP TALK1_3

TALK1_1:
	// TK リーゼと初めて話した
	CHECK_GAME_FLAG(3515)
	ON_JUMP TALK1_2

	GAME_FLAG_ON(3515)
	MSG("You are...")
	MSG("You who wear the trappings of a knight,|what business have you with the Spirit Sanctum?")
	MSG("...Searching for clues about Castle Strangerock,|you say?")
	MSG("My sincerest apologizes, but there has been an incident|in the ruins to the north, and no one may venture there|until the investigation is concluded.")
	MSG("Your search will have to wait, I'm afraid.")
	ret
//　　※以降、繰り返し

TALK1_2:
	MSG("My sincerest apologizes, but there has been an incident|in the ruins to the north, and no one may venture there|until the investigation is concluded.")
	MSG("Your search will have to wait, I'm afraid.")
	ret

TALK1_3:
	// TK リーゼと初めて話した
	CHECK_GAME_FLAG(3515)
	ON_JUMP TALK1_4

	MSG("You are...")
	MSG("I heard tell of a knight accompanying a researcher who|seeks Castle Strangerock. That would be you, I presume.")
	MSG("I am the head priestess of the Spirit Sanctum.|Please call me Liese.")
	MSG("Unfortunately, something rather unsettling happened|in the ruins to the north. I'm afraid all travel|there is barred until the investigation ends.")
	GAME_FLAG_ON(3515)

TALK1_4:
	CHECK_GAME_FLAG(3516)
	ON_JUMP TALK1_5

	MSG("Hm? You wish to enter the Back-Alley Ruins?|Why would you desire to do that...?")
	MSG("...")
	MSG("...So it was Spence.|That man is quite troublesome at times.")
	MSG("Very well, then.")
	MSG("You may enter, but be warned:|monsters have made their home inside.")
	MSG("Please be sure you're well-equipped|before setting foot in the ruins.")

TALK1_5:
	CHECK_MAX_ITEM(0)
	ON_JUMP TALK1_6

	MSG("Allow me to give you the key to|access the area.")

	SE("SE_GETITEM")
	SYS("#C2Liese gave you the [Back-Alley Ruins Key].")
	GET_ITEM(200, 1)
	GAME_FLAG_ON(3517)

	room_flag_on(2)
	jump TALK1_8

TALK1_6:
	GAME_FLAG_ON(3516)
	MSG("In order for me to give you the key,|please make some room in your bag.")
	ret

TALK1_8:
	check_room_flag(2)
	on_jump TALK1_9

//▽遺跡の鍵を手に入れた後&&一度屋外マップに出た
	MSG("Sir Knight, how goes your exploration of the ruins?")
	MSG("When raising your level, one must start by considering|the allocation of Bonus Points in advance.")
	MSG("Do not forget, you must visit me here at|the Spirit Sanctum if you wish to level up.")

	ret

TALK1_9:
	MSG("Knights such as yourself have gone off seeking|Castle Strangerock and never come back.")
	MSG("As you proceed within the ruins,|you may chance upon those who didn't return.")
	MSG("Do be careful.")


EXIT:
	ret
}

