	END
}

//////////////////////////////////////////////////////////////////////
// リーゼ 港でたたずみ、破魔矢をくれるイベント

DEF("Liese")

RES("INIT")
{
	look_chr("Liese","-")
}

RES("CLICK")
{
	cross_fade(60)
	permit_script_camera(1)
	set_script_camera(-5.39,0.00,-12.61,  -10.0,160.0,0.0, 6, 15.0)
	rotate_script_camera(0,-10,0, 800, 1)

	set_skip_label("SKIP")
	cinema_on(0)

	stop_pc(0)
	set_pos("PC", -6.12,-1.00,-13.16)
	set_deg("PC", 129)

	set_deg("Liese", 193)
	NO_LOOK_PC("Liese")
	look_chr("Liese", "PC")

	wait(120)

//　　船着場にいるリーゼに話しかけると、フェード＆キャラ再配置
//　　してイベント開始。リーゼは体は湖に向けて顔だけ主人公側に、
//　　主人公は体ごとリーゼのほうを向いている。

	MSG_EX("#S3#C3Liese|#C0Greetings, Sir Knight.",-1,2)
	MSG_EX("#S3#C3Liese|#C0If you're wondering, I stand here in the hope that|I might see Castle Strangerock upon the lake this day.",-1,2)

//　　顔を正面に戻して、湖面を見据えるリーゼロット
	look_chr("Liese", "-")
	wait(30)

	MSG_EX("#S3#C3Liese|#C0'Tis the perfect weather for such a sighting.",-1,2)
	MSG_EX("#S3#C3Liese|#C0I often feel as though the castle is not so much|shrouded in mist, as it is lost within it.",-1,2)
	MSG_EX("#S3#C3Liese|#C0Some say it hides itself with purpose,|to guard the Sacred Sword.",-1,2)
	MSG_EX("#S3#C3Liese|#C0But to me, it seems more incident than intent.|It is not hiding, but trapped, and it wishes to|be saved.",-1,2)
	MSG_EX("#S3#C3Liese|#C0It struggles with its captor, occasionally|breaking free and letting itself be seen,|only to be captured once again.",-1,2)
	MSG_EX("#S3#C3Liese|#C0'Tis desperate, and alone...",-1,2)
	wait(30)
	MSG_EX("#S3#C3Liese|#C0But there is hope...for all mist|must inevitably dissipate.",-1,2)
	MSG_EX("#S3#C3Liese|#C0And the day will come when Castle Strangerock escapes|its accursed fate, revealing itself in full...",-1,2)

//　　リーゼロット、再び主人公のほうを向く。
	cross_fade(60)
	set_deg("Liese", 220)
	look_chr("Liese", "PC")
	set_script_camera(-5.26,0.20,-12.74,  -10.0,180.0,0.0, 4, 15.0)
	wait(60)

	MSG_EX("#S3#C3Liese|#C0Sir Knight, I do believe you to be an|honorable person, a man I can trust.",-1,2)
	MSG_EX("#S3#C3Liese|#C0Lady Wells speaks highly of you and tells me|excitedly of your exploits on this island.",-1,2)
	wait(30)
	CHECK_MAX_ITEM(0)
	ON_JUMP NO_ITEM

	set_deg("Liese", 250)
	MSG_EX("#S3#C3Liese|#C0I would like...for you to have this.",-1,2)
	wait(30)

	SE("SE_GETITEM")
	sys_ex("Received [Liese's Purging Arrow].",-1,0x00000200)
	wait(30)

	look_chr("Liese", "-")
	MSG_EX("#S3#C3Liese|#C0'Tis not of much use as a weapon, but such was not its|purpose. I prepared it as a charm to ward off evil.",-1,2)
	MSG_EX("#S3#C3Liese|#C0I cannot guarantee it will be of use to you,|but I believe it may offer some aid in your|travels.",-1,2)
	MSG_EX("#S3#C3Liese|#C0May it guide you straight and true.",-1,2)
	look_chr("Liese", "PC")
	MSG_EX("#S3#C3Liese|#C0And with that, I bid you safe journey,|for I must now return to the Sanctum.",-1,2)

	fade_out(60)
	wait(60)

SKIP:
	CHECK_MAX_ITEM(0)
	ON_JUMP SKIP_NO_ITEM

	// EV B-11 リーゼの破魔矢イベント
	game_flag_on(3610)
	GET_ITEM(191, 1)

	hide_chr("Liese")
	permit_script_camera(0)
	wait(60)
	cinema_off(0)

	fade_in(60)
	end


NO_ITEM:
	MSG_EX("#S3#C3Liese|#C0There is something I wish to give you,|but it appears your bag is somewhat...overburdened.",-1,2)
	MSG_EX("#S3#C3Liese|#C0Please see me again when your load is lightened.",-1,2)

	cross_fade(60)
	permit_script_camera(0)
	wait(60)
	cinema_off(0)

	// TK 持ち物がいっぱいで破魔矢をもらえなかった
	GAME_FLAG_ON(3612)
	end

SKIP_NO_ITEM:
	permit_script_camera(0)
	cinema_off(0)

	// TK 持ち物がいっぱいで破魔矢をもらえなかった
	GAME_FLAG_ON(3612)

	fade_in(60)
}

//////////////////////////////////////////////////////////////////////
// フローレットとＮＰＣのアラーナが立ち話している

DEF("Fleurette")

RES("CLICK")
{
	cross_fade(60)
	permit_script_camera(1)
	set_script_camera(4.52,1.00,-1.07,  -10.0,190.0,0.0, 6, 15.0)
	rotate_script_camera(0,-10,0, 800, 1)

	cinema_on(0)

	stop_pc(0)
	set_pos("PC", 3.56,0.00,-1.07)
	set_deg("PC", 155)
	set_deg("Fleurette", 282)

	set_skip_label("SKIP")
	wait(60)

	MSG_EX("#S3#C3Fleurette|#C0Ah, brave knight.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0The town of this era is quite peculiar.|I have taken some time to walk its streets|and take stock of its people.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0The spiritual attendants did attempt|to bar my way, however...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0My elder sister protected this town because|of the Dragon King resting in that castle...",-1,2)
	wait(20)
	set_deg("Fleurette", 240)
	wait(20)
	MSG_EX("#S3#C3Fleurette|#C0My sister was very gentle.|I always looked up to her.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Even though our faces are alike,|we could not be more different.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0You see, my sister was very frail.|She had not the strength even for training.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0It was never spoken of, but because of her poor|constitution, she was considered...inferior.",-1,2)
	wait(20)
	look_chr("Fleurette", "PC")
	wait(20)
	MSG_EX("#S3#C3Fleurette|#C0Still, my sister should never have|gone and done what she did.",-1,2)
	wait(20)
	look_chr("Fleurette", "-")
	wait(20)
	MSG_EX("#S3#C3Fleurette|#C0It was at that time, 500 years ago...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Though I thought I'd be singing a requiem of|passing, here I am seeking revenge instead.",-1,2)
	wait(20)
	look_chr("Fleurette", "PC")
	set_deg("Fleurette", 282)
	wait(20)
	MSG_EX("#S3#C3Fleurette|#C0Brave knight, please bring an end to my sister.|It is for her own sake, as well...",-1,2)
	wait(40)
	cross_fade(60)
	set_script_camera(4.52,1.00,-1.07,  -10.0,190.0,0.0, 10, 15.0)
	MSG_EX("#S3#C3Fleurette|#C0I...I should return to the Spirit Sanctum.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0If you happen upon Dvorak,|please mention none of this to him.",-1,2)

//　　画面、フェードアウト。フローレットを屋外から消して精霊堂
//　　へ移動。プレイヤー操作許可。

	fade_out(60)
	wait(60)

SKIP:
	// 3804	EV D-0-1 フローレットの回想
	game_flag_on(3804)

	hide_chr("Fleurette")
	FOCUS_CHR("PC")
	permit_script_camera(0)
	wait(60)
	cinema_off(0)

	fade_in(60)
	end

}

//////////////////////////////////////////////////////////////////////
// シャル

DEF("Char")

RES("CLICK")
{
	FOCUS_CHR("Char")
	SET_NAME("Char", "Char")
	SET_MOTION("Char", "ATTACK1",-1)

	// 3703	EV C-4 相似の二人(アニエスに会った)
	check_game_flag(3703)
	on_jump TALK2

	// まだあってない
	jump TALK1

//--------------------------------------------------------------------

TALK1:
//　　▽奇岩城でアニエスに会っていない場合
	check_room_flag(11)
	on_jump TALK1_2

	MSG("#N0!")
	MSG("Look, over there! There it is!!")
	MSG("Shouldn't you be off to Castle Strangerock?")
	MSG("Looks like once the water drained away,|this beach became a path to the castle!")
	room_flag_on(11)
	// 3729	TK シャルと城が現れてから初めて会話した
	game_flag_on(3729)
	jump EXIT

//　　※以降、繰り返し用
TALK1_2:
	MSG("Shouldn't you be off to Castle Strangerock?")
	MSG("Looks like once the water drained away,|this beach became a path to the castle!")
	jump EXIT

//--------------------------------------------------------------------
//　　▽奇岩城でアニエスに会っている場合
TALK2:
	// 3729	TK シャルと城が現れてから初めて会話した
	check_game_flag(3729)
	on_jump TALK2_1

//　　→奇岩城出現後、初めて話す場合
	MSG("#N0!")
	MSG("Look, over there! There it is!!")
	jump TALK2_2

//　　　　→奇岩城出現後、話したことがある場合
TALK2_1:
	MSG("#N0, what's wrong?")

//　　→ここで統合
TALK2_2:
	MSG("...Huh? There's a barrier around Castle Strangerock|that's keeping you from entering?")
	MSG("So THAT'S what that transparent|green wall is...")
	MSG("Hmmm... Let me think...")
	MSG("There might be some clue hidden|in the memoirs and tabulae.")
	MSG("Also, there seems to be a statue of a|woman in front of Castle Strangerock.")
	MSG("For some reason it bears a strong|resemblance to Lady Liese...")
	MSG("Maybe that statue is related to the people|you saw who were petrified around the ruins?")
	MSG("Is there anyone you found in the ruins who|hasn't been released from the stone yet?")
	MSG("Perhaps a clue might lie with that person!")
	MSG("I'm going to go to our room and|look over the documents again.")

	fade_out(60)
	wait(60)

	// 3723	TK シャルと城が現れたことについて話す
	game_flag_on(3723)

	hide_chr("Char")

	wait(60)
	fade_in(60)
	end

EXIT:
	SET_MOTION("Jean","STAND",-1)
	END

}

