// ============================================================================
// 地下道入り口
// ============================================================================

DEF("gate2TEST")
RES("CLICK")
{
	//↑testを付け足して無力化

	CINEMA_ON(0)

	STOP_PC(0)
	ACTIVE_CHR("SCREEN")
	SEL("#c2Exit the town? |Exit|Cancel")

	CHECK_SELECT(0)
	ON_JUMP SEL1
	JUMP SEL2

SEL1:
	WAIT(30)
	SHAKE(0,10)
	SHAKE(0,10)

		CHECK_GAME_FLAG(591)
		ON_SKIP(4)
		WAIT(30)
		SYS("#c2Something seems to be blocking the door from the other side.")
		CINEMA_OFF(0)
		END

	SWITCH_ON("gate2")
	WAIT(30)
	FADE_OUT(-1)
	GAME_FLAG_ON(3000)
//	GAME_FLAG_ON(3301)
	WAIT(40)
	SE("SE_CHG_AREA")
	WAIT(20)
	ENTRY_MAP("0588_0097")
	END

SEL2:
	CINEMA_OFF(0)
	END
}

// ============================================================================
// 火山入り口
// ============================================================================

