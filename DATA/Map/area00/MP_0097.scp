TALK3_4:
	MSG("No matter how skilled you get, those salamanders|are quite the handful, don'tcha think?")
	MSG("I guess anythin' livin' on Eaglet Mountain|is gonna be tough as nails, though.")
	jump EXIT
//▼ガーディアン取得後
TALK2:
	MSG("Within me is a Guardian|I was fated to have.")
	MSG("My whole family has been in the minin' business|for as long as anyone can remember, you see.")
	MSG("That's why my father chose the Guardian|that'll help me find lots of ore.")
	jump EXIT

//▼ゲーム開始直後
TALK1:
	MSG("*sigh* Damn freight lift's busted.")
	MSG("Can't do any work 'til it's fixed.")
	jump EXIT

EXIT:
	SET_MOTION("Damon","STAND",-1)
	END
}

