//////////////////////////////////////////////////////////////////////
// ギュンター

DEF("Gunter")

RES("CLICK")
{
	FOCUS_CHR("Gunter")
	SET_NAME("Gunter", "Gateman Gunter")
	SET_MOTION("Gunter", "ATTACK1",-1)

	call TALK_Gunter

}

@TALK_Gunter
{
	//▼障壁消滅後
	check_game_flag(3710)
	on_jump TALK7
	//▼奇岩城出現後
	check_game_flag(3702)
	on_jump TALK6
	//▼インフェルノ戦後
	check_game_flag(4)
	on_jump TALK5
	//▼カニグモ戦後
	check_game_flag(1)
	on_jump TALK4
	//▼トレント戦後
	check_game_flag(3)
	on_jump TALK3
	//▼ガーディアン取得後
	check_game_flag(3532)
	on_jump TALK2
	//▼ゲーム開始直後
	jump TALK1

//--------------------------------------------------------------------

//▼障壁消滅後
TALK7:
	MSG("Castle Strangerock pops up,|and dark clouds roll in...")
	MSG("There's an ill wind blowin', and I couldn't|begin to guess what it'll bring.")
	jump EXIT
//▼奇岩城出現後
TALK6:
	check_room_flag(0)
	on_jump TALK6_2

TALK6_1:
	MSG("Some strangers have been spotted|outside the town recently.")
	MSG("Odd-lookin' lads. No coincidence that|a traveler's been killed out there,|I'd say.")
	MSG("Last anyone saw of 'em, they were|headed east from the Clover Ruins.")
	MSG("If you're goin' out there anyway,|and you think you're up to it,|you could try followin' their trail.")
	MSG("Just my opinion, but I think the townsfolk|had better stay in for a while.")
	room_flag_on(0)
	jump EXIT

//　　★繰り返し
TALK6_2:
	MSG("Some strangers have been spotted|outside the town recently.")
	MSG("Last anyone saw of 'em, they were|headed east from the Clover Ruins.")
	MSG("If you're goin' out there anyway,|and you think you're up to it,|you could try followin' their trail.")
	jump EXIT
//▼インフェルノ戦後
TALK5:
	MSG("Maybe it's just my imagination, but|things seem a little quiet today.|Too quiet, if you know what I mean.")
	MSG("I've got this sinkin' feeling that|it's the quiet before the storm...")
	jump EXIT
//▼カニグモ戦後
TALK4:
	MSG("You've fought a lot of undead, right?|Ever crossed swords with one that had|its bones stickin' out?")
	MSG("I hear that when those kinds are killed,|they'll often leave a bone or two behind.|Real sturdy ones, too. They make great keys.")
	MSG("So if you find a spot with lotsa undead like|that, be sure you remember where it is. If|you ever run out of keys, that's where you go!")
	jump EXIT
//▼トレント戦後
TALK3:
	MSG("As you wander the ruins out there,|keep an eye out for an oddly-marked|circular stone platform.")
	MSG("It ain't that far from here...|and I think there was another one|near that statue.")
	MSG("I'm really fascinated by those things.|I'd love t'know what they were used for...")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	check_room_flag(0)
	on_jump TALK2_2

TALK2_1:
	MSG("If you're goin' outside, be sure you take care.")
	MSG("The route ain't marked, and gettin' lost|is as easy as breathin'. Branchin' paths|every which way, and ruins all over...")
	MSG("It can be pretty dauntin', but don't|lose your head! Just push on, and|you'll be fine. I'm sure of it!")
	MSG("...Though, be sure you don't get|carried away, either, you hear?")
	MSG("You think you're in trouble, you come|right on back to town. No sense in|dyin' young.")
	room_flag_on(0)
	jump EXIT

//　　★繰り返し
TALK2_2:
	MSG("The route ain't marked, and gettin' lost|is as easy as breathin'. Branchin' paths|every which way, and ruins all over...")
	MSG("It can be pretty dauntin', but don't|lose your head! Just push on, and|you'll be fine. I'm sure of it!")
	jump EXIT

//▼ゲーム開始直後
TALK1:
	check_room_flag(0)
	on_jump TALK1_2

TALK1_1:
	MSG("A man was killed here yesterday. Murdered.|Just north in the Clover Ruins, and not by|monsters, but by his own kind.")
	MSG("He was a tourist visitin' the island.|Everyone's still all shook up about it.|And ain't no leads on who did it.")
	MSG("No one's goin' in or out of town right now.|Not 'til the investigation's complete.|Not 'til I get the okay.")
	room_flag_on(0)
	jump EXIT

//　　★繰り返し
TALK1_2:
	MSG("A man was killed here yesterday. Murdered.|Just north in the Clover Ruins, and not by|monsters, but by his own kind.")
	MSG("No one's goin' in or out of town right now.|Not 'til the investigation's complete.|Not 'til I get the okay.")
	jump EXIT

EXIT:
	SET_MOTION("Gunter","STAND",-1)
	RET
}


//////////////////////////////////////////////////////////////////////
// ダーナ

DEF("Dana")

RES("CLICK")
{
	FOCUS_CHR("Dana")
	SET_NAME("Dana", "Dana")
	SET_MOTION("Dana", "ATTACK1",-1)

	//▼障壁消滅後
	check_game_flag(3710)
	on_jump TALK7
	//▼奇岩城出現後
	check_game_flag(3702)
	on_jump TALK6
	//▼インフェルノ戦後
	check_game_flag(4)
	on_jump TALK5
	//▼カニグモ戦後
	check_game_flag(1)
	on_jump TALK4
	//▼トレント戦後
	check_game_flag(3)
	on_jump TALK3
	//▼ガーディアン取得後
	check_game_flag(3532)
	on_jump TALK2
	//▼ゲーム開始直後
	jump TALK1

//--------------------------------------------------------------------

//▼障壁消滅後
TALK7:
	MSG("Earlier today I thought I saw a lady|wearing a black dress...")
	MSG("But the moment I turned to look,|she was gone!")
	MSG("Just where the heck did she go?")
	jump EXIT
//▼奇岩城出現後
TALK6:
	MSG("Is THAT the castle in the mist that everyone|says they see from time to time?")
	MSG("I always pictured it to be more...fanciful.|The real thing seems to have a sinister air.")
	jump EXIT
//▼インフェルノ戦後
TALK5:
	MSG("Hey, hey, good sir.|Won't you have a dance with us?")
	jump EXIT
//▼カニグモ戦後
TALK4:
	MSG("*phew* I'm getting kind of hungry.")
	MSG("I'll have to grab something|at the tavern later.")
	jump EXIT
//▼トレント戦後
TALK3:
	MSG("We've taken quite a liking to|this town.")
	MSG("In the great cities we'd have a bigger audience,|but they'd never comment on our performance.")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	check_room_flag(1)
	on_jump TALK2_2

TALK2_1:
	MSG("In Harlech the people are very friendly, though.|They always stop to chat and tell us the most|wonderful stories about the spirits here!")
	MSG("Such fantastical tales like the mysterious|castle nestled atop the lake...")
	MSG("Aww, I wish I could've been born|in this country.")
	MSG("If I had been blessed with a Guardian,|my dancing could have been amazing!")
	room_flag_on(1)
	jump EXIT

//　　★繰り返し
TALK2_2:
	MSG("Aww, I wish I could've been born|in this country.")
	MSG("If I had been blessed with a Guardian,|my dancing could have been amazing!")
	jump EXIT

//▼ゲーム開始直後
TALK1:
	MSG("Helloooo, knight. Aren't YOU a fine specimen!")
	MSG("We're traveling entertainers here in Harlech|on tour. You're welcome to watch us dance as|long as you'd like!")
	jump EXIT

EXIT:
	SET_MOTION("Dana","STAND",-1)
	END
}


