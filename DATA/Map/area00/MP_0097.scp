	// フローレットがいない場合
TALK7_2:
	MSG("After speaking with Lady Liese,|the child finally stopped crying.")
	MSG("What a relief...")
	MSG("Still, there's something different about|Lady Liese that I just can't put my finger|on.")
	jump EXIT

	//▽フローレットが屋外へ移動する前
TALK7_3:
	MSG("Oh dear, oh dear... The way things are now,|I simply MUST go pray at the Spirit Sanctum.")
	MSG("If Lady Liese is there, I'm sure she'll|have some advice to bestow upon me.")
	jump EXIT

//▼奇岩城出現後
TALK6:
	MSG("Ever since the castle appeared|my child has been inconsolable.")
	MSG("Now, now, you poor thing...")
	MSG("Does that castle bode no good will|at all?")
	jump EXIT
//▼インフェルノ戦後
TALK5:
	MSG("My child finally opened her eyes...")
	MSG("Watching over the growth of my child|is such a delight and a blessing.")
	jump EXIT
//▼カニグモ戦後
TALK4:
	MSG("I simply MUST ensure.|I will visit the Spirit Sanctum and|petition the spirits for their favor...")
	MSG("After all, my child is still too|young to offer up her own prayers.")
	jump EXIT
//▼トレント戦後
TALK3:
	MSG("Long ago, it's said that a great maiden gave|birth to the Guardians. That's the legend of|how the spirits came to be, anyway.")
	MSG("Amidst the ruins of this island you'll find|many statues in her image scattered about.")
	MSG("If one was to prostrate in prayer in front|of one, it might just enhance a Guardian's|growth...")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	MSG("As one grows, so too does the|Guardian one bears within.")
	MSG("Were this child to be raised with care,|the Guardian within would also be raised up|and grant greater protection to the child...")
	MSG("Thanks be to Xanadu...")
	jump EXIT

//▽精霊堂でリーゼの儀式を見た後
TALK1:
	MSG("This? 'Tis a shrine built to the Guardians.|Fashioned by man, in reverence to those|who watch over us...")
	MSG("I pray here to ask that this child|be granted divine protection.")
	MSG("You can find shrines like this all over|the island. And just by touching them,|all your wounds will be healed.")
	MSG("After much ordeal, I was finally blessed with a child,|so I must make every effort to raise her well.")
	jump EXIT

EXIT:
	SET_MOTION("Alana","STAND",-1)
	END
}

//////////////////////////////////////////////////////////////////////
// ネッド

DEF("Ned")

RES("CLICK")
{

	FOCUS_CHR("Ned")
	SET_NAME("Ned", "Fisherman Ned")
	SET_MOTION("Ned", "ATTACK1",-1)

	//▼障壁消滅後
	check_game_flag(3710)
	on_jump TALK7
	//▼奇岩城出現後
	check_game_flag(3702)
	on_jump TALK6
	//▼インフェルノ戦後
	check_game_flag(4)
	on_jump TALK5
	//▼カニグモ戦後
	check_game_flag(1)
	on_jump TALK4
	//▼トレント戦後
	check_game_flag(3)
	on_jump TALK3
	//▼ガーディアン取得後
	check_game_flag(3532)
	on_jump TALK2
	//▼ゲーム開始直後
	jump TALK1

//--------------------------------------------------------------------

//▼障壁消滅後
TALK7:
	MSG("Ever since that castle appeared the|townsfolk have been a bit riled up...")
	MSG("It's just so eerie that I think|everyone's got an uneasy feelin'.|Don't blame 'em.")
	MSG("I reckon' there are monsters inside.|It's not what you'd call a welcomin'|kinda place.")
	MSG("Mr. Knight, please do somethin'|ta put us all at ease.")
	jump EXIT
//▼奇岩城出現後
TALK6:
	check_room_flag(9)
	on_jump TALK6_2

TALK6_1:
	MSG("Great Guardians, ain't that a surprise!")
	MSG("I was just goin' out ta fish when suddenly all|the water started ta drain out of the lake.")
	MSG("Even though I went out ta fish, this is|the first time I've come back by walkin'!")
	MSG("It looked like all the water was sucked|right out. Just what happened over there?")
	room_flag_on(9)
	jump EXIT

//　　★繰り返し
TALK6_2:
	MSG("Well, now, with the lake like this I wonder|what's gonna happen to my business.")
	MSG("Haha. Guess I could go home|and get a few more winks.")
	jump EXIT
//▼インフェルノ戦後
TALK5:
	check_room_flag(9)
	on_jump TALK5_2

TALK5_1:
	MSG("Looks like my son doesn't want|ta be a fisherman...")
	MSG("I thought he'd take ta the family business|without all this bickerin' and moanin'.")
	MSG("He mustn't realize yet that his|blood is just yearnin' for it.|I'm sure he'll come 'round.")
	room_flag_on(9)
	jump EXIT

//　　★繰り返し
TALK5_2:
	MSG("I'm headin' out ta fish now.")
	MSG("Lately, with all this fog blowin' 'round|Castle Strangerock has been seen more and|more.")
	jump EXIT
//▼カニグモ戦後
TALK4:
	MSG("Ta catch the fish of Lake Orwell you|need ta have a bit of strategy,|if you know what I mean.")
	MSG("See, them fish run right into obstacles.|Just seems ta be their nature, ya know?")
	MSG("So if you use blockades, you can|force 'em into a narrow spot.")
	MSG("Haha, rather handy, huh?")
	jump EXIT
//▼トレント戦後
TALK3:
	MSG("Heya, Mr. Knight. Didja know this lake has|the most divine whitescale fish around?")
	MSG("Mmmhmm, bitin' inta one of them|salt baked fish is just heavenly!")
	MSG("They're best when the catch is fresh, yessiree.|Absolutely lip-smackin' delicious.")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	MSG("Well, now... Weren't you that chap that|was carried to the Spirit Sanctum yesterday|with all them wounds?")
	MSG("You sure you should be movin' about?")
	MSG("Even with Miss Liese's tendin' to you,|innit a bit early to be cavortin' about?")
	jump EXIT

//▼ゲーム開始直後
TALK1:
	check_room_flag(9)
	on_jump TALK1_2

TALK1_1:
	MSG("Strangerock? Yeah, I see Strangerock all|the time. Hard ta miss it in my line of|work.")
	MSG("Ain't got nothin' ta say about it, though.|I've seen it, sure, but I don't know nothin'|special.")
	MSG("Shows up on misty days like this one, it does.|You often hear a bell chime before it appears,|too. But try and get close and it vanishes.")
	MSG("Everybody 'round here knows all that, though.")
	MSG("Might be more ta learn if you dig for it.|There are lots of ruins on this here island,|and lots of history to go with 'em.")
	MSG("Heck, they even found some new ruins|right here in town the other day!")
	room_flag_on(9)
	jump EXIT

//　　★繰り返し
TALK1_2:
	MSG("Ain't got nothin' much ta say about Strangerock.|I've seen it, sure, but I don't know nothin'|special.")
	MSG("Shows up on misty days like this one, it does.|You often hear a bell chime before it appears,|too. But try and get close and it vanishes.")
	jump EXIT

EXIT:
	SET_MOTION("Ned","STAND",-1)
	END
}

