//====================================================================
// ボートを使ってイベント制御
//====================================================================

DEF("boat")

RES("INIT")
{
	// 3711	EV C-12 聖剣の巫女姫
	check_game_flag(3711)
	off_jump NEXT
	// 3803	EV D-0 シャルの心配
	check_game_flag(3803)
	off_jump EV_CHAR_DS
NEXT:

	// 4		インフェルノを倒したか？
	check_game_flag(   4)
	off_jump NEXT3
	// 3617	EV B-9b インフェルノ倒した後、シャルと話した
	check_game_flag(3617)
	off_jump EV_CHAR_MOUNTAIN
NEXT3:

	// 3603	EV B-4 トレント戦後(ドヴォルザークとの会話)
	check_game_flag(3603)
	off_jump NEXT4
	// 3623	TK B-4c トレント戦後、クラウンについてのシャルの会話
	check_game_flag(3623)
	off_jump EV_INN2
NEXT4:

	// EV 降霊の儀式後
	check_game_flag(3531)
	off_jump NEXT5
	// 寺院から宿屋へ、 見た？
	check_game_flag(3532)
	off_jump EV_INN
NEXT5:

	// オープニングからきたのでなければ終了
	check_game_flag(3500)
	off_jump EXIT
	// OP 見た？
	check_game_flag(3501)
	off_jump EV_OP

EXIT:
	end

//-- Ｄ-０　シャルの心配 ---------------------------------------------
EV_CHAR_DS:
	call CHAR_EVENT_DS
	end

//-- Ｂ-９　インフェルノ戦後のハーレック -----------------------------
EV_CHAR_MOUNTAIN:
	// 地下道から来たときは、
	CHECK_ENTRY_GATE("0097_0588")
	OFF_JUMP EV_CHAR_MOUNTAIN_2
	// 柵はすでに壊れてる？
	CHECK_GAME_FLAG(3001)
	OFF_JUMP EXIT

EV_CHAR_MOUNTAIN_2:
	call CHAR_EVENT_MOUNTAIN
	end

//-- Ｂ-４Ｂ トレント戦後のハーレック --------------------------------
EV_INN2:
	// 地下道から来たときは、
	CHECK_ENTRY_GATE("0097_0588")
	OFF_JUMP EV_INN2_2
	// 柵はすでに壊れてる？
	CHECK_GAME_FLAG(3001)
	OFF_JUMP EXIT

EV_INN2_2:
	call CHAR_EVENT_BOSS1
	end

//-- 宿へのスクロール ------------------------------------------------
EV_INN:
	call INN_SCROLL_EVENT
	end

//-- オープニングイベント呼び出し ------------------------------------
EV_OP:
	call OPENING_EVENT
	end
}

//////////////////////////////////////////////////////////////////////
// Ｄ-０　シャルの心配

@CHAR_EVENT_DS
{
	//--------------------------------------------------------------------
	CINEMA_ON(0)
	HIDE_CHR("Rodney")

	show_chr("Char")
	set_pos("Char", -2.08,-0.00,-0.36)
	set_deg("Char", 240)

	SET_MOTION("Lew","ATTACK2",0)
	SET_MOTION("Paty","ATTACK2",0)

	permit_script_camera(1)
	set_script_camera(-14,-0.00,-5.15,  -10.0,170.0,0.0, 15, 15.0)
	set_skip_label("SKIP")

	look_chr("PC", "-")
	INIT_WALK_DST("PC")
	set_walk_dst("PC",  -14.91,-0.00,-5.72)
	set_walk_dst("PC",  -13.39,-0.00,-5.89)
	walk_pos("PC",0,0.03)

	wait_walk("PC")

//　　精霊堂でドラゴンスレイヤーを手に入れて、街へ出たところで
//　　強制的にイベント開始。

	MSG_EX("#S3#C3Char|#C0#N0!",-1,2)

	look_chr("Char", "-")
	INIT_WALK_DST("Char")
	set_walk_dst("Char",  -6.65,0.00,-3.04)
	set_walk_dst("Char",  -10.39,-0.00,-5.76)
	set_walk_dst("Char",  -12.24,-0.00,-6.13)
	walk_pos("Char",1,0.05)
	wait_walk("Char")

//　　主人公に駆け寄ってくるシャル。

	MSG_EX("#S3#C3Char|#C0Ah...",-1,2)
	MSG_EX("#S3#C3Char|#C0That sword...|Is it really...?",-1,2)
	look_chr("Char", "PC")
	MSG_EX("#S3#C3Char|#C0Then, your body is back to normal?",-1,2)

//　　うなずく素振りを見せる主人公。
	SET_MOTION("PC","EMPTY23",30)
	WAIT(90)

	look_chr("Char", "-")
	MSG_EX("#S3#C3Char|#C0*sniff*",-1,2)
	SET_MOTION("Char","ATTACK2",30)
	MSG_EX("#S3#C3Char|#C0I'm so relieved...",-1,2)
	WAIT(120)
	MSG_EX("#S3#C3Char|#C0Hey, umm, #N0...",-1,2)
	MSG_EX("#S3#C3Char|#C0Now that...",-1,2)
	MSG_EX("#S3#C3Char|#C0Now that your body has recovered,|you don't need to fight anymore, right?",-1,2)
	look_chr("Char", "PC")	

//　　少し間を置いて首を振る主人公
	WAIT(120)
	SET_MOTION("PC","EMPTY24",30)
	WAIT(120)

	look_chr("Char", "-")
	MSG_EX("#S3#C3Char|#C0I see...",-1,2)
	SET_DEG("Char",170)
	MSG_EX("#S3#C3Char|#C0...",-1,2)
	MSG_EX("#S3#C3Char|#C0You're really something, #N0...",-1,2)
	SET_DEG("PC",150)
	WAIT(120)
	MSG_EX("#S3#C3Char|#C0I'm always at a loss for words...",-1,2)


	CROSS_FADE(60)
	SET_SCRIPT_CAMERA_EX( "Char", -2, 0,-30,0, 5, 15 )
	MOVE_SCRIPT_LOOK_AT( -0.5,0.5,0,2000, 0)

	SET_MOTION("Char","ATTACK1",30)
	MSG_EX("#S3#C3Char|#C0It's just like the time you became a knight.",-1,2)
	MSG_EX("#S3#C3Char|#C0You made such an important decision|all by yourself.",-1,2)
	MSG_EX("#S3#C3Char|#C0I...I was really worried about you...",-1,2)
	WAIT(120)
	look_chr("Char", "PC")
	WAIT(90)
	MSG_EX("#S3#C3Char|#C0And now, again...!",-1,2)
	MSG_EX("#S3#C3Char|#C0...",-1,2)


	FOCUS_CHR("PC")
	CROSS_FADE(60)
	permit_script_camera(0)

	SET_MOTION("Lew","STAND",0)
	SET_MOTION("Paty","STAND",0)
	SET_DEG_EX("Char","PC")
	SET_MOTION("Char","ATTACK1",30)
	MSG_EX("#S3#C3Char|#C0I'm sorry, #N0.|I should know better...",-1,2)
	WAIT(60)
	MSG_EX("#S3#C3Char|#C0J-just promise me you'll take care.|I'll be rooting for you from town.",-1,2)

	look_chr("Char", "-")
	INIT_WALK_DST("Char")
	set_walk_dst("Char",   -5,0,-2)
	walk_pos("Char",1,0.05)
	WAIT(60)
	SET_DEG("PC",90)
	WAIT(60)

//　　画面フェードアウト。
	fade_out(60)
	wait(120)

SKIP:
	// 3803	EV D-0 シャルの心配
	game_flag_on(3803)

	// 操作許可
	stop_walk("PC")
	stop_walk("Char")
	hide_chr("Char")
	look_chr("PC", "-")
	set_pos("PC",  -13.39,-0.00,-5.89)
	SET_DEG("PC",90)

	FOCUS_CHR("PC")
	permit_script_camera(0)
	fade_in(60)
	CINEMA_OFF(0)

}

//////////////////////////////////////////////////////////////////////
// Ｂ-９　インフェルノ戦後のハーレック
@CHAR_EVENT_MOUNTAIN
{
	//--------------------------------------------------------------------
	CINEMA_ON(0)

	//カメラグリンッ現象防止のため一時的に入れ替える
	CAMERA_OFF("遺跡入り口")
	CAMERA_OFF("火山入り口")
	CAMERA_OFF("全体")
	CAMERA_ON("全体２")

	set_pos("PC", 6.59,0.00,0.35)
	set_deg("PC", 140)

	permit_script_camera(1)
	set_script_camera(11.05,0.00,-0.42,  -8.0,190.0,0.0, 18, 15.0)
	set_skip_label("SKIP")

//　　インフェルノを倒してハーレックに戻って来ると強制的にイベ
//　　ント開始。街の中(宿屋手前あたりか)を歩く主人公を背後から
//　　シャルが呼び止める。

	look_chr("PC", "-")
	INIT_WALK_DST("PC")
	set_walk_dst("PC",  8.71,0.00,-0.98)
	set_walk_dst("PC", 11.04,0.00,-1.24)
	set_walk_dst("PC", 13.61,0.00,-0.97)
	walk_pos("PC",0,0.03)

	fade_in(80)
	wait_walk("PC")

	MSG_EX("#S3#C3Char|#C0#N0!",-1,2)

//　　後ろから走ってくるシャル。
	show_chr("Char")
	set_pos("Char", 0.04,0.00,-0.26)
	set_deg("Char", 56)

	set_deg("PC", 140)
	look_chr("PC", "Char")

	look_chr("Char", "-")
	INIT_WALK_DST("Char")
	set_walk_dst("Char",   5.83,0.00,-1.65)
	set_walk_dst("Char",  10.30,0.00,-1.78)
	walk_pos("Char",1,0.05)
	wait_walk("Char")

	MSG_EX("#S3#C3Char|#C0Did you just get back?",-1,2)
	set_motion("Char","ATTACK1",-1)
	MSG_EX("#S3#C3Char|#C0Hee hee... Glad you made it in one piece!",-1,2)
	MSG_EX("#S3#C3Char|#C0Are you well?|No mortal wounds, I take it?",-1,2)
	look_chr("Char", "PC")
	MSG_EX("#S3#C3Char|#C0I thought I'd get us some tea for when you|returned, and here you are! Shall we have a cup?",-1,2)

//　　画面フェードアウト。
	fade_out(80)
	wait(120)

SKIP:
	//カメラ一応戻しとく
	CAMERA_ON("遺跡入り口")
	CAMERA_ON("火山入り口")
	CAMERA_ON("全体")
	CAMERA_OFF("全体２")
	permit_script_camera(0)
	ENTRY_MAP("009d_009c")
}



//////////////////////////////////////////////////////////////////////
// Ｂ-４Ｂ トレント戦後のハーレック

@CHAR_EVENT_BOSS1
{
	//--------------------------------------------------------------------
	CINEMA_ON(0)
	//カメラグリンッ現象防止のため一時的に入れ替える
	CAMERA_OFF("遺跡入り口")
	CAMERA_OFF("火山入り口")
	CAMERA_OFF("全体")
	CAMERA_ON("全体２")


	permit_script_camera(1)
	set_script_camera(11.05,0.00,-0.42,  -8.0,190.0,0.0, 18, 15.0)
	set_skip_label("SKIP")

//　　トレント戦後、ハーレックに戻ると強制的にイベント開始。
//　　宿屋へ向かって歩く主人公。浜辺からシャルがやってくる。

	set_pos("PC", 10.72,0.00,-1.22)
	set_deg("PC", 140)
	set_motion("PC", "STAND", 0)

	look_chr("PC", "-")
	INIT_WALK_DST("PC")
	set_walk_dst("PC", 11.04,0.00,-1.24)
	set_walk_dst("PC", 13.61,0.00,-0.97)
	walk_pos("PC",0,0.03)

	fade_in(80)
	wait_walk("PC")

	MSG_EX("#S3#C3Char|#C0#N0!",-1,2)

//　　後ろから走ってくるシャル。
	show_chr("Char")
	set_pos("Char", 0.04,0.00,-0.26)
	set_deg("Char", 56)

	set_deg("PC", 140)
	look_chr("PC", "Char")

	look_chr("Char", "-")
	INIT_WALK_DST("Char")
	set_walk_dst("Char",   5.83,0.00,-1.65)
	set_walk_dst("Char",  10.30,0.00,-1.78)
	walk_pos("Char",1,0.05)
	wait_walk("Char")

	MSG_EX("#S3#C3Char|#C0Hee hee... Welcome back!",-1,2)

//　　画面フェードアウト。
	fade_out(80)
	wait(120)

SKIP:
	//カメラ一応戻しとく
	CAMERA_ON("遺跡入り口")
	CAMERA_ON("火山入り口")
	CAMERA_ON("全体")
	CAMERA_OFF("全体２")
	permit_script_camera(0)
	ENTRY_MAP("009d_009c")
}

//////////////////////////////////////////////////////////////////////
// 宿屋へのスクロール

@INN_SCROLL_EVENT
{
	//--------------------------------------------------------------------
	CINEMA_ON(0)

	permit_script_camera(1)
	set_script_camera(-13.36,0.00,-4.86,  -7.0,180.0,0.0, 20, 15.0)
	move_script_look_at(25.0,2,0, 800, 1)
	rotate_script_camera(0,24,0, 800, 1)
	set_motion("PC", "STAND", -1)
	refresh("PC")
	HIDE_CHR("PC")
	HIDE_CHR("Rodney")

	set_skip_label("SKIP")

	SE("SE_MORNING")

	show_chr("Char")
	set_pos("Char", -13.39,-0.00,-5.84)
	set_deg("Char", 56)

	wait(180)

	look_chr("Char", "-")
	INIT_WALK_DST("Char")
	set_walk_dst("Char", -10.04,0.00,-5.05)
	set_walk_dst("Char",  -6.88,0.00,-2.05)
	set_walk_dst("Char",  -2.68,-0.00,-1.04)
	set_walk_dst("Char",   5.83,0.00,-1.65)
	set_walk_dst("Char",  13.46,0.00,-1.36)
	set_walk_dst("Char",  16.29,1.00,-0.48)
	walk_pos("Char",1,0.05)

	wait(20)

	fade_in(80)
//	wait(620)
	wait_walk("Char")

	scale_script_camera(0.6, 400, 1)
	set_deg("Char", 102)
	set_motion("Char", "ATTACK1", -1)
	wait(90)
	switch_on("myroom_door")
	move_script_look_at(0.0,3,0, 400, 1)
	wait(60)

//	wait_camera(0)

	INIT_WALK_DST("Char")
	set_walk_dst("Char", 16.63,1.25,-0.49)
	walk_pos("Char",0,0.02)
	wait(20)

	fade_out(80)
	wait(120)
	SHOW_CHR("PC")
	ENTRY_MAP("009d_009c")

SKIP:
	SHOW_CHR("PC")
	ENTRY_MAP("009d_009c")

//	CINEMA_OFF(0)
//	permit_script_camera(0)
}




//////////////////////////////////////////////////////////////////////
// オープニングのイベント

@OPENING_EVENT
{
	//--------------------------------------------------------------------
	CINEMA_ON(0)

	bgm(-1,0,-1)

	show_chr("Char")
	show_chr("Boatman")
	hide_chr("Ned")

	set_pos("PC", -9.48,-2.0, -13.19)
	set_deg("PC", 200.0)
	set_pos("Char", -10.49, -2.0, -14.88)
	set_deg("Char", 319.0)
	set_pos("Boatman", -12.53, -2.0, -14.11)
	set_deg("Boatman",123.0)

	set_motion("PC", "STAND",0)
	set_motion("Char", "STAND",0)
	set_motion("Boatman", "STAND",0)


	look_chr("PC",  "Boatman")
	look_chr("Char","Boatman")
	look_chr("Boatman", "Char")

	permit_script_camera(1)
	set_script_camera(10.0,4.0,-5.0,  -8.-30,200.0,0.0, 20, 15.0)
	move_script_look_at(-18,-2,-10, 700, 1)
	rotate_script_camera(4,-40,0, 700, 1)

	// エリアネーム表示
	DISP_PLACE(0)
	fade_in(120)

	set_skip_label("SKIP")

	wait(700)
//	move_script_look_at(-14,-2,0, 600, 1)
//	rotate_script_camera(10,-40,0, 600, 1)
//	wait(600)
	cross_fade(120)
	set_script_camera(-9.6,-1.0,-16.0,  -11.0,160.0,0.0, 12, 15.0)

	rotate_script_camera(0,20,0, 1000, 1)

//▼ハーレックの街・船着場

//　　オープニング終了後、フェードアウト抜けてハーレックの街。
//　　「ハーレックの街」字幕表示しつつ、カメラは街の中央部から
//　　船着場へ振る。主人公たちの乗ってきた船がつながれている。
//　　主人公、シャル、船頭は船から降りて、桟橋で会話している状
//　　態。

	MSG_EX("#S3#C3Boatman|#C0Ye've got great timin', comin' here when y'did. Castle|only shows itself when there's mist hangin' over the lake.",-1,2)
	MSG_EX("#S3#C3Boatman|#C0Orwell's Castle Strangerock. Everybody 'round these|parts knows about it. Good for tourism, I warrant.",-1,2)

//	jump EXIT2

	MSG_EX("#S3#C3Char|#C0Interesting...",-1,2)
	MSG_EX("#S3#C3Char|#C0Pity it vanished as quickly as it did, though.|I would have liked to get a better look at it.",-1,2)

	MSG_EX("#S3#C3Boatman|#C0Sorry, miss. Ye'd have no luck there. Darn thing|always runs away when ye get too close, all shy-like.",-1,2)
	MSG_EX("#S3#C3Boatman|#C0Some say it's just a mirage, and that there's an|ol' trickster witch makin' it appear and disappear.",-1,2)
	MSG_EX("#S3#C3Boatman|#C0Either way, if ye're here long enough, ye'll|get to see it again. Lotsa times, too, I bet.",-1,2)

	MSG_EX("#S3#C3Char|#C0Glad to hear it!",-1,2)

	MSG_EX("#S3#C3Boatman|#C0And no talk of Strangerock's complete without bringin'|up the legend of the sword, Tu Long Jian.",-1,2)

	set_deg_ex("Char","Boatman")
	set_motion("Char","ATTACK1",-1)
	MSG_EX("#S3#C3Char|#C0Tu Long Jian?",-1,2)
	MSG_EX("#S3#C3Char|#C0If I'm not mistaken, that would translate from the old tongue|as &22Dragonslayer.&22 My, what a glorious name for a sword!",-1,2)

	MSG_EX("#S3#C3Boatman|#C0Surprised a scholarly lass like you don't already|know 'bout it.",-1,2)
	MSG_EX("#S3#C3Boatman|#C0Legends say that the Dragonslayer sleeps|within the darkest depths of Strangerock.",-1,2)
	MSG_EX("#S3#C3Boatman|#C0All just scuttlebutt, though. Nobody even knows if the|castle's real, much less that fancy soundin' sword.",-1,2)

	MSG_EX("#S3#C3Char|#C0Still... An ancient castle that only appears in the mist,|and a holy sword that rests therein...",-1,2)
	MSG_EX("#S3#C3Char|#C0It's like a fairy tale! Just hearing about|it makes my heart beat faster!",-1,2)

	MSG_EX("#S3#C3Boatman|#C0Ha! Ye got spirit, miss. If ye wanna know more,|talk to the locals. They got me beat on all the details.",-1,2)

	MSG_EX("#S3#C3Char|#C0I certainly will! Thank you so much for all|you've done, kind sir. May your return be swift.",-1,2)

	MSG_EX("#S3#C3Boatman|#C0My pleasure. Good luck out there.|Be sure and take care now.",-1,2)

//　　シャル、主人公のほうへ向く。
	cross_fade(120)
	look_chr("Boatman", "PC")
	look_chr("Char", "PC")
	set_deg_ex("Char","PC")
	set_motion("Char","STAND",-1)
	scale_script_camera(0.8, 1, 1)
	wait(140)

	MSG_EX("#S3#C3Char|#C0Well, #N0, we made it. I suppose the first thing|to do would be to secure our lodgings, no?",-1,2)

//　　うなずく主人公
	look_chr("PC", "Char")
	wait(60)
	set_motion("Char","ATTACK1",-1)
	MSG_EX("#S3#C3Char|#C0All right, then...",-1,2)
	MSG_EX("#S3#C3Char|#C0Off we go!",-1,2)
	MSG_EX("#S3#C3Char|#C0The first step of our adventure to unraveling the mystery around|that peculiar old castle begins now! Come, we've no time to waste!",-1,2)

//　　シャル、宿屋のほうへ走り去っていく。
//　　主人公もシャルの後を追って歩き出し画面フェードアウト。
	look_chr("Boatman", "Char")
	set_motion("Char","STAND",-1)
	look_chr("Char", "-")
	INIT_WALK_DST("Char")
	set_walk_dst("Char", -6.46, -1, -14.03)
	set_walk_dst("Char", -5.74, -1,  -8.65)
	set_walk_dst("Char", -7.60,  0,  -5.11)
	set_walk_dst("Char", -6.21,  0,  -2.52)
	look_chr("Boatman", "PC")
	set_walk_dst("Char", -2.38,  0,  -0.47)
	set_walk_dst("Char",  4.40,  0,  -1.64)
	walk_pos("Char",1,0.05)

	wait(60)
	move_script_look_at(10,5,0, 800, 1)

	wait(60)
	look_chr("PC", "Boatman")
	wait(20)
	set_deg_ex("PC","Boatman")
	wait(60)

	look_chr("PC", "-")
	INIT_WALK_DST("PC")
	set_walk_dst("PC", -6.46, -1, -14.03)
	set_walk_dst("PC", -5.74, -1,  -8.65)
	set_walk_dst("PC", -7.60,  0,  -5.11)
	set_walk_dst("PC", -6.21,  0,  -2.52)
	walk_pos("PC",0,0.022)
	wait(180)
	stop_env_se("SE_NAMI",4000)
	fade_out(120)
	wait(120)

	//-----------------------------
	ENTRY_IMG(0,"mono\MONO05_01",0)
	ENTRY_IMG(1,"mono\MONO05_02",0)
	ENTRY_IMG(2,"mono\MONO05_03",0)
	ENTRY_IMG(3,"mono\MONO05_04",0)
	ENTRY_IMG(4,"mono\MONO05_05",0)
	ENTRY_IMG(5,"mono\MONO05_06",0)
	SET_IMG( 0, 000,000, 0,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)
	FADE_IN(60)
	WAIT(60)
	//-----------------------------

	SET_MSG_TIME(5,40,90,90)
	MSG_EX("Three years had passed since the War of the Knights...",-1,0x00000094)
	MSG_EX("And with that struggle, the man whom I had loved as my|brother back at the orphanage had suddenly lost his honor,|and his way. He was adrift.",-1,0x00000094)
	MSG_EX("I could not bear to see my brother in such a state.|And so I invited him to join me on this expedition.",-1,0x00000094)
	MSG_EX("Looking back, it truly was the first step on an adventure.|Neither of us had any inkling of the tribulations to come...",-1,0x00000094)
	SET_MSG_TIME(-1,-1,-1,-1)

	//-----------------------------
	FADE_OUT(60)
	WAIT(60)
	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)
	//-----------------------------

	// EV 桟橋のイベントを見た
	game_flag_on(3501)
	ENTRY_MAP("009d_009c")

EXIT2:
	// 操作許可
	stop_walk("PC")
	stop_walk("Char")
	permit_script_camera(0)
	fade_in(10)
	CINEMA_OFF(0)

EXIT:
	end

SKIP:
	//-----------------------------
	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)
	//-----------------------------
	// EV 桟橋のイベントを見た
	game_flag_on(3501)
	ENTRY_MAP("009d_009c")
}

//--------------------------------------------------------------------

}


