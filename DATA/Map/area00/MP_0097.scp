//　　★繰り返し
TALK3_2:
	MSG("If'n you go to Eaglet Mountain, any|chance you could check on the lift?")
	MSG("Just a li'l while ago, you could use|that lift to get up the mountain.")
	MSG("Dammit all... With it outta commission|like that I can't get back to work.")
	jump EXIT

TALK3_3:
	// 3621	TK 昇降機復帰後のダモン報酬
	check_game_flag(3621)
	on_jump TALK3_4

	MSG("Ohhh, you got the lift to return?!")
	MSG("Thanks a bushel!|Now I can get back to work.")
	MSG("No matter how skilled you get, those salamanders|are quite the handful, don't you think?")
	MSG("Eaglet Mountain is where|they call home, after all...")
	MSG("Anyhow, you really helped me out here.")
	MSG("Allow me to give you somethin'.|Just a little extra.")

//	SYS("５００Ｇ手に入れた。")
	SE("SE_GETITEM")
