
// ----------------------------------------------------------------------------
// マップ街外観                                                                    
// ----------------------------------------------------------------------------

//-- ROOM_FLAG -------------------------------------------------------
//  0 ギュンター会話
//  1 ダーナ会話
//  2 ゾーイ会話
//  3 リュー会話
//  4 パティ会話
//  5 ダモン会話
//  6 デボラ会話
//  7 ロドニー会話
//  8 アラーナ会話
//  9 ネッド会話
// 10 ジーン会話
// 11 シャル会話
//


DEF("MAP")

// マップ出るときに呼ばれる ---------------------------------------------------
//RES("EXIT")
//{
//	// "地名表示"が終わっていない可能性があるので強制消去
//	IMG_OFF(0)
//	IMG_OFF(1)
//	IMG_OFF(2)
//	IMG_OFF(3)
//	CINEMA_OFF(0)
//}

// マップ入るときに呼ばれる ---------------------------------------------------
RES("INIT")
{
	//シャルと会話用限定カメラ。イベントでグリンッってならない為だけの物です。普段は必ずオフにすること。
	CAMERA_OFF("全体２")


	//水マップか否か
	CHECK_GAME_FLAG(3302)
	OFF_SKIP(3)
	LOAD_MAP("MP_008d")
	HIDE_CHR("boat")
	SKIP(1)

	SE("SE_NAMI")

//-- 火山0813マップ炎壁のハマリ防止用 ------------------------------------------
	GAME_FLAG_OFF(800)


//-- アニエスシステム初期化 ------------------------------------------

	game_flag_off(3630)
	game_flag_off(3631)
	game_flag_off(3632)
	game_flag_off(3633)
	game_flag_off(3634)
	game_flag_off(3635)
	game_flag_off(3636)
	game_flag_off(3637)

//-- ワープの強制停止処理 --------------------------------------------

	// 3603	EV B-4 トレント戦後(ドヴォルザークとの会話)
	check_game_flag(3603)
	off_jump NO_WARP
	// 3623	TK B-4c トレント戦後、クラウンについてのシャルの会話
	check_game_flag(3623)
	off_jump WARP_STOP

	// 4		インフェルノを倒したか？
	check_game_flag(   4)
	off_jump NO_WARP
	// 3617	EV B-9b インフェルノ倒した後、シャルと話した
	check_game_flag(3617)
	off_jump WARP_STOP

	jump NO_WARP

WARP_STOP:
	cancel_pc_warp(0)

NO_WARP:

//--------------------------------------------------------------------
	// 3518	EV 遺跡の扉を開けた
	CHECK_GAME_FLAG(3518)
	OFF_JUMP CLOSE_DOOR

	INIT_SWITCH_ON("t_door")

CLOSE_DOOR:

// 地名表示 --------------------------------------------------------------------

	// フェード処理（下記ゲート以外から来たらマップ名表示）
	CHECK_ENTRY_GATE("0097_0093")
	ON_JUMP NEXT
	CHECK_ENTRY_GATE("0097_0094")
	ON_JUMP NEXT
	CHECK_ENTRY_GATE("0097_0095")
	ON_JUMP NEXT
	CHECK_ENTRY_GATE("0097_0096")
	ON_JUMP NEXT
	CHECK_ENTRY_GATE("0097_009b")
	ON_JUMP NEXT

	// オープニングからきたのでなければ終了(最初からはじめていないはず) 
	check_game_flag(3500)
	off_jump OPEN
	// OP すでにイベントを見ていたら終了
	check_game_flag(3501)
	off_jump NEXT

	// INN SCROLL すでにイベントを見ていたら終了
	check_game_flag(3531)
	off_jump OPEN
	check_game_flag(3532)
	off_jump NEXT

	// EV C-2 リーゼが倒れる
	check_game_flag(3701)
	off_jump OPEN
	// EV C-2b リーゼが倒れて寺院から出た処理。
	check_game_flag(3721)
	off_jump NEXT

OPEN:
	GAME_FLAG_OFF(3000)

	// エリアネーム表示
	DISP_PLACE(0)

NEXT:



// NPCの初期化 ---------------------------------------------------------------

	HIDE_CHR("Char")
	HIDE_CHR("Boatman")

	ENTRY_CHR( 0, 076)
	ENTRY_CHR( 1, 069)
	ENTRY_CHR( 2, 068)
	ENTRY_CHR( 3, 073)
	ENTRY_CHR( 4, 057)
	ENTRY_CHR( 5, 070)
	ENTRY_CHR( 6, 058)
	ENTRY_CHR( 7, 074)
	ENTRY_CHR( 8, 122)
	ENTRY_CHR( 9, 468)
	ENTRY_CHR(10, 513)
	ENTRY_CHR(11, 071)
	ENTRY_CHR(12, 398)

	PUT_CHR( 0, "Gunter",  2.42,0.00,25.75, 181)
	PUT_CHR( 1, "Dana",   -5.81,0.00,13.88, 143)
	PUT_CHR( 2, "Zoe",    -4.88,0.00,14.82, 171)
	PUT_CHR( 3, "Lew",    -4.43,0.00,10.06, 359)
	PUT_CHR( 4, "Paty",   -3.76,0.00,11.45, 334)
	PUT_CHR( 5, "Damon", -13.39,0.63, 9.21, 332)
	PUT_CHR( 6, "Deborah", 11.05,-2.77,-13.82, 177)
	PUT_CHR( 7, "Rodney", -5.81,0.00,-1.40, 174)
	PUT_CHR( 8, "Alana",  -3.3,0.00,22.86, 347)
	PUT_CHR( 9, "Ned",     4.89,0.00,13.04, 124)
	PUT_CHR(10, "Jean",   -3.15,-1.00,-10.62, 173)

	//▼障壁消滅後
	check_game_flag(3710)
	off_jump POS_7

	set_pos("Dana",  -0.67,-4.88,-17.80)
	set_deg("Dana", 186)
	set_pos("Zoe",  -1.76,-4.82,-17.51)
	set_deg("Zoe", 157)
	set_pos("Damon", 3.77,-3.76,-13.28)
	set_deg("Damon", 184)
	set_pos("Ned",   -10.15,-4.91,-18.22)
	set_deg("Ned", 181)
	set_pos("Lew",    2.14,-5.32,-20.73)
	set_deg("Lew", 175)
	set_pos("Paty",   3.33,-5.61,-20.71)
	set_deg("Paty", 209)
	set_pos("Alana",  11.05,0.00,5.52)
	set_deg("Alana", 195)
	set_walk_range("Rodney", 3.0, 50, 90)
	jump POS_END

POS_7:
	//▼奇岩城出現後
	check_game_flag(3702)
	off_jump POS_6

	set_pos("Rodney", -8.54,-4.75,-17.32)
	set_deg("Rodney", 186)
	set_pos("Dana",  -0.67,-4.88,-17.80)
	set_deg("Dana", 186)
	set_pos("Zoe",  -1.76,-4.82,-17.51)
	set_deg("Zoe", 157)
	set_pos("Damon", 3.77,-3.76,-13.28)
	set_deg("Damon", 184)
	set_pos("Ned",   -10.15,-4.91,-18.22)
	set_deg("Ned", 181)
	set_pos("Lew",    2.14,-5.32,-20.73)
	set_deg("Lew", 175)
	set_pos("Paty",   3.33,-5.61,-20.71)
	set_deg("Paty", 209)
	set_pos("Alana",  11.05,0.00,5.52)
	set_deg("Alana", 195)

	// TK シャルと城が現れたことについて話す
	check_game_flag(3723)
	on_jump POS_END
	SHOW_CHR("Char")
	SET_POS("Char",  10.61,0.00,-6.30)
	SET_DEG("Char", 168)

	jump POS_END

POS_6:
	//▼インフェルノ戦後
	check_game_flag(4)
	off_jump POS_5

	set_pos("Ned",   -4.43,0.00,10.06)
	set_deg("Ned", 359)
	set_pos("Rodney",   -3.76,0.00,11.45)
	set_deg("Rodney", 334)
	set_pos("Lew",    7.31,-3.23,-13.10)
	set_deg("Lew", 170)
	set_pos("Paty",   9.06,-3.21,-14.24)
	set_deg("Paty", 240)
	set_pos("Alana",  11.05,0.00,5.52)
	set_deg("Alana", 195)
	jump POS_END

POS_5:
	//▼カニグモ戦後
	check_game_flag(1)
	off_jump POS_4

	set_pos("Jean",   4.06,-2.86,-8.18)
	set_deg("Jean", 211)

	set_pos("Alana",  11.05,0.00,5.52)
	set_deg("Alana", 195)
	set_walk_range("Rodney", 3.0, 50, 90)
	jump POS_END

POS_4:
	//▼トレント戦後
	check_game_flag(3)
	off_jump POS_3

	set_pos("Alana",  11.05,0.00,5.52)
	set_deg("Alana", 195)
	set_walk_range("Rodney", 3.0, 50, 90)
	jump POS_END

POS_3:
	//▼ガーディアン取得後
	check_game_flag(3532)
	off_jump POS_2

	set_pos("Alana",  11.05,0.00,5.52)
	set_deg("Alana", 195)
	set_walk_range("Rodney", 3.0, 50, 90)
	jump POS_END

POS_2:
	//▼ゲーム開始直後

	// 3514	EV 赤子を抱いた母親
	check_game_flag(3514)
	on_skip 1
	hide_chr("Alana")

	// EV 宿酒場のイベント(調査開始)
	check_game_flag(3502)
	on_skip 2
	hide_chr("Rodney")
	skip 1
	set_walk_range("Rodney", 3.0, 50, 90)


POS_END:



//-- リーゼとフローレットの特殊処理 ----------------------------------

	// 1		カニグモを倒したか？
	check_game_flag( 1)
	off_jump NO_LIESE
	// EV B-11 リーゼの破魔矢イベント
	check_game_flag(3610)
	on_jump NO_LIESE

	PUT_CHR(11, "Liese",   -4.82,-1.00,-13.99, 180)
	NO_LOOK_PC("Liese")
	look_chr("Liese","-")

NO_LIESE:

	// 3800	EV 祭壇の花嫁
	CHECK_GAME_FLAG(3800)
	on_jump NO_FLEURETTE

	// 3804	EV D-0-1 フローレットの回想
	check_game_flag(3804)
	on_jump NO_FLEURETTE

	// 4017	0627	ポータルエリア５、中盤　街でフローレのイベント起動にも利用します
	check_game_flag(4017)
	off_jump NO_FLEURETTE

	// EV C-12 聖剣の巫女姫
	CHECK_GAME_FLAG(3711)
	OFF_JUMP NO_FLEURETTE

	PUT_CHR(12, "Fleurette",   5.18,0.00,-2.51, 96)
	look_chr("Fleurette","-")
	set_pos("Alana", 7.38,0.00,-3.78)
	set_deg_ex("Fleurette","Alana")
	set_deg_ex("Alana","Fleurette")

NO_FLEURETTE:

//--------------------------------------------------------------------

	// 地下道への柵は破壊されていないか？
	CHECK_GAME_FLAG(3001)
	OFF_SKIP(1)
	HIDE_CHR("saku")

	// カギ設定
	CHECK_GAME_FLAG(591)
	OFF_SKIP(6)
	CHECK_GAME_FLAG(1519)
	ON_SKIP(2)
	KAGI("d1519",1)
	SKIP(2)
	INIT_SWITCH_ON("d1519")
	ENABLE_EV_POP("d1519",0)

	// カギ設定
	CHECK_GAME_FLAG(1814)
	ON_SKIP(2)
	KAGI("d1814",1)
	SKIP(1)
	INIT_SWITCH_ON("d1814")

}

