	check_room_flag(2)
	on_jump TALK1_2

TALK1_1:
	MSG("We're entertainers from another land. I guess|you could even say we're 'exotic' dancers,|since we've come from afar.")
	MSG("This isn't our first time in Harlech, though.|We toured here several years ago, as well.")
	MSG("Things seem a bit different from what I remember.|The air feels...stormy, perhaps, or troubled.")
	MSG("I guess the war lingers on in spirit|even though it's ended.")
	MSG("The lakes of Lyndale are widely regarded as hubs|of peace and tranquility in these chaotic times,|though. To feel such unease here is troubling...")
	room_flag_on(2)
	jump EXIT

//　　★繰り返し
TALK1_2:
	MSG("In the areas surrounding the capital they say there are|countless children who've lost everything. Their homes,|their families... Everything was taken by the war.")
	MSG("It pains me just to think of it...")
	jump EXIT

EXIT:
	SET_MOTION("Zoe","STAND",-1)
	END
}

