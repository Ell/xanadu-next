// ----------------------------------------------------------------------------
// カギ開け
// ----------------------------------------------------------------------------

DEF("d1519")
RES("KAGI")
{
	GAME_FLAG_ON(1519)
	SWITCH_ON("d1519")
	ENABLE_EV_POP("d1519",0)
}

RES("CLICK")
{
//	CINEMA_ON(0)
//	STOP_PC(0)
	CHECK_GAME_FLAG(591)
	ON_SKIP(4)
	WAIT(30)
	SYS("#c2Something seems to be blocking the door from the other side.")
	CINEMA_OFF(0)
	END



}

DEF("d1814")
RES("KAGI")
{
	GAME_FLAG_ON(1814)
}


// ----------------------------------------------------------------------------
// セーブ
// ----------------------------------------------------------------------------

DEF("save")
RES("CLICK")
{
	CINEMA_ON(0)
	STOP_PC(0)

	refresh("PC")
	se("SE_HEAL")

	SEL("Record your deeds? |#c2Save|Cancel")
	CHECK_SELECT(0)
	OFF_JUMP SEL_A

		CALL_SHOP(4)
//		SE("SE_UP_PRM")
//		SYS("#c2今までの冒険を記録しました。")

SEL_A:
	CHECK_SELECT(1)

	CINEMA_OFF(0)
}


// ============================================================================
// 門(exit)
// ============================================================================

DEF("gate")
RES("CLICK")
{
	// EV 降霊の儀式終了、シャルとの会話
	check_game_flag(3532)
	on_jump NEXT

	STOP_PC(0)

	ACTIVE_CHR("Gunter")
	SET_NAME("Gunter", "Gateman Gunter")
	SET_MOTION("Gunter", "ATTACK1",-1)

	SET_DEG_EX("Gunter", "PC")

	call TALK_Gunter

EXIT:
	SET_MOTION("Gunter","STAND",-1)
	SET_DEG("Gunter", 180)
	END

//-- 出入り可能 ------------------------------------------------------
NEXT:
	CINEMA_ON(0)

	STOP_PC(0)
	ACTIVE_CHR("SCREEN")
	SEL("Exit the town? |#C2Exit|Cancel")

	CHECK_SELECT(0)
	ON_JUMP SELALL_1
	JUMP SELALL_2

SELALL_1:
	WAIT(30)
	SHAKE(0,10)
	SHAKE(0,10)
	SWITCH_ON("gate")
	WAIT(30)
	FADE_OUT(-1)
	GAME_FLAG_ON(3000)
//	GAME_FLAG_ON(3301)
	WAIT(40)
	SE("SE_CHG_AREA")
	WAIT(20)
	ENTRY_MAP("0710_out")
	END

SELALL_2:
	CINEMA_OFF(0)
	END

}

