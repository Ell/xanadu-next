RES("CLICK")
{

	CINEMA_ON(0)

	STOP_PC(0)
	ACTIVE_CHR("SCREEN")
//	SEL("　#c2街から出ますか？　|　　・はい|　　・いいえ")
	SEL("Exit the town? |#C2Exit|Cancel")

	CHECK_SELECT(0)
	ON_JUMP SELALL_1
	JUMP SELALL_2

SELALL_1:
	WAIT(30)
	SHAKE(0,10)
	SHAKE(0,10)
	SWITCH_ON("gate3")
	WAIT(30)
	FADE_OUT(-1)
	GAME_FLAG_ON(3000)
//	GAME_FLAG_ON(3301)
	WAIT(40)
	SE("SE_CHG_AREA")
	WAIT(20)
	ENTRY_MAP("0861_0097")
	END

SELALL_2:
	CINEMA_OFF(0)
	END

}

