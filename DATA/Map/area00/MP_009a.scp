// ============================================================================
// ギルドマスター
// ============================================================================
DEF("gm")
RES("EVENT")
{
	call etr_pc

// 準備が整った直後 -----------------------------------------------------------
	check_game_flag(3501)
	on_jump skip0
	add_shop_script("gm_msg1")
	game_flag_on(3501)
skip0:

	erase_shop_list(0)
	entry_shop_list("228/229/230")
	call_shop(50000)

	switch_off("door_gm")
	set_pos_ex("PC","out_gm")
	set_deg("PC",180)
	call rtn_pc
}
