//--------------------------------------------------------------------

//▼障壁消滅後
TALK7:
	check_room_flag(4)
	on_jump TALK7_2

TALK7_1:
	MSG("The Ballad of Castle Strangerock is complete.|Would you care to hear my latest masterpiece?")
	MSG("The castle resting on the lake...|Freed from fog's embrace...")
	MSG("Amidst a vision...a tender time...|Will vanish if you chase...")
	MSG("As all transient things must do...|It will scatter on the wind...")
	MSG("But in this moment a vision is born...|Of forgotten times and dreams of old...")
	MSG("For there lies Strangerock...|Take heed, attend, behold...")
	MSG("Although, it feels like something|that arose from a dream, all the same.")
	MSG("Well, I've completed my song at last.|I should be glad to have seen it through.")
	room_flag_on(4)
	jump EXIT

//　　★繰り返し
TALK7_2:
	MSG("Although, it feels like something|that arose from a dream all the same.")
	MSG("Well, I've completed my song at last.|I should be glad to have seen it through.")
	jump EXIT
//▼奇岩城出現後
TALK6:
	check_room_flag(4)
	on_jump TALK6_2

TALK6_1:
	MSG("Castle Strangerock? Ah, yes, I saw it...")
	MSG("Even though I journeyed all this way to|compose a poem about Castle Strangerock...")
	MSG("Seeing the real thing feels ominous,|somehow.")
	MSG("It was even more fantastic than|I dared imagine.")
	MSG("Its presence was almost overwhelming,|if I must be honest.")
	room_flag_on(4)
	jump EXIT

//　　★繰り返し
TALK6_2:
	MSG("It was so majestic seeing Castle Strangerock|rise out of the mist like that.")
	MSG("I had no idea what to expect...")
	jump EXIT
//▼インフェルノ戦後
TALK5:
	check_room_flag(4)
	on_jump TALK5_2

TALK5_1:
	MSG("There is another lake next to Orwell|to the east, called the Cebrian.")
	MSG("However, you can't see it from this town.")
	MSG("In olden times, it was said that when|the water level of Orwell lowered,|the water in Cebrian would rise.")
	MSG("Because of that, there's a rumor that|both lakes share the same water vein.")
	room_flag_on(4)
	jump EXIT

//　　★繰り返し
TALK5_2:
	MSG("There is another lake next to Orwell|to the east called Cebrian.")
	MSG("There's a rumor that both lakes|share the same water vein.")
	jump EXIT
//▼カニグモ戦後
TALK4:
	MSG("I've heard that this island has a place|that the locals call 'Trechier Woods.'")
	MSG("It has quite the ominous reputation.|It's said that once people enter,|they become trapped and lost inside.")
	MSG("Even if you think you can return to the|path, you're already under its spell.")
	MSG("In order to escape the forest, there seems|to be a particular route you must take.")
	jump EXIT
//▼トレント戦後
TALK3:
	MSG("Have you seen the great mountain|to the west of this island?")
	MSG("The peak is coated with snow,|and yet I hear that within it|a tremendous fire burns...")
	MSG("Such a beautiful and sacred place...|I believe it's known as Eaglet Mountain.")
	jump EXIT

//▼ガーディアン取得後
TALK2:
	check_room_flag(4)
	on_jump TALK2_2

TALK2_1:
	MSG("I thought I'd compose a song|dedicated to Castle Strangerock.")
	MSG("The beautiful land here is quite mysterious.")
	MSG("The whole island is covered in a sprawl|of fantastical ruins, and the people|are blessed by ancient spirits...")
	MSG("There is certainly no lack of musical|inspiration in such a magical setting.")
	MSG("If I couldn't make a memorable piece|surrounded by so many muses, I could|hardly call myself a troubadour!")
	room_flag_on(4)
	jump EXIT

//　　★繰り返し
TALK2_2:
	MSG("There is certainly no lack of musical|inspiration in such a magical setting.")
	MSG("If I couldn't make a memorable piece|surrounded by so many muses, I could|hardly call myself a troubadour!")
	jump EXIT

//▼ゲーム開始直後
TALK1:
	check_room_flag(4)
	on_jump TALK1_2

TALK1_1:
	MSG("A new face, I see. Welcome. My name is Sandra.|I'm a troubadour, come to compose songs about|this rich and fascinating land.")
	MSG("These lonely ruins inspire such grand thoughts...|such profound poetry... It's as if they call to my heart.|Please, won't you listen to my song before you go?")
	MSG("As birds trill their timeless songs...|And flowers stand in bloom...")
	MSG("The Khan named Kublai lays the base|of his thousand-year old tomb...")
	MSG("Brick on brick, never beaten...|To further his fancy anew...")
	MSG("Heaven made real, an earthly Eden...|Hereafter called Xanadu...")
	room_flag_on(4)
	jump EXIT

//　　★繰り返し
TALK1_2:
	MSG("Brick on brick, never beaten...|To further his fancy anew...")
	MSG("Heaven made real, an earthly Eden...|Hereafter called Xanadu...")
	jump EXIT

EXIT:
	SET_MOTION("Sandra","STAND",-1)
	END
}
