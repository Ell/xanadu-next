
// ----------------------------------------------------------------------------
// マップ  宿酒場２Ｆ　宿泊用部屋
// ----------------------------------------------------------------------------

//-- ROOM_FLAG -------------------------------------------------------
// 0 シャル会話
//

DEF("MAP")

RES("INIT")
{

	//▼奇岩城出現後
	check_game_flag(3702)
	off_jump NEXT
	// TK シャルと城が現れたことについて話す
	check_game_flag(3723)
	on_jump NEXT
	HIDE_CHR("Char")

NEXT:

}

//////////////////////////////////////////////////////////////////////
// シャル


DEF("Char")

// マップ切り替えイベント
RES("INIT")
{
//▼シャルが調査を始めた
	CHECK_GAME_FLAG(3501)
	OFF_JUMP EXIT
//会話１
	CHECK_GAME_FLAG(3502)
	OFF_JUMP EVENT1

	// EV 降霊の儀式後
	check_game_flag(3531)
	off_jump EXIT
	// EV 
	check_game_flag(3532)
	off_jump EVENT3

	// 3603	EV B-4 トレント戦後(ドヴォルザークとの会話)
	check_game_flag(3603)
	off_jump EXIT
	// 3623	TK B-4c トレント戦後、クラウンについてのシャルの会話
	check_game_flag(3623)
	off_jump EVENT4

	// 4		インフェルノを倒したか？
	check_game_flag(   4)
	off_jump EXIT
	// 3617	EV B-9b インフェルノ倒した後、シャルと話した
	check_game_flag(3617)
	off_jump EVENT5
	// イベントなし
	jump EXIT

//-- Ｂ-９　インフェルノ戦後のハーレック -----------------------------

EVENT5:

	set_pos("PC",-0.69,0.00,-0.36)
	set_deg("PC", 349)
	SET_MOTION("PC","STAND",-1)

	permit_script_camera(1)
	set_script_camera_EX("Char",1,-32,185.0,0.0, 7, 15.0)

	set_deg("Char", 191)
	look_chr("Char", "PC")

	CINEMA_ON(0)
	fade_in(120)
	wait(120)

	set_skip_label("SKIP5")

//　　フェード抜け。自室でシャルと向き合って会話している主人公

	MSG_EX("#S3#C3Char|#C0...Did you find another crown?",-1,2)
	MSG_EX("#S3#C3Char|#C0After exploring Eaglet Mountain, I dare say|you've pretty much scoured this whole island!",-1,2)
	MSG_EX("#S3#C3Char|#C0You've done wonderfully.",-1,2)

	look_chr("Char", "-")
	MSG_EX("#S3#C3Char|#C0Up to this point we've gathered three crowns...|And a fair number of tabulae, too.",-1,2)
	MSG_EX("#S3#C3Char|#C0We should check around town.|Maybe there's some clue about|Castle Strangerock we can still learn.",-1,2)
	look_chr("Char", "PC")
	WAIT(60)
	MSG_EX("#S3#C3Char|#C0With all that endless fighting you've done, #N0,|a relaxing stroll would probably do you good.",-1,2)

//　　→フェード抜けで操作許可

	focus_chr("PC")
	cross_fade(60)
	set_script_camera_EX("PC",0,-45,225,0.0, 20, 15.0)
	reset_map_rot_y(1,0)
	permit_script_camera(0)
	CINEMA_OFF(0)
	wait(60)



	// 3617	EV B-9b インフェルノ倒した後、シャルと話した
	game_flag_on(3617)
	END

SKIP5:
	reset_map_rot_y(1,0)
	focus_chr("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)

	// 3617	EV B-9b インフェルノ倒した後、シャルと話した
	game_flag_on(3617)

	fade_in(60)
	wait(60)
	END

//-- Ｂ-４Ｂ トレント戦後のハーレック --------------------------------

EVENT4:

	set_pos("PC",-0.69,0.00,-0.36)
	set_deg("PC", 349)
	SET_MOTION("PC","STAND",-1)

	permit_script_camera(1)
	set_script_camera_EX("Char",1,-32,185.0,0.0, 7, 15.0)

	set_deg("Char", 191)
	look_chr("Char", "PC")

	CINEMA_ON(0)
	fade_in(120)
	wait(120)

	set_skip_label("SKIP4")

//　　トレント戦後、ハーレックに戻ると強制的に宿屋へ飛んで
//　　イベント開始。シャルと向き合って会話している主人公。

	wait(90)
	look_chr("Char", "PC")
	wait(30)
	MSG_EX("#S3#C3Char|#C0Wow, what a simply splendid crown...",-1,2)
	look_chr("Char", "PC")
	MSG_EX("#S3#C3Char|#C0Didn't you say you found a crown|down in the Back-Alley Ruins?",-1,2)

	wait(60)
	look_chr("Char", "-")
	wait(20)

	MSG_EX("#S3#C3Char|#C0And that was when you were wounded|by that swordsman...",-1,2)
	MSG_EX("#S3#C3Char|#C0From what I've found in my research,|it seems like this crown has something|to do with the Sacred Sword.",-1,2)

	look_chr("Char", "PC")
	MSG_EX("#S3#C3Char|#C0And I would guess that that swordsman and|the old man accompanying him probably also|know something about the Sacred Sword.",-1,2)
	MSG_EX("#S3#C3Char|#C0I wonder who they could be...",-1,2)
	MSG_EX("#S3#C3Char|#C0It sounds like there may be another crown, though.|Perhaps we can figure out more by finding it?",-1,2)

	wait(60)
	look_chr("Char", "-")
	wait(20)

	MSG_EX("#S3#C3Char|#C0It might be a good idea to see if there's|any correlation in the tabulae.",-1,2)

	look_chr("Char", "PC")
	set_deg_ex("Char", "PC")
	wait(60)

	MSG_EX("#S3#C3Char|#C0Now, #N0...|Be on your guard around those people.",-1,2)
	MSG_EX("#S3#C3Char|#C0If anything like before were to|happen to you again, I'd...",-1,2)

	focus_chr("PC")
	cross_fade(60)
	set_script_camera_EX("PC",0,-45,225,0.0, 20, 15.0)
	reset_map_rot_y(1,0)
	permit_script_camera(0)
	CINEMA_OFF(0)
	wait(60)

	// 3623	TK B-4c トレント戦後、クラウンについてのシャルの会話
	game_flag_on(3623)
	END

SKIP4:
	reset_map_rot_y(1,0)
	focus_chr("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)

	// 3623	TK B-4c トレント戦後、クラウンについてのシャルの会話
	game_flag_on(3623)

	fade_in(60)
	wait(60)
	END


//--------------------------------------------------------------------
EVENT3:

	set_pos("PC",-0.69,0.00,-0.36)
	set_deg("PC", 349)
	SET_MOTION("PC","STAND",-1)

	permit_script_camera(1)
	set_script_camera_EX("Char",1,-32,185.0,0.0, 7, 15.0)

	set_deg("Char", 191)
	look_chr("Char", "PC")

	CINEMA_ON(0)
	fade_in(120)
	wait(120)

	set_skip_label("SKIP3")

	MSG_EX("#S3#C3Char|#C0So, while you've been resting, I've been doing a|bit of research. And I think I found something...",-1,2)

	sys("#S3#C2Char produced from her bag the|tabulae you found in the ruins.",-1,2)
	add_text_time(6000000)

	wait(60)
	look_chr("Char", "-")
	wait(20)

	MSG_EX("#S3#C3Char|#C0These are tabulae from|the ruins, #N0.",-1,2)
	wait(20)
	MSG_EX("#S3#C3Char|#C0You had these on you when you were found.|I hope you don't mind that I looked them over.",-1,2)
	MSG_EX("#S3#C3Char|#C0They're quite old. The lettering carved into|them is no longer used, and hasn't been for a|very, very long time.",-1,2)
	MSG_EX("#S3#C3Char|#C0'Tis considered a sacred script of sorts, and one|used exclusively by the literati of Xanadu Kingdom.",-1,2)
	MSG_EX("#S3#C3Char|#C0You've heard of Xanadu, no? Troubadours often sing of it.|Songstress Sandra downstairs seems enamored with it, in fact.",-1,2)
	MSG_EX("#S3#C3Char|#C0Scholars tell that it was once quite a prosperous|kingdom. Some even called it a paradise on Earth.|It stood for over a thousand years!",-1,2)
	MSG_EX("#S3#C3Char|#C0And it would seem all the ruins around here|are in some way related to this Xanadu kingdom.",-1,2)
	MSG_EX("#S3#C3Char|#C0I'm willing to bet Castle Strangerock|has some connection, as well.",-1,2)
	MSG_EX("#S3#C3Char|#C0If you find any other slates or tablets like these,|be sure you bring them to me for translation, okay?",-1,2)
	MSG_EX("#S3#C3Char|#C0These are exactly the kinds of things we're looking for.|They're the keys to unlocking the mysteries of Harlech Island.",-1,2)
	MSG_EX("#S3#C3Char|#C0And with enough time, I can easily decipher|each and every one you show me.",-1,2)
	wait(40)
	look_chr("Char", "PC")
	MSG_EX("#S3#C3Char|#C0Speaking of which, I actually translated these|particular tabulae while you were resting.",-1,2)
	MSG_EX("#S3#C3Char|#C0If you're interested in reading my notes,|just let me know!",-1,2)
	wait(60)
	look_chr("Char", "-")
	wait(120)
	MSG_EX("#S3#C3Char|#C0#N0...",-1,2)
	wait(120)
	look_chr("Char", "PC")
	set_deg_ex("Char", "PC")
	wait(60)
	MSG_EX("#S3#C3Char|#C0I'll do whatever I can to help you.",-1,2)
	MSG_EX("#S3#C3Char|#C0So please...find the Sacred Sword.|Find the Dragonslayer. Okay?",-1,2)

	focus_chr("PC")
	cross_fade(60)
	set_script_camera_EX("PC",0,-45,225,0.0, 20, 15.0)
	reset_map_rot_y(1,0)
	permit_script_camera(0)
	CINEMA_OFF(0)
	wait(60)

	// EV 宿酒場のイベント(調査開始)
	game_flag_on(3532)
	// EV B-1 聖剣の探索へ(シャルとの会話)
	game_flag_on(3600)
	END

SKIP3:
	reset_map_rot_y(1,0)
	focus_chr("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)

	// EV 宿酒場のイベント(調査開始)
	game_flag_on(3532)
	// EV B-1 聖剣の探索へ(シャルとの会話)
	game_flag_on(3600)
	fade_in(60)
	wait(60)
	END

//--------------------------------------------------------------------
EVENT1:
	set_pos("PC",-0.69,0.00,-0.36)
	set_deg("PC", 349)
	SET_MOTION("PC","STAND",-1)

	permit_script_camera(1)
//	set_script_camera_EX("Char",3,-35,205.0,0.0, 8, 15.0)
//	move_script_look_at(0,0,-2.0, 400, 1)
//	rotate_script_camera(0,-10,0, 400, 1)

	set_deg("Char", 191)
	look_chr("Char", "PC")
	set_script_camera_EX("PC",3,-35,195,0.0, 8, 15.0)
	wait(60)

	CINEMA_ON(0)
	fade_in(120)
	wait(120)

	set_skip_label("SKIP")

//	stop_camera(0)
	cross_fade(60)
	MSG_EX("#S3#C3Char|#C0So, here we are. 'Tis not a bad room at all, really! Rather|cozy, in fact. Should make an excellent base of operations.",-1,2)
	MSG_EX("#S3#C3Char|#C0Which brings us to our mission here. We're to be the first|explorers to uncover the mysteries of Castle Strangerock!",-1,2)
	wait(20)
	look_chr("Char", "-")
	MSG_EX("#S3#C3Char|#C0Exciting, no?",-1,2)
	MSG_EX("#S3#C3Char|#C0However, despite its fame, there is|very little information about it.",-1,2)
	wait(20)
	set_motion("Char","ATTACK1",-1)
	MSG_EX("#S3#C3Char|#C0All we truly know, in fact, is that it|appears on the lake when the mist rolls in.",-1,2)
	MSG_EX("#S3#C3Char|#C0That's why I think our best course of action is|to explore the ruins scattered across this island.",-1,2)
	look_chr("Char", "PC")
	wait(20)
	MSG_EX("#S3#C3Char|#C0Between the ruins and any local legends we may happen|upon, I'm certain we'll find some clue to aid our search.",-1,2)
	MSG_EX("#S3#C3Char|#C0I suppose the best place to start is with the townsfolk.|Let's ask around and see what we can learn, shall we?",-1,2)
	MSG_EX("#S3#C3Char|#C0If we split up, we'll cover more ground.|Good luck, #N0!",-1,2)

	focus_chr("PC")
	cross_fade(60)
	set_script_camera_EX("PC",0,-45,225,0.0, 20, 15.0)
	reset_map_rot_y(1,0)
	permit_script_camera(0)
	CINEMA_OFF(0)

	// EV 宿酒場のイベント(調査開始)
	game_flag_on(3502)

EXIT:
	END


SKIP:
	reset_map_rot_y(1,0)
	permit_script_camera(0)
	CINEMA_OFF(0)

	// EV 宿酒場のイベント(調査開始)
	game_flag_on(3502)
	focus_chr("PC")
	fade_in(60)
	wait(60)
	END
}

//////////////////////////////////////////////////////////////////////
// シャル会話処理

RES("CLICK")
{
	FOCUS_CHR("Char")
	SET_NAME("Char", "Char")
	SET_MOTION("Char", "ATTACK1",-1)

	//3711	EV C-12 聖剣の巫女姫(▽ドラゴンスレイヤー入手後)
	check_game_flag(3711)
	on_jump NEXT

	// 3717	EV C-11b 黒き花嫁後のシャルとの会話
	check_game_flag(3717)
	ON_JUMP NEXT

	// 3710	EV C-11 黒き花嫁(▼障壁消滅後)
	check_game_flag(3710)
	on_jump TALK

NEXT:

//-- 石板と手記の判定 ------------------------------------------------

	// Ｂパート始まるまでは石板は渡せない
	check_game_flag(3532)
	off_jump MENU_TOP

	// 石板持ってる？（0:石板/1:手記）
	check_text_item(0)
	off_jump NoStone
	// 全部没収（0:石板/1:手記）
	msg("Ah, you've brought me more tabulae to translate!|I'll decipher these right away.")
	sys("Relinquished tabulae to Char.")
	pick_text_item(0)
NoStone:

	// 手記ってる？（0:石板/1:手記）
	check_text_item(1)
	off_jump NoPaper
	// 全部没収（0:石板/1:手記）
	msg("Ooh, I see you've found some old memoirs!|I'll get started on translating these right away.")
	sys("Relinquished memoirs to Char.")
	pick_text_item(1)
	// EV 手記を預けたことがある
	game_flag_on(3611)
NoPaper:

//--------------------------------------------------------------------

MENU_TOP:
	// EV 手記を預けたことがある
	check_game_flag(3611)
	on_jump MENU4

	// Ｂパート開始
	check_game_flag(3532)
	on_jump MENU3

	// 最初のシャルと話したフラグ
	check_game_flag(3510)
	on_jump MENU2

	jump MENU1

//-- 会話のみ --------------------------------------------------------

MENU1:
	jump TALK


//-- 荷物預けあり ----------------------------------------------------

MENU2:
	SEL("#c1Need something?|#c2Talk|Rest|Store/Retrieve Items|Nothing")
	check_select(0)
	on_jump TALK
	check_select(1)
	on_jump REST
	check_select(2)
	on_jump ITEM

	jump EXIT

//-- 荷物預け、石板あり、手記なし ------------------------------------

MENU3:
	SEL("#c1Need something?|#c2Talk|Rest|Store/Retrieve Items|Read Tabulae|Nothing")
	check_select(0)
	on_jump TALK
	check_select(1)
	on_jump REST
	check_select(2)
	on_jump ITEM
	check_select(3)
	on_jump STONE_PLATE

	jump EXIT

//-- 荷物預け、石板、手記あり ----------------------------------------

MENU4:
	SEL("#c1Need something?|#c2Talk|Rest|Store/Retrieve Items|Read Tabulae|Read Memoirs|Nothing")
	check_select(0)
	on_jump TALK
	check_select(1)
	on_jump REST
	check_select(2)
	on_jump ITEM
	check_select(3)
	on_jump STONE_PLATE
	check_select(4)
	on_jump NOTE_BOOK

	jump EXIT

//-- 会話選択 --------------------------------------------------------
TALK:
	call TALK_CHAR
	jump MENU_TOP

//-- 休憩する --------------------------------------------------------

REST:
	fade_out(30)
	wait(30)
	wait(30)
	refresh("PC")
	se("SE_HEAL")
	sys("#c2You feel rested and refreshed.")
	set_time(12,00)

	// セーブ回数カウント
	INC_SAVE_COUNT( 0 )

	call_shop(4)
	check_use_shop(0)
	off_jump no_use
	sys("#C2The details of your adventure have been recorded.")
no_use:
	fade_in(30)
	wait(30)
	jump MENU_TOP
	jump EXIT

//-- 荷物を預ける ----------------------------------------------------
ITEM:
	// 預かり所

	////////////////////////////////////////////////////
	// ★05/09/10:ショップ説明スクリプトを入店時に再生
	check_game_flag(77)
	on_jump skip_help
	game_flag_on(77)
	add_shop_script("help")
skip_help:
	////////////////////////////////////////////////////
	call_shop(3)
	jump MENU_TOP

//-- 石板を読む ------------------------------------------------------
STONE_PLATE:
	CINEMA_ON(0)

	// 石板MENU呼び出し（0:石板/1:手記）
	call_text(0)

	// call_text()内で「キャンセル(12)」を選んだ時はここでスキップさせる
	check_sel_text(12)
	on_jump PLATE_END
	check_sel_text(-1)
	on_jump PLATE_END

	// 石板用背景を読みこみ
	load_novel_bg("epitaph\plate")
	// 石板用背景表示
	novel_on(0)
	wait(60)

	SET_MSG_TIME(5,40,50, 30)

	// 選んだ石板に応じた文面の表示
	check_sel_text(0)
	on_jump Stone1
	check_sel_text(1)
	on_jump Stone2
	check_sel_text(2)
	on_jump Stone3
	check_sel_text(3)
	on_jump Stone4
	check_sel_text(4)
	on_jump Stone5
	check_sel_text(5)
	on_jump Stone6
	check_sel_text(6)
	on_jump Stone7
	check_sel_text(7)
	on_jump Stone8
	check_sel_text(8)
	on_jump Stone9
	check_sel_text(9)
	on_jump Stone10
	check_sel_text(10)
	on_jump Stone11
	check_sel_text(11)
	on_jump Stone12

	jump STONE_END
//--------------------------------------------------------------------
Stone1:
	MSG_EX("#S3#C0[To the Inheritors |of History]",-1,0x00000094)
	MSG_EX("#S3#C0I tell of my homeland,|founded by the great|Kublai Khan, and|proclaimed an Eden|by all who behold|its fair vistas.| |Its name,|Xanadu.",-1,0x00000094)
	MSG_EX("#S3#C0Here,|the songs of the birds|ring out,| |the flowers are always|in bloom,| |and the light of the sun|doth shine warmly|upon all the land.",-1,0x00000094)
	MSG_EX("#S3#C0Truly, Xanadu is a place|of beauty, and peace.",-1,0x00000094)
	MSG_EX("#S3#C0However, it is not my intent|to extol the glory|of this countryside herein.|Rather, the duty|that falls upon me|is that of minutiae and fact - | |to make accurate record|of the history|that's befallen us.",-1,0x00000094)
	MSG_EX("#S3#C0And even in such a|place as Xanadu,|for every light that|burns pure, a shadow|is also cast.",-1,0x00000094)
	MSG_EX("#S3#C0To those who shall inherit|and succeed our history,|I beg ye read this account|carefully|and with open mind.",-1,0x00000094)
	MSG_EX("#S3#C0I must regrettably chronicle|that twice did our paths|cross with a hideous calamity|of unimaginable horror.| |The devil Galsis - |he who rules the world|of nothingness.|He who brings forth|apparitions to defile us.",-1,0x00000094)
	MSG_EX("#S3#C0At his hands,|the ideals of our just|and righteous community|turned to ashes,| |and our Eden|became a land|governed by lust and vice.",-1,0x00000094)
	MSG_EX("#S3#C0As we stand now, however,|we have overcome|these tribulations,|and re-established|a prosperity|befitting Xanadu.",-1,0x00000094)
	MSG_EX("#S3#C0We owe our gratitude|for this good fortune|to the heroes and wise men|of the past|who drove this devil|from our land.",-1,0x00000094)
	MSG_EX("#S3#C0The first invasion of Galsis |was thwarted |by a valorous youth |who bore the Sacred Sword, |sent to our aid |by his liege, King Giuliden, |and guided |by the one star's light.",-1,0x00000094)
	MSG_EX("#S3#C0The second invasion|of Galsis|was repelled|by a beautiful|and valiant princess|who carried with her|the selfsame sword.",-1,0x00000094)
	MSG_EX("#S3#C0Both of these figures |have since been accorded|the highest honors in|the annals of history.",-1,0x00000094)
	MSG_EX("#S3#C0Light coexists with shadow,|and so too must the tales|of Xanadu's calamitous past|coexist with those|of its heroes.",-1,0x00000094)
	MSG_EX("#S3#C0If we are to remember|the trials we have faced,|'tis important|we also remember|the means through which|they were overcome...",-1,0x00000094)

	// 石版用背景消去
	novel_off(0)
	wait(60)
	INIT_SWITCH_ON("tabula1")

	check_game_flag(3900)
	on_jump STONE_END

	// 3710	EV C-11 黒き花嫁(▼障壁消滅後)
	check_game_flag(3710)
	on_jump Stone1_end

	MSG("The phrasing suggests that it was written|by a historian from ancient Xanadu.")
	MSG("It really is a remarkable find!")
	MSG("If its contents are accurate, that means|Xanadu was visited by some sort of demon|not once, but twice!")
	MSG("And this &22Sacred Sword&22... I can only|assume it to be the Dragonslayer itself.")
	MSG("I'm not familiar with this legendary hero or princess the|historian writes of, however. I wonder who they were...")
	MSG("Hey, #N0. Don't you find this all very exciting?|Doesn't it just give you the shivers?")
	MSG("Whenever I hear these grand tales of old, I always|think about all the people who lived in those times,|the people who got caught up in it all...")
	MSG("And I always imagine,|what if we were them...")

Stone1_end:
	game_flag_on(3900)
	// お弁当処理
	CHECK_MAX_ITEM(0)
	ON_JUMP STONE_END
	MSG("...Ah, sorry. I got a bit caught up|in it all for a moment.")
	MSG("Before you go, I have something to give you.|Believe it or not, I actually made you lunch!")
	MSG("After all you've been through,|'tis the least I can do.")
	jump GET_FOOD
//--------------------------------------------------------------------
Stone2:
	MSG_EX("#S3#C0[The Chosen Ones]",-1,0x00000094)
	MSG_EX("#S3#C0He came without warning|during the reign of|His Highness King Giuliden.| |Dragon King Galsis - such|was the name given to the|calamity that brought cruelty|and avarice in its wake.",-1,0x00000094)
	MSG_EX("#S3#C0| |Galsis released his minions |upon the land, and in the |blink of an eye, Xanadu was|swept under a wave of terror.| |The renowned artisan Seisen |was  forced to  construct a |maze for  the devil  within |the  sacred catacombs  that |stretched beneath the royal |capital.",-1,0x00000094)
	MSG_EX("#S3#C0| |Powerless to resist Galsis'|corrupting influence, those|who  had  formerly  thrived|under  the  reign  of  King |Giuliden  began  inundating|him with unreasonable|demands. | |Rumor   had  it  that   the |treasured crowns themselves,|long-standing   symbols  of |Xanadu's  royal  line,  had |been torn from  his  grasp; |and  with their loss,  the|world plunged into darkness.",-1,0x00000094)
	MSG_EX("#S3#C0Still,|despite the looming shadows |of fear  and  disgrace, His |Highness remained undaunted. | |He bided  his  time, quietly |waiting for  a portent from |above.",-1,0x00000094)
	MSG_EX("#S3#C0| |Finally,|with  the help  of a  noted |astrologer,  he  found  his |foretoken  and arranged for |an audience with a group of |youths  boasting  a  heroic |disposition. | |The youths were placed under |the tutelage of seven offi- |ciating  sages who  helped |train  them   in  body  and |spirit to stand up  against |the devil's regime.",-1,0x00000094)
	MSG_EX("#S3#C0|Valor, merit, charm,|empathy, wisdom, mysticism, |and victory;  such were the |subjects  of mastery taught |by the Seven Sages,  all of |whom  were   merciless  and |unforgiving tutors. | |One  brave  soul persevered|through   their    ruthless|instruction,  and it was he|who  ultimately  set  forth |into the  vast  underground |labyrinth  that Galsis  had |made his lair.",-1,0x00000094)
	MSG_EX("#S3#C0Singlehandedly, |he retrieved all the crowns, |and even obtained the Sacred |Sword known as Dragonslayer.",-1,0x00000094)
	MSG_EX("#S3#C0| | |This sword is said  to house |the  deified   spirit  of  a |great  hero   who spent  his |life   hunting   dragons  of |wicked   heart;  some   even |claim  it  to  be  his  very |incarnation made steel.| |And with weapon in hand,|this brave soul faced innume- |rable  threats, culminating |in the triumphant defeat of |the Dragon King, Galsis.",-1,0x00000094)
	MSG_EX("#S3#C0|He  truly was  a courageous |youth;  and  the  king,|a  great  and  wise  man.",-1,0x00000094)
	MSG_EX("#S3#C0| |Through their  valor  and|wisdom, Xanadu was pulled|back from the brink of hell. | |Even now, the people of this |land  recount  the  glorious|tale of these two |valiant men. | |'Tis  with  heavy heart  I |must  report, however,  that |the name  of  this  youthful|savior  has  been  lost  to|history.",-1,0x00000094)
	MSG_EX("#S3#C0| |As  our  story  draws  to a |close, the demonic Galsis|lay defeated, and  Xanadu's |peaceful days were returned. | |But  as you surely must  be |aware,  dear  reader,  this |was not  to be  the  tale's |final conclusion...",-1,0x00000094)

	// 石版用背景消去
	novel_off(0)
	wait(60)
	INIT_SWITCH_ON("tabula2")

	check_game_flag(3901)
	on_jump STONE_END

	// 3710	EV C-11 黒き花嫁(▼障壁消滅後)
	check_game_flag(3710)
	on_jump Stone2_end

	MSG("...It seems to chronicle Xanadu's struggle|against some fell creature named Galsis.")
	MSG("The Sacred Sword...Dragonslayer.|Its legend has been passed down from generation|to generation, even as far back as this...")

	check_game_flag(3907)
	on_jump Stone2_2

//	⇒石板⑧天蠍の石板を読んでいない

	CHECK_ITEM(187)
	on_jump Stone2_1
	CHECK_ITEM(188)
	on_jump Stone2_1
	CHECK_ITEM(189)
	on_jump Stone2_1
	CHECK_ITEM(190)
	on_jump Stone2_1

//		⇒クラウンを一つも持っていない
	MSG("And these crowns... I'll bet they're the same ones|sought after by that swordsman you fought, #N0...")
	MSG("It says here that they're|&22long-standing symbols of Xanadu's royal line&22.|They must be quite a sight to behold!")
	MSG("So what does that swordsman want with them,|I wonder. Is he a treasure hunter?")
	jump Stone2_end

//		⇒クラウンと一つでも持っている
Stone2_1:
	MSG("And these crowns... I find it far too coincidental that|this journey began with you being struck down for that very|thing, #N0. I surmise that the crowns in these|ruins are the very ones written of in this tablet.")
	MSG("And if so...well, the tablet says they're|&22long-standing symbols of Xanadu's royal line&22.|I believe they must be rather rare and valuable treasures.")
	MSG("You'd best treat them as such.|Take good care of them if you come across more, okay?")
	jump Stone2_end

//	⇒石板⑧天蠍の石板を読んでいる
Stone2_2:
	MSG("And this Dragonslayer...|It houses the deified spirit of a dragon hunter and|may even be his very incarnation? The language here|suggests that the Sacred Sword is regarded as nothing|less than a god...")
	jump Stone2_end

Stone2_end:
	game_flag_on(3901)
	// お弁当処理
	CHECK_MAX_ITEM(0)
	ON_JUMP STONE_END
	MSG("Oh, #N0! Before you go, take this.|I made you some food for your travels.")
	MSG("I hope you like it!")
	jump GET_FOOD
//--------------------------------------------------------------------
Stone3:
	MSG_EX("#S3#C0[When the Rain Falls]",-1,0x00000094)
	MSG_EX("#S3#C0No matter the era, bad|tidings never  warn of|their approach.|Their arrival is sudden,|and devastating.",-1,0x00000094)
	MSG_EX("#S3#C0| |Several  years  passed  in |tranquil procession following |the fated struggle between |the valiant youth  and |Galsis. | |One  night,  when the moon |was  nearing  its  peak, a |messenger approached  King |Giuliden's private chambers |as he rested.",-1,0x00000094)
	MSG_EX("#S3#C0| |Galsis, whose body had been |entombed within the labyrinth, |was  returning to life;  his |pulse had begun beating anew.",-1,0x00000094)
	MSG_EX("#S3#C0Understanding the urgency of|the situation, the king cal- |led forth  the  brave  sword |bearer  and the  seven  wise |sages to his castle. | |I surmise the reason was to |discern  the meaning behind |Galsis' revival.",-1,0x00000094)
	MSG_EX("#S3#C0| |It is  said  that this|council lasted seven  days,|from  early morning through|the darkest hours of night. | |As  dawn  broke  on  the |eighth day at the castle a |conclusion was reached, and |the meeting adjourned at |long last.",-1,0x00000094)
	MSG_EX("#S3#C0| |The devil's body was to be |borne to the castle and |sealed within a barrier of |tremendous power, so as to |arrest the beast's rebirth.",-1,0x00000094)
	MSG_EX("#S3#C0| |King Giuliden appointed his |own  daughter  as a  Sacred |Maiden  to  this  end,  and |commanded her  to  maintain |the  devil's  seal,  for as |long as she drew breath.",-1,0x00000094)
	MSG_EX("#S3#C0| |The Seven Sages would serve |to support her in this task, |as best as they were able. | |Thus spawned a noble tradi- |tion,  wherein  the  eldest |daughter of the royal family |would  inherit the  duty of |protecting and maintaining |this seal.",-1,0x00000094)
	MSG_EX("#S3#C0| |Through |this adjudication, peace |persisted  in Xanadu for many |hundreds of years thereafter. | |Occasional   rumors  of the |devil's revival did surface |from  time   to  time,  but |history   records  no  such |occurrences. | |Xanadu's  rich  and idyllic |existence continued  unaba- |ted, and all was well.",-1,0x00000094)
	MSG_EX("#S3#C0Such was the state of the |land until a particular |young woman came along...",-1,0x00000094)

	// 石版用背景消去
	novel_off(0)
	wait(60)
	INIT_SWITCH_ON("tabula3")

	check_game_flag(3902)
	on_jump STONE_END

	// 3710	EV C-11 黒き花嫁(▼障壁消滅後)
	check_game_flag(3710)
	on_jump Stone3_end

	MSG("Seems this Galsis was sealed away|after his first defeat.")
	MSG("It stands to reason, then, that actually|killing devils like this might be impossible. ")
	MSG("And this tradition where the first princess|of each king would inherit the role of a|Sacred Maiden and maintain the seal...")
	MSG("It seems like a tremendous burden. To be forced|into a lifetime of servitude, and be responsible|for guarding such monstrous evil... How terrible.")

Stone3_end:
	game_flag_on(3902)
	// お弁当処理
	CHECK_MAX_ITEM(0)
	ON_JUMP STONE_END
	MSG("Ah, but enough of that! Here's your lunch, #N0.|I made it while I was translating.")
	MSG("I put a lot into this one,|so be sure to savor it!")
	jump GET_FOOD
//--------------------------------------------------------------------
Stone4:
	MSG_EX("#S3#C0[The Unblessed Bride]",-1,0x00000094)
	MSG_EX("#S3#C0| |The  advent  of  the  Black|Bride   is   an  event   of|considerable  renown,  and|has  thus been  recorded in|much  detail  by  the|scholars  of  the  era. | |The  following  is directly|sourced from  one of  these|accounts:",-1,0x00000094)
	MSG_EX("#S3#C0I fear I shall never forget |the terrible events of this |accursed day.",-1,0x00000094)
	MSG_EX("#S3#C0| |It  should  have   been  an |auspicious  occasion,  with |Princess Fleurette celebra- |ting her 16th year. | |Her  birthday   rites   did|progress without  incident,|but just as the investiture|ceremony  for the  title of|Sacred  Maiden  was about|to  begin,  something|dreadful occurred.",-1,0x00000094)
	MSG_EX("#S3#C0That terrible woman|appeared before us, veiled|in  the deepest  black. She|calmly  stepped in front of|the crowd, seemingly|oblivious  to  the audacity|of her own actions.| |She  opened  her   insolent|mouth, and  these are  the|words she spoke...",-1,0x00000094)
	MSG_EX("#S3#C0&22I  have  freed  the  devil|Galsis from his seal within|the castle,&22 she said.",-1,0x00000094)
	MSG_EX("#S3#C0And that's not all!| |She  even went so far as to |call  herself  that demon's |bride!",-1,0x00000094)
	MSG_EX("#S3#C0| |Everyone in|attendance began to laugh.| |As one might imagine, there |weren't many left who still |put much stock in tales of |Galsis.| |That  the  woman  was  also|widely known as a religious|fanatic  did her no favors.|Indeed, the  crowd  lost no|time  in  chastising  her,|right then and there.",-1,0x00000094)
	MSG_EX("#S3#C0But not a moment later, the |derision and  laughter  all |came to an abrupt halt.",-1,0x00000094)
	MSG_EX("#S3#C0The clear  |blue  sky, which  had seemed|so  auspicious just  moments|before  during  Princess|Fleurette's  celebration|ceremony,  suddenly  became|choked  with  dark  clouds. | |Then, accompanied by roiling|thunder, the voice of none |other  than   Galsis  himself |resounded throughout the land.",-1,0x00000094)
	MSG_EX("#S3#C0|In short, it was a|declaration of war upon|Xanadu.| |And in  that  very  moment,|one could feel the onset of|a  new  era  of  terror and|chaos, engulfing our would- |be utopia  like the  clouds|swallowed the light above.",-1,0x00000094)
	MSG_EX("#S3#C0| | |There could be no doubt that |this traitorous woman spoke |the truth:  she  had taken a |vow  of  marriage  with  the |great Dragon King of legend.| |Although just  an  ordinary |human being,  she unleashed |the  wrath of ultimate evil |upon our fair kingdom.  She |alone  had  overthrown |centuries  of  peace  in  a |mere instant.",-1,0x00000094)
	MSG_EX("#S3#C0| |'Black Bride,' |they've begun calling her. | |A fitting name. ",-1,0x00000094)

	// 石版用背景消去
	novel_off(0)
	wait(60)
	INIT_SWITCH_ON("tabula4")

	check_game_flag(3903)
	on_jump STONE_END

	// 3710	EV C-11 黒き花嫁(▼障壁消滅後)
	check_game_flag(3710)
	on_jump Stone4_end

	MSG("...This one's all about a woman who |came to be known as the 'Black Bride.'")
	MSG("What kind of person would marry a devil?|It's inhuman! Did her own people hold no|interest for her?")
	MSG("There's something terribly creepy about it all.|To become the wife of such a wicked creature...|'Tis truly disturbing.")

Stone4_end:
	game_flag_on(3903)
	// お弁当処理
	CHECK_MAX_ITEM(0)
	ON_JUMP STONE_END
	MSG("...Ah, I almost forgot. I've made a lunch for you,|#N0. It's all packed up and ready for you|to take on your next excursion!")
	MSG("I'm quite proud of this one, actually.|All the patrons of the tavern downstairs seemed|to really enjoy it, and I hope you will too.")
	jump GET_FOOD
//--------------------------------------------------------------------
Stone5:
	MSG_EX("#S3#C0[Where the Star Shines]",-1,0x00000094)
	MSG_EX("#S3#C0His Highness|did not  hesitate.  As soon |as the demon's challenge was|delivered, he  issued his own |royal decree ordering the|deaths of Galsis and his|unholy bride.",-1,0x00000094)
	MSG_EX("#S3#C0| |The ones named to carry out |this mission were none other |than General  Vanaporte and |his most elite fighters.| |His Highness entrusted them |with the  Sacred Sword  and |seemed to  anticipate  that |the might of  the  warriors |and  the supremacy  of  the|holy blade  would  lead  to  |certain victory.",-1,0x00000094)
	MSG_EX("#S3#C0|Now, if |you've  been  following |along carefully, dear reader, |you will undoubtedly take |issue with this course |of action. | |Indeed,  when  the  kingdom |last faced Galsis, the|appointed challenger had|been a youth trained by the|Seven Sages that bore the|Sacred Sword alone against|the demon.",-1,0x00000094)
	MSG_EX("#S3#C0| |That   approach   succeeded |where all others had failed.|So why, then, would the|king  abandon  precedent in|this  manner?| |The answer, it seems,  lies |up   above;   for   in  the |heavens,  no star  could be |seen, and thus no gathering |of youths would convene. ",-1,0x00000094)
	MSG_EX("#S3#C0| |When the call for heroes was|sounded  previously, history|records  that  three  stars|shone  as   one,   cutting|through  the  thick  black|clouds  that hung  over the|land like  a beacon  in the|night.",-1,0x00000094)
	MSG_EX("#S3#C0| |This small constellation has |come  to  be  known  as  the |Dragon's Fang,  and  its|twinkling points are said to|combine  into a single  star|once  every  three   hundred|years.| |From  time immemorial, this |merging was seen  as a good |omen, and only in its light |could a hero be revealed. ",-1,0x00000094)
	MSG_EX("#S3#C0|It seems, however, that the |devil's  revival  under the |auspices of the Black Bride |was  an  event  even   Lady |Destiny could  not foresee.  |This time the Dragon's Fang|did  not  coalesce,  but|remained  dim  and  apart,|barely  able  to  penetrate|the looming darkness.| |Under this bleak sky|Xanadu's army  failed,|and this time there appear- |ed  no  hope of  a  hero's |arrival to set things right.",-1,0x00000094)
	MSG_EX("#S3#C0|It was in  this direst  of|times,  when  anxiety  and|unease permeated  the every|waking thought of  all  who|dwelt  within  the  castle,|that something occurred. | |The royal  medium  herself, |Princess Fleurette, went |missing. | |And with her, |the Seven Sages... ",-1,0x00000094)

	// 石版用背景消去
	novel_off(0)
	wait(60)
	INIT_SWITCH_ON("tabula5")

	check_game_flag(3904)
	on_jump STONE_END

	// 3710	EV C-11 黒き花嫁(▼障壁消滅後)
	check_game_flag(3710)
	on_jump Stone5_end

	MSG("...Seems like this is talking about|the battle between Xanadu and Galsis.")
	MSG("And it says that when the|three stars in the night sky meet,|'tis a portent for something amazing.")
	MSG("'Twould be wonderful if this country|could see peace soon too...")

Stone5_end:
	game_flag_on(3904)
	// お弁当処理
	CHECK_MAX_ITEM(0)
	ON_JUMP STONE_END
	MSG("...Ah, #N0!|I made some food for you.")
	MSG("You can't fight on an|empty stomach, right?")
	jump GET_FOOD
//--------------------------------------------------------------------
Stone6:
	MSG_EX("#S3#C0[The Princess|Ne'er Returning]",-1,0x00000094)
	MSG_EX("#S3#C0| |If the  literature  of this|era  rings  true, then  the|fair Princess Fleurette was|a young lady  of  the  most|cheerful disposition, unmat- |ched in both  academic  and|military talent, and beloved|by all her people.",-1,0x00000094)
	MSG_EX("#S3#C0| |But though it  is an incon- |trovertible  fact  that she|inherited   the  title   of|Sacred  Maiden  at the time|of  her  16th  birthday,|little  detail  is known of|her life before that day.",-1,0x00000094)
	MSG_EX("#S3#C0Of course, the question most|pertinent to these  records|is that of  her whereabouts|when she and the Seven Sages|vanished from Xanadu.",-1,0x00000094)
	MSG_EX("#S3#C0| |The following|account is one|that may prove most familiar|to my readers, as it endures|to  this  very  day  in the|canon  of  tales  recounted|to our young.| |Regrettably,  there  exists|no official report of these|events, so all  information|herein     pertaining    to|Princess Fleurette's emprise|is  comprised  from  hearsay|and rumor of the time.",-1,0x00000094)
	MSG_EX("#S3#C0| |The last confirmed location|of  Princess Fleurette  and|her   party   was  in   the|vicinity of Lyndale.| |With the Dragonslayer shim- |mering in  her  hands,  our|noble heroine had her sights|set  upon  the   mysterious|castle  that  appeared only|amidst the fog on the water;",-1,0x00000094)
	MSG_EX("#S3#C0the selfsame fort  that had|eluded the  prior  frenzied|searching  of   Xanadu's|army -  Castle Strangerock,|stronghold of Galsis.",-1,0x00000094)
	MSG_EX("#S3#C0| |The princess  and the Seven|Sages,  having successfully|infiltrated  the  elusive|citadel,  had   thus  set|about  tracking  down   the|devil and his bride therein.| |And in those  haunted halls,|to behold the mere shadow of|the  princess  wielding  the|Sacred  Sword  was as  if to|see  the  Guardian  Valkyria|herself, such  was the level|of mastery  displayed by our|heroine.",-1,0x00000094)
	MSG_EX("#S3#C0|At long last, after seven|days of fierce battle,|Princess Fleurette's holy|blade was plunged through|the massive neck of the|Dragon King.| |The  Black  Bride, with her|husband dead  and her power|lost, is  said to have then|relinquished Castle Strange- |rock into the water's deep,|and   herself  to   eternal|sleep...",-1,0x00000094)
	MSG_EX("#S3#C0Of course, |this  is  all  little  more|than  folktale.  Whatever|truth there may be  to this|grandiose   epic  has  been|lost to the ages.",-1,0x00000094)
	MSG_EX("#S3#C0| |It is historical fact,|however,  that  the|incursions  wrought by  the|devil's  minions  suddenly|ceased no more  than  a|single month after Princess|Fleurette's disappearance|from Xanadu.| |And since that time, neither|scale  nor  claw  has  been|seen of Galsis or his bride.",-1,0x00000094)
	MSG_EX("#S3#C0| |Now, |the princess is heralded as |one of the great figures of |our time; a savior regarded |with reverence  and admira- |tion akin to  that bestowed |upon the founder himself  - |the great Kublai Khan.| |And after these events,  no |further incidents occurred, |leaving   Xanadu's   record |books with naught but peace |and prosperity to this very |day.",-1,0x00000094)
	MSG_EX("#S3#C0| |I must  admit that  even  I, |typically unaffected as I am|by  the march  of  time that |I  commit  to  record,  have |become   enamored  of   this |lore.  When  I call  to mind|that   image   of   Princess|Fleurette  brandishing   her|holy  blade,  I  find myself|lost  in  the  moment...",-1,0x00000094)

	// 石版用背景消去
	novel_off(0)
	wait(60)
	INIT_SWITCH_ON("tabula6")

	// 3710	EV C-11 黒き花嫁(▼障壁消滅後)
	check_game_flag(3710)
	on_jump Stone6_0

	//▼奇岩城出現後
	check_game_flag(3702)
	on_jump Stone6_0

	// 3619	TK B-9d シャル、誘導後に石板を読んだ
	check_game_flag(3619)
	on_jump Stone6_end
	// 3618	TK B-9c シャル、石板への誘導会話
	check_game_flag(3618)
	off_jump Stone6_0

	// 読んだことある？
	check_game_flag(3905)
	off_jump Stone6_B

//▽以前に《処女の石板》を読んだことがある
Stone6_A:
	MSG("I know you've read it before,|but judging by what's written here...|Well, do you think about this part?")
	MSG("It says the Black Bride &22then relinquished|Castle Strangerock into the water's deep&22...|This HAS to be some sort of clue, don't you agree?")
	MSG("I guess we can't know for sure since|it might just be a fairy tale.")
	MSG("But there might be some leads at|the bottom of that lake, though!")
	game_flag_on(3619)
	jump Stone6_end

//▽初めて《処女の石板》を読んだ
Stone6_B:
	MSG("...Even though this tabula is talking|about some legend, it clearly|mentions Castle Strangerock!")
	MSG("It seems that castle was home|to the Dragon King, Galsis.")
	MSG("And based on the description here regarding it...")
	MSG("It says the Black Bride &22then relinquished|Castle Strangerock into the water's deep&22...|This HAS to be some sort of clue, don't you agree?")
	MSG("I guess we can't know for sure since|it might just be a fairy tale.")
	MSG("But there might be some leads at|the bottom of that lake, though!")
	game_flag_on(3619)
	jump Stone6_end

Stone6_0:
	check_game_flag(3905)
	on_jump STONE_END

	// 3710	EV C-11 黒き花嫁(▼障壁消滅後)
	check_game_flag(3710)
	on_jump Stone6_2

	MSG("...Seems like this is talking about|Princess Fleurette.")
	MSG("She must've looked amazing wielding the|Sacred Sword against Galsis!")

	// 3702	EV C-3 奇岩城出現
	check_game_flag(3702)
	on_jump Stone6_end

	MSG("And then there's that mention of Castle Strangerock...|It might just be a clue!")
	MSG("Except, I guess we can't be certain if the rumors|from that era are true. It says the Black Bride|sunk it into the lake...")
	jump Stone6_end

Stone6_2:
	// 3711	EV C-12 聖剣の巫女姫
	check_game_flag(3711)
	off_jump Stone6_end

//	⇒フローレットに会っている
	MSG("...Seems like this is talking about|Fleurette.")
	MSG("How could Liese raise a weapon|against her own sister...?")
	MSG("...")
	jump Stone6_end

Stone6_end:
	check_game_flag(3905)
	on_jump STONE_END

	game_flag_on(3905)
	// お弁当処理
	CHECK_MAX_ITEM(0)
	ON_JUMP STONE_END
	MSG("...Oh, before I forget,|I made lunch for you.")
	MSG("Ehehe, I hope you like it.|I put a lot of work into it this time!")
	jump GET_FOOD
