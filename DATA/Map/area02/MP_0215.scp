DEF("switch")
RES("CLICK")
{
	area_flag_on(5)
	wait(60)
	focus_chr("door")
	switch_on("door")
	wait(60)
	room_flag_on(1)
}

DEF("door")
RES("CLICK")
{
	check_area_flag(5)
	off_skip(10)

	
//‚n‚j
	check_room_flag(1)
	on_skip(4)
	switch_on("door")
	wait(60)
	room_flag_on(1)
	end

	switch_off("door")
	wait(60)
	room_flag_off(1)
	end

//NG
	end
}
