
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(6,6,6)
	// (ａ)が(ｂ)の確率で出現
		// ゴブリン 03
		ENTRY_MONSTER(188,100)
	// (ａ)％の確率でエンカウント
	ENCOUNT(100)
}

