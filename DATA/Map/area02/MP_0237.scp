
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(5,5,3)
	// (ａ)が(ｂ)の確率で出現
		// リザードマン 07
		ENTRY_MONSTER(8,100)
		// サラマンダー 08
		ENTRY_MONSTER(7,100)
	// (ａ)％の確率でエンカウント
	ENCOUNT(100)
}

