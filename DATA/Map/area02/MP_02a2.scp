
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(1,3,2)
	// (ａ)モンスターが(ｂ)の確率で出現
		// スライム
		ENTRY_MONSTER(4,100)
	// (ａ)％の確率でエンカウント
	ENCOUNT(100)
}


// ----------------------------------------------------------------------------
// 0203 の箱を壊したか（扉を開けたことがあるか？）                             
// ----------------------------------------------------------------------------

DEF("door")

RES("CLICK")
{
	CHECK_GAME_FLAG(150)
	ON_JUMP L_FLAG
	MSG("You feel a strong presence on the other side.")
	END

L_FLAG:
	SWITCH_RVS("door")
	END
}

