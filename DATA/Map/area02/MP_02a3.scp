
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(3,6,3)
	// (ａ)モンスターが(ｂ)の確率で出現
		// スライム
		ENTRY_MONSTER(4,100)
		// ユイナル 10
		ENTRY_MONSTER(3,100)
	// (ａ)％の確率でエンカウント
	ENCOUNT(70)
}

