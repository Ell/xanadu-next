
// ----------------------------------------------------------------------------
// マップ
// ----------------------------------------------------------------------------

// 初期状態---------------------------------------------------------
DEF("MAP")

RES("INIT")
{
	CHECK_GAME_FLAG(102)
	ON_JUMP L_HOOK 
	JUMP L_EN

L_HOOK:
	SWITCH_ON("tama")
	SWITCH_ON("mamori")
	JUMP L_EN

L_EN:
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(1,1,1)
	// (ａ)が(ｂ)の確率で出現
		// ポイズンスライム 04
		ENTRY_MONSTER(64,100)
}

// 戦闘勝利---------------------------------------------------------
RES("WIN")
{
	SWITCH_ON("mamori")
}


// ----------------------------------------------------------------------------
// 宝玉取ったかい？                                                            
// ----------------------------------------------------------------------------


DEF("tama")

RES("INIT")
{
	CHECK_GAME_FLAG(102)
	ON_JUMP L_EN

	ENCOUNT(100)

L_EN:
	END
}

RES("CLICK")
{
	CHECK_GAME_FLAG(102)
	ON_JUMP GET 

	SWITCH_ON("tama")
	GAME_FLAG_ON(101)
	GAME_FLAG_ON(102)
	WAIT(60)
	MSG("Obtained [Red Jewel].")
	END

GET:
	END
}


