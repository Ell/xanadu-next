
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	lock("key1",1)

	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(4,7,3)
	// (ａ)が(ｂ)の確率で出現
		// ゴブリン 03
		ENTRY_MONSTER(0,80)
		// ゴブリンアーチャー 04
		ENTRY_MONSTER(1,100)
	// (ａ)％の確率でエンカウント
	ENCOUNT(70)
}



// ----------------------------------------------------------------------------
// 扉の向こう側に炎がある場合は開けない                                        
// ----------------------------------------------------------------------------


DEF("door")

RES("CLICK")
{
	CHECK_GAME_FLAG(114)
	ON_JUMP L_FLAG
	MSG("You feel a strong presence on the other side.")
	END

L_FLAG:
	SWITCH_RVS("door")
	END
}


