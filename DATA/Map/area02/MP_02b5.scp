
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	lock("key1",1)

	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(3,6,6)
	// (ａ)が(ｂ)の確率で出現
		// ポイズンスライム 04
		ENTRY_MONSTER(64,70)
		// ゴブリンアーチャー 04
		ENTRY_MONSTER(1,100)
	// (ａ)％の確率でエンカウント
	ENCOUNT(70)
}

