
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(3,6,2)
	// (ａ)が(ｂ)の確率で出現
		// フレイムバット 04
		ENTRY_MONSTER(179,100)
	// (ａ)％の確率でエンカウント
	ENCOUNT(70)
}

