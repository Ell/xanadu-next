
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	lock("key1",1)

	CHECK_GAME_FLAG(106)
	ON_JUMP L_HOOK 
	JUMP L_EN

L_HOOK:
	SWITCH_ON("tama")
	SWITCH_ON("mamori")
	JUMP L_EN

L_EN:
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(1,3,2)
	// (ａ)が(ｂ)の確率で出現
		// レッドスライム 02
		ENTRY_MONSTER(63,100)
}

// 戦闘勝利---------------------------------------------------------
RES("WIN")
{
	SWITCH_ON("mamori")
}


// ----------------------------------------------------------------------------
//                                                                             
// ----------------------------------------------------------------------------


DEF("tama")

RES("INIT")
{
	CHECK_GAME_FLAG(106)
	ON_JUMP L_EN

	ENCOUNT(100)

L_EN:
	END
}

RES("CLICK")
{
	CHECK_GAME_FLAG(106)
	ON_JUMP GET 

	SWITCH_ON("tama")
	GAME_FLAG_ON(105)
	GAME_FLAG_ON(106)
	WAIT(60)
	MSG("Obtained 3rd [Red Jewel].")
	END

GET:
	END
}


