

// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(5,10,6)
	// (ａ)が(ｂ)の確率で出現
		// レッドスライム 02
		ENTRY_MONSTER(63,100)
		// ポイズンスライム 04
		ENTRY_MONSTER(64,100)
	// (ａ)％の確率でエンカウント
	ENCOUNT(70)
}


// ----------------------------------------------------------------------------
// 扉の向こう側に炎がある場合は開けない                                        
// ----------------------------------------------------------------------------


DEF("door")

RES("CLICK")
{
	CHECK_GAME_FLAG(122)
	ON_JUMP L_FLAG
	MSG("You feel a strong presence on the other side.")
	END

L_FLAG:
	SWITCH_RVS("door")
	END
}


