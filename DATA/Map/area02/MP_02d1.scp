
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	lock("key1",1)

	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(1,5,3)
	// (ａ)が(ｂ)の確率で出現
		// スケルトン 05
		ENTRY_MONSTER(6,80)
		// ブラックスライム 06
		ENTRY_MONSTER(177,100)
	// (ａ)％の確率でエンカウント
	ENCOUNT(70)
}

