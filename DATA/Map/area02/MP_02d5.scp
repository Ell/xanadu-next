
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(5,8,4)
	// (ａ)が(ｂ)の確率で出現
		// スケルトン 05
		ENTRY_MONSTER(6,100)
		// ゴブリンシャーマン 06
		ENTRY_MONSTER(182,50)
	// (ａ)％の確率でエンカウント
	ENCOUNT(70)
}

