
// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	CHECK_GAME_FLAG(71)
	ON_JUMP L_FLAG
	END

L_FLAG:
	INIT_SWITCH_ON("gate")
	END
}


// ----------------------------------------------------------------------------
//                                                                             
// ----------------------------------------------------------------------------

DEF("gate")

RES("CLICK")
{
	CHECK_GAME_FLAG(71)
	ON_JUMP L_FLAG

	SWITCH_ON("gate")
	GAME_FLAG_ON(70)
	GAME_FLAG_ON(71)

L_FLAG:
	END
}


