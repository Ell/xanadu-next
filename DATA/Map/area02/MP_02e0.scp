// ----------------------------------------------------------------------------
// ゲート分岐                                                                  
// ----------------------------------------------------------------------------

DEF("02e0_02c0_e")

RES("EVENT")
{
	CHECK_GAME_FLAG(148)
	ON_JUMP L_MAP
	// スイッチが入ってないならそのまま
	ENTRY_MAP("02c0_02e0")
	END

L_MAP:
	// スイッチが入っているなら 02e1 へ
	ENTRY_MAP("02e1_02e0")
}




