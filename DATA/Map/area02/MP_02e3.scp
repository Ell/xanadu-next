DEF("MAP")
RES("INIT")
{
	// 魔物出現
	// 合計(ａ)～(ｂ)匹が、(ｃ)匹同時に出現
	SET_ENCOUNT_INFO(1,1,1)
	// (ａ)が(ｂ)の確率で出現
		// オーガー
		ENTRY_MONSTER(29,100)
}

RES("WIN")
{
	BANKO(0)
}
