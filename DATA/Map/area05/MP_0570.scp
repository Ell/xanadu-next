DEF("MAP")

RES("INIT")
{
	// カギ設定
	CHECK_GAME_FLAG(1513)
	ON_SKIP(2)
	KAGI("d1513",1)
	SKIP(1)
	INIT_SWITCH_ON("d1513")

	// レッドスライム
	put_monster("m00",063,5,0,0,0)
	put_monster("m01",063,5,0,0,1)
	put_monster("m02",063,5,0,0,2)

	CHECK_GAME_FLAG(536)
	ON_JUMP NEXT

	LOAD_MAP("MP_0589")
	LOAD_HITMAP("MP_0589h")
	// 水マップ
	SE("SE_MIZU")

END

NEXT:



}


// ----------------------------------------------------------------------------
// カギ開け
