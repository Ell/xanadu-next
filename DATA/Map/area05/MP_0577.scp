// ----------------------------------------------------------------------------
// カギ開け
// ----------------------------------------------------------------------------

DEF("d1506")
RES("KAGI")
{
	GAME_FLAG_ON(1506)
}

DEF("d1508")
RES("KAGI")
{
	GAME_FLAG_ON(1508)
}


// ============================================================================
// 門(exit)
// ============================================================================

DEF("gate")
RES("CLICK")
{

	CINEMA_ON(0)

	STOP_PC(0)
	ACTIVE_CHR("SCREEN")
	SEL("Head outside?|#c2Leave|Cancel")

	CHECK_SELECT(0)
	ON_JUMP SEL1
	JUMP SEL2

SEL1:

	WAIT(30)
	SWITCH_ON("gate")
	FADE_OUT(-1)
	GAME_FLAG_ON(3000)
	WAIT(40)
	SE("SE_CHG_AREA")
	WAIT(20)

	ENTRY_MAP("0757_out")

SEL2:
	CINEMA_OFF(0)
	END
}


// ----------------------------------------------------------------------------
// 宝箱                                                                        
// ----------------------------------------------------------------------------


DEF("box")
RES("INIT")
{
	CHECK_GAME_FLAG(575)
	OFF_JUMP next
	CHECK_ROOM_MEMO(255)
	OFF_JUMP NEXT
// ★05/06/21:イベントアイテム箱→開けっぱで残す。
//	HIDE_CHR("box")
	INIT_SWITCH_ON("box")
NEXT:
}

// ----------------------------------------------------------------------------
// カード入手演出
@draw_card
{
	novel_on(0,1)
	wait(60)

	SE("SE_GDN_CRD")
	ENTRY_IMG(6,"card\god03",0)
	SET_IMG( 0, 236,160, 6,  0,  0,168,224, 0, 0x00ffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	MOVE_IMG(0, 0,-32, 60, 1)
	COLOR_IMG(0, 0xffffffff, 0xff000000, 60, 1)
	wait(60)
	wait(90)
//	COLOR_IMG(0, 0x00ffffff, 0xff000000, 60, 1)
//	wait(60)
//	IMG_OFF(0)

//	novel_off(0)
//	wait(60)

	ret
}

RES("CLICK")
{
	CINEMA_ON(0)
	STOP_PC(0)
	FOCUS_CHR("box")

	CHECK_GAME_FLAG(575)
	OFF_JUMP ITEM

//２回目以降は、お金
GOLD:
	SWITCH_ON("box")
	POP_ITEM_ICON("box", 225, 0,0.25,0, 1,80,0)
	WAIT(140)

	DEL_ITEM_ICON("box")
	ATTACH_EFC("EFC_99ITEM_GET","box","POS")
//	WAIT(45)

	sys_ex("Acquired [50 Gold]!",-1,0x00000200)

	GET_GOLD(50)
	ROOM_MEMO_ON(255)
//	SET_COLOR("box",0x00000000,45,1)
	FOCUS_CHR("PC")
	CINEMA_OFF(0)
	END

ITEM:
	SWITCH_ON("box")
	POP_ITEM_ICON("box", 103, 0,0.25,0, 1,80,0)
	WAIT(140)

//	call draw_card

	DEL_ITEM_ICON("box")
	ATTACH_EFC("EFC_99CARD_GET","box","POS")

WAIT(60)

	GET_SPIRIT(3)
	GAME_FLAG_ON(575)
	ROOM_MEMO_ON(255)
	sys_ex("Acquired the Guardian Card [Belladonna]!",-1,0x00000200)

call draw_card

	//----------------------------
//	novel_on(0,1)
//	wait(60)
COLOR_IMG(0, 0xb0ffffff, 0xff000000, 30, 1)
wait(30)
	sys_ex("About the Guardian [Belladonna]",-1,0x00000200)
	sys_ex("By bearing this Guardian, all recovery potions|will have improved efficacy.",-1,0x00000200)
	novel_off(0)
COLOR_IMG(0, 0x00ffffff, 0xff000000, 60, 1)
	wait(60)
IMG_OFF(0)
	//----------------------------
	
	FOCUS_CHR("PC")
	CINEMA_OFF(0)

	END
}

