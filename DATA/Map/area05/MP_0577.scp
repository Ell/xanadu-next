// ----------------------------------------------------------------------------
// はりがみ
// ----------------------------------------------------------------------------

DEF("kami")
RES("CLICK")
{
	FOCUS_CHR("kami")
	SET_NAME("kami","Guidepost")
	SYS("For those unable to see through lies,|reaching the other side will be difficult.")
}

// ----------------------------------------------------------------------------
// 石像のリアクション
// ----------------------------------------------------------------------------
DEF("Statue")
RES("CLICK")
{
	check_game_flag(3941)
	on_jump no_res

	check_spirit_lv_max(0)
	on_jump max_lv

	// まだLVが上げられるならレベルアップ
	room_flag_on(253)
	attach_efc("EFC_SPIRIT_LVUP2","Statue","POS")
	wait(50)
	spirit_lv_up( 1 )
	sys_ex("Your Guardian has improved a level!",-1,0x00000200)
	game_flag_on(3941)
	end

max_lv:
	sys("The Guardian which you bear within you|is unable to improve any further.")
	end

no_res:
	sys("Nothing happens.")
	end
}
