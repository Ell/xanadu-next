DEF("tbox")
RES("INIT")
{
	CHECK_GAME_FLAG(500)
	OFF_JUMP next

//	SET_TREASURE("tbox",1,227,"ITEM")
	INIT_SWITCH_ON("tbox")

next:
}

RES("CLICK")
{
	CINEMA_ON(0)
	STOP_PC(0)
	FOCUS_CHR("tbox")

	CHECK_GAME_FLAG(500)
	OFF_JUMP ITEM

ITEM:
// Œ®
	SWITCH_ON("tbox")
	POP_ITEM_ICON("tbox", 227, -5.5,0,-1, 1,80,0)
	WAIT(140)

//	CHECK_MAX_ITEM(0)
//	ON_JUMP EXIT

	DEL_ITEM_ICON("tbox")
	ATTACH_EFC("EFC_99ITEM_GET","tbox","POS")

	sys_ex("Acquired [Key]!",-1,0x00000200)

	GET_ITEM(227, 1)
	GAME_FLAG_ON(500)
	FOCUS_CHR("PC")
	CINEMA_OFF(0)
	END

EXIT:
	SE("SE_ERROR")
	DEL_ITEM_ICON("tbox")
	sys_ex("Your bags are full. You have no room for this item.",-1,0x00000200)
	SWITCH_OFF("tbox")
	FOCUS_CHR("PC")
	CINEMA_OFF(0)
}



