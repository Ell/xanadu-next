DEF("MAP")

RES("INIT")
{
	// ƒVƒlƒXƒRژ‍ƒXƒyƒNƒ^ƒNƒ‹ƒYON
	ROOM_FLAG_ON(254)

	CHECK_GAME_FLAG(599)
	ON_SKIP(1)
	HIDE_CHR("tbox")

	// ƒoƒbƒg
	put_monster("m00",319,4,0,0,0)
	put_monster("m01",319,4,0,0,1)
	put_monster("m02",319,4,0,0,2)
	// ƒŒƒbƒhƒXƒ‰ƒCƒ€
	put_monster("m03",063,4,0,0,3)
	put_monster("m04",063,4,0,0,4)
	put_monster("m05",063,4,0,0,5)
	put_monster("m06",063,4,0,0,6)

	// گ…ƒ}ƒbƒv
	SE("SE_MIZU")

	// ƒJƒMگف’è
	CHECK_GAME_FLAG(1507)
	ON_SKIP(2)
	KAGI("d1507",1)
	SKIP(1)
	INIT_SWITCH_ON("d1507")

}

// “|‚µ‚½‚¼--------------------------------------------------------------
RES("WIN")
{
	CHECK_GAME_FLAG(599)
	ON_JUMP next

	STOP_PC(0)

	SE("SE_STOPPER")
	CINEMA_ON(0)
	FOCUS_CHR("null")
	EFC("EFC_ADD_TREASURE",-5.5,0,-1)
	SHOW_CHR("tbox")
	WAIT(60)
	CINEMA_OFF(0)

	GAME_FLAG_ON(599)

next:
}


