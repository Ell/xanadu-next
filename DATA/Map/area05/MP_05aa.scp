RES("INIT")
{
	// 듼귩긊깛긣깒긞긣궳봨됹궢궫궔갎
	CHECK_GAME_FLAG(578)
	OFF_SKIP(1)
	HIDE_CHR("iwa")

	// 긇긎먠믦
	CHECK_GAME_FLAG(1524)
	ON_SKIP(2)
	KAGI("d1524",1)
	SKIP(1)
	INIT_SWITCH_ON("d1524")

	// 긇긎먠믦
	CHECK_GAME_FLAG(1526)
	ON_SKIP(2)
	KAGI("d1526",1)
	SKIP(1)
	INIT_SWITCH_ON("d1526")

}


