RES("INIT")
{
	// マミー
	put_monster("m00",012,10,0,0,0)
	put_monster("m01",012,10,0,0,1)
	// スケルトン
	put_monster("m02",380,10,0,0,2)
	put_monster("m03",380,10,0,0,3)
	put_monster("m04",380,10,0,0,4)

	// カギ設定
	CHECK_GAME_FLAG(1542)
	ON_SKIP(2)
	KAGI("d1542",1)
	SKIP(1)
	INIT_SWITCH_ON("d1542")

	// カギ設定
	CHECK_GAME_FLAG(1544)
	ON_SKIP(2)
	KAGI("d1544",1)
	SKIP(1)
	INIT_SWITCH_ON("d1544")

}


