
// ----------------------------------------------------------------------------
// マップ初期状態                                                              
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
// 死神出さない
	PERMIT_DEATH(0)
}


// ----------------------------------------------------------------------------
// ボタンが押されているかチェック                                              
// ----------------------------------------------------------------------------


// ----------------------------------------------------------------------------
DEF("sw")
RES("FOOT")
{
	CHECK_GRID(1,2,"box")
	ON_JUMP NEXT
	END

NEXT:
	
	// パズルクリア================
	clear_puzzle(0)
	// ============================

	END
}

