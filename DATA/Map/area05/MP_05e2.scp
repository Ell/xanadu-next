
// ----------------------------------------------------------------------------
// マップ初期状態                                                              
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
// 死神出さない
	PERMIT_DEATH(0)
}


// ----------------------------------------------------------------------------
// ボタンが押されているかチェック                                              
// ----------------------------------------------------------------------------


// ----------------------------------------------------------------------------
DEF("sw1")
RES("FOOT")
{
	CHECK_GRID(1,2,"box1")
	ON_JUMP NEXT
	END

NEXT:

	CHECK_GRID(3,2,"box2")
	ON_JUMP NEXT2
	END

NEXT2:

	// パズルクリア================
	clear_puzzle(0)
	// ============================

	END
}


// ----------------------------------------------------------------------------
DEF("sw2")
RES("FOOT")
{
	CHECK_GRID(1,2,"box1")
	ON_JUMP NEXT
	END

NEXT:

	CHECK_GRID(3,2,"box2")
	ON_JUMP NEXT2
	END

NEXT2:

	// パズルクリア================
	clear_puzzle(0)
	// ============================

	END
}
