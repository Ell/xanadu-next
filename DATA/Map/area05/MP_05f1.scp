
// ----------------------------------------------------------------------------
// マップ初期状態                                                              
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
// 死神出さない
	PERMIT_DEATH(0)
}


// ----------------------------------------------------------------------------
// ボタンが押されているかチェック                                              
// ----------------------------------------------------------------------------


// ----------------------------------------------------------------------------
DEF("sw1")
RES("FOOT")
{
	call hako
	END
}

// ----------------------------------------------------------------------------
DEF("sw2")
RES("FOOT")
{
	call hako
	END
}

// ----------------------------------------------------------------------------
DEF("sw3")
RES("FOOT")
{
	call hako
	END
}


// ----------------------------------------------------------------------------
// 箱関連サブルーチン                                                        
// ----------------------------------------------------------------------------

// スイッチの上に乗っているのは３つの箱のうちのどれかかい
@hako
{
	CHECK_GRID(3,1,"box1")
	ON_JUMP H1
	CHECK_GRID(3,1,"box2")
	ON_JUMP H1
	CHECK_GRID(3,1,"box3")
	ON_JUMP H1
	END

H1:
	CHECK_GRID(4,2,"box1")
	ON_JUMP H2
	CHECK_GRID(4,2,"box2")
	ON_JUMP H2
	CHECK_GRID(4,2,"box3")
	ON_JUMP H2
	END

H2:
	CHECK_GRID(5,3,"box1")
	ON_JUMP H3
	CHECK_GRID(5,3,"box2")
	ON_JUMP H3
	CHECK_GRID(5,3,"box3")
	ON_JUMP H3
	END

H3:
	// パズルクリア================
	clear_puzzle(0)
	// ============================

	RET
}
