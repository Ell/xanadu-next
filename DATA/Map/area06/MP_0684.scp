
// ----------------------------------------------------------------------------
// マップ初期化                                                                
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	BGM( 20, 0, -1)

	// カギ設定
	CHECK_GAME_FLAG(1689)
	ON_SKIP(2)
	//KAGI("d1689",1)
	SKIP(1)
	INIT_SWITCH_ON("d1689")

//--------------------------------------------------------------------

	ENTRY_CHR( 0, 072)
	ENTRY_CHR( 1, 398)
	ENTRY_CHR( 2,  36)
	ENTRY_CHR( 3,  37)
	ENTRY_CHR( 4,  38)
	ENTRY_CHR( 5,  39)
	ENTRY_CHR( 6,  40)
	ENTRY_CHR( 7,  41)

	// 3800	EV 祭壇の花嫁
	check_game_flag(3800)
	on_jump NEXT

	// 最初のイベント用はリーゼのみ
	PUT_CHR( 0, "Liese",       -0.03,4.88,22.46,   0)

	// 3711	EV C-12 聖剣の巫女姫
	check_game_flag(3711)
	on_jump EXIT

	// DS 持っていない
	hide_chr("Liese")
	jump EXIT

NEXT:

	// 3801	EV ボス戦闘前イベント
	check_game_flag(3801)
	on_jump NEXT2

	//魔法で封じられた
	PUT_CHR( 7, "Beatrice",    -3.31,2.06,-12.65, 351)
	PUT_CHR( 6, "Dvorak",      -0.26,2.06, -8.98, 359)
	load_npc_eqp(7,00)
	dvorak(1)
	PUT_CHR( 5, "Gandaltua",    1.90,2.06, -9.41, 350)
	PUT_CHR( 4, "Sturm",       -1.42,2.19,-14.25, 348)
	PUT_CHR( 3, "Tiowald",      1.43,2.06,-12.88, 346)
	SET_MOTION("Beatrice","EMPTY19",0)
	SET_MOTION("Dvorak","EMPTY16",0)
	SET_MOTION("Gandaltua","EMPTY19",0)
	SET_MOTION("Sturm","EMPTY19",0)
	SET_MOTION("Tiowald","EMPTY19",0)

	//おまえら動くな
	ENABLE_AUTO_TURN("Beatrice", 0)
	ENABLE_AUTO_TURN("Dvorak", 0)
	ENABLE_AUTO_TURN("Gandaltua", 0)
	ENABLE_AUTO_TURN("Sturm", 0)
	ENABLE_AUTO_TURN("Tiowald", 0)

	INIT_SWITCH_ON("door")
	ENABLE_EV_POP( "door", 0)
	SE(SE_EVENT_46)
	jump EXIT

NEXT2:

//ガルシスにやられたあとここくると、フローにいてもらっては困る。どうする？


	// 救援に来た
	PUT_CHR( 1, "Fleurette",    0.5,2.06,-12.5, 151)
	PUT_CHR( 2, "Avatarlaha",  -2.0,2.06, -12.0, 147)

	//魔法で封じられた
	PUT_CHR( 7, "Beatrice",    -3.31,2.06,-12.65, 351)
	PUT_CHR( 6, "Dvorak",      -0.26,2.06, -8.98, 359)
	load_npc_eqp(7,00)
	dvorak(1)
	PUT_CHR( 5, "Gandaltua",    1.90,2.06, -9.41, 350)
	PUT_CHR( 4, "Sturm",       -1.42,2.19,-14.25, 348)
	PUT_CHR( 3, "Tiowald",      1.43,2.06,-12.88, 346)
	SET_MOTION("Beatrice","EMPTY19",0)
	SET_MOTION("Dvorak","EMPTY16",0)
	SET_MOTION("Gandaltua","EMPTY19",0)
	SET_MOTION("Sturm","EMPTY19",0)
	SET_MOTION("Tiowald","EMPTY19",0)
	INIT_SWITCH_ON("door")
	ENABLE_EV_POP( "door", 0)
	SE(SE_EVENT_46)

EXIT:
	end
}


// ----------------------------------------------------------------------------
// カギ開け
// ----------------------------------------------------------------------------
//イベントで開けた後通ろうとすると鍵アイコンがでてしまうので隠しました。
//DEF("d1689")
//RES("KAGI")
//{
//	GAME_FLAG_ON(1689)
//}

DEF("door")
RES("CLICK")
{
	STOP_PC(0)
	SYS("The door is tightly shut.")
}


//--------------------------------------------------------------------
//-- イベント 
//--------------------------------------------------------------------

DEF("Liese")
RES("INIT")
{
	// 3800	EV 祭壇の花嫁
	check_game_flag(3800)
	on_jump EXIT

//--------------------------------------------------------------------

	// 3711	EV C-12 聖剣の巫女姫
	check_game_flag(3711)
	on_jump START

	// まだドラスレを持っていない場合

	STOP_PC(0)
	set_deg_EX("PC", "Liese")
	PC_WEAPON( 0, 1 )

	STOP_BGM(0, 120)

	SYS("Silence permeates the vast room.")
	WAIT(30)

	BGM( 20, 0, -1)

	cross_fade(120)

	CINEMA_ON(0)

	permit_script_camera(1)
	set_script_camera(0.00,0.13,-21.56,  -15.0,180.0,0.0, 12, 30.0)
	move_script_look_at( 0,9,42, 700, 1)
	rotate_script_camera(20,0,0, 800, 1)
	wait_camera(0)



	FOCUS_CHR("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)

	end

//--------------------------------------------------------------------

START:
	STOP_PC(0)
	set_deg_EX("PC", "Liese")
	PC_WEAPON( 0, 1 )

	STOP_BGM(0, 120)

	SYS("An exceedingly evil presence can be felt in the area.")
	WAIT(30)

	BGM( 20, 0, -1)

	cross_fade(120)

	CINEMA_ON(0)

	permit_script_camera(1)
	set_script_camera(0.00,0.13,-21.56,  -15.0,180.0,0.0, 12, 30.0)
	move_script_look_at( 0,9,42, 700, 1)
	rotate_script_camera(20,0,0, 800, 1)

	PUT_CHR( 7, "Beatrice",    -3.31,2.06,-12.65, 351)
	PUT_CHR( 6, "Dvorak",      -0.26,2.06, -8.98, 359)
	PUT_CHR( 5, "Gandaltua",    1.90,2.06, -9.41, 350)
	PUT_CHR( 4, "Sturm",       -1.42,2.19,-14.25, 348)
	PUT_CHR( 3, "Tiowald",      1.43,2.06,-12.88, 346)
	HIDE_CHR("Beatrice")
	HIDE_CHR("Dvorak")
	HIDE_CHR("Gandaltua")
	HIDE_CHR("Sturm")
	HIDE_CHR("Tiowald")


	set_skip_label("SKIP")

	wait_camera(0)
//　　画面ビスタサイズ化して、イベントムービー開始。
//　　部屋の奥へスクロールして、祭壇に祈りを捧げている
//　　リーゼを映し出す。そのままの姿勢でセリフ表示。

	MSG_EX("#S3#C3Lieselotte|#C0Just as I expected...|You came, Sir Knight.",-1,2)

//　　祭壇の前で立ち上がり、
//　　主人公のほうを向くリーゼロット。

	move_script_look_at(  0,-1, 0, 300, 1)
	rotate_script_camera(-25,0, 0, 300, 1)

	set_deg_EX("Liese", "PC")
	wait(120)

	MSG_EX("#S3#C3Lieselotte|#C0Hmmhmmhmm, no need to look at me like that.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0You have arrived at the very place|where my husband will soon be revived.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0I must say, I'm impressed.",-1,2)

	wait_camera(0)

	set_pos("PC", 0.0,4.06,9.41)
	set_deg("PC", 0)
	look_chr("PC", "Liese")

	INIT_WALK_DST("Liese")
	set_walk_dst("Liese", 0.00,4.88,19.74)
	walk_pos("Liese",0,0.03)

	move_script_look_at( 0, 0,-12, 300, 1)
	rotate_script_camera(-10,0,0, 300, 1)
	wait(120)

	MSG_EX("#S3#C3Lieselotte|#C0While I was in the village, I truly owed|you a great debt of gratitude, Sir Knight.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Since you have come all this way,|I really SHOULD express my deepest of|thanks by allowing you to join our side.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0However, as I mentioned before...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0I simply cannot overlook the existence of|my husband's ultimate enemy, the Sacred Sword.",-1,2)
	wait_camera(0)


//　　祭壇を歩いて降り、主人公の正面に立つリーゼロット。

	INIT_WALK_DST("Liese")
	set_walk_dst("Liese", -3.61,4.88,19.10)
	set_walk_dst("Liese", -3.85,4.88,16.69)
	set_walk_dst("Liese", -3.20,4.88,14.39)
	set_walk_dst("Liese", -2.10,5.00,12.80)
	walk_pos("Liese",0,0.03)

	move_script_look_at( 0, 0, 0, 300, 1)
	rotate_script_camera(-5,-40,0, 300, 1)
	wait(120)
	set_deg_EX("PC", "Liese")

	MSG_EX("#S3#C3Lieselotte|#C0Tonight there will be a banquet.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0For the opening toast I shall fill|the chalice with a knight's blood.",-1,2)
	set_deg_EX("PC", "Liese")
	MSG_EX("#S3#C3Lieselotte|#C0If I use the blood of the brave soul|who wields the Sacred Sword, I'm sure it'll|be like sweet nectar to my husband...",-1,2)
	WAIT(30)

	wait_walk("Liese")
	wait_camera(0)
	MSG_EX("#S3#C3Male Voice|#C0...You'd best let us handle this, knight!",-1,2)


//　　次の瞬間、主人公の背後からドヴォルザークのスキルが炸裂。
//　　飛び退ってかわす主人公。スキル技が直撃するも、指先一つ動
//　　かさずに障壁を張ってかわすリーゼロット。声のした方向を
//　　キッと見据える。


	SE(SE_EVENT_43)
	FADE_OUT_EX( 10, 0, "0xffffffff", 0)
	wait(10)
	set_deg("Liese", 176)
	wait(20)
	set_script_camera(0,1.5,-11.8,  -20,176,0, 5, 15)
	move_script_look_at(-2.2,4.75,24.6,  140, 0)
	rotate_script_camera(23,0,0, 140, 1)
	set_pos("PC", 2.20,4.06,9.37, 292)
	set_deg("PC", -110)
	ATTACH_EFC("EFC_06LIESE_BARIA","Liese","POS")
	blur(30)
	FADE_IN_EX( 10, 0, "0xffffffff", 0)

	wait(140)
	blur(0)

	move_script_look_at(0.11,-0.2,-1.23,  5, 0)
	WAIT(5)
	SE(SE_EVENT_44)
	move_script_look_at(0.22,-0.4,-2.46,  200, 0)
	wait(200)
	set_deg_EX("PC", "Liese")


//入り口で剣を構えているドヴォルザーク。
//　　他の導師たちもすでに部屋へ入り込んでいる状態。

	SHOW_CHR("Beatrice")
	SHOW_CHR("Dvorak")
	SHOW_CHR("Gandaltua")
	SHOW_CHR("Sturm")
	SHOW_CHR("Tiowald")
	load_npc_eqp(7,00)
	dvorak(1)
	SET_MOTION("Dvorak","EMPTY1",0)

	cross_fade(60)
	set_script_camera(0.11,2.06,-8.00,  -33.5.0,20.0,-1.0, 9, 15.0)
	rotate_script_camera(0,-10,0, 300, 1)
	move_script_look_at( 0, 0, -4, 300, 1)
	wait(120)

	SET_MOTION("Dvorak","STAND",-1)
	SET_MOTION("Gandaltua","ATTACK1",-1)
	MSG_EX("#S3#C3Gandharva|#C0Well, well...|As inelegant as ever, I see.",-1,2)

	SET_MOTION("Beatrice","ATTACK1",-1)
	MSG_EX("#S3#C3Beatrice|#C0Brave knight, we have come to aid you!",-1,2)

	INIT_WALK_DST("Tiowald")
	set_walk_dst("Tiowald", 1.43,2.06,-12.88)
	walk_pos("Tiowald",0,0.01)
	MSG_EX("#S3#C3Theobald|#C0It has truly been a while, Princess Lieselotte...",-1,2)
	wait_walk("Tiowald")

	//リーゼと石像カメラ
	CROSS_FADE(60)
	SET_SCRIPT_CAMERA_EX( "Liese", -2, 15,5,0, 3, 15 )
	rotate_script_camera(0, 10, 0, 1000, 1)
	SET_MOTION("Tiowald","ATTACK1",-1)
	WAIT(30)
	MSG_EX("#S3#C3Theobald|#C0Or if you prefer, Black Bride!",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0...",-1,2)
	wait(120)

	cross_fade(30)
	set_script_camera(0.11,3,-12.5,  -30,-185,0, 12, 15.0)
	rotate_script_camera(0,20,0, 1000, 1)
	SET_MOTION("Sturm","ATTACK1",-1)
	MSG_EX("#S3#C3Sturm|#C0...Galsis seems to be nearby.",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0So we merely need clear the way?",-1,2)
	wait(20)
	set_deg_EX("Liese", "Dvorak")

//　　ドヴォルザークが前に出ようとするが、リーゼが
//　　手をかざすと黒い炎が現れて導師たちの体を縛り上げる。

	cross_fade(30)
	set_script_camera(-2.44,6,13.22,  -5.0,90.0,0.0,  3, 12)
	rotate_script_camera(8,85,0,   140, 1)
	scale_script_camera( 5.3,      140, 1)
	wait(10)
	SE(SE_EVENT_45)
	wait(20)
	BLUR(30)
	SET_MOTION("Liese","ATTACK2",-1)
	WAIT(130)

	SE(SE_EVENT_46)
	ATTACH_EFC("EFC_06LIESE_THU1","Beatrice","POS")
	ATTACH_EFC("EFC_06LIESE_THU1","Dvorak","POS")
	SET_MOTION("Beatrice","EMPTY19",5)
	SET_MOTION("Dvorak","EMPTY16",5)
	WAIT(10)
	ATTACH_EFC("EFC_06LIESE_THU1","Gandaltua","POS")
	ATTACH_EFC("EFC_06LIESE_THU1","Sturm","POS")
	SET_MOTION("Gandaltua","EMPTY19",5)
	SET_MOTION("Sturm","EMPTY19",5)
	WAIT(10)
	ATTACH_EFC("EFC_06LIESE_THU1","Tiowald","POS")
	SET_MOTION("Tiowald","EMPTY19",5)
	BLUR(0)
	MSG_EX("#S3#C3Lieselotte|#C0Bow down, insolent curs!",-1,2))
	WAIT_CAMERA(0)
	//おまえら動くな
	ENABLE_AUTO_TURN("Beatrice", 0)
	ENABLE_AUTO_TURN("Dvorak", 0)
	ENABLE_AUTO_TURN("Gandaltua", 0)
	ENABLE_AUTO_TURN("Sturm", 0)
	ENABLE_AUTO_TURN("Tiowald", 0)

	scale_script_camera( 4.5, 1000, 1)
	WAIT(30)
	MSG_EX("#S3#C3Lieselotte|#C0What do you have to say now that I have|stripped your bodies of all will...?",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0Urk...",-1,2)
	WAIT(60)


//　　リーゼロット、祭壇の脇にある出口付近まで歩いて振り向く。
	INIT_WALK_DST("Liese")
	set_walk_dst("Liese", -3.99,4.88,15.89)
	set_walk_dst("Liese", -4.41,4.88,18.93)
	set_walk_dst("Liese", -8.90,4.00,21.58)
	set_walk_dst("Liese", -9.74,4.00,25.58)
	walk_pos("Liese",0,0.03)

	move_script_look_at( -2, 1, 10, 300, 1)
	rotate_script_camera(-5, 0, 0, 300, 1)
	wait(300)

	cross_fade(30)
	set_script_camera(-5.5,5.2,21,  -12.0,165.0,0.0, 8, 15.0)
	move_script_look_at( -3, 0.5, 4, 300, 1)
	rotate_script_camera(-5, 0, 0, 300, 1)

	wait_walk("Liese")

	wait(60)
	se("SE_DOOR")
	switch_on("door")
	ENABLE_EV_POP( "door", 0)
	GAME_FLAG_ON(1689)
	wait(60)

	set_deg_EX("Liese", "PC")
	MSG_EX("#S3#C3Lieselotte|#C0Brave knight, nothing can disturb us now.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Please, follow me...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0My husband is waiting for you.",-1,2)

//　　言い置いて、扉の向こうに消えるリーゼロット。

	INIT_WALK_DST("Liese")
	set_walk_dst("Liese", -9.52,4.00,27.79)
	walk_pos("Liese",0,0.03)

	fade_out(120)
	wait(200)
	hide_chr("Liese")

	jump NEXT

SKIP:
	//魔法で封じられた状態にする
	SHOW_CHR("Gandaltua")
	SHOW_CHR("Sturm")
	SHOW_CHR("Tiowald")
	SHOW_CHR("Beatrice")
	SHOW_CHR("Dvorak")
	load_npc_eqp(7,00)
	dvorak(1)
	SET_MOTION("Beatrice","EMPTY19",0)
	SET_MOTION("Dvorak","EMPTY16",0)
	SET_MOTION("Gandaltua","EMPTY19",0)
	SET_MOTION("Sturm","EMPTY19",0)
	SET_MOTION("Tiowald","EMPTY19",0)
	//おまえら動くな
	ENABLE_AUTO_TURN("Beatrice", 0)
	ENABLE_AUTO_TURN("Dvorak", 0)
	ENABLE_AUTO_TURN("Gandaltua", 0)
	ENABLE_AUTO_TURN("Sturm", 0)
	ENABLE_AUTO_TURN("Tiowald", 0)

	hide_chr("Liese")
	DELETE_EFC("Liese")
	blur(0)
	QUAKE(2,2,0)

	// よけた後の位置
	set_pos("PC", 2.20,4.06,9.37, 292)
	set_deg_EX("PC", "Liese")

	// ドア開く
	INIT_SWITCH_ON("door")
	ENABLE_EV_POP( "door", 0)
	GAME_FLAG_ON(1689)

	STOP_SE(0)
	SE(SE_EVENT_46)

NEXT:
//　　⇒操作フリーに。

	FOCUS_CHR("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)
	fade_in(60)

//	BGM(-1)

	// 3800	EV 祭壇の花嫁
	game_flag_on(3800)

EXIT:
	end

}

//////////////////////////////////////////////////////////////////////
// ボス戦闘開始イベント続き

DEF("Fleurette")

RES("INIT")
{
	// 3800	EV 祭壇の花嫁
	check_game_flag(3800)
	off_jump EXIT

	// 3801	EV ボス戦闘前イベント
	check_game_flag(3801)
	off_jump EXIT

	STOP_PC(0)
	reset_camera(0)
	permit_script_camera(1)
	set_script_camera(-0.72,6,-11.39,  -16.0,180.0,0.0, 15, 15)
	fade_in(60)

	set_skip_label("SKIP")


//▼奇岩城・祭壇部屋
//　　フェードアウト抜けで導師たちのいる祭壇部屋でフローレット
//　　が導師たちの呪縛を解除しているところに、地震と地響きが
//　　始まる。

	MOVE_SCRIPT_LOOK_AT( 0,-2.5,0, 480, 0)
	SET_DEG_EX("Fleurette","Tiowald")
	SET_DEG_EX("Avatarlaha","Sturm")
	SET_MOTION("Fleurette","EMPTY5",0)
	SET_MOTION("Avatarlaha","EMPTY2",0)
	WAIT(640)

	//揺れて中断
	SE("SE_EVENT_13")
	QUAKE(2,2,-1)
	ATTACH_EFC("EFC_06SAMON_GAL4","Fleurette","POS")
	SET_MOTION("Fleurette","EMPTY6",0)
	SET_MOTION("Avatarlaha","EMPTY3",0)
	WAIT(75)
	SET_MOTION("Fleurette","EMPTY7",0)
	SET_DEG("Fleurette",0)
	WAIT(60)

	SET_DEG_EX("Avatarlaha","Fleurette")
	WAIT(60)
	MSG_EX("#S3#C3Beatrice|#C0My princess...could that be...?",-1,2)
	WAIT(60)
	MSG_EX("#S3#C3Fleurette|#C0...Indeed, 'tis the same seal of the Shrine Maiden|used when I passed on the Dragonslayer...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0This is undoubtedly my sister's work.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0However...I don't fully understand this seal...",-1,2)

//　　ティオバルト、何か思い当たるフシがある仕草。

	MSG_EX("#S3#C3Theobald|#C0Is it possible...",-1,2)

//　　一同、ティオバルトのほうを向く。

	SET_DEG_EX("Fleurette","Tiowald")
	SET_DEG_EX("Avatarlaha","Tiowald")
	WAIT(60)
	MSG_EX("#S3#C3Theobald|#C0Is it possible...that we are merely|going about this in quite the wrong way...?",-1,2)

//　　画面フェードアウト

	MOVE_SCRIPT_LOOK_AT( 0,1,0, 80, 0)
//	stop_env_SE("SE_EVENT_13", 2000)
	fade_out(60)
	wait(80)
	ENTRY_MAP("0685_0683")


SKIP:
	wait(80)
	ENTRY_MAP("0685_0683")

EXIT:
	end
}


//////////////////////////////////////////////////////////////////////
// 導師たちの一般メッセージ

DEF("Dvorak")
RES("CLICK")
{
	FOCUS_CHR("Dvorak")
	SET_NAME("Dvorak", "Dvorak")
//	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG("Urk, such power she wields...")
	MSG("Lady Fleurette will be with us soon...")
	END
}

DEF("Gandaltua")
RES("CLICK")
{
	FOCUS_CHR("Gandaltua")
	SET_NAME("Gandaltua", "Gandharva")
//	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG("Just what I expected of the Black Bride.|Such power...")
	MSG("Hrmph... I don't foresee us leaving this|state anytime soon...")
	END
}

DEF("Beatrice")
RES("CLICK")
{
	FOCUS_CHR("Beatrice")
	SET_NAME("Beatrice", "Beatrice")
//	SET_MOTION("Beatrice", "ATTACK1",-1)
	MSG("Urgh...|We'll be...fine...")
	END
}

DEF("Sturm")
RES("CLICK")
{
	FOCUS_CHR("Sturm")
	SET_NAME("Sturm", "Sturm")
//	SET_MOTION("Sturm", "ATTACK1",-1)
	MSG("Did I...get too careless...?")
	END
}

DEF("Tiowald")
RES("CLICK")
{
	FOCUS_CHR("Tiowald")
	SET_NAME("Tiowald", "Theobald")
//	SET_MOTION("Tiowald", "ATTACK1",-1)
