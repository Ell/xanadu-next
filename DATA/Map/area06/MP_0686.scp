	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)

	BGM(2, 0, 0)

	fade_in(100)
	wait(120)

//	SET_MSG_TIME(5,40,90,90)
	SET_MSG_TIME(5,80,90,90)
	MSG_EX("Three years after the War of the Knights--",240,0x00000094)
	MSG_EX("A death knell was rung for the ways of old,|and a fresh wind began to blow.",380,0x00000094)
	MSG_EX("Though a relic of that passing age, he continued|to walk the path of a knight, undeterred.",360,0x00000094)
	MSG_EX("And even after these events now told,|we continued to travel together.",360,0x00000094)
	MSG_EX("Our wanderings took us many places, but often|we were met along the way by a white phoenix.",400,0x00000094)
	MSG_EX("Was he pursuing those enduring maidens?|Or was it they who led him onward...",420,0x00000094)
//	MSG_EX("それは私には分かりません。",260,0x00000094)

	MSG_EX("He spoke little of the events|which occurred between himself and the others.",420,0x00000094)
	MSG_EX("Even to this day, he still carries|that sword to every place we visit.",400,0x00000094)
	MSG_EX("While we witness the unfolding of this new era,|his strength is necessary for the sake of the people.",420,0x00000094)
	MSG_EX("That is what I've discovered about|the last lone knight. Still...",420,0x00000094)
	MSG_EX("Perhaps this is merely a requiem|devoted to his fellow fallen knights. ",400,0x00000094)
	MSG_EX("Perfectly fitting for an awkward fellow,|don't you think?",260,0x00000094)

	fade_out(120)
	wait(120)
	fade_out(0)

	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)

	// スタッフロール
	CALL_ENDING( 115 )
	fade_out(0)

	// 一枚絵表示
	ENTRY_IMG(0,"mono\MONO06_01",0)
	ENTRY_IMG(1,"mono\MONO06_02",0)
	ENTRY_IMG(2,"mono\MONO06_03",0)
	ENTRY_IMG(3,"mono\MONO06_04",0)
	ENTRY_IMG(4,"mono\MONO06_05",0)
	ENTRY_IMG(5,"mono\MONO06_06",0)
	SET_IMG( 0, 000,000, 0,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)

	// 一枚絵表示
	ENTRY_IMG( 6,"mono\MONO07_01",0)
	ENTRY_IMG( 7,"mono\MONO07_02",0)
	ENTRY_IMG( 8,"mono\MONO07_03",0)
	ENTRY_IMG( 9,"mono\MONO07_04",0)
	ENTRY_IMG(10,"mono\MONO07_05",0)
	ENTRY_IMG(11,"mono\MONO07_06",0)
	SET_IMG( 6, 000,000, 6,  0,  0,256,256, 0, 0x00ffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 7, 256,000, 7,  0,  0,256,256, 0, 0x00ffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 8, 512,000, 8,  0,  0,256,256, 0, 0x00ffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 9, 000,256, 9,  0,  0,256,256, 0, 0x00ffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG(10, 256,256,10,  0,  0,256,256, 0, 0x00ffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG(11, 512,256,11,  0,  0,256,256, 0, 0x00ffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON( 6)
	IMG_ON( 7)
	IMG_ON( 8)
	IMG_ON( 9)
	IMG_ON(10)
	IMG_ON(11)

	wait(60)

//無音状態を作る★
	WAIT(300)

	BGM(23, 0, 0)
	fade_in(120)
	wait(120)

	wait(120)
	MSG_EX("Tomorrow we begin our journey once more.",280,0x00000094)
	MSG_EX("Liese, Fleurette,|what do you see of this world from the sky?",420,0x00000094)
	MSG_EX("The knight is certainly doing his best.|Please watch over him, both of you.",420,0x00000094)
