	SET_DEG("Beatrice",0)
	SET_DEG("Liese0",180)

	set_motion("PC", EMPTY22, 0)
	set_motion("Liese0", EMPTY3, 0)
	set_motion("Fleurette", EMPTY8, 0)
	set_motion("Gandaltua", EMPTY20, 0)
	LOOK_CHR("Gandaltua","PC")
	delete_efc("Liese")

	//カメラ切り替え
	WAIT(50)
	fade_in(60)
	set_script_camera(0,0,0,  -45,180,0, 17, 15)
	MOVE_SCRIPT_LOOK_AT( 0,0,5, 180, 1)
	WAIT(180)

	CROSS_FADE(60)
	PERMIT_SCRIPT_CAMERA(0)
//	CINEMA_OFF(60)
	PC_FLAG(5, 1)
	ret
}















//////////////////////////////////////////////////////////////////////
// 会話リーゼ

DEF("Liese0")

RES("CLICK")
{
	// 会話禁止
	PC_FLAG(3, 1)

	MSG("I truly wish to thank you for your efforts.|Please end this all by your hand.")
	MSG("While our fates have deemed it otherwise...")
	MSG("I would have liked...|to meet you under more normal circumstances...")

	PUT_CHR( 8, "LieseHit",    -0.00,-0.13,8.42, 180)
	hide_chr("LieseHit")
	show_chr("LieseHit")

}






//////////////////////////////////////////////////////////////////////
// リーゼ攻撃用

DEF("LieseHit")
RES("ATTACK")
{
//	CINEMA_ON(60)
	PC_FLAG(5, 0)
	stop_pc(0)
	pc_weapon(1, 1)
	set_motion("PC","EMPTY23",5)
	WAIT(29)

	FADE_OUT_EX(10, 1,"0xffffffff", 0)
	BLUR(10)
	SLOW(5)
	WAIT(10)
	SE("SE_EVENT_50")
	BLUR(0)
	SLOW(0)

	set_skip_label("SKIP")

	wait(260)

//　　フェード抜けて、リーゼロットをしゃがんで抱きかかえている
//　　主人公。リーゼロットの体の上にはドラゴンスレイヤーが添え
//　　られている。フローレットが近くに寄り添っている状態。

	MSG_EX("#S3#C3Lieselotte|#C0Thank you...brave knight...",-1,2)
	WAIT(60)
	MSG_EX("#S3#C3Lieselotte|#C0Hmmhmm... For someone born with such a feeble body...|I really did live for a long time...",-1,2)

	set_pos("PC",          -0.21,-0.13,9.50)
	set_pos("Liese0",       0.00,-0.13,9.50)
	set_pos("Fleurette",    0.60,-0.13,9.50)
	set_pos("Avatarlaha",  -2.12,-0.63,4.61)
	set_pos("Beatrice",    -3.07,-0.13,8.41)
	set_pos("Dvorak",      -2,-0.13,13)
	set_pos("Tiowald",     -0.03,-0.63,4.24)
	set_pos("Sturm",        4,-0.63,7)
	set_pos("Gandaltua",    2.5,-0.13,12)
	set_motion("Gandaltua", STAND, 0)

	set_deg("PC",           90)
	set_deg("Liese0",        180)
	set_deg("Fleurette",   270)
	set_deg("Avatarlaha",  39)
	set_deg("Beatrice",    85)
	set_deg("Dvorak",      170)
	set_deg("Tiowald",     351)
	set_deg("Sturm",       300)
	set_deg("Gandaltua",   221)

	HIDE_CHR("LieseHit")

	// 移動、スキル、会話禁止解除
	PC_FLAG(1, 0)
	PC_FLAG(2, 0)
	PC_FLAG(3, 0)
	SET_PC_EQUIP( 0 ,0)

	SET_MOTION("Liese0","EMPTY4",0)
	SET_MOTION("Fleurette","EMPTY9",0)
	SET_MOTION("PC","EMPTY25",0)
	set_motion("Gandaltua", EMPTY18, 0)
	WAIT(180)

	//遠景カメラ
	permit_script_camera(1)
	set_script_camera(0.00, 0.5,8.53, -70,150,0, 12, 30)
	rotate_script_camera(0,40,0, 2000, 1)

	FADE_IN_EX(120, 1,"0xffffffff", 0)
	wait(180)

//２部
	MSG_EX("#S3#C3Fleurette|#C0When a babe is born it cries,|the onlookers cheer in great delight...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0And when thine time to leave is nigh,|the onlookers do naught but cry--",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Thyself alone doth bear a smile.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0'Tis a proverb of Xanadu.",-1,2)

	CROSS_FADE(60)
	set_script_camera(0.00, 0.5,8.53, -30,170,0, 4.0, 30)
	rotate_script_camera(5,20,0, 2000, 1)

	MSG_EX("#S3#C3Fleurette|#C0Liese...|She has such a peaceful look.",-1,2)
	wait(120)

	MSG_EX("#S3#C3Theobald|#C0Princess Fleurette, 'tis time we go...",-1,2)
	wait(60)

	MSG_EX("#S3#C3Fleurette|#C0I understand.",-1,2)

	look_chr("Fleurette","PC")
	wait(60)

	MSG_EX("#S3#C3Fleurette|#C0Sir Knight, please keep my sister just like that.",-1,2)

//　　フローレット、リーゼロットに祈りを捧げる姿勢。
//　　ドラゴンスレイヤーが反応して輝き出す。

	cross_fade(60)
	set_script_camera(0.00,0.5,8.53, -10,210,0, 4, 30)
	SCALE_SCRIPT_CAMERA( 0.8, 2000, 0)
	wait(120)

	MSG_EX("#S3#C3Fleurette|#C0Liese...you were always concerned|about ensuring my happiness.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0For me to repay you for that,|there is but one solution.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Let us be together forever.|In utmost cheer, like those childhood days long past...",-1,2)
	SET_MOTION("Fleurette","EMPTY10",20)
	WAIT(68)
	SE("SE_EVENT_01")
	ATTACH_EFC("EFC_06FENIX1","Fleurette","POS")
	SET_MOTION("Fleurette","EMPTY11", 20)
	WAIT(60)
	SE("SE_EVENT_54")
	ATTACH_EFC("EFC_06FENIX2","Fleurette","POS")
	WAIT(120)

	cross_fade(60)
	set_script_camera(0.00,0.5,8.53, -30,290,0, 20, 30)
	rotate_script_camera(0,30,0, 2000, 1)
	WAIT(30)

	INIT_WALK_DST("Dvorak")
	set_walk_dst("Dvorak",  -1.5,-0.13,12)
	walk_pos("Dvorak",0,0.02)
	WAIT_WALK("Dvorak")
	
	MSG_EX("#S3#C3Dvorak|#C0Lady Fleurette, what are you...?",-1,2)
	WAIT(60)
	MSG_EX("#S3#C3Fleurette|#C0Sir Knight, along with the sages...",-1,2)
	WAIT(90)
	MSG_EX("#S3#C3Fleurette|#C0I bid you farewell...",-1,2)



//　　ドラゴンスレイヤーが眩い光を放ち、辺り一面が光に
//　　覆われる。画面、そのままホワイトアウト。

	FADE_OUT_EX(60, 1,"0x99ffffff", 0)
	blur(10)
	SLOW(1)
	wait(60)
	FADE_IN_EX(30, 1,"0x99ffffff", 0)
	wait(30)

	FADE_OUT_EX(30, 1,"0xAAffffff", 0)
	wait(30)
	FADE_IN_EX(30, 1,"0xAAffffff", 0)
	wait(60)
	blur(20)
	SE("SE_EVENT_55")
	FADE_OUT_EX(120, 1,"0xffffffff", 0)
	WAIT(120)

	blur(0)
	SLOW(0)
	STOP_ENV_SE("SE_NAMI2", 4000)
	STOP_ENV_SE("SE_EVENT_54", 4000)
	DELETE_EFC("Fleurette")
	stop_bgm(0, 3000)

	WAIT(120)

	play_movie("system\ins02.dat", 1)

//　　以降は挿入ムービーによるイベント
//　　光はやがて一箇所に集約され、それが次第に不死鳥の
//　　形を作っていく。
//　　不死鳥となったフローレットは力強く羽ばたき、その
//　　まま上空へと飛び立っていく。ムービーはここで終了。
//　　フェードアウト抜けて、再び奇岩城。
//    明るい背景

	FADE_OUT(0)

	set_script_camera(-1.21, 7.13,14.86,  0,150,0, 15, 30)
	MOVE_SCRIPT_LOOK_AT( 0,-5,0, 1400, 1)
	LOAD_MAP("MP_0689")

	HIDE_CHR("Liese0")
	HIDE_CHR("Fleurette")
	set_motion("Gandaltua", STAND, 0)

	//PC用目線先配置★
	ENTRY_CHR(10,  283)
	PUT_CHR( 10, "PCLOOK",    -0.00,2.15,18, 180)

	set_pos("PC",           0.04,-0.13,15.66)
	set_pos("Avatarlaha",  -1.64,-0.13,13.98)
	set_pos("Beatrice",    -3.45,-0.13,13.62)
	set_pos("Dvorak",       1.77,-0.13,14.65)
	set_pos("Tiowald",      0.12,-0.13,12.91)
	set_pos("Sturm",        0.90,-0.13,11.01)
	set_pos("Gandaltua",   -1.43,-0.13,10.67)

	set_deg("PC",           348)
	set_deg("Avatarlaha",   325)
	set_deg("Beatrice",     347)
	set_deg("Dvorak",       347)
	set_deg("Tiowald",      318)
	set_deg("Sturm",        341)
	set_deg("Gandaltua",    339)

	//PC上を向く★
	look_chr("PC", "PCLOOK")
	LOOK_CHR("Avatarlaha","-")
	LOOK_CHR("Beatrice","-")
	LOOK_CHR("Dvorak","-")
	LOOK_CHR("Tiowald","-")
	LOOK_CHR("Sturm","-")
	LOOK_CHR("Gandaltua","-")

	//SET_PC_EQUIP( 0 ,1)
	PC_WEAPON( 0,1)
	set_motion("PC","STAND",0)
	FOCUS_CHR("PC")

//エピローグへ。（注意：ここからノンストップ再生）

	wait(70)

	FADE_IN(120)
	wait(120)

	MSG_EX("#S3#C3Sturm|#C0What the...?",120,2)
	wait(30)

	MSG_EX("#S3#C3Beatrice|#C0Is that...Lady Fleurette...?",200,2)
	wait(30)

//	MSG_EX("#S3#C0ドヴォルザーク「一体何が起こったというのだ。」",200,2)
//	wait(30)

	MSG_EX("#S3#C3Theobald|#C0A white phoenix... I understand now...",180,2)
	MSG_EX("#S3#C3Theobald|#C0By assuming that shape, Lady Fleurette will|be able to keep Galsis sealed for all eternity.",300,2)
	MSG_EX("#S3#C3Theobald|#C0However, since it is an immortal creature,|her vigil will also be eternal.",260,2)
	wait(30)

//	MSG_EX("#S3#C0ベアトリーチェ「そ、そんな……」",120,2)
//	wait(30)
//
//	MSG_EX("#S3#C0アバターラハ「何と……悲壮な決意でしょう……」",180,2)
//	wait(30)

	CROSS_FADE(60)
	set_script_camera(0,1.1,12, -5,290,0, 8, 30)
	rotate_script_camera(0,15,0, 2100, 1)
	wait(40)

	SET_MOTION("Beatrice","EMPTY2",30)
	MSG_EX("#S3#C3Beatrice|#C0But, how could she have become a phoenix...?",220,2)
	MSG_EX("#S3#C3Beatrice|#C0I wasn't even aware Lady Fleurette|had that much power...",280,2)
	wait(40)

	LOOK_CHR("Beatrice","Tiowald")
	set_motion("Tiowald", ATTACK1, -1)
	MSG_EX("#S3#C3Theobald|#C0Lady Fleurette will not stand her watch alone.|Lady Lieselotte is with her, as well.",280,2)
	LOOK_CHR("Sturm","-")
	wait(30)

	set_motion("Gandaltua", ATTACK1, -1)
	MSG_EX("#S3#C3Gandharva|#C0Hmm, so you're saying this resolution could|only be achieved because the Sacred Maidens|were twins...?",280,2)
	wait(60)

	MSG_EX("#S3#C3Abhidharma|#C0So in the end it seems like|nothing we did was of any use...",280,2)
	wait(40)

	CROSS_FADE(60)
	LOOK_CHR("Beatrice","-")
	set_script_camera(1.66,1.3,14.55, -10,35,0, 3, 30)
	SCALE_SCRIPT_CAMERA( 1.2, 1000, 0)

	MSG_EX("#S3#C3Dvorak|#C0Nay, we may yet have a role.",220,2)
	MSG_EX("#S3#C3Dvorak|#C0Even when all seems lost, we may|be all that remains in the future.",260,2)
	wait(30)

	look_chr("Dvorak", "PC")
	wait(40)

	cross_fade(60)
	SET_SCRIPT_CAMERA_EX( "PC",-2, 3,100,0, 3, 15 )
	SCALE_SCRIPT_CAMERA( 0.8, 1000,0)
	MOVE_SCRIPT_LOOK_AT( 0,0.5,2, 1000, 1)

	WAIT(40)
	MSG_EX("#S3#C3Dvorak|#C0Would you not agree, knight?",340,2)
	WAIT(240)

	FADE_OUT(240)
	WAIT(240)

SKIP:
	STOP_ENV_SE("SE_EVENT_54",500)
	set_skip_label("SKIP2")

//	FADE_OUT_EX(0, 1,"0xffffffff", 0)
	fade_out(0)
	blur(0)
	SLOW(0)
	stop_bgm(0, 4000)
	STOP_ENV_SE("SE_NAMI2", 4000)

	WAIT(300)

	ENTRY_IMG(0,"mono\MONO05_01",0)
	ENTRY_IMG(1,"mono\MONO05_02",0)
	ENTRY_IMG(2,"mono\MONO05_03",0)
	ENTRY_IMG(3,"mono\MONO05_04",0)
	ENTRY_IMG(4,"mono\MONO05_05",0)
