
// ----------------------------------------------------------------------------
// マップ初期化時にボスパーツを全部読み込む                                                                      
// ----------------------------------------------------------------------------

DEF("MAP")
RES("INIT")
{
	// SE再生
	SE("SE_THUNDER")
	SE("SE_WIND2")
	SE("SE_NAMI2")

	// リーゼ戦用カメラOFF
	CAMERA_OFF("リーゼ戦")

	// ★05/05/18:ブラックオニキス禁止フラグON
	room_flag_on(255)

	// コア
	load_chr("M_0322\ARM_322a",0)
	// ＤＳ
	load_chr("M_0322\ARM_322b",1)
	// ヒットマップ
	load_chr("M_0322\M_0322h",8)
	set_collision_obj("body",8)

	lock_camera("ボス戦")
	set_scroll_rect(-0,-2.5, 0,15)


// ＨＰリンク設定
	link_hp_chr("core","body")
	
	// ビット隠す（呼び出しはプログラム側でやる）
	hide_chr("bit1")
	hide_chr("bit2")
	hide_chr("bit3")
	hide_chr("bit4")

	set_target_chr("body")
	bgm(17,0,-1)

	ENTRY_CHR( 0,  72)
	ENTRY_CHR( 1, 535)
	ENTRY_CHR( 2,  36)
	ENTRY_CHR( 3,  37)
	ENTRY_CHR( 4,  38)
	ENTRY_CHR( 5,  39)
	ENTRY_CHR( 6,  40)
	ENTRY_CHR( 7,  41)
	ENTRY_CHR( 8, 538)
	ENTRY_CHR( 9, 543)

// 3808	EV リーゼ攻撃モード
	CHECK_GAME_FLAG(3808)
	OFF_JUMP NEXT

	BGM(19, 0, -1)

	KILL_CHR("KAMINARI",0,0,1)
	STOP_ENV_SE("SE_THUNDER", 4000)
	STOP_ENV_SE("SE_WIND2", 4000)
	CAMERA_ON("リーゼ戦")
	CINEMA_ON(0)
	PC_FLAG(5, 1)

	//PCの処理
	set_pos("PC", 0.0,-0.63,6.75)
	set_deg("PC", 0)
	PC_WEAPON(1, 0)
	// 移動、スキル、キャンプ禁止
	PC_FLAG(1, 1)
	PC_FLAG(2, 1)
	PC_FLAG(4, 1)
	SET_PC_EQUIP( 1 ,0)
	SET_PC_EQUIP( 3 ,0)
	FOCUS_CHR("PC")
	set_motion("PC", EMPTY22, 0)

	//NPC処理
	PUT_CHR( 1, "Fleurette",   1.00,-0.88, 0.0, 20)
	PUT_CHR( 2, "Avatarlaha",  2.14,-0.88,-2.25, 0)
	PUT_CHR( 3, "Tiowald",    -1.85,-0.88,-2.43, 0)
	PUT_CHR( 4, "Sturm",      -3.96,-0.88,-1.12, 0)
	PUT_CHR( 5, "Gandaltua",   1.5, -0.88, 0.3,210)
	PUT_CHR( 6, "Dvorak",      -1,-0.88, 0.68,  0)
	PUT_CHR( 7, "Beatrice",    0.97,-0.88,-3.22, 0)
	PUT_CHR( 9, "Liese0",       -0.00,-0.13, 8.42, 180)
	set_motion("Liese0", EMPTY3, 0)
	set_motion("Fleurette", EMPTY8, 0)
	set_motion("Gandaltua", EMPTY20, 0)
	LOOK_CHR("Gandaltua","PC")
	load_npc_eqp(7,00)
	DVORAK( 0)

	hide_chr("core",0,1,120)
	hide_chr("body",0,1,400)

	end

NEXT:h
	// 3809	EV ボス戦闘後イベントを呼び出し用(DEBUG)
	CHECK_GAME_FLAG(3809)
	OFF_JUMP NEXT2

	hide_chr("core",0,1,120)
	hide_chr("body",0,1,400)
	stop_bgm(0,1)

NEXT2:

	end
}


// コア //////////////////////////////////////////////////////////////////////
DEF("core")

RES("INIT")
{
}
RES("KILL")
{
	sys("The battle is won!")
}







// 胴体 //////////////////////////////////////////////////////////////////////

DEF("body")
RES("INIT")
{
	// 3809	EV ボス戦闘後イベントを呼び出し用(DEBUG)
	CHECK_GAME_FLAG(3809)
	OFF_JUMP NEXT

	// 3808	EV リーゼ攻撃モード
	CHECK_GAME_FLAG(3808)
	ON_JUMP LISE_HIT

	stop_bgm(0)

	CINEMA_ON(0)
	call EVENT_LISE
	jump EXIT


//-- リーゼ攻撃モード ------------------------------------------------

LISE_HIT:
	set_pos("PC", 0.0,-0.63,7.00)
	set_deg("PC", 0)

	// 移動禁止
	PC_FLAG(1, 1)
	// スキル禁止
	PC_FLAG(2, 1)
	// キャンプ禁止
	PC_FLAG(4, 1)
	PC_FLAG(10, 1)
	set_motion("PC", EMPTY22, 0)

	CINEMA_ON(0)
	PC_FLAG(5, 1)

	// リーゼ戦用カメラ
	CAMERA_ON("リーゼ戦")

	KILL_CHR("KAMINARI",0,0,1)
	STOP_ENV_SE("SE_THUNDER", 4000)
	STOP_ENV_SE("SE_WIND2", 4000)
	end


NEXT:
	//0685から着た場合の処理、導入ムービー
	permit_script_camera(1)
	set_script_camera(-0.7,8.5,7, -55,195,0, 9, 15)
	set_motion("body","EMPTY1",0)
	STOP_PC(0)
	set_pos("PC",0.00,-0.875,0.00)
	set_deg_ex("PC","body")


	FADE_IN_EX( 60, 1, "0xffffffff",0)
	SE("SE_B6_79001")
	SE("SE_B6_79002")
	blur(30)
	SLOW(4)
	wait(50)
	SE("SE_B6_79003")
	SLOW(0)
	wait(50)

	rotate_script_camera(40,-15,0, 10, 1)
	move_script_look_at(0,-3.5,0, 10, 1)
	blur(50)
	SLOW(4)
	wait(10)
	SLOW(0)
	blur(0)
	scale_script_camera(1.1, 60, 1)
	wait(55)
//	SE("SE_B6_79001")

	//引く
	scale_script_camera(2.5, 120, 1)
	move_script_look_at(0,-3,0, 120, 1)
	blur(2)
	wait(100)
//	SE("SE_B6_79001")
	STOP_ENV_SE("SE_B6_79001",1500)

	//後処理
	FOCUS_CHR("PC")
	permit_script_camera(0)
	CROSS_FADE(60)
	blur(0)
	CINEMA_OFF(0)

EXIT:
	end
}



RES("KILL")
{
	stop_pc(0)
	set_motion("body","DYING",0)
	delete_efc("body")
	delete_efc("core")
	delete_efc("bit1")
	delete_efc("bit2")
	delete_efc("bit3")
	delete_efc("bit4")

	kill_chr("core",0,1,120)
	kill_chr("bit1",0,1,120)
	kill_chr("bit2",0,1,120)
	kill_chr("bit3",0,1,120)
	kill_chr("bit4",0,1,120)
	kill_chr("kao1",0,1,120)
	kill_chr("kao2",0,1,120)
	kill_chr("kao3",0,1,120)

	set_target_chr("-")

//ここから死亡デモ-------------------------------------------

	stop_bgm(0)

	blur(50)
	SE("SE_B6_79800")
	SLOW(6)
	FADE_OUT_EX( 16, 0, "0xffffff7d", 4)
	wait(20)
	SLOW(0)
	cinema_on(0)

	//カメラ位置決定
	cross_fade(60)
	permit_script_camera(1)
	set_script_camera(0,10,12, -30,-145,0, 10, 0)

	//PCの位置補正
	refresh("PC")
	set_pos("PC",0.00,-0.12,9.0)
	set_deg_ex("PC","body")
	set_motion("PC","EMPTY2",0)
	DELETE_EFC("PC")

	//ガル顔アップ横なめ
	rotate_script_camera(10,10,0, 250, 1)
	wait(60)
	SLOW(2)
	wait(60)
	SLOW(0)
	wait(130)

	//コア周辺下へパーン
	cross_fade(60)
	move_script_look_at(0,-9,0, 50, 0)
	rotate_script_camera(0,-15,0, 50, 0)
	scale_script_camera(0.7, 50, 0)
	wait(50)
	rotate_script_camera(0,-3,0, 50, 1)
	set_motion("PC","EMPTY3",50)
	wait(50)
	SLOW(4)
	scale_script_camera(1.5, 20, 0)
	wait(20)
	SLOW(0)

	//中央から旋回
	rotate_script_camera(-5.0,-10,0,280, 1)
	blur(40)
	wait(40)
	set_motion("PC","STAND",0)
	WAIT(100)
	SE("SE_B6_79801")
	wait(50)
	SLOW(2)
	wait(15)
	SE("SE_B6_79801")
	wait(15)
	SLOW(0)
//	wait(75)
	wait(40)
	SE("SE_B6_79802")
	wait(35)

	//一気に引く
	blur(100)
	scale_script_camera(3, 5, 0)
	wait(2)
	SLOW(3)
	wait(3)
	SLOW(0)
	blur(0)

	//ゆっくり旋回しつつホワイトアウト
	blur(60)
	rotate_script_camera(-10,-60,0,660, 1)
	QUAKE(5,5,660)
	FADE_IN_EX(20, 0, "0xffffff7d", 0)
	wait(20)
	set_collision_obj("body",-1)
	FADE_OUT_EX(590, 0, "0xffffffff", 0)
	WAIT(100)
	EFC("EFC_SPI_DEAD",0,3,10)
	WAIT(200)
	kill_chr("body",0,1,300)
	WAIT(600)
	
	blur(0)

	INIT_SWITCH_ON("beatgalsis")

//--------------------------------------------------------------------

	call EVENT_LISE

	end
}


@EVENT_LISE
{
	// リーゼ戦用カメラON
	CAMERA_ON("リーゼ戦")

	//PC
	stop_pc(0)
	PC_WEAPON( 0,1)
	set_motion("PC","STAND",-1)
	set_pos("PC",0.25,-0.88,0)
	set_deg("PC", 10)
	SET_PC_EQUIP( 1 ,0)
	SET_PC_EQUIP( 3 ,0)

	//NPC
	PUT_CHR( 0, "Liese",    -0.00,-0.13,8.42, 180)
	PUT_CHR( 1, "Fleurette",    -0.76,-0.63,-5.91, 6)
	PUT_CHR( 2, "Avatarlaha",    2.41,-0.63,-7.00, 0)
	PUT_CHR( 3, "Tiowald",    1.44,-0.63,-6.76, 0)
	PUT_CHR( 4, "Sturm",    -4.05,-0.63,-6.32, 0)
	PUT_CHR( 5, "Gandaltua",    -0.05,-0.63,-6.25, 0)
	PUT_CHR( 6, "Dvorak",      -1.72,-0.63,-6.58, 126)
	PUT_CHR( 7, "Beatrice",   -1.82,-0.63,-6.69, 0)
	PUT_CHR( 9, "Liese0",       -0.00,-0.13, 8.42, 180)
	load_npc_eqp(7,00)
	DVORAK(0)
	HIDE_CHR("Liese")
	HIDE_CHR("Liese0")

	//カメラ
	permit_script_camera(1)
	set_script_camera(-0.0,-0.63,6.11,  -25.0,130.0,0.0, 12, 30.0)
	move_script_look_at( 0,1,-6, 400, 1)
	rotate_script_camera(5,5,0, 400, 1)
	FADE_IN_EX(300, 0, "0xffffffff", 0)

//	↓作業的にスキップできないと辛いのでとりあえず入れました
	set_skip_label("SKIP")
	wait(300)


//▼奇岩城・崩壊した塔屋上
//　　フローレットと導師たちが駆けつけてくる。

	MSG_EX("#S3#C3Fleurette|#C0Brave knight!!",-1,2)

	INIT_WALK_DST("Fleurette")
	set_walk_dst("Fleurette", -0.59,-0.88,-1.61)
	walk_pos("Fleurette",1,0.05)

	wait(20)
	set_deg("PC", 245)
	look_chr("PC", "Fleurette")
	wait(40)

	INIT_WALK_DST("Dvorak")
	set_walk_dst("Dvorak", -1.64,-0.88,0.68)
	walk_pos("Dvorak",1,0.035)
	wait_walk("Dvorak")
	set_Deg("Dvorak", 42)
	look_chr("Dvorak", "-")

	MSG_EX("#S3#C3Fleurette|#C0Are you all right?",-1,2)

	move_script_look_at( 0,0,-1, 500, 1)
	rotate_script_camera(0,-20,0, 500, 1)

	INIT_WALK_DST("Avatarlaha")
	set_walk_dst("Avatarlaha", 2.14,-0.88,-2.25)
	walk_pos("Avatarlaha",0,0.03)
	wait(60)

	INIT_WALK_DST("Beatrice")
	set_walk_dst("Beatrice", -1.85,-0.88,-2.43)
	walk_pos("Beatrice",0,0.03)
	wait_walk("Beatrice")
	look_chr("Beatrice", "PC")

	set_Deg("Avatarlaha", 328)
	look_chr("Avatarlaha", "PC")

	INIT_WALK_DST("Tiowald")
	set_walk_dst("Tiowald", 0.97,-0.88,-3.22)
	set_walk_dst("Tiowald", 0.92,-0.88,-1.78)
	walk_pos("Tiowald",0,0.02)
	wait(60)

	INIT_WALK_DST("Sturm")
	set_walk_dst("Sturm", -3.96,-0.88,-1.12)
	walk_pos("Sturm",0,0.03)
	wait_walk("Sturm")
	set_Deg("Sturm", 50)
	look_chr("Sturm", "PC")
	look_chr("Tiowald", "PC")

	INIT_WALK_DST("Gandaltua")
	set_walk_dst("Gandaltua", -0.02,-0.63,-4.66)
	walk_pos("Gandaltua",0,0.03)
	wait_walk("Gandaltua")


//　　主人公に寄り添うフローレット。
//　　ドヴォルザーク、まわりを見渡す仕草。

	INIT_WALK_DST("Fleurette")
	set_walk_dst("Fleurette", -0.38,-0.88,-1.00)
	walk_pos("Fleurette",0,0.02)
	set_deg_EX("Fleurette", "PC")

	set_deg("Dvorak", 350)
	wait(60)
	set_deg("Dvorak", 10)
	wait(60)

	MSG_EX("#S3#C3Gandharva|#C0Has Galsis...been defeated?",-1,2)

	set_motion("Sturm", ATTACK1, -1)
	MSG_EX("#S3#C3Sturm|#C0It surely seems that way, but...",-1,2)

//　　ドヴォルザークが主人公に語りかける。
//	dvorak(0, 0)
	wait(60)

	cross_fade(60)
	set_script_camera(0.25,0.88,-1.00,  -12.0,70.0,0.0, 7, 30.0)
	set_deg_EX("Dvorak", "PC")
	wait(60)

	set_motion("Dvorak", ATTACK1, -1)
	look_chr("PC", "Dvorak")
	MSG_EX("#S3#C3Dvorak|#C0Knight, the words Galsis spoke before you fought...|What did the creature say?",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0'Twas quite like that which|the Black Bride would utter...",-1,2)

	look_chr("Tiowald", "Fleurette")
	MSG_EX("#S3#C3Theobald|#C0...",-1,2)

//　　次の瞬間、光の柱が立ち上り(オニキスエフェクト)、力尽きて
//　　膝をついたリーゼロットが現れる。全員、驚いて身構える。
//　　並んで剣を構えて、フローレットを守る主人公とドヴォルザーク。

	
	SHOW_CHR("Liese")
	ATTACH_EFC("EFC_WARP_E","Liese","POS")
	SE("SE_WARP3")
	cross_fade(60)
	set_script_camera(-0.00,-0.13,8.53,  -12.0,180.0,0.0, 8, 30.0)
	move_script_look_at( 0,0.5,0, 1000, 1)

	wait(20)
	ATTACH_EFC("EFC_WARP_T","Liese","POS")
	wait(120)

	set_deg_EX("PC", "Liese")
	look_chr("PC", "Liese")
//	set_deg_EX("Dvorak", "Liese")

	MSG_EX("#S3#C3Fleurette|#C0Liese...",-1,2)

	MSG_EX("#S3#C3Lieselotte|#C0Brave knight...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0This is not yet over.|Not for as long as I remain Galsis' wife...",-1,2)

//	move_script_look_at( 0,4,-12, 500, 1)
//	rotate_script_camera(-20,0,0, 500, 1)

	MSG_EX("#S3#C3Theobald|#C0...Princess Lieselotte, enough of this.",-1,2)

	cross_fade(60)
	set_script_camera(-0.35,0.00,-1.17,  -12.0,45.0,0.0, 10, 30.0)
	wait(60)

	MSG_EX("#S3#C3Dvorak|#C0Sage Theobald?",-1,2)

	look_chr("Tiowald", "Liese")
	set_motion("Tiowald", ATTACK1, -1)
	MSG_EX("#S3#C3Theobald|#C0I am quite certain everyone saw it, as well.",-1,2)
	MSG_EX("#S3#C3Theobald|#C0Princess Lieselotte has, for some reason,|assumed an appearance as such...",-1,2)
	wait(30)
	set_deg("Dvorak", 32)
	look_chr("Dvorak", "Liese")

	MSG_EX("#S3#C3Lieselotte|#C0...",-1,2)
	wait(30)

	MSG_EX("#S3#C3Theobald|#C0Will you explain yourself?|...I speak of your true intentions.",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(-0.00, 0.63,8.53,  -12.0,180.0,0.0, 5, 30.0)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0I...",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(-0.35,0.00,-1.17,  -12.0,45.0,0.0, 10, 30.0)
	wait(60)

	// フローレを前まで歩かせる
	move_script_look_at( 0,0.5,7, 500, 1)

	INIT_WALK_DST("Fleurette")
	set_walk_dst("Fleurette", -0.69,-0.88,0.31)
	set_walk_dst("Fleurette", -0.56,-0.88,2.04)
	set_walk_dst("Fleurette",  0.01,-0.63,4.61)
	walk_pos("Fleurette",0,0.02)

//	move_script_look_at( 0,0,4, 200, 1)

	MSG_EX("#S3#C3Fleurette|#C0Liese...",-1,2)

	wait_walk("Fleurette")
	set_deg_EX("Fleurette", "Liese")
	wait(60)
	wait_camera(0)
	wait(60)

	cross_fade(60)
	set_script_camera(-0.00,1.00,6.42,  -25.0,100.0,0.0, 9, 30.0)
	rotate_script_camera(0,20,0, 2000, 1)

	look_chr("Fleurette", "Liese")

	MSG_EX("#S3#C3Fleurette|#C0500 years ago...what happened?|What happened after you sealed us away?",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0We thought Galsis would have chosen|to keep us within Castle Strangerock.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Yet there upon the island of Harlech|did you stay and protect us...",-1,2)
	cross_fade(60)
	set_script_camera(-0.67,1.03,7.24,  -8.0,150.0,0.0, 6, 30.0)
	rotate_script_camera(5,0,0, 1000, 1)
	wait(60)

	MSG_EX("#S3#C3Fleurette|#C0But I fail to understand your reasoning|behind sealing the Dragon King within yourself.",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Because of the words Galsis said earlier...|There is no way we could NOT notice it!",-1,2)
	wait(60)
	MSG_EX("#S3#C3Lieselotte|#C0Fleur...",-1,2)
	wait(20)
	fade_out(60)
	stop_bgm(0, 1000)
	wait(120)

	KILL_CHR("KAMINARI",0,0,1)
	STOP_ENV_SE("SE_THUNDER", 4000)
	STOP_ENV_SE("SE_WIND2", 4000)

	BGM(19, 0, 0)
	MSG_EX("#S3#C3Lieselotte|#C0What have I...|What course can I take to make it right?",-1,2)
	wait(60)

	set_script_camera(0.06,1.0,4.34,  -2.0,5.0,0.0, 8, 30.0)
	move_script_look_at( 1.0,0,0, 1000, 1)

	fade_in(60)
	MSG_EX("#S3#C3Lieselotte|#C0...We were born as twins into the royal family,|and as such we both were trained to be Sacred Maidens.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0As is the norm for twins,|we developed irreplaceable memories together.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Perhaps...due to the intense training we endured,|our bonds grew far deeper than the norm.",-1,2)

	MSG_EX("#S3#C3Fleurette|#C0Liese...",-1,2)

	cross_fade(60)
	set_script_camera(-0.84,1.03,8.01,  5.0,90.0,0.0, 6, 30.0)
	move_script_look_at( 0,-0.5,-3, 1200, 1)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0The ever lighthearted and carefree Fleur...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0With my frail body, I think I even|envied you a bit from what I remember.",-1,2)
	wait(30)
	MSG_EX("#S3#C3Lieselotte|#C0I did not want the burden of the Maiden's Seal|to be yours to bear. I wanted you free of those|tethers, free to walk your own path to happiness.",-1,2)
	wait(30)
	MSG_EX("#S3#C3Lieselotte|#C0For Galsis to be sealed within a maiden|is much akin to the proverbial stake in the coffin.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0And the concept of marriage? You would be unable|to have even the tiniest bit of a normal life.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0So the night before our 16th birthday...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0I heard that you had been chosen|to be the maiden...",-1,2)

	look_chr("Fleurette", "-")

	MSG_EX("#S3#C3Fleurette|#C0Ah...",-1,2)
	wait(60)

	cross_fade(60)
	set_script_camera(-0.06,1.0,4.34,  -2.0,355.0,0.0, 5, 30.0)
	rotate_script_camera(5,0,0, 1000, 1)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0Thinking about how weak my body was,|one can somewhat understand the reasoning.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Still, with the reality so prominent in my mind,|a chasm in my heart opened wide.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0My sister had just been burdened with a terrible fate.|I simply refused to allow that one reality to happen.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0I cursed myself for having|such a weak constitution...",-1,2)
	wait(30)

	MSG_EX("#S3#C3Fleurette|#C0Sis...",-1,2)
	wait(30)

	cross_fade(60)
//	set_script_camera(-1.20,-0.88,-1.89,  -55.0,30.0,0.0, 14, 30.0)
	set_script_camera(-1.0, 0.0, -0.5,  -8.0,45.0,0.0, 6, 30.0)
	move_script_look_at( 2, 0.2,-3, 800, 1)
	set_deg_EX("Dvorak", "Liese")
	wait(60)

	set_motion("Dvorak", ATTACK1, -1)
	MSG_EX("#S3#C3Dvorak|#C0The maiden selection process was decided|in utmost secrecy.",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0Who had the audacity to...",-1,2)
	wait(30)

	set_motion("Gandaltua", ATTACK1, -1)
	MSG_EX("#S3#C3Gandharva|#C0Ah I see. 'Twas Lorelei, was it not?",-1,2)
	wait(60)

	cross_fade(60)
	set_script_camera(0.01,-0.13,8.50,  -25.0,180.0,0.0, 9, 30.0)
	rotate_script_camera(5,0,0, 1000, 1)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0...You are quite correct.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0She would marry the Dragon King,|and thus inherit a vast amount of power...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Intending to use that power and the maiden|training to trick Galsis, she proposed I seal|him away within myself.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Maybe, if the Dragon King vanished from Xanadu,|then Fleur wouldn't have to become a Sacred Maiden.",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(0.01,1.13,8.50,  -4.0,200.0,0.0, 15, 30.0)
	wait(60)

	look_chr("Sturm", "Liese")
	wait(10)

	MSG_EX("#S3#C3Sturm|#C0Lorelei...|Was there no limit to her wretchedness?",-1,2)
	wait(30)

	MSG_EX("#S3#C3Lieselotte|#C0In her eyes I was but a tool to facilitate|the release of the Dragon King.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0But in so telling, there seemed to be|yet one shining ray of hope for me.",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(-0.84,1.03,4.51,  5.0,90.0,0.0, 4, 30.0)
	wait(60)

	MSG_EX("#S3#C3Fleurette|#C0I only...",-1,2)
	wait(60)
	move_script_look_at( 0,0,0.5, 500, 1)
	look_chr("Fleurette", "Liese")

	MSG_EX("#S3#C3Fleurette|#C0I only wanted you to be happy, Liese...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0Only a strong Sacred Maiden|such as myself would do, and...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0...so I thought...",-1,2)
	look_chr("Fleurette", "-")
	wait(30)

	cross_fade(60)
	set_script_camera(0.1,1.23,7.5,  3.0,150.0,0.0, 3, 30.0)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0I know...|Thank you...my beloved Fleur...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0You see, that's why I wished|for your happiness...",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(-0.84,1.03,5.01,  5.0,90.0,0.0, 4, 30.0)
	wait(60)

	MSG_EX("#S3#C3Fleurette|#C0Liese...",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(0.45,1.23,7.5,  3.0,150.0,0.0, 3, 30.0)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0There was no other with a body of my constitution.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0So I accepted the proposal Lorelei offered.",-1,2)

	fade_out(60)
	wait(60)

// ■一枚絵　大広間を進む黒き花嫁
	ENTRY_IMG(0,"mono\MONO01_01",0)
	ENTRY_IMG(1,"mono\MONO01_02",0)
	ENTRY_IMG(2,"mono\MONO01_03",0)
	ENTRY_IMG(3,"mono\MONO01_04",0)
	ENTRY_IMG(4,"mono\MONO01_05",0)
	ENTRY_IMG(5,"mono\MONO01_06",0)
	SET_IMG( 0, 000,000, 0,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)

	fade_in(60)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0And so, before the day had ended,|I sought out the seal that lay deep|within the castle.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Beatrice|#C0Thus is the story behind the Black Bride...",-1,2)
	wait(30)

	MSG_EX("#S3#C3Lieselotte|#C0Yes...",-1,2)

	fade_out(60)
	wait(60)

	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)
// ■一枚絵　ドラスレを構えるフローレット
	MSG_EX("#S3#C3Lieselotte|#C0Not long after the battle between the Dragon King|and Xanadu started, Fleur and her companions began|their assault on Castle Strangerock.",-1,2)
	ENTRY_IMG(0,"mono\MONO02_01",0)
	ENTRY_IMG(1,"mono\MONO02_02",0)
	ENTRY_IMG(2,"mono\MONO02_03",0)
	ENTRY_IMG(3,"mono\MONO02_04",0)
	ENTRY_IMG(4,"mono\MONO02_05",0)
	ENTRY_IMG(5,"mono\MONO02_06",0)
	SET_IMG( 0, 000,000, 0,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)

	fade_in(60)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0Though it seemed the fight was in Xanadu's favor,|there was a single miscalculation.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Fleurette|#C0...A miscalculation?",-1,2)
	wait(30)

	fade_out(60)
	wait(60)

	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)

// ■一枚絵　剣のアップ
	MSG_EX("#S3#C3Lieselotte|#C0The legendary wielder of the Sacred Sword|never emerged.",-1,2)
	ENTRY_IMG(0,"mono\MONO03_01",0)
	ENTRY_IMG(1,"mono\MONO03_02",0)
	ENTRY_IMG(2,"mono\MONO03_03",0)
	ENTRY_IMG(3,"mono\MONO03_04",0)
	ENTRY_IMG(4,"mono\MONO03_05",0)
	ENTRY_IMG(5,"mono\MONO03_06",0)
	SET_IMG( 0, 000,000, 0,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)

	fade_in(60)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0The Sacred Sword only grants true power|to the brave soul it chooses itself.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Even though Fleur wielded it with conviction,|she was unable to deal any grave wounds to Galsis.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Theobald|#C0As I suspected...",-1,2)
	wait(30)

	fade_out(60)
	wait(60)

	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)

// ■一枚絵　城の真上に現れるガルシス
	MSG_EX("#S3#C3Fleurette|#C0Then does that mean,|while the fight was raging on...",-1,2)
	wait(30)
	ENTRY_IMG(0,"mono\MONO04_01",0)
	ENTRY_IMG(1,"mono\MONO04_02",0)
	ENTRY_IMG(2,"mono\MONO04_03",0)
	ENTRY_IMG(3,"mono\MONO04_04",0)
	ENTRY_IMG(4,"mono\MONO04_05",0)
	ENTRY_IMG(5,"mono\MONO04_06",0)
	SET_IMG( 0, 000,000, 0,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)

	fade_in(60)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0Yes, 'twas probable that every single person|would have had their life extinguished.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0I waited, watching the battle unfold, biding my time|for a chance when I could seal away the Dragon King.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Unfortunately, that chance never materialized,|and you finally faced off against Galsis.",-1,2)

	fade_out(60)
	wait(60)

	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)

	MSG_EX("#S3#C3Lieselotte|#C0And so I...",-1,2)

	set_script_camera(0.25,-0.0,0.00,  -10.0,330.0,0.0, 10, 30.0)
	rotate_script_camera(0,5,0, 800, 1)
	fade_in(60)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0I used magic to seal away time on the Dragon King...|and swept you up in it, as well.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Fleurette|#C0So...you...|That petrification was...",-1,2)
	MSG_EX("#S3#C3Fleurette|#C0In order to...save us?",-1,2)
	wait(30)

	MSG_EX("#S3#C3Lieselotte|#C0Yes, my apologies...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0In order to save you all|I...I had to.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Dvorak|#C0By the phoenix's flame...",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(-0.09,0.60,8.48,  5.0,340.0,0.0, 2, 30.0)
	move_script_look_at( 0, 0.8,0, 800, 1)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0After those events, I then sealed the|Dragon King's body as if it were a Guardian.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Alas, as time marched on, his|strength slowly returned.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0And I was unable to suppress him|with my powers any longer.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Abhidharma|#C0So those were the circumstances which led|to our release from the stone?",-1,2)
	wait(30)

	MSG_EX("#S3#C3Lieselotte|#C0Yes...",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(-0.81,1.0,6.66,  -8.0,45.0,0.0, 6, 30.0)
	move_script_look_at( 0, -1.0,-8, 600, 1)
//	set_script_camera(-0.09,0.60,8.48,  5.0,340.0,0.0, 2, 30.0)
//	move_script_look_at( 0, 0.8,0, 800, 1)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0On just that day, a dying knight|was brought to my side.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0It seemed like the duty had been left to me,|one who had strayed down the path of evil...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Though he was fading away, I felt a radiant|strength from the soul of that wounded knight.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0I thought, the brave hero of the Sacred Sword|may have finally appeared...",-1,2)
	look_chr("PC", "Liese")
	MSG_EX("#S3#C3Lieselotte|#C0And so I decided to entrust this|knight with my one final hope.",-1,2)
	wait(30)

	look_chr("Beatrice", "Liese")
	MSG_EX("#S3#C3Beatrice|#C0We...we had naught a clue until now...",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(-0.00, 0.23,8.53,  -12.0,180.0,0.0, 8, 30.0)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0It was entirely as I intended it.|You have done nothing wrong.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0As long as Galsis was not freed,|then things would have gone on as such...",-1,2)
	wait(30)

	MSG_EX("#S3#C3Fleurette|#C0Liese...",-1,2)
	wait(30)

	MSG_EX("#S3#C3Lieselotte|#C0I have truly caused a great deal|of trouble for everyone.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0However, it isn't over yet...|This entire dilemma has not yet been overcome.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Gandharva|#C0What do you mean by that?",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(-0.00, 0.23,8.53,  -12.0,180.0,0.0, 4, 30.0)
	move_script_look_at( 0, 1.0, 0, 200, 1)
//	set_script_camera(0.14, 0.7,8.23,  -5.0,100.0,0.0, 5, 30.0)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0Because I kept Galsis sealed within me|for so long, we have become...merged.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Right now I am Lieselotte, but at the same|time I am also the Dragon King, Galsis.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Fleurette|#C0No...",-1,2)
	wait(30)

	MSG_EX("#S3#C3Lieselotte|#C0There remains to us but one way|to thwart the Dragon King.",-1,2)

	fade_out(60)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0Brave knight, please drive the Dragonslayer|through my body.",-1,2)
	wait(30)
	MSG_EX("#S3#C3Lieselotte|#C0And, Fleur, you will need to seal|me through the Sacred Sword.",-1,2)
	wait(30)

	set_script_camera(-0.10,0.88,2.85,  -20.0,0.0,0.0, 8, 30.0)
	rotate_script_camera(0,20,0, 1200, 1)
	fade_in(60)
	wait(60)

	MSG_EX("#S3#C3Fleurette|#C0I...I can't...|I won't do that!!",-1,2)
	wait(30)

	MSG_EX("#S3#C3Lieselotte|#C0...In the end, I think I've only|caused you pain.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Please find it in your heart|to forgive your flawed sister.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Fleurette|#C0Why must we...?|Isn't there... Isn't there another way?!",-1,2)
	wait(30)

	MSG_EX("#S3#C3Lieselotte|#C0Unfortunately, we have not the time|to debate this.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Even now Galsis is swiftly recovering from|the wounds he's been given.",-1,2)
	wait(30)

	MSG_EX("#S3#C3Fleurette|#C0But...",-1,2)
	wait(30)

	cross_fade(60)
	set_script_camera(-0.00, 0.75,8.53,  -12.0,180.0,0.0, 4.4, 30.0)
	scale_script_camera(0.9, 500, 0)
	wait(60)

	MSG_EX("#S3#C3Lieselotte|#C0I have lived 500 years for the sake|of this moment.",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0Wise sages, Fleur, I beg you.",-1,2)
	wait(60)

//	cross_fade(60)
	fade_out(60)
	wait(120)

	set_script_camera(-0.38,-0.88,0.83, -20,160,0, 10, 30)
	fade_in(60)
	wait(60)

//　　ドヴォルザークが主人公に歩み寄る。
	INIT_WALK_DST("Dvorak")
	set_walk_dst("Dvorak",  -0.82,-0.88,0.13)
	walk_pos("Dvorak",0,0.02)
	wait_walk("Dvorak")

	MSG_EX("#S3#C3Dvorak|#C0Such cruel words a princess doth utter...|'Tis possible you have become friends.",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0Were it possible to take your stead,|I would gladly accept this burden myself.",-1,2)

//　　手でドヴォルザークを制する主人公。
	LOOK_CHR("PC","Dvorak")
	WAIT(30)
	set_motion("PC", EMPTY24, 0)
	wait(120)

	cross_fade(60)
	set_script_camera(0.01,1.13,8.50,  -35.0,160.0,0.0, 6, 30.0)
	wait(60)

	HIDE_CHR("Liese")
	SHOW_CHR("Liese0")
	MSG_EX("#S3#C3Lieselotte|#C0I'm truly grateful that the Sacred Sword|chose one such as you...",-1,2)
	MSG_EX("#S3#C3Lieselotte|#C0I'm ready, brave knight...",-1,2)

//　　リーゼ、膝を突いて両手を合わせ、祈りを捧げる姿勢に。
	set_motion("Liese0", EMPTY3, -1)
	wait(80)

	MSG_EX("#S3#C3Lieselotte|#C0Raise your sword.",-1,2)
	wait(80)

	fade_out(60)
	wait(120)


