	set_walk_dst("Dvorak",  -0.82,-0.88,0.13)
	walk_pos("Dvorak",0,0.02)
	wait_walk("Dvorak")

	MSG_EX("#S3#C0ドヴォルザーク「貴公にとっても酷な話だ……|　　　　　　　　姫とは懇意にしていたのであろう。」",-1,2)
	MSG_EX("#S3#C0ドヴォルザーク「代われるものならば、|　　　　　　　　私が代わりたいところだが……」",-1,2)

//　　手でドヴォルザークを制する主人公。
	LOOK_CHR("PC","Dvorak")
	WAIT(30)
	set_motion("PC", EMPTY24, 0)
	wait(120)

	cross_fade(60)
	set_script_camera(0.01,1.13,8.50,  -35.0,160.0,0.0, 6, 30.0)
	wait(60)

	HIDE_CHR("Liese")
	SHOW_CHR("Liese0")
	MSG_EX("#S3#C0リーゼロット「聖剣が選んだのが|　　　　　　　あなたで本当によかった……」",-1,2)
	MSG_EX("#S3#C0リーゼロット「それでは騎士殿……」",-1,2)

//　　リーゼ、膝を突いて両手を合わせ、祈りを捧げる姿勢に。
	set_motion("Liese0", EMPTY3, -1)
	wait(80)

	MSG_EX("#S3#C0リーゼロット「お願いします。」",-1,2)
	wait(80)

	fade_out(60)
	wait(120)


SKIP:
	//フラグとか環境とか
	GAME_FLAG_ON(3808)
	KILL_CHR("KAMINARI",0,0,1)
	STOP_ENV_SE("SE_THUNDER", 4000)
	STOP_ENV_SE("SE_WIND2", 4000)
	CAMERA_ON("リーゼ戦")

	BGM(19, 0, -1)

	//PCの処理
	set_pos("PC", 0.0,-0.63,6.75)
	set_deg("PC", 0)
	PC_WEAPON(1, 0)
	PC_FLAG(1, 1)
	PC_FLAG(2, 1)
	PC_FLAG(4, 1)
	PC_FLAG(10, 1)
	FOCUS_CHR("PC")
	LOOK_CHR("PC","-")

	//NPC処理
	HIDE_CHR("Liese")
	SHOW_CHR("Liese0")

	STOP_WALK("PC")
	STOP_WALK("Fleurette")
	STOP_WALK("Avatarlaha")
	STOP_WALK("Tiowalde")
	STOP_WALK("Sturme")
	STOP_WALK("Gandaltua")
	STOP_WALK("Dvorake")
	STOP_WALK("Beatrice")

	SET_POS("Fleurette",1.00,-0.88, 0.0)
	SET_POS("Avatarlaha",2.14,-0.88,-2.25)
	SET_POS("Tiowald",-1.85,-0.88,-2.43)
	SET_POS("Sturme",-3.96,-0.88,-1.12)
	SET_POS("Gandaltua", 1.5, -0.88, 0.3)
	SET_POS("Dvorak", -1,-0.88, 0.68)
	SET_POS("Beatrice", 0.97,-0.88,-3.22)
	SET_POS("Liese0", -0.00,-0.13, 8.42)

	SET_DEG("Fleurette",20)
	SET_DEG("Avatarlaha",0)
	SET_DEG("Tiowald",0)
	SET_DEG("Sturme",0)
	SET_DEG("Gandaltua",210)
	SET_DEG("Dvorak",0)
	SET_DEG("Beatrice",0)
	SET_DEG("Liese0",180)

	set_motion("PC", EMPTY22, 0)
	set_motion("Liese0", EMPTY3, 0)
	set_motion("Fleurette", EMPTY8, 0)
	set_motion("Gandaltua", EMPTY20, 0)
	LOOK_CHR("Gandaltua","PC")
	delete_efc("Liese")

	//カメラ切り替え
	WAIT(50)
	fade_in(60)
	set_script_camera(0,0,0,  -45,180,0, 17, 15)
	MOVE_SCRIPT_LOOK_AT( 0,0,5, 180, 1)
	WAIT(180)

	CROSS_FADE(60)
	PERMIT_SCRIPT_CAMERA(0)
//	CINEMA_OFF(60)
	PC_FLAG(5, 1)
	ret
}















//////////////////////////////////////////////////////////////////////
// 会話リーゼ

DEF("Liese0")

RES("CLICK")
{
	// 会話禁止
	PC_FLAG(3, 1)

	MSG("本当にお世話になりました……|あなたの手で全てを終わらせて下さい。")
	MSG("私に許されることではありませんが……")
	MSG("あなたとは……|もっと普通に出会いたかった……")

	PUT_CHR( 8, "LieseHit",    -0.00,-0.13,8.42, 180)
	hide_chr("LieseHit")
	show_chr("LieseHit")

}






//////////////////////////////////////////////////////////////////////
// リーゼ攻撃用

DEF("LieseHit")
RES("ATTACK")
{
//	CINEMA_ON(60)
	PC_FLAG(5, 0)
	stop_pc(0)
	pc_weapon(1, 1)
	set_motion("PC","EMPTY23",5)
	WAIT(29)

	FADE_OUT_EX(10, 1,"0xffffffff", 0)
	BLUR(10)
	SLOW(5)
	WAIT(10)
	SE("SE_EVENT_50")
	BLUR(0)
	SLOW(0)

	set_skip_label("SKIP")

	wait(260)

//　　フェード抜けて、リーゼロットをしゃがんで抱きかかえている
//　　主人公。リーゼロットの体の上にはドラゴンスレイヤーが添え
//　　られている。フローレットが近くに寄り添っている状態。

	MSG_EX("#S3#C0リーゼロット「ありがとう……騎士殿……」",-1,2)
	WAIT(60)
	MSG_EX("#S3#C0リーゼロット「ふふ……病弱の私が……|　　　　　　　ずいぶん長く生きてしまいましたね……」",-1,2)

	set_pos("PC",          -0.21,-0.13,9.50)
	set_pos("Liese0",       0.00,-0.13,9.50)
	set_pos("Fleurette",    0.60,-0.13,9.50)
	set_pos("Avatarlaha",  -2.12,-0.63,4.61)
	set_pos("Beatrice",    -3.07,-0.13,8.41)
	set_pos("Dvorak",      -2,-0.13,13)
	set_pos("Tiowald",     -0.03,-0.63,4.24)
	set_pos("Sturm",        4,-0.63,7)
	set_pos("Gandaltua",    2.5,-0.13,12)
	set_motion("Gandaltua", STAND, 0)

	set_deg("PC",           90)
	set_deg("Liese0",        180)
	set_deg("Fleurette",   270)
	set_deg("Avatarlaha",  39)
	set_deg("Beatrice",    85)
	set_deg("Dvorak",      170)
	set_deg("Tiowald",     351)
	set_deg("Sturm",       300)
	set_deg("Gandaltua",   221)

	HIDE_CHR("LieseHit")

	// 移動、スキル、会話禁止解除
	PC_FLAG(1, 0)
	PC_FLAG(2, 0)
	PC_FLAG(3, 0)
	SET_PC_EQUIP( 0 ,0)

	SET_MOTION("Liese0","EMPTY4",0)
	SET_MOTION("Fleurette","EMPTY9",0)
	SET_MOTION("PC","EMPTY25",0)
	set_motion("Gandaltua", EMPTY18, 0)
	WAIT(180)

	//遠景カメラ
	permit_script_camera(1)
	set_script_camera(0.00, 0.5,8.53, -70,150,0, 12, 30)
	rotate_script_camera(0,40,0, 2000, 1)

	FADE_IN_EX(120, 1,"0xffffffff", 0)
	wait(180)

//２部
	MSG_EX("#S3#C0フローレット「生まれる時に汝は泣き、|　　　　　　　見守る者たちは喜ぶ……」",-1,2)
	MSG_EX("#S3#C0フローレット「汝が世を去る時、|　　　　　　　見守る者たちは泣くが───」",-1,2)
	MSG_EX("#S3#C0フローレット「汝のみは微笑むべし。」",-1,2)
	MSG_EX("#S3#C0フローレット「……ザナドゥに伝わることわざです。」",-1,2)

	CROSS_FADE(60)
	set_script_camera(0.00, 0.5,8.53, -30,170,0, 4.0, 30)
	rotate_script_camera(5,20,0, 2000, 1)

	MSG_EX("#S3#C0フローレット「姉君……何て安らかな顔……」",-1,2)
	wait(120)

	MSG_EX("#S3#C0ティオバルト「フローレット様、そろそろ……」",-1,2)
	wait(60)

	MSG_EX("#S3#C0フローレット「わかっています。」",-1,2)

	look_chr("Fleurette","PC")
	wait(60)

	MSG_EX("#S3#C0フローレット「騎士殿、そのまま姉君をお願いします。」",-1,2)

//　　フローレット、リーゼロットに祈りを捧げる姿勢。
//　　ドラゴンスレイヤーが反応して輝き出す。

	cross_fade(60)
	set_script_camera(0.00,0.5,8.53, -10,210,0, 4, 30)
	SCALE_SCRIPT_CAMERA( 0.8, 2000, 0)
	wait(120)

	MSG_EX("#S3#C0フローレット「姉君……あなたはいつも|　　　　　　　私の幸せを考えてくれていました。」",-1,2)
	MSG_EX("#S3#C0フローレット「私がそれに報いるのだとしたら、|　　　　　　　答えは一つしかありません。」",-1,2)
	MSG_EX("#S3#C0フローレット「ずっと一緒にいましょう。|　　　　　　　幸せだった、幼いあの日のように……」",-1,2)
	SET_MOTION("Fleurette","EMPTY10",20)
	WAIT(68)
	SE("SE_EVENT_01")
	ATTACH_EFC("EFC_06FENIX1","Fleurette","POS")
	SET_MOTION("Fleurette","EMPTY11", 20)
	WAIT(60)
	SE("SE_EVENT_54")
	ATTACH_EFC("EFC_06FENIX2","Fleurette","POS")
	WAIT(120)

	cross_fade(60)
	set_script_camera(0.00,0.5,8.53, -30,290,0, 20, 30)
	rotate_script_camera(0,30,0, 2000, 1)
	WAIT(30)

	INIT_WALK_DST("Dvorak")
	set_walk_dst("Dvorak",  -1.5,-0.13,12)
	walk_pos("Dvorak",0,0.02)
	WAIT_WALK("Dvorak")
	
	MSG_EX("#S3#C0ドヴォルザーク「フローレット様、一体何を……」",-1,2)
	WAIT(60)
	MSG_EX("#S3#C0フローレット「騎士殿、それから導師たち……」",-1,2)
	WAIT(90)
	MSG_EX("#S3#C0フローレット「さようなら……」",-1,2)



//　　ドラゴンスレイヤーが眩い光を放ち、辺り一面が光に
//　　覆われる。画面、そのままホワイトアウト。

	FADE_OUT_EX(60, 1,"0x99ffffff", 0)
	blur(10)
	SLOW(1)
	wait(60)
	FADE_IN_EX(30, 1,"0x99ffffff", 0)
	wait(30)

	FADE_OUT_EX(30, 1,"0xAAffffff", 0)
	wait(30)
	FADE_IN_EX(30, 1,"0xAAffffff", 0)
	wait(60)
	blur(20)
	SE("SE_EVENT_55")
	FADE_OUT_EX(120, 1,"0xffffffff", 0)
	WAIT(120)

	blur(0)
	SLOW(0)
	STOP_ENV_SE("SE_NAMI2", 4000)
	STOP_ENV_SE("SE_EVENT_54", 4000)
	DELETE_EFC("Fleurette")
	stop_bgm(0, 3000)

	WAIT(120)

	play_movie("system\ins02.dat", 1)

//　　以降は挿入ムービーによるイベント
//　　光はやがて一箇所に集約され、それが次第に不死鳥の
//　　形を作っていく。
//　　不死鳥となったフローレットは力強く羽ばたき、その
//　　まま上空へと飛び立っていく。ムービーはここで終了。
//　　フェードアウト抜けて、再び奇岩城。
//    明るい背景

	FADE_OUT(0)

	set_script_camera(-1.21, 7.13,14.86,  0,150,0, 15, 30)
	MOVE_SCRIPT_LOOK_AT( 0,-5,0, 1400, 1)
	LOAD_MAP("MP_0689")

	HIDE_CHR("Liese0")
	HIDE_CHR("Fleurette")
	set_motion("Gandaltua", STAND, 0)

	set_pos("PC",           0.04,-0.13,15.66)
	set_pos("Avatarlaha",  -1.64,-0.13,13.98)
	set_pos("Beatrice",    -3.45,-0.13,13.62)
	set_pos("Dvorak",       1.77,-0.13,14.65)
	set_pos("Tiowald",      0.12,-0.13,12.91)
	set_pos("Sturm",        0.90,-0.13,11.01)
	set_pos("Gandaltua",   -1.43,-0.13,10.67)

	set_deg("PC",           348)
	set_deg("Avatarlaha",   325)
	set_deg("Beatrice",     347)
	set_deg("Dvorak",       347)
	set_deg("Tiowald",      318)
	set_deg("Sturm",        341)
	set_deg("Gandaltua",    339)

	LOOK_CHR("PC","-")
	LOOK_CHR("Avatarlaha","-")
	LOOK_CHR("Beatrice","-")
	LOOK_CHR("Dvorak","-")
	LOOK_CHR("Tiowald","-")
	LOOK_CHR("Sturm","-")
	LOOK_CHR("Gandaltua","-")

	//SET_PC_EQUIP( 0 ,1)
	PC_WEAPON( 0,1)
	set_motion("PC","STAND",0)
	FOCUS_CHR("PC")

//エピローグへ。（注意：ここからノンストップ再生）

	wait(60)

	FADE_IN(120)
	wait(120)

	MSG_EX("#S3#C0シュトゥルム「何と…………」",120,2)
	wait(30)

	MSG_EX("#S3#C0ベアトリーチェ「あれは……フローレット様……？」",220,2)
	wait(30)

//	MSG_EX("#S3#C0ドヴォルザーク「一体何が起こったというのだ。」",200,2)
//	wait(30)

	MSG_EX("#S3#C0ティオバルト「白い不死鳥……なるほど……」",180,2)
	MSG_EX("#S3#C0ティオバルト「フローレット様はあの姿で永遠に|　　　　　　　ガルシスを封じていくつもりなのじゃ。」",300,2)
	MSG_EX("#S3#C0ティオバルト「不死鳥ともなれば、|　　　　　　　命が尽きることはないからのう。」",260,2)
	wait(40)

//	MSG_EX("#S3#C0ベアトリーチェ「そ、そんな……」",120,2)
//	wait(30)
//
//	MSG_EX("#S3#C0アバターラハ「何と……悲壮な決意でしょう……」",180,2)
//	wait(30)

	CROSS_FADE(60)
	set_script_camera(0,1.1,12, -5,290,0, 8, 30)
	rotate_script_camera(0,15,0, 2100, 1)
	wait(40)

	SET_MOTION("Beatrice","EMPTY2",30)
	MSG_EX("#S3#C0ベアトリーチェ「でも、まさか不死鳥なんて……」",220,2)
	MSG_EX("#S3#C0ベアトリーチェ「いくらフローレット様でも|　　　　　　　　そこまでの力がおありとは……」",320,2)
	wait(40)

	LOOK_CHR("Beatrice","Tiowald")
	set_motion("Tiowald", ATTACK1, -1)
	MSG_EX("#S3#C0ティオバルト「フローレット様だけではない……|　　　　　　　リーゼロット様も一緒じゃよ。」",280,2)
	LOOK_CHR("Sturm","-")
	wait(30)

	set_motion("Gandaltua", ATTACK1, -1)
	MSG_EX("#S3#C0ガンダルチュア「ふむ、双子の巫女だからこそ|　　　　　　　　成せる解決方法ってわけか……」",280,2)
	wait(60)

	MSG_EX("#S3#C0アバターラハ「結局……我々は何の|　　　　　　　役にも立てなかったようですね……」",280,2)
	wait(40)

	CROSS_FADE(60)
	LOOK_CHR("Beatrice","-")
	set_script_camera(1.66,1.3,14.55, -10,35,0, 3, 30)
	SCALE_SCRIPT_CAMERA( 1.2, 1000, 0)

	MSG_EX("#S3#C0ドヴォルザーク「……我々の役目はこれからなのだろう。」",240,2)
	MSG_EX("#S3#C0ドヴォルザーク「何もかも失っても|　　　　　　　　未来だけは残っているものだ。」",280,2)
	wait(40)

	look_chr("Dvorak", "PC")
	wait(40)

	cross_fade(60)
	SET_SCRIPT_CAMERA_EX( "PC",-2, 3,100,0, 3, 15 )
	SCALE_SCRIPT_CAMERA( 0.8, 1200,0)
	MOVE_SCRIPT_LOOK_AT( 0,0.5,2, 1200, 1)
//	この時プレイヤーがあらぬ方向を向いてることがありますが、それはデバッグで飛んだ時です。
//	ガルシスをちゃんと倒してここにくると前を向いてるはずです。


	WAIT(60)
	MSG_EX("#S3#C0ドヴォルザーク「そうだろう、騎士よ。」",340,2)
	WAIT(320)

	FADE_OUT(240)
	WAIT(240)

SKIP:
	STOP_ENV_SE("SE_EVENT_54",500)
	set_skip_label("SKIP2")

//	FADE_OUT_EX(0, 1,"0xffffffff", 0)
	fade_out(0)
	blur(0)
	SLOW(0)
	stop_bgm(0, 4000)
	STOP_ENV_SE("SE_NAMI2", 4000)

	WAIT(240)

	ENTRY_IMG(0,"mono\MONO05_01",0)
	ENTRY_IMG(1,"mono\MONO05_02",0)
	ENTRY_IMG(2,"mono\MONO05_03",0)
	ENTRY_IMG(3,"mono\MONO05_04",0)
	ENTRY_IMG(4,"mono\MONO05_05",0)
	ENTRY_IMG(5,"mono\MONO05_06",0)
	SET_IMG( 0, 000,000, 0,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)

	BGM(2, 0, -1)

	fade_in(100)
	wait(120)

//	SET_MSG_TIME(5,40,90,90)
	SET_MSG_TIME(5,80,90,90)
	MSG_EX("騎士戦争から三年───",240,0x00000094)
	MSG_EX("古き時代は終わりを告げ、|新しい風が吹き始めていました。",380,0x00000094)
	MSG_EX("一人の騎士が選んだ道は、|騎士で在り続けること。",360,0x00000094)
	MSG_EX("この事件の後も、|彼と私は旅を続けました。",360,0x00000094)
	MSG_EX("私たちの訪れる先には|必ず白い不死鳥が現れたそうです。",400,0x00000094)
	MSG_EX("彼が彼女たちを追いかけているのか、|それとも彼女たちが彼を導いているのか……",420,0x00000094)
//	MSG_EX("それは私には分かりません。",260,0x00000094)

	MSG_EX("彼がリーゼさんたちの思い出を|語ることはほとんどありませんでした。",420,0x00000094)
	MSG_EX("ただ、訪れた地で|彼は今日も剣を振るい続けています。",400,0x00000094)
	MSG_EX("新しい時代を見守りながら、|彼の力を必要としている人たちのために。",420,0x00000094)
	MSG_EX("それが彼の見出した|最後の騎士としての在り方……そして……",420,0x00000094)
	MSG_EX("今は亡き騎士たちに捧ぐ|鎮魂歌のつもりかもしれません。",400,0x00000094)
	MSG_EX("不器用な彼にぴったりですね。",260,0x00000094)

	fade_out(60)
	wait(60)
	fade_out(0)

	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)

	// スタッフロール
	CALL_ENDING( 115 )
	fade_out(0)

	// 一枚絵表示
	ENTRY_IMG(0,"mono\MONO06_01",0)
	ENTRY_IMG(1,"mono\MONO06_02",0)
	ENTRY_IMG(2,"mono\MONO06_03",0)
	ENTRY_IMG(3,"mono\MONO06_04",0)
	ENTRY_IMG(4,"mono\MONO06_05",0)
	ENTRY_IMG(5,"mono\MONO06_06",0)
	SET_IMG( 0, 000,000, 0,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)

	wait(60)

	BGM(23, 0, -1)
	fade_in(120)
	wait(120)

	wait(120)
	MSG_EX("明日、また私たちは旅立ちます。",280,0x00000094)
	MSG_EX("リーゼさん、フローレットさん、|空の上からこの世界はどう見えますか？",420,0x00000094)
	MSG_EX("彼はとても頑張っています。|二人でどうか見守ってあげて下さい。",420,0x00000094)
	wait(40)
	SET_MSG_TIME(5,120,90,60)
