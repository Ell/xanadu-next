	SET_MSG_TIME(-1,-1,-1,-1)

	fade_out(120)
SKIP2:
	skip_enable(0)

	stop_bgm(0,3000)
	wait(120)
	BGM(18, 0, -1)
	wait(60)

	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)

	// クリア後のスコア表示
