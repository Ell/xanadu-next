
// ----------------------------------------------------------------------------
// マップ初期化                                                                
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// SE再生
	SE("SE_WIND")

	// スライム
	PUT_MONSTER("m00",004,3,0,0,0)
	PUT_MONSTER("m01",004,3,0,0,1)
	PUT_MONSTER("m02",004,3,0,0,2)

	// カギ設定
	CHECK_GAME_FLAG(1700)
	ON_SKIP(2)
	KAGI("d_1700",1)
	SKIP(1)
	INIT_SWITCH_ON("d_1700")

}


// ----------------------------------------------------------------------------
// カギ開け
// ----------------------------------------------------------------------------

DEF("d_1700")
RES("KAGI")
{
	GAME_FLAG_ON(1700)
}




