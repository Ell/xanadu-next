//////////////////////////////////////////////////////////////////////
// 
// サラマンダー前、アニエスイベント
//
// room_flag
//	0 : アニエス
//	1 : アニエス霊薬繰り返し
//

// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// 水マップ
	SE("SE_MIZU")

	// アニエス
	HIDE_CHR("Aniece")

//鍵チェック
//	CHECK_GAME_FLAG(700)
//	ON_JUMP next
//	LOCK("key",0)
//	JUMP next2
//next:
//	INIT_SWITCH_ON("key")

//next2:

	CHECK_GAME_FLAG(728)
	OFF_SKIP(2)
	INIT_SWITCH_ON("key")
	HIDE_CHR("daiza")

//-- イベント用にモンスターの消去判定 --------------------------------

	// 3601	EV B-2 ガンダルチュア前(アニエスとの会話)
	check_game_flag(3601)
	off_jump NEXT3

	// 3616	EV B-2d 円盤扉をアニエスが開けた
	check_game_flag(3616)
	off_jump NEXT4

NEXT3:
	// スライム
	put_monster("m00",004,3,0,0,0)
	put_monster("m01",004,3,0,0,1)
	// ゴブリンアーチャー
	put_monster("m04",001,3,0,0,2)
	// ゴブリン
	put_monster("m02",000,3,0,0,3)
	put_monster("m03",000,3,0,0,4)
	put_monster("m05",000,3,0,0,5)

NEXT4:
	// カギ設定
	CHECK_GAME_FLAG(728)
	OFF_SKIP(5)
	CHECK_GAME_FLAG(1705)
	ON_SKIP(2)
	KAGI("d1705",1)
	SKIP(1)
	INIT_SWITCH_ON("d1705")

	// 3616	EV B-2d 円盤扉をアニエスが開けた
	check_game_flag(3616)
	off_jump NO_ANIECE

	// 3614	EV B-2b アニエスから骨削りのナイフを購入した
	check_game_flag(3614)
	on_jump NO_ANIECE

	// アニエスシステム
	CHECK_MONSTER(0)
	ON_JUMP NO_ANIECE
	SHOW_CHR("Aniece")
	set_pos("Aniece",-7.40,-0.00,16.80)
	set_deg("Aniece", 21)

	// グラディウス、バックラー、ローブ
	load_npc_eqp(00,10)
	load_npc_eqp(60,11)
	load_npc_eqp(80,12)
NO_ANIECE:

}

// ----------------------------------------------------------------------------
// カギ開け
// ----------------------------------------------------------------------------

DEF("d1705")
RES("KAGI")
{
	GAME_FLAG_ON(1705)
}


