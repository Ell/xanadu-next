
// ----------------------------------------------------------------------------
// マップ初期状態                                                              
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{
	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)

	// ポータル関連
	CHECK_GAME_FLAG(4018)
	ON_SKIP(2)
	LOAD_MAP("MP_075a")
	HIDE_CHR("cover")

	// SE再生
	SE("SE_WIND")

	CHECK_GAME_FLAG(4018)
	OFF_JUMP NEXT
	SWITCH_ON("portal")
	KILL_CHR("cover",0,0,1)

NEXT:

	// カギ設定
	CHECK_GAME_FLAG(1700)
	ON_SKIP(2)
	KAGI("d_1700",1)
	SKIP(1)
	INIT_SWITCH_ON("d_1700")

}

// ----------------------------------------------------------------------------
// カギ開け
// ----------------------------------------------------------------------------

DEF("d_1700")
RES("KAGI")
{
	GAME_FLAG_ON(1700)
}


// ----------------------------------------------------------------------------
// ポータル
// ----------------------------------------------------------------------------
DEF("portal")


//RES("INIT")
//{
