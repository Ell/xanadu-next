
// ----------------------------------------------------------------------------
// マップ初期化                                                                
// ----------------------------------------------------------------------------

DEF("MAP")

RES("INIT")
{

	INIT_SWITCH_ON("stop_n")
	INIT_SWITCH_ON("stop_e")
	INIT_SWITCH_ON("stop_w")

}


// ----------------------------------------------------------------------------
// モンスター出現サブルーチン                                                  
// ----------------------------------------------------------------------------
@MON
{

	CHECK_RNDMAP_FLOOR(0)
	ON_JUMP 0
	CHECK_RNDMAP_FLOOR(1)
	ON_JUMP 1
	CHECK_RNDMAP_FLOOR(2)
	ON_JUMP 2
	CHECK_RNDMAP_FLOOR(3)
	ON_JUMP 3

	0:
	// 第１部
	// イービルアイ
	put_monster("m00",023,15,2,0,0)
	put_monster("m01",023,15,2,0,1)
	put_monster("m02",023,15,2,0,2)
	put_monster("m03",023,15,2,0,3)
	put_monster("m04",023,15,2,0,4)
	put_monster("m05",023,15,2,0,5)
	JUMP PASS

	1:
	// 第２部
	// イービルアイ
	put_monster("m00",023,15,2,0,0)
	put_monster("m01",023,15,2,0,1)
	put_monster("m02",023,15,2,0,2)
	put_monster("m03",023,15,2,0,3)
	put_monster("m04",023,15,2,0,4)
	put_monster("m05",023,15,2,0,5)
	JUMP PASS

	2:
	// 第３部
	// ブラックスライム
	put_monster("m00",177,15,2,0,0)
	put_monster("m01",177,15,2,0,1)
	put_monster("m02",177,15,2,0,2)
	put_monster("m03",177,15,2,0,3)
	put_monster("m04",177,15,2,0,4)
	put_monster("m05",177,15,2,0,5)
	JUMP PASS

	3:
	// 第４部
	// イービルアイ
	put_monster("m00",023,15,2,0,0)
	put_monster("m01",023,15,2,0,1)
		put_monster("m02",392,15,2,0,2)
	put_monster("m03",023,15,2,0,3)
	put_monster("m04",023,15,2,0,4)
	put_monster("m05",023,15,2,0,5)
	JUMP PASS

PASS:
	
	RET
}


// ----------------------------------------------------------------------------
// 勝利イベント                                                                
// ----------------------------------------------------------------------------

RES("WIN")
{
	// 既にストッパーをはずしているなら終了
	CHECK_AREA_FLAG(45)
	OFF_SKIP(1)
	END

	AREA_FLAG_ON(45)
		STOP_PC(0)
		WAIT(60)
		SE("SE_STOPPER")
		CINEMA_ON(0)
		FOCUS_CHR("null")
		SWITCH_ON("stop_n")
		SWITCH_ON("stop_e")
		SWITCH_ON("stop_w")
		WAIT(90)
		CINEMA_OFF(0)
}


// ----------------------------------------------------------------------------
// 中ボスイベントトリガー
// ----------------------------------------------------------------------------

DEF("boss_n")
RES("EVENT")
{
	//入口ならスルー
	CHECK_ENTRY_GATE("0945_N")
	OFF_SKIP(1)
	END

	// 既に倒しているのでは
	CHECK_AREA_FLAG(45)
	OFF_SKIP(1)
	END

	// 二度目に踏んでも何も出ないよ
	CHECK_ROOM_FLAG(1)
	OFF_SKIP(1)
	END

	// イベント開始
	QUAKE(0,10,60)
	SWITCH_OFF("stop_n")

	CINEMA_ON(0)
	STOP_PC(0)

	WAIT(60)
	FOCUS_CHR("null")

	// モンスター出現
	CALL MON

	QUAKE(0,10,60)
	WAIT(120)
	CINEMA_OFF(0)
	ROOM_FLAG_ON(1)
}


