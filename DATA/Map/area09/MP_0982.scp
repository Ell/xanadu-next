
// ----------------------------------------------------------------------------
// 宝箱                                                                        
// ----------------------------------------------------------------------------

DEF("sw")
RES("STEP_ON")
{
	CINEMA_ON(0)
	STOP_PC(0)
	WAIT(50)
	SET_MOTION("sw","DOWN",0)
	SET_MOTION("sw","STAND",10)
	WAIT(25)
	SET_MOTION("sw","HOOK",0)
	SHAKE(3,3)

	WAIT(60)

	// 地図見えフラグ
	AREA_FLAG_ON(100)

	CINEMA_OFF(0)
}

