//////////////////////////////////////////////////////////////////////////////
// 子デス死亡
//////////////////////////////////////////////////////////////////////////////
DEF("1st")
RES("KILL")
{
	delete_efc("1st")
	set_motion("1st","DOWN")
	SE("SE_B5_73600")
	attach_efc("EFC_TRE_BREAK","1st","CTR")
	set_color("1st",0xFF000000,60,1)

	room_flag_on(0)
	check_room_flag(1)
	off_jump skip
	check_room_flag(2)
	off_jump skip

//	call defeat_boss
skip:
}

DEF("2nd")
RES("KILL")
{
	delete_efc("2nd")
	set_motion("2nd","DOWN")
	attach_efc("EFC_TRE_BREAK","2nd","CTR")
	SE("SE_B5_73600")
	set_color("2nd",0xFF000000,60,1)

	room_flag_on(1)
	check_room_flag(0)
	off_jump skip
	check_room_flag(2)
	off_jump skip

//	call defeat_boss
skip:
}
DEF("3rd")
RES("KILL")
{
	delete_efc("3rd")
	set_motion("3rd","DOWN")
	attach_efc("EFC_TRE_BREAK","3rd","CTR")
	SE("SE_B5_73600")
	set_color("3rd",0xFF000000,60,1)

	room_flag_on(2)
	check_room_flag(0)
	off_jump skip
	check_room_flag(1)
	off_jump skip

//	call defeat_boss

skip:
}

