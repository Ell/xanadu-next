//////////////////////////////////////////////////////////////////////////////
// 親デス死亡
//////////////////////////////////////////////////////////////////////////////
RES("KILL")
{
	// 通常アタリマップ読み込み
	LOAD_HITMAP("MP_0998h")

	// ぱぱ死亡…。
	GAME_FLAG_ON(6)
	game_flag_on(3708)
	GAME_FLAG_ON(905)

	BLUR(30)
	STOP_PC(0)
	delete_efc("papa")
	set_target_chr("-")

	set_motion("papa","DOWN")
	SE("SE_B5_74000")
	SE("SE_B3_67000")
	ATTACH_EFC("EFC_FLY_DEAD1","papa","CTR")
	SE("SE_B1_60900")
	SLOW(3)
	WAIT(50)
	SLOW(0)
	set_motion("papa","DEAD")

	KILL_CHR("papa",0,1,180)
	ATTACH_EFC("EFC_FLY_DEAD2","papa","POS")
	KILL_CHR("1st",0,1,180)
	ATTACH_EFC("EFC_FLY_DEAD2","1st","POS")
	KILL_CHR("2nd",0,1,180)
	ATTACH_EFC("EFC_FLY_DEAD2","2nd","POS")
	KILL_CHR("3rd",0,1,180)
	ATTACH_EFC("EFC_FLY_DEAD2","3rd","POS")

	FADE_OUT_EX( 200, 1, 0xffffffff", 0)
	WAIT(200)

	REFRESH("PC")
	// シネスコ時スペクタクルズON
	ROOM_FLAG_OFF(254)

	//初期カメラ
	CINEMA_ON(0)
	PERMIT_SCRIPT_CAMERA(1)
	SET_SCRIPT_CAMERA( 0,0.2,0,  -40,220,0,  9,32 )
	scale_script_camera(1.2, 1000, 1)
	BLUR(0)
	SLOW(0)

	CAMERA_OFF("こども用")
	CAMERA_OFF("ぱぱ用")
	CAMERA_ON("通常用")
	// BGM異界イベント用
	BGM(22, 0, -1)
	SET_SPOT_ORG( 1, 0.00,0.00,0.00 )
	SET_SCROLL_RECT(-1000,-1000,1000,1000)

	//各キャラ配置
	HIDE_CHR("core")
	HIDE_CHR("stop")
	SHOW_CHR("lole2")
	delete_efc("para")
	SET_COLOR("lole2", 0xDD995555, 1, 0)
	SET_POS("lole2",0,0,0)
	SET_POS("PC",0,0,-3)
	SET_DEG("PC",0)
	PC_WEAPON( 0 ,1)
	set_pos("1st",     0.00,0.00, 6.00)
	set_pos("2nd",     5.20,0.00,-3.00)
	set_pos("3rd",     0.20,0.00,-3.00)
	set_pos("papa",    0.20,0.00, 2.00)

	// ドヴォルザークは消してしまう
	HIDE_CHR("Dvorak")

	// ワープゲート配置
	ENTRY_CHR( 2, 459)
	ENTRY_CHR( 3, 460)
	ENTRY_CHR( 4, 461)
	ENTRY_CHR( 5, 462)
	ENTRY_CHR( 6, 479)
	ENTRY_CHR( 7, 480)
	ENTRY_CHR( 8, 481)
	PUT_CHR( 2, "PoleRed",     0.00,0.00, 6.00,   0)
	PUT_CHR( 3, "PoleBlue",    5.20,0.00,-3.00,   0)
	PUT_CHR( 4, "PoleYellow", -5.20,0.00,-3.00,   0)
	PUT_CHR( 5, "Base",        0.00,0.00, 0.00,   0)
	PUT_CHR( 6, "NullBase3",   0.00,0.00, 0.00,   0)
	PUT_CHR( 7, "NullBase2",   0.00,0.50, 0.00,   0)
	PUT_CHR( 8, "NullBase1",   0.00,1.00, 0.00,   0)

	WAIT(120)
	FADE_IN_EX(30, 1, 0xffffffff", 0)

//スキップ
	set_skip_label("SKIP_BOSS")

	//ボス戦終了後、イベント開始。人間の姿に戻ったローレライ
	WAIT(120)
	MSG_EX("#S3#C3Lorelei|#C0Impossible... A person like you has...?",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0I want you...to listen well...knight...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0Master Galsis'...revival...is not far off...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0I sense it strongly...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0Master Galsis'...heart beats stronger|with each passing day...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0Knight... When that time comes...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0Hmmhmmhmmhmmhmm...",-1,2)
	WAIT(60)

	//ローレライ殺す。
	KILL_CHR("lole2",0,1,240)
	ATTACH_EFC("EFC_FLY_DEAD2","lole2","POS")
	wait(30)
	SE("SE_EVENT_25")


//-- ワープゲート出現 ------------------------------------------------
	CROSS_FADE(30)
	PERMIT_SCRIPT_CAMERA(1)
	SET_SCRIPT_CAMERA( 0,0,0,  -20,180,0,16,32 )
	scale_script_camera(1.3, 1000, 1)
	QUAKE(1,1,670)
	PC_WEAPON(0)

	// ★３本の柱 //////////////////////////
	// せりあがりアニメ…
	set_motion("PoleRed",	"EMPTY1")
	wait(20)
	set_motion("PoleBlue",	"EMPTY1")
	wait(20)
	set_motion("PoleYellow","EMPTY1")
	wait(60)
	SE("SE_EVENT_26")
	wait(60)

	wait(20)
//	SE("SE_EVENT_26")
	wait(20)
//	SE("SE_EVENT_26")
	wait(70)

	// 以降はループアニメを繰り返す
	set_motion("PoleRed",	"EMPTY2")
	wait(10)
	set_motion("PoleBlue",	"EMPTY2")
	wait(10)
	set_motion("PoleYellow","EMPTY2")
	wait(10)

	// ★台座 ///////////////////////////////
	// せりあがりアニメ…
	set_motion("Base","EMPTY1")
	wait(120)
	SE("SE_EVENT_27")
	wait(80)
//	SE("SE_EVENT_27")
	wait(80)
//	SE("SE_EVENT_27")
	wait(20)
	SE("SE_EVENT_28")
	wait(69)
	// 以降はループアニメを繰り返す
	set_motion("Base","EMPTY2")
	wait(300)


//-- 後処理 ------------------------------------------------
	FOCUS_CHR("PC")
	PERMIT_SCRIPT_CAMERA(0)
	CROSS_FADE(60)
	SET_SPOT_ORG( 0, 0,0,0 )
	CINEMA_OFF(0)

	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)
	INIT_SWITCH_ON("beatlorelei")

	ret


SKIP_BOSS:
	HIDE_CHR("lole2")
	HIDE_CHR("1st")
	HIDE_CHR("2nd")
	HIDE_CHR("3rd")
	HIDE_CHR("papa")
	delete_efc("lole2")
	delete_efc("para")
	delete_efc("1st")
	delete_efc("2nd")
	delete_efc("3rd")
	QUAKE(0,0,1)
	SET_SPOT_ORG( 0, 0.00,0.00,0.00 )

	// BGM異界イベント用
	BGM(22, 0, -1)
	set_motion("PoleRed",	"EMPTY2")
	set_motion("PoleBlue",	"EMPTY2")
	set_motion("PoleYellow","EMPTY2")
	set_motion("Base","EMPTY2")
	BLUR(0)
	SLOW(0)
	STOP_SE(0)

	FOCUS_CHR("PC")
	PERMIT_SCRIPT_CAMERA(0)
	CINEMA_OFF(0)
	fade_in(60)

	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)
	INIT_SWITCH_ON("beatlorelei")

	ret

}

