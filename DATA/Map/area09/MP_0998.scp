//////////////////////////////////////////////////////////////////////
// ローレライボス戦
//
// ROOM_FLAG
//  0: 1st 死亡チェック用
//  1: 2nd 死亡チェック用
//  2: 3rd 死亡チェック用
//  3: イベントトリガー対策
//  4: ボス名のIMG登録したか
//
//////////////////////////////////////////////////////////////////////////////
// 初期化
//////////////////////////////////////////////////////////////////////////////

DEF("MAP")
RES("INIT")
{
	// BGM異界イベント用
	BGM(22, 0, -1)

	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)

	// ポータル関連
	CHECK_GAME_FLAG(4016)
	ON_SKIP(2)
	LOAD_MAP("MP_099a")
	HIDE_CHR("cover")


	SET_COLOR("k03",0x00000000,1,0)
	SET_COLOR("k04",0x00000000,1,0)
	SET_COLOR("k05",0x00000000,1,0)
	SET_COLOR("k06",0x00000000,1,0)
	SET_COLOR("k07",0x00000000,1,0)
	SET_COLOR("k08",0x00000000,1,0)
	SET_COLOR("k09",0x00000000,1,0)
	SET_COLOR("k10",0x00000000,1,0)
	SET_COLOR("k11",0x00000000,1,0)
	SET_COLOR("k12",0x00000000,1,0)
	SET_COLOR("k13",0x00000000,1,0)
	SET_COLOR("k14",0x00000000,1,0)
	SET_COLOR("k15",0x00000000,1,0)
	SET_COLOR("k16",0x00000000,1,0)
	SET_COLOR("k17",0x00000000,1,0)
	SET_COLOR("k18",0x00000000,1,0)
	SET_COLOR("k19",0x00000000,1,0)
	SET_COLOR("k20",0x00000000,1,0)
	SET_COLOR("k21",0x00000000,1,0)
	SET_COLOR("k22",0x00000000,1,0)
	SET_COLOR("k23",0x00000000,1,0)

	// ★05/05/18:ブラックオニキス禁止フラグON
	room_flag_on(255)
	//とりあえず隠す
	HIDE_CHR("lole2")
	BLUR(0)
	SLOW(0)

// 05/04/26追記：ランダムマップから来た時のフェードを戻す処理 ----------------
	CHECK_GAME_FLAG(920)
	OFF_JUMP SKIP_FADE

	CHECK_GAME_FLAG(3000)
	OFF_JUMP SKIP_FADE
	CINEMA_ON(0)
	FADE_IN(-1)
	CINEMA_OFF(0)
	// フラグ戻して
	GAME_FLAG_OFF(3000)

SKIP_FADE:
// ---------------------------------------------------------------------------

	// EV C-9 《魅》のローレライを見たか（＝倒したか）
	check_game_flag(3708)
	off_jump NEXT3

	// ワープゲート出現
	ENTRY_CHR( 2, 459)
	ENTRY_CHR( 3, 460)
	ENTRY_CHR( 4, 461)
	ENTRY_CHR( 5, 462)
	ENTRY_CHR( 6, 479)
	ENTRY_CHR( 7, 480)
	ENTRY_CHR( 8, 481)

	PUT_CHR( 2, "PoleRed",     0.00,0.00, 6.00,   0)
	PUT_CHR( 3, "PoleBlue",    5.20,0.00,-3.00,   0)
	PUT_CHR( 4, "PoleYellow", -5.20,0.00,-3.00,   0)
	PUT_CHR( 5, "Base",        0.00,0.00, 0.00,   0)
	PUT_CHR( 6, "NullBase3",   0.00,0.00, 0.00,   0)
	PUT_CHR( 7, "NullBase2",   0.00,0.50, 0.00,   0)
	PUT_CHR( 8, "NullBase1",   0.00,1.00, 0.00,   0)

	set_motion("PoleRed",	"EMPTY2")
	set_motion("PoleBlue",	"EMPTY2")
	set_motion("PoleYellow","EMPTY2")
	set_motion("Base","EMPTY2")

	jump NEXT2

NEXT3:
	// 40 「武」の賢者ドヴォルザーク
	ENTRY_CHR( 0, 498)
	PUT_CHR( 0, "Dvorak",  -2.77,-11.61,-33.9, 180)
	ENABLE_AUTO_TURN("Dvorak", 0)
	ENTRY_CHR( 9, 234)
	PUT_CHR( 9, "Dvonull",  -2.77,-11.61,-35.15, 180)
	ENABLE_EV_POP( "Dvonull", 0)

	// 124 「魅」の賢者ローレライ
	ENTRY_CHR( 1, 124)
	PUT_CHR( 1, "Lorele",  0.00,0.00,0.00,   0)

NEXT2:

	CHECK_GAME_FLAG(6)
	ON_SKIP(1)
	INIT_SWITCH_ON("efc")

	CHECK_GAME_FLAG(4016)
	OFF_JUMP START
	SWITCH_ON("portal")
	KILL_CHR("cover",0,0,1)

START:
	// うにゃーん空間
//	set_raster_info( 0, 10,10, 0.001,0.001, 1,0, -1,-1, 0.5)
	set_raster_info( 0, 200,200, 0.010,0.010, 1,1, -1,-1, 0.5)
	raster(0,1)	
	SET_CHR_SURFACE_ATTR("papa","M_0083e",0)

	// とりあえず隠す
	HIDE_CHR("1st")
	HIDE_CHR("2nd")
	HIDE_CHR("3rd")
	HIDE_CHR("core")
	HIDE_CHR("papa")
	HIDE_CHR("box")
	camera_off("こども用")
	CAMERA_Off("ぱぱ用")
	HIDE_CHR("stop")	

	// ぱぱ用コリジョンモデルのアタッチ
	load_chr("M_0083\M_0083h",0)
	//set_collision_obj("papa",0)

	CHECK_GAME_FLAG(905)
	OFF_JUMP NEXT
	CHECK_GAME_FLAG(906)
	ON_JUMP NEXT
	SHOW_CHR("box")
	
NEXT:
}

//////////////////////////////////////////////////////////////////////////////
// 部屋投入後デモ
//////////////////////////////////////////////////////////////////////////////
DEF("demoboss")
RES("INIT")
{
//見たかチェック
	CHECK_GAME_FLAG(920)
	ON_JUMP NEXT

	// シネスコ時スペクタクルズON
	ROOM_FLAG_OFF(254)

	CINEMA_ON(0)
	STOP_PC(0)
	HIDE_CHR("Lorele")
	SET_POS("PC",0,-11.6,-57.5)
	SET_DEG("PC",0)
	PC_WEAPON(1,1)
	FOCUS_CHR("PC")
	SET_MOTION("PC","DEAD",0)

	PERMIT_SCRIPT_CAMERA(1)
	SET_SCRIPT_CAMERA(0,-8,-57.5,-80,120, 0,20,12)
	ROTATE_SCRIPT_CAMERA(0,20,0, 300, 0)
	FADE_IN(120)

//スキップ
	set_skip_label("SKIP")

	WAIT(240)
	CROSS_FADE(60)
	SET_SCRIPT_CAMERA(0,-10,-56,-15,180, 0,10,12)
	ROTATE_SCRIPT_CAMERA(10,0,0, 240, 0)
	SET_MOTION("PC","WAKE",0)
	WAIT(200)
	CROSS_FADE(30)
	SET_SCRIPT_CAMERA(0,-1,-20, 0,180, 0, 8,12)
	ROTATE_SCRIPT_CAMERA(10,0,0, 300, 0)
	SCALE_SCRIPT_CAMERA(0.7, 300,1)
	WAIT(180)
	set_color("demoboss",0x00000000,120,1)
	WAIT(60)
	GAME_FLAG_ON(920)

	//後処理
	FADE_OUT(60)
	WAIT(60)
	FOCUS_CHR("PC")
	PERMIT_SCRIPT_CAMERA(0)	
	HIDE_CHR("demoboss")
	SHOW_CHR("Lorele")

	WAIT(60)
	CINEMA_OFF(0)
	FADE_IN(60)
	GAME_FLAG_OFF(3000)

	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)
	END

SKIP:
	//後処理
	GAME_FLAG_ON(920)
	FOCUS_CHR("PC")
	PERMIT_SCRIPT_CAMERA(0)	
	SET_MOTION("PC","STAND",0)
	HIDE_CHR("demoboss")
	delete_efc("demoboss")
	SHOW_CHR("Lorele")

	WAIT(60)
	CINEMA_OFF(0)
	FADE_IN(60)
	GAME_FLAG_OFF(3000)

	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)
	END

NEXT:
	HIDE_CHR("demoboss")
	delete_efc("demoboss")

}

//////////////////////////////////////////////////////////////////////////////
// パパデス登場
//////////////////////////////////////////////////////////////////////////////
DEF("start")
RES("EVENT")
{

//-- ローレライイベント ----------------------------------------------

	check_room_flag(3)
	on_jump NEXT
	room_flag_on(3)

	// EV C-9 《魅》のローレライ
	check_game_flag(3708)
	on_jump NEXT

	// シネスコ時スペクタクルズON
	ROOM_FLAG_OFF(254)

	// ボス戦用アタリマップ読み込み
	LOAD_HITMAP("MP_0998bh")

	CINEMA_ON(0)
	STOP_PC(0)
	cross_fade(100)
	SET_POS("PC",0,0,-6)
	SET_DEG("PC",0)
	SET_SPOT_ORG( 1, 0.00,0.00,0.00 )
	permit_script_camera(1)
	set_script_camera(0,1.5,0,  3,190,0, 7, 15.0)
	ROTATE_SCRIPT_CAMERA( 0,-15,0, 500, 0)
	scale_script_camera(0.9,500, 0)

//スキップ
	set_skip_label("SKIP")


//　　ボスマップに入るとイベント開始。ローレライ長台詞
	wait(100)
	MSG_EX("#S3#C3Lorelei|#C0...Just who might YOU be?",-1,2)
	WAIT_CAMERA(0)

	cross_fade(10)
	set_script_camera(0,1.5,0,  -15,170,0, 4, 15.0)
	ROTATE_SCRIPT_CAMERA( -5,-5,0, 800, 1)
	set_deg("Lorele", 180)
	WAIT(60)
	MSG_EX("#S3#C3Lorelei|#C0My name is Lorelei.",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0I stand by Dragon King Galsis' side|much like the Black Bride...",-1,2)
	WAIT(60)

	CROSS_FADE(30)
	set_script_camera(0,0,0,  -30,-40,0, 30, 15)
	ROTATE_SCRIPT_CAMERA( 5,80,0, 2000, 1)
	WAIT(100)
	MSG_EX("#S3#C3Lorelei|#C0For a chick to be born it must|burst through the egg's shell...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0To create such an event,|the whole world must be thrown into ruin.",-1,2)
	WAIT(60)
	MSG_EX("#S3#C3Lorelei|#C0'Twas known as a paradise,|that prosperous land from which Xanadu rose...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0And yet, the reality was, the greedy people were|drowning themselves in pleasure and indolence.",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0For men who have forsaken the moral path,|destruction at Master Galsis' hands is truly necessary...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0And with the destruction of such baseness,|a new world will rise.",-1,2)
	WAIT(120)

	cross_fade(30)
	SET_SPOT_ORG( 1, -4.58,-4,-34.56 )
	set_script_camera(-2.77,-11,-33.9,  -20,210,0, 10, 15.0)
	ROTATE_SCRIPT_CAMERA( 0,-20,0, 1000, 1)
	WAIT(100)
	MSG_EX("#S3#C3Lorelei|#C0Knight, have you come to stop me,|much like those ignorant, 'militant' sages?",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0Show me what lies in your heart...",-1,2)
	wait(60)

	cross_fade(30)
	SET_SPOT_ORG( 1, 0.00,0.00,0.00 )
	set_script_camera(0,1.5,-5,  -20,90,0, 4, 15)
	MOVE_SCRIPT_LOOK_AT( 0,0,-1, 1000, 0)
	MSG_EX("#S3#C3Lorelei|#C0I see a man, once content with his own weakness,|now spurred on by the fear of his approaching death...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0'Tis quite foolhardy to believe|one so cowardly could challenge me...",-1,2)
	wait(50)

	cross_fade(30)
	set_script_camera(0,1.5,0,  -15,20,0, 6, 15)
	scale_script_camera(1.3, 1000, 1)
	SET_MOTION("Lorele","ATTACK1",10)
	MSG_EX("#S3#C3Lorelei|#C0Judgment is at hand, knight.",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0Behold this blessing from Master Galsis.|Bow before this wondrous power!",-1,2)

//　　ローレライ、醜い死神の姿へと変化する。

	bgm(15,0,-1)

	ROTATE_SCRIPT_CAMERA(5,0,0,180, 0)
	QUAKE(0,3,260)
	BLUR(30)
	SLOW(1)	
	FADE_IN_EX(20, 0, "0xffffffff", 0)
	ATTACH_EFC("EFC_FLY_INAZUMA","Lorele","POS")
	SE("SE_B1_61000")
	move_vec("Lorele", 0,-4,0, 180)
	SE("SE_B5_72000")
	wait(180)
	HIDE_CHR("Lorele")

	//パパ出し	
	SET_SCRIPT_CAMERA(0,1.5,0, -5,180,0, 12,12)
	ROTATE_SCRIPT_CAMERA(5,0,0,260, 0)
	QUAKE(0,3,260)
	BLUR(30)
	SLOW(1)	
	FADE_IN_EX(20, 0, "0xffffffff", 0)

	ATTACH_EFC("EFC_FLY_INAZUMA","papa","POS")
	SHOW_CHR("papa")
	SET_MOTION("papa","EMPTY1",0)
	SE("SE_B5_72100")
	WAIT(220)

	//顔アップ
	CROSS_FADE(30)
	SET_SCRIPT_CAMERA_EX("papa",2, -20,120,0, 6, 14)
	SCALE_SCRIPT_CAMERA(1.2, 180,1)

	SE("SE_B3_66004")
	CALL NAME
	wait(30)
	SE("SE_B5_72200")
	wait(120)
	CALL NAME_ERASE
	wait(40)

	//カメラセットオン
	BLUR(0)
	SLOW(0)
	FOCUS_CHR("PC")
	CROSS_FADE(60)
	PERMIT_SCRIPT_CAMERA(0)
	SET_SPOT_ORG( 0, 0.00,0.00,0.00 )
	SET_SCROLL_RECT(-5,-4.5,5,7.5)
	SHOW_CHR("stop")
	set_target_chr("papa")

	// シネマＯＦＦ
	CINEMA_OFF(0)

	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)

	END


SKIP:

	//カメラセットオン
	CALL NAME_ERASE2

	BLUR(0)
	SLOW(0)
	STOP_SE(0)

	CROSS_FADE(60)
	FOCUS_CHR("PC")
	PERMIT_SCRIPT_CAMERA(0)
	bgm(15,0,-1)
	SET_SPOT_ORG( 0, 0.00,0.00,0.00 )
	SET_POS("Lorele",0,0,0)
	set_deg("Lorele",180)
	HIDE_CHR("Lorele")
	delete_efc("Lorele")
	SHOW_CHR("papa")
	delete_efc("papa")
	SET_SCROLL_RECT(-5,-4.5,5,7.5)
	SHOW_CHR("stop")
	set_target_chr("papa")
	QUAKE(0,0,1)

	// シネマＯＦＦ
	CINEMA_OFF(0)
	fade_in(60)

	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)

	END
NEXT:
	END
}

// マップ名--------------------------------------------------------------
@NAME
{
	ENTRY_IMG(0,"BOSS05",0)

	// αが'1'の時は'加算モード'なので「透明」にする時は、
	// ディフューズを'0x00ffffff'ではなく'0xff000000'としないといけないのデス。
	//  ｽﾌﾟﾗｲﾄ 表示位置 Tex TX  TY  TW  TH α ディフューズ スペキュラ 拡大 回 中 Fit
	SET_IMG( 0, 192,346, 0,  0,  0,255, 64, 1, 0xff000000, 0xff000000, 1,1, 0, 1,1)
//	SET_IMG( 2, 192,346, 0,  0,144,255, 48, 1, 0xff000000, 0xff000000, 1.5,1.5, 0, 1,1)
	IMG_ON(0)
//	IMG_ON(2)

	//  4: ボス名のIMG登録したか
	room_flag_on(4)

	// 発生までに'間'が欲しい場合はこんな風にします。
	SUSPEND_IMG(0,45)
//	SUSPEND_IMG(2,30)

	// フェードイン
	COLOR_IMG    (0, 0xffffffff, 0xff000000, 30, 1)
//	SCALE_IMG    (2, 1, 1                    30, 1)
//	COLOR_IMG_EX (2, 0xffdfffaf, 0xff000000, 30, 1, 0, 1, 1)
	RET
}

// マップ名消すぞ--------------------------------------------------------------
@NAME_ERASE
{
	COLOR_IMG(0, 0xff000000, 0xff000000, 45, 1)
	RET
}

// マップ名消すぞ--------------------------------------------------------------
@NAME_ERASE2
{
	//  4: ボス名のIMG登録したか
	check_room_flag(4)
	off_jump EXIT

	COLOR_IMG(0, 0xff000000, 0xff000000, 1, 1)
//	COLOR_IMG(2, 0xff000000, 0xff000000, 1, 1)

EXIT:
	RET
}

