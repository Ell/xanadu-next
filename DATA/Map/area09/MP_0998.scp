	PERMIT_SCRIPT_CAMERA(0)
	CINEMA_OFF(0)

	GAME_FLAG_ON(6)
}
*/


//////////////////////////////////////////////////////////////////////
// テレポーターに乗った
//////////////////////////////////////////////////////////////////////
DEF("NullBase1")
RES("STEP_ON")
{
	stop_pc(0)
	CINEMA_ON(0)

	INIT_WALK_DST("PC")
	SET_WALK_DST("PC",0,1,0)
	WALK_POS("PC",0,0.026)
	WAIT_WALK("PC")
	FOCUS_CHR("PC")

	WAIT(90)
	ATTACH_EFC("EFC_WARP_T","NullBase1","POS")
	SHAKE(5,5)
	WARP_CHR("PC", 0)
	wait(120)

	stop_bgm(0,2000)
	fade_out(60)
	wait(120)

	// 3718	EV C-9b 城へのワープを抜けた
	check_game_flag(3718)
	on_jump NEXT

	set_skip_label("SKIP")

	//-----------------------------
	ENTRY_IMG(0,"mono\MONO05_01",0)
	ENTRY_IMG(1,"mono\MONO05_02",0)
	ENTRY_IMG(2,"mono\MONO05_03",0)
	ENTRY_IMG(3,"mono\MONO05_04",0)
	ENTRY_IMG(4,"mono\MONO05_05",0)
	ENTRY_IMG(5,"mono\MONO05_06",0)
	SET_IMG( 0, 000,000, 0,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 1, 256,000, 1,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 2, 512,000, 2,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 3, 000,256, 3,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 4, 256,256, 4,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	SET_IMG( 5, 512,256, 5,  0,  0,256,256, 0, 0xffffffff, 0xff000000, 1,1, 0, 1,1)
	IMG_ON(0)
	IMG_ON(1)
	IMG_ON(2)
	IMG_ON(3)
	IMG_ON(4)
	IMG_ON(5)
	FADE_IN(60)
	WAIT(60)
	//-----------------------------

	SET_MSG_TIME(5,40,90,90)
	MSG_EX("...'Cowardice is not a woeful trait.'|That was their favorite phrase.",-1,0x00000094)
	MSG_EX("One's own fear may betray you,|but the most important thing is to not run away.",-1,0x00000094)
	MSG_EX("By admitting one's own weakness,|therein lies true strength.",-1,0x00000094)
	MSG_EX("Still, after they had said such things,|the veracity of those words held a much|stronger impact than could be imagined.",-1,0x00000094)
	MSG_EX("In such that way, they were|quite the same as I.",-1,0x00000094)

	SET_MSG_TIME(-1,-1,-1,-1)

	//-----------------------------
	FADE_OUT(60)
	WAIT(60)
	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)
	//-----------------------------

SKIP:
	//-----------------------------
	IMG_OFF(0)
	IMG_OFF(1)
	IMG_OFF(2)
	IMG_OFF(3)
	IMG_OFF(4)
	IMG_OFF(5)
	//-----------------------------

	// 3718	EV C-9b 城へのワープを抜けた
	game_flag_on(3718)

NEXT:
	ENTRY_MAP("0682_0998")
}

RES("INIT")
{
	CHECK_ENTRY_GATE("0998_0682")
	OFF_JUMP EXIT

	stop_pc(0)
	set_pos("PC", -0.00,1.00, 0.00)
	set_deg("PC", 180)
	WARP_CHR("PC", 1)
	wait(120)

	look_chr("PC", "-")
	INIT_WALK_DST("PC")
	set_walk_dst("PC", 0.0, 0.0, -3.0)
	walk_pos("PC",0,0.03)
	wait_walk("PC")

	FOCUS_CHR("PC")

EXIT:
	END
}


//////////////////////////////////////////////////////////////////////////////
// ポータル
//////////////////////////////////////////////////////////////////////////////
DEF("portal")

RES("EVENT")
{
	// ★05/06/20:Ｆクリスタルは最初の一回だけでいい事になりました（ひ）

	// 既にあけているか？
	CHECK_GAME_FLAG(4016)
	ON_JUMP NEXT

	// ファイアクリスタルを持っているか？
	CHECK_ITEM(177,1)
	OFF_JUMP NEXT2

	// 出現イベント
	INIT_WALK_DST("PC")

	STOP_PC(0)
	CINEMA_ON(0)
	SET_WALK_DST("PC",0,-11.5,-45.625)
	WALK_POS("PC",0,0.026)
	WAIT_WALK("PC")
	INIT_WALK_DST("PC")
	WAIT(30)
	
	CROSS_FADE(60)
	PERMIT_SCRIPT_CAMERA(1)
	SET_SCRIPT_CAMERA_EX( "portal", -2, -45,-15,0, 12, 32)
	ROTATE_SCRIPT_CAMERA( 0,30,0,999, 0)
	WAIT(60)
SE("SE_WARP1")
	KILL_CHR("cover",0,1,120)
	LOAD_MAP("MP_0998")
	SHOW_CHR("cover")
	SWITCH_ON("portal")
	WAIT(120)
	WAIT(120)

	GAME_FLAG_ON(4016)
	
	CROSS_FADE(30)
	PERMIT_SCRIPT_CAMERA(0)
	WAIT(60)
	CALL_PORTAL(0)
	CINEMA_OFF(0)
	END

NEXT:

	// ポータル
	INIT_WALK_DST("PC")
	STOP_PC(0)
	CINEMA_ON(0)
	SET_WALK_DST("PC",0,-11.5,-45.625)
	WALK_POS("PC",0,0.026)
	WAIT_WALK("PC")
	INIT_WALK_DST("PC")
	WAIT(30)
	CALL_PORTAL(0)
	CINEMA_OFF(0)

NEXT2:

}


//////////////////////////////////////////////////////////////////////////////
// セーブ
//////////////////////////////////////////////////////////////////////////////

DEF("save")
RES("CLICK")
{
	CINEMA_ON(0)
	STOP_PC(0)

	refresh("PC")
	se("SE_HEAL")

	SEL("Record your deeds?|#c2Save|Cancel")
	CHECK_SELECT(0)
	OFF_JUMP SEL_A

		CALL_SHOP(4)
		SE("SE_UP_PRM")

SEL_A:
	CHECK_SELECT(1)

	CINEMA_OFF(0)
}


//////////////////////////////////////////////////////////////////////////////
// ドヴォルザーク
//////////////////////////////////////////////////////////////////////////////
DEF("Dvorak")

RES("CLICK")
{
	// EV C-8 ドヴォルザークの敗北
	check_game_flag(3707)
	on_jump TALK1_2

	// シネスコ時スペクタクルズON
	ROOM_FLAG_OFF(254)

	call DVORAK_LOSE

	jump EXIT

TALK1_2:
	FOCUS_CHR("Dvorak")
	SET_NAME("Dvorak", "Dvorak")

	SYS("#C2Dvorak is unconscious.")

EXIT:
	END
}

//--------------------------------------------------------------------

@DVORAK_LOSE
{
	CINEMA_ON(0)
	set_pos("PC", -0.62,-11.61,-35)
	SET_DEG("PC",290)

	cross_fade(120)
	permit_script_camera(1)
	set_script_camera(-1.04,-11.74,-35.76,  -25.5,200.0,0.0, 12, 15.0)

	rotate_script_camera(0,-20,0, 2000, 1)

	set_skip_label("SKIP")		

	wait(120)

	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C3Dvorak|#C0So...*cough*...|So you have come.",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0Ahead waits Lorelei...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0We imprisoned her because|she committed a sin most grave,|she who once stood beside us...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0...The weak cannot live...eh...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0What have I...really...|All this time...I never once needed help, yet...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0*cough* No apology will absolve my failure.",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0Lady Fleurette...",-1,2)

	SYS("Dvorak has lost consciousness.")
	fade_out(120)
	wait(120)

SKIP:

	FOCUS_CHR("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)
	fade_in(60)
	wait(60)
	game_flag_on(3707)

	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)

	jump EXIT

EXIT:
	END
}


// ドヴォルザークイベント

DEF("EV_Dvorak")
RES("EVENT")
{
	// EV C-8 ドヴォルザークの敗北
	check_game_flag(3707)
	on_jump EXIT

	// シネスコ時スペクタクルズON
	ROOM_FLAG_OFF(254)

	stop_pc(0)
	call DVORAK_LOSE

EXIT:
	END
}

