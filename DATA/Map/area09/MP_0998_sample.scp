// ============================================================================
// 城へ
// ============================================================================

DEF("0998_0602")
RES("EVENT")
{
	CHECK_GAME_FLAG(6)
	OFF_SKIP(3)
	STOP_PC(0)
	SYS("#C2Skipping to the temporary castle event.")
	ENTRY_MAP("0602_0998")
}


// ============================================================================
// ポータル
// ============================================================================
DEF("portal")

RES("EVENT")
{
	// ファイアクリスタルを持っているか？
	CHECK_ITEM(177,1)
	OFF_JUMP NEXT2

	// 既にあけているか？
	CHECK_GAME_FLAG(4016)
	ON_JUMP NEXT

	// 出現イベント
	STOP_PC(0)
	CINEMA_ON(0)
	WAIT(60)
	
	CROSS_FADE(30)
	PERMIT_SCRIPT_CAMERA(1)
	SET_SCRIPT_CAMERA_EX( "portal", -2, -45,-15,0, 12, 32)
	ROTATE_SCRIPT_CAMERA( 0,30,0,999, 0)
	WAIT(60)
	SWITCH_ON("portal")
	WAIT(120)

	GAME_FLAG_ON(4016)
	
	CROSS_FADE(30)
	PERMIT_SCRIPT_CAMERA(0)
	WAIT(60)
	CALL_PORTAL(0)
	CINEMA_OFF(0)
	END

NEXT:

	// ポータル
	STOP_PC(0)
	CINEMA_ON(0)
	CALL_PORTAL(0)
	CINEMA_OFF(0)

NEXT2:

}


// ----------------------------------------------------------------------------
// セーブ
// ----------------------------------------------------------------------------

DEF("save")
RES("CLICK")
{
	CINEMA_ON(0)
	STOP_PC(0)

	SEL("Record your deeds?|#c2Save|Cancel")
	CHECK_SELECT(0)
	OFF_JUMP SEL_A

		CALL_SHOP(4)
		SE("SE_UP_PRM")
		SYS("#c2Your adventure until now has been recorded.")

SEL_A:
	CHECK_SELECT(1)

	CINEMA_OFF(0)
}


//////////////////////////////////////////////////////////////////////
// ドヴォルザーク

DEF("Dvorak")

RES("CLICK")
{
	// EV C-8 ドヴォルザークの敗北
	check_game_flag(3707)
	on_jump TALK1_2

	CINEMA_ON(0)

	set_pos("PC", -0.62,-11.61,-35.53)
	set_deg("PC", 290)

	cross_fade(120)
	permit_script_camera(1)
	set_script_camera(-1.04,-11.74,-35.76,  -25.5,200.0,0.0, 12, 15.0)

	rotate_script_camera(0,-20,0, 300, 1)

	wait(120)

	MSG_EX("#S3#C3Dvorak|#C0The lord has...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0*cough* What a disgraceful state to be seen in...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0Ahead waits Lorelei...imprisoned because|she committed a sin most grave, she who|once stood beside us...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0Knight, take this...",-1,2)

	SYS("#C2Acquired [Crown of Rebick]!")

	MSG_EX("#S3#C3Dvorak|#C0This is...|You must not let it fall into his hands...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0I will not chide you...|'Tis wisest to retreat...immediately...",-1,2)
	MSG_EX("#S3#C3Dvorak|#C0Guh... Please forgive me...Lady Fleurette...",-1,2)

	fade_out(120)
	wait(120)

	SYS("#C2Dvorak has lost consciousness.")

	permit_script_camera(0)
	CINEMA_OFF(0)

	fade_in(60)
	wait(60)
	game_flag_on(3707)

	jump EXIT

//　　⇒操作フリー
//　　　話しかけると以下の繰り返し用メッセージ

TALK1_2:
	FOCUS_CHR("Dvorak")
	SET_NAME("Dvorak", "Dvorak")
	SET_MOTION("Dvorak", "ATTACK1",-1)

	SYS("#C2Dvorak is unconscious.")

EXIT:
	END
}

