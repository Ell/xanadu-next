// ローレライボス戦
//
// ROOM_FLAG
//  0: イベントトリガー対策
//
//




//////////////////////////////////////////////////////////////////////////////
// 初期化
//////////////////////////////////////////////////////////////////////////////

DEF("MAP")

RES("INIT")
{
	// EV C-9 《魅》のローレライ
	check_game_flag(3708)
	on_jump NEXT2

	// 40 「武」の賢者ドヴォルザーク
	ENTRY_CHR( 0, 040)
	PUT_CHR( 0, "Dvorak",  -2.00,-11.61,-35.13, 116)
	// 124 「魅」の賢者ローレライ
	ENTRY_CHR( 1, 124)
	PUT_CHR( 1, "Lorele",  0.00,0.00,6.00,   0)
NEXT2:

	CHECK_GAME_FLAG(6)
	ON_SKIP(1)
	INIT_SWITCH_ON("efc")

	CHECK_GAME_FLAG(4016)
	OFF_JUMP p
	SWITCH_ON("portal")
p:

	// マップ移動のフェード
	CHECK_GAME_FLAG(3000)
	OFF_JUMP START
	

	// もとどおり
	CHECK_GAME_FLAG(920)
	OFF_JUMP START
	BLUR(0)
	SLOW(0)
	CINEMA_ON(0)
	FADE_IN(-1)
	CINEMA_OFF(0)

	// フラグ戻して
	GAME_FLAG_OFF(3000)

START:



	// うにゃーん空間
	set_raster_info( 0, 10,10, 0.001,0.001, 1,0, -1,-1, 0.5)
	raster(0,1)	
	SET_CHR_SURFACE_ATTR("papa","M_0083e",0)

	// とりあえず全部隠す
	HIDE_CHR("1st")
	HIDE_CHR("2nd")
	HIDE_CHR("3rd")
	HIDE_CHR("core")
	HIDE_CHR("papa")
	HIDE_CHR("box")
	camera_off("こども用")
	CAMERA_Off("ぱぱ用")
	HIDE_CHR("stop")

	CHECK_GAME_FLAG(920)
	OFF_SKIP(1)
	HIDE_CHR("demoboss")	
	
	// ぱぱ用コリジョンモデルのアタッチ
	load_chr("M_0083\M_0083h",0)
//	set_collision_obj("papa",0)

	CHECK_GAME_FLAG(905)
	OFF_JUMP NEXT
	CHECK_GAME_FLAG(906)
	ON_JUMP NEXT
	SHOW_CHR("box")
	
NEXT:
}



// ----------------------------------------------------------------------------
// 部屋投入後デモ
// ----------------------------------------------------------------------------

DEF("demoboss")
RES("INIT")
{
//★05/02/18:デスの設定が変わるようなのでこの演出は没とする。
HIDE_CHR("demoboss")
end

	CHECK_GAME_FLAG(920)
	ON_JUMP NEXT

	BLUR(0)
	SLOW(0)
	FADE_IN(-1)
	CINEMA_ON(0)
	skip_enable(1)
	STOP_PC(0)
	PERMIT_SCRIPT_CAMERA(1)
	SET_SCRIPT_CAMERA(0,-8,-48,-20,180, 0, 8,12)
	ROTATE_SCRIPT_CAMERA(10,0,0, 240, 0)
	WAIT(240)
	CROSS_FADE(30)
	SET_SCRIPT_CAMERA(0,-1,-20, 0,180, 0, 8,12)
	ROTATE_SCRIPT_CAMERA(16,0,0, 240, 0)
	SCALE_SCRIPT_CAMERA(0.7, 300,1)
	WAIT(180)
	set_color("demoboss",0x00000000,120,1)
	WAIT(120)
	GAME_FLAG_ON(920)

	FADE_OUT_EX(30, 0, "0xff000000", 0)
	WAIT(60)
	CINEMA_OFF(0)
	PERMIT_SCRIPT_CAMERA(0)	
	HIDE_CHR("demoboss")
	FADE_IN_EX(30, 0, "0xff000000", 0)
	END
	
NEXT:
}


DEF("NullBase1")
RES("STEP_ON")
{
	stop_pc(0)
	sys("Reached the highest pedestal.")
}

// ----------------------------------------------------------------------------
// パパデス登場
// ----------------------------------------------------------------------------
DEF("start")
RES("EVENT")
{
	ENTRY_CHR( 2, 459)
	ENTRY_CHR( 3, 460)
	ENTRY_CHR( 4, 461)
	ENTRY_CHR( 5, 462)
	ENTRY_CHR( 6, 479)
	ENTRY_CHR( 7, 480)
	ENTRY_CHR( 8, 481)

	PUT_CHR( 2, "PoleRed",     0.00,0.00, 6.00,   0)
	PUT_CHR( 3, "PoleBlue",    5.20,0.00,-3.00,   0)
	PUT_CHR( 4, "PoleYellow", -5.20,0.00,-3.00,   0)
	PUT_CHR( 5, "Base",        0.00,0.00, 0.00,   0)
	PUT_CHR( 6, "NullBase3",   0.00,0.00, 0.00,   0)
	PUT_CHR( 7, "NullBase2",   0.00,0.50, 0.00,   0)
	PUT_CHR( 8, "NullBase1",   0.00,1.00, 0.00,   0)

// アニメサンプルです ---------------------------
	stop_pc(0)
	focus_chr_ex("Base",60,1,0)

	// ★３本の柱 //////////////////////////
	// せりあがりアニメ…
	set_motion("PoleRed",	"EMPTY1")
	set_motion("PoleBlue",	"EMPTY1")
	set_motion("PoleYellow","EMPTY1")
	wait(270)
	// 以降はループアニメを繰り返す
	set_motion("PoleRed",	"EMPTY2")
	set_motion("PoleBlue",	"EMPTY2")
	set_motion("PoleYellow","EMPTY2")

	// ★台座 ///////////////////////////////
	// せりあがりアニメ…
	set_motion("Base","EMPTY1")
	wait(369)
	// 以降はループアニメを繰り返す
	set_motion("Base","EMPTY2")

	jump NEXT

//-- ローレライイベント ----------------------------------------------

	// EV C-9 《魅》のローレライ
	check_game_flag(3708)
	on_jump NEXT

	STOP_PC(0)

	CINEMA_ON(0)
	cross_fade(100)

	permit_script_camera(1)
	set_script_camera(0.0,0.0,0.0,  -15.5,180.0,0.0, 20, 15.0)
	SET_POS("PC",0,0,-6)

	SET_SPOT_ORG( 1, 0.00,0.00,0.00 )

	wait(40)

	move_script_look_at(0,0,8, 300, 1)
	scale_script_camera(0.5, 300, 1)


//　　ボスマップに入るとイベント開始。ローレライが主人公に背中
//　　を向けて立っている。

	MSG_EX("#S3#C3Lorelei|#C0...Just who might YOU be?",-1,2)

	wait_camera(0)



//　　主人公をほうへ振り向くローレライ。

	set_deg("Lorele", 180)

	MSG_EX("#S3#C3Lorelei|#C0My name is Lorelei.",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0I joined the Dragon King|much like the Black Bride...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0Knight, are you in agreement with those|ignorant sages? Have you come here to slay me?",-1,2)

//　　ローレライ、ゆっくり主人公のほうへ歩み寄る。

//	INIT_WALK_DST("Lorele")
//	set_walk_dst("Lorele", 0, 0, 0)
//	walk_pos("Lorele",0,0.022)

	move_vec("Lorele", 0,0,-6, 400)
	move_script_look_at(0,0,-4, 400, 1)
	scale_script_camera(0.8, 400, 1)

	MSG_EX("#S3#C3Lorelei|#C0For a chick to be born it must|burst through the egg's shell...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0To create such an event,|the whole world must be thrown into ruin.",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0'Twas known as a paradise,|that prosperous land from which Xanadu rose...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0And yet, the reality was, the greedy people were|drowning themselves in pleasure and indolence.",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0For men who have forsaken the moral path,|destruction at Master Galsis' hands is truly necessary...",-1,2)

	wait_camera(0)
	wait_walk("Lorele")

	cross_fade(60)
	set_script_camera(0.0,0.0,-4.0,  -15.5,10.0,0.0, 10, 15.0)

	MSG_EX("#S3#C3Lorelei|#C0Oh? Allow me to peer...into your own future...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0I see a man, once content with his own weakness,|and yet...",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0He is now spurred on by the fear of his|approaching death... The knight's pride is|but an embarrassment...",-1,2)

	wait_camera(0)

//　　ローレライ、醜い死神の姿へと変化する。


	ROTATE_SCRIPT_CAMERA(5,0,0,180, 0)
	QUAKE(0,3,260)
	BLUR(30)
	SLOW(1)	
	FADE_IN_EX(20, 0, "0xffffffff", 0)
	ATTACH_EFC("EFC_FLY_INAZUMA","Lorele","POS")
	move_vec("Lorele", 0,-4,0, 180)
	wait(180)
	HIDE_CHR("Lorele")

	//パパ出し	
	SET_SCRIPT_CAMERA(0,1.5,0, -5,180,0, 12,12)
	ROTATE_SCRIPT_CAMERA(5,0,0,260, 0)
	QUAKE(0,3,260)
	BLUR(30)
	SLOW(1)	
	FADE_IN_EX(20, 0, "0xffffffff", 0)

	ATTACH_EFC("EFC_FLY_INAZUMA","papa","POS")
	SHOW_CHR("papa")
	SET_MOTION("papa","EMPTY1",0)
	WAIT(220)
	//顔アップ
	CROSS_FADE(30)
	SET_SCRIPT_CAMERA_EX("papa",2, -20,120,0, 6, 14)
	SCALE_SCRIPT_CAMERA(1.2, 180,1)
	WAIT(180)

	MSG_EX("#S3#C3Lorelei|#C0Judgment is at hand, knight.",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0The cowardice you bear, much like Xanadu's sins,|would mean death ten thousand fold in a world of|Galsis' making.",-1,2)
	MSG_EX("#S3#C3Lorelei|#C0Die here and now, a nobody, a worthless knight|whose name will never be remembered!",-1,2)

	game_flag_on(3708)

	//カメラセットオン
	BLUR(0)
	SLOW(0)
	CROSS_FADE(60)
	PERMIT_SCRIPT_CAMERA(0)
	FOCUS_CHR_ex("papa",0,0,0)
	SET_SCROLL_RECT(-5,-7.5,5,7.5)

	// シネマＯＦＦ
	CINEMA_OFF(0)

	END



//-- ボスの登場 ------------------------------------------------------

	CHECK_GAME_FLAG(905)
	ON_JUMP NEXT

	// PCの動きを止める
	GAME_FLAG_ON(905)
	STOP_PC(0)
	FADE_OUT_EX(30, 0, "0xff000000", 0)
	WAIT(30)
	CAMERA_OFF("通常用")
	CAMERA_ON("ぱぱ用")
	SET_POS("PC",0,0,-6)	
//	BGM(4,0,-1)	
	BGM(17,0,-1)

//	SHOW_CHR("stop")
//	SHOW_CHR("papa")

	SET_SCROLL_RECT(-5,-7.5,5,7.5)

//	FOCUS_CHR_ex("papa",0,0,0)
	FOCUS_CHR_ex("PC",0,0,0)

	FADE_IN_EX(30, 0, "0xff000000", 0)
//	WAIT(30)

NEXT:
	END
}

