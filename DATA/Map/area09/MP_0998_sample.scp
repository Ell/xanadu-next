// ----------------------------------------------------------------------------
// 親デス死亡
// ----------------------------------------------------------------------------
DEF("papa")
RES("KILL")
{
	kill_chr("papa",0,1,60)
	wait(60)

	CROSS_FADE(60)
	
	show_chr("1st")
	show_chr("2nd")
	show_chr("3rd")
	show_chr("core")
	SET_DEG_EX("1st","")
	SET_DEG_EX("2nd","")
	SET_DEG_EX("3rd","")

	set_pos("PC",0,0,0)
	FOCUS_CHR_ex("PC",0,0,0)

	camera_on("こども用")
	camera_off("ぱぱ用")

	SET_SCROLL_RECT(-5,-4.5,5,7.5)

	end
}
