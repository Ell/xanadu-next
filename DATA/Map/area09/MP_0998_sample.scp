// ----------------------------------------------------------------------------
// 子デス死亡
// ----------------------------------------------------------------------------
DEF("1st")
RES("KILL")
{
	set_motion("1st","DOWN")
	attach_efc("EFC_TRE_BREAK","1st","CTR")
	
	room_flag_on(0)
	check_room_flag(1)
	off_jump skip
	check_room_flag(2)
	off_jump skip
	
	call defeat_boss
skip:
}
DEF("2nd")
RES("KILL")
{
	set_motion("2nd","DOWN")
	attach_efc("EFC_TRE_BREAK","2nd","CTR")

	room_flag_on(1)
	check_room_flag(0)
	off_jump skip
	check_room_flag(2)
	off_jump skip
	
	call defeat_boss
skip:
}
DEF("3rd")
RES("KILL")
{
	set_motion("3rd","DOWN")
	attach_efc("EFC_TRE_BREAK","3rd","CTR")

	room_flag_on(2)
	check_room_flag(0)
	off_jump skip
	check_room_flag(1)
	off_jump skip
	
	call defeat_boss
skip:
}

// ----------------------------------------------------------------------------
// 子デス死亡
// ----------------------------------------------------------------------------
//DEF("core")
//RES("KILL")

@defeat_boss
{
	GAME_FLAG_ON(905)
	delete_efc("1st")
	delete_efc("2nd")
	delete_efc("3rd")
	STOP_PC(0)

	SET_SCROLL_RECT(-1000,-1000,1000,1000)

	CINEMA_ON(0)
	CROSS_FADE(15)
	PERMIT_SCRIPT_CAMERA(1)
	CAMERA_OFF("こども用")
	CAMERA_OFF("ぱぱ用")
	CAMERA_ON("通常用")
	
	KILL_CHR("1st",0,1,240)
	ATTACH_EFC("EFC_FLY_DEAD2","1st","POS")
	KILL_CHR("2nd",0,1,240)
	ATTACH_EFC("EFC_FLY_DEAD2","2nd","POS")
	KILL_CHR("3rd",0,1,240)
	ATTACH_EFC("EFC_FLY_DEAD2","3rd","POS")

	HIDE_CHR("core")
	
	// 宝箱
	CROSS_FADE(60)
	SET_SCRIPT_CAMERA( 0,0.5,0,-60,180,0,15,32 )
	SCALE_SCRIPT_CAMERA(0.95, 150,0)
	HIDE_CHR("stop")
	WAIT(30)
	SWITCH_OFF("efc")
//	EFC("EFC_ADD_TREASURE",0,0,0)
//	SHOW_CHR("box")
	WAIT(120)

	// BGM変更、シネマ解除
//	bgm(2,0,-1)
	bgm(11,0,-1)
	CROSS_FADE(60)
	PERMIT_SCRIPT_CAMERA(0)
	CINEMA_OFF(0)

	GAME_FLAG_ON(6)

	ret
}
