//////////////////////////////////////////////////////////////////////
// テレポーターに乗った
//////////////////////////////////////////////////////////////////////
DEF("NullBase1")
RES("STEP_ON")
{
	stop_pc(0)
	CINEMA_ON(0)

	INIT_WALK_DST("PC")
	SET_WALK_DST("PC",0,1,0)
	WALK_POS("PC",0,0.026)
	WAIT_WALK("PC")
	FOCUS_CHR("PC")

	WAIT(90)
	ATTACH_EFC("EFC_WARP_T","NullBase1","POS")
	SHAKE(5,5)
	WARP_CHR("PC", 0)
	wait(120)

	fade_out(60)
	wait(120)

	SET_MSG_TIME(5,40,50, 30)
	MSG_EX("#S3#C0臆病は悪いことではない───|彼の口癖でした。|　|自分の臆病を知りつつも、|逃げないことこそが大切なのだ。|　|自分の弱さを認めること、それは強さであると。",-1,0x00000090)
	MSG_EX("#S3#C0しかし、そんな彼も|この後、待ち受ける事実に|かつてない衝撃を受けることになります。|　|それは、この私にとっても同じでした。",-1,0x00000090)
	SET_MSG_TIME(-1,-1,-1,-1)

	ENTRY_MAP("0682_0998")
}

RES("INIT")
{
	CHECK_ENTRY_GATE("0998_0682")
	OFF_JUMP EXIT

	stop_pc(0)
	set_pos("PC", -0.00,1.00, 0.00)
	set_deg("PC", 180)
	WARP_CHR("PC", 1)
	wait(120)

	look_chr("PC", "-")
	INIT_WALK_DST("PC")
	set_walk_dst("PC", 0.0, 0.0, -3.0)
	walk_pos("PC",0,0.03)
	wait_walk("PC")

	FOCUS_CHR("PC")

EXIT:
	END
}


//////////////////////////////////////////////////////////////////////////////
// ポータル
//////////////////////////////////////////////////////////////////////////////
DEF("portal")

RES("EVENT")
{
	// ★05/06/20:Ｆクリスタルは最初の一回だけでいい事になりました（ひ）

	// 既にあけているか？
	CHECK_GAME_FLAG(4016)
	ON_JUMP NEXT

	// ファイアクリスタルを持っているか？
	CHECK_ITEM(177,1)
	OFF_JUMP NEXT2

	// 出現イベント
	STOP_PC(0)
	CINEMA_ON(0)
	SET_WALK_DST("PC",0,-11.5,-45.625)
	WALK_POS("PC",0,0.026)
	WAIT_WALK("PC")
	INIT_WALK_DST("PC")
	WAIT(30)
	
	CROSS_FADE(60)
	PERMIT_SCRIPT_CAMERA(1)
	SET_SCRIPT_CAMERA_EX( "portal", -2, -45,-15,0, 12, 32)
	ROTATE_SCRIPT_CAMERA( 0,30,0,999, 0)
	WAIT(60)
	KILL_CHR("cover",0,1,120)
	SWITCH_ON("portal")
	WAIT(120)
	WAIT(120)

	GAME_FLAG_ON(4016)
	
	CROSS_FADE(30)
	PERMIT_SCRIPT_CAMERA(0)
	WAIT(60)
	CALL_PORTAL(0)
	CINEMA_OFF(0)
	END

NEXT:

	// ポータル
	STOP_PC(0)
	CINEMA_ON(0)
	SET_WALK_DST("PC",0,-11.5,-45.625)
	WALK_POS("PC",0,0.026)
	WAIT_WALK("PC")
	INIT_WALK_DST("PC")
	WAIT(30)
	CALL_PORTAL(0)
	CINEMA_OFF(0)

NEXT2:

}


//////////////////////////////////////////////////////////////////////////////
// セーブ
//////////////////////////////////////////////////////////////////////////////

DEF("save")
RES("CLICK")
{
	CINEMA_ON(0)
	STOP_PC(0)

	SEL("#c2セーブしますか？|セーブ|やめる")
	CHECK_SELECT(0)
	OFF_JUMP SEL_A

		CALL_SHOP(4)
		SE("SE_UP_PRM")
		SYS("#c2今までの冒険を記録しました。")

SEL_A:
	CHECK_SELECT(1)

	CINEMA_OFF(0)
}


//////////////////////////////////////////////////////////////////////////////
// ドヴォルザーク
//////////////////////////////////////////////////////////////////////////////
DEF("Dvorak")

RES("CLICK")
{
	// EV C-8 ドヴォルザークの敗北
	check_game_flag(3707)
	on_jump TALK1_2

	CINEMA_ON(0)
	set_pos("PC", -0.62,-11.61,-35)
	SET_DEG("PC",290)

	cross_fade(120)
	permit_script_camera(1)
	set_script_camera(-1.04,-11.74,-35.76,  -25.5,200.0,0.0, 12, 15.0)

	rotate_script_camera(0,-20,0, 2000, 1)

	set_skip_label("SKIP")		

	wait(120)

	SET_MOTION("Dvorak", "ATTACK1",-1)
	MSG_EX("#S3#C0ドヴォルザーク「貴公は……くっ……」",-1,2)
	MSG_EX("#S3#C0ドヴォルザーク「みっともないところを見せるな……」",-1,2)
	MSG_EX("#S3#C0ドヴォルザーク「……この先にいるのはローレライ……」",-1,2)
	MSG_EX("#S3#C0ドヴォルザーク「大罪を犯したゆえ、|　　　　　　　　我々が幽閉したかつての同志だ……」",-1,2)
	MSG_EX("#S3#C0ドヴォルザーク「悪いことは言わぬ……|　　　　　　　　すぐさま……引き返すがいい……」",-1,2)
	MSG_EX("#S3#C0ドヴォルザーク「ぐっ……申し訳ありませぬ……|　　　　　　　　……フローレット様……」",-1,2)

	SYS("ドヴォルザークは気を失ったようだ。")

	fade_out(120)
	wait(120)
	permit_script_camera(0)
	CINEMA_OFF(0)
	fade_in(60)
	wait(60)
	game_flag_on(3707)

	jump EXIT



TALK1_2:
	FOCUS_CHR("Dvorak")
	SET_NAME("Dvorak", "ドヴォルザーク")

	SYS("#C2ドヴォルザークは気を失っている。")

EXIT:
	END
}




