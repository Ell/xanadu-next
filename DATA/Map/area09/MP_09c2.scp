//////////////////////////////////////////////////////////////////////
// ガンダルチュアイベント

DEF("EV_Gandaltua")

RES("EVENT")
{
	// EV C-7 ガンダルチュア
	check_game_flag(3706)
	on_jump EXIT

	// シネスコ時スペクタクルズONFF
	ROOM_FLAG_OFF(254)

	BGM(18, 0, -1)

	CINEMA_ON(0)
	stop_pc(0)
	set_pos("PC",4.82,16.00,-0.04)
	set_deg("PC", 94)

	cross_fade(120)
	permit_script_camera(1)
	set_script_camera(11.67,16.00,-0.29, -15.5,250.0,0.0, 20, 15.0)
	rotate_script_camera(0,30,0, 300, 1)

	//武器もってなければスキップ。
	CHECK_PC_EQUIP(0,-1)
	ON_SKIP(1)
	PC_WEAPON(1,1)

	set_skip_label("SKIP")

//　　祠の中に入って、ゲートの直前マップまで進むとイベント開始。
//　　橋の上に巨漢の男、ガンダルチュアが立っている。

	MSG_EX("#S3#C3Large Man|#C0So you approach as well...",-1,2)

	wait_camera(0)

//　　身構える主人公。
//　　武器もってなければスキップ。
	CHECK_PC_EQUIP(0,-1)
	ON_SKIP(5)
	scale_script_camera(0.8, 20, 1)
	cross_fade(60)
	wait(60)
	MSG_EX("#S3#C3Large Man|#C0Stay your hand. My outward aspect may be intimidating,|but do not mistake me for a monster.",-1,2)
	MSG_EX("#S3#C3Large Man|#C0Despite appearances, I am rather brittle.",-1,2)

	WAIT(60)
	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C3Large Man|#C0I am called Gandharva.",-1,2)

	MSG_EX("#S3#C3Gandharva|#C0As you might already be aware, obstinate knight,|I am a friend of Dvorak.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0I have reasons for waiting|in such a treacherous place...",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0You see, I have a request to make of you.",-1,2)

//　　剣を鞘に収める主人公。

	set_script_camera(11.67,16.00,-0.29, -15.5,270.0,0.0, 15, 15.0)
	cross_fade(60)


	//武器もってなければスキップ。
	CHECK_PC_EQUIP(0,-1)
	ON_SKIP(1)
	PC_WEAPON(0)

	wait(60)
	SET_MOTION("PC","EMPTY23",-1)
	WAIT(100)

	MSG_EX("#S3#C3Gandharva|#C0Heheh...|I like a man who listens.",-1,2)
	wait(40)
	MSG_EX("#S3#C3Gandharva|#C0Although our reasons differ, both|our objectives lie within Castle Strangerock.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0Up ahead is a place where time and space are askew.|'Tis known as the [Time Crevice].",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0It takes a fair amount of skill to make it through,|but you will find it a direct route into Castle Strangerock.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0I am aware there is a device within the castle|which is capable of extinguishing this troublesome barrier.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0If you chance upon that device,|I would like you to release the barrier.",-1,2)
	wait(60)

	set_script_camera(6.33,16.00,-0.33, -15.5,0.0,0.0, 12, 15.0)
	move_script_look_at(2,0,0, 600, 1)
	cross_fade(60)

	MSG_EX("#S3#C3Gandharva|#C0...However, to reach Castle Strangerock there|is also an obstacle of another sort, a woman.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0You will find this witch within the Time Crevice|itself. She has been confined there for an age.",-1,2)
	wait(40)
	MSG_EX("#S3#C3Gandharva|#C0While Dvorak has gone on ahead,|I fear she may be the end of him.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0If by chance you should meet, 'twould|be wise to pool your strength against her.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0Very well, then, O Mighty Knight.|I hope you will heed my request.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0I'm sure you will be of aid...|Your aura gives me great confidence.",-1,2)

	fade_out(60)
	WAIT(90)


SKIP:
	PC_WEAPON(0,1)

	game_flag_on(3706)
	bgm(-1,0,-1)

	FOCUS_CHR("PC")
	permit_script_camera(0)
	CINEMA_OFF(0)
	fade_in(60)
	wait(60)

	// シネスコ時スペクタクルズONFF
	ROOM_FLAG_ON(254)

EXIT:
	end
}

//////////////////////////////////////////////////////////////////////
// ガンダルチュア

DEF("Gandaltua")

RES("INIT")
{
	// EV C-7c ガンダルチュアとシュトゥルムの会話イベント
	check_game_flag(3725)
	on_jump EXIT

	// EV C-7b ガンダルチュアとの会話後、ランダムマップに飛んだ
	check_game_flag(3724)
	off_jump EXIT

//--------------------------------------------------------------------

	// シネスコ時スペクタクルズONFF
	ROOM_FLAG_OFF(254)

	CINEMA_ON(0)
	stop_pc(0)


	HIDE_CHR("PC")

	stop_camera(0)
	BLUR(0)
	SLOW(0)

	fade_out(0)
	wait(60)

	permit_script_camera(1)
	set_script_camera(12.67,16.00,-0.29, -15.5,270.0,0.0, 12, 15.0)

	set_deg("Gandaltua", 90)

	fade_in(120)
	wait(120)

	set_skip_label("SKIP")

//　　主人公がゲートに入って時の狭間に移動したら、画面ブラック
//　　アウト。フェードアウト抜けて、再び祠のガンダルチュア。
//　　主人公の去った扉のほうを見つめている。

	SHOW_CHR("Sturm")
	SHOW_CHR("Tiowald")
	SHOW_CHR("Beatrice")
	SHOW_CHR("Avatarlaha")
	set_pos("Sturm",      -2.27,16.00,-1.22)
	set_pos("Tiowald",    -5.09,16.00,-0.31)
	set_pos("Beatrice",   -1.42,16.00,0.42)
	set_pos("Avatarlaha", -5.24,16.00,1.18)
	set_deg("Sturm",      90)
	set_deg("Tiowald",    90)
	set_deg("Beatrice",   90)
	set_deg("Avatarlaha", 90)

	MSG_EX("#S3#C3Beatrice|#C0It seems he has left...",-1,2)

	move_script_look_at(-4,1,0, 600, 1)
	rotate_script_camera(10,0,0, 600, 1)

	INIT_WALK_DST("Beatrice")
	set_walk_dst("Beatrice",  4.05,16.00,0.54)

	INIT_WALK_DST("Sturm")
	set_walk_dst("Sturm",  1.71,16.00,-1.27)

	INIT_WALK_DST("Avatarlaha")
	set_walk_dst("Avatarlaha",  0.16,16.00,1.19)

	INIT_WALK_DST("Tiowald")
	set_walk_dst("Tiowald",  -2.42,16.00,-0.34)

	walk_pos("Beatrice",0,0.05)
	walk_pos("Sturm",0,0.05)
	wait(40)
	walk_pos("Avatarlaha",0,0.05)
	walk_pos("Tiowald",0,0.05)

	wait_walk("Beatrice")
	set_deg("Beatrice", 111)
	look_chr("Beatrice","Gandaltua")

	wait_walk("Sturm")
	set_deg("Sturm", 171)

	wait_walk("Avatarlaha")
	set_deg_ex("Avatarlaha", "Sturm")
	look_chr("Avatarlaha","Gandaltua")

	wait(120)
//	wait_camera(0)

	MSG_EX("#S3#C3Gandharva|#C0'Twas fortuitous that I managed to|speak with him in time.",-1,2)

//	set_deg_ex("Gandaltua","Tiowald")
	set_deg("Gandaltua" 170)
	wait(5)
	INIT_WALK_DST("Gandaltua")
	set_walk_dst("Gandaltua",  8.39,16.00,-0.27)
	walk_pos("Gandaltua",0,0.03)
	wait_walk("Gandaltua")

	SET_MOTION("Avatarlaha", "ATTACK1",-1)
	MSG_EX("#S3#C3Abhidharma|#C0Our power is nary a match|for Lorelei.",-1,2)
	MSG_EX("#S3#C3Abhidharma|#C0Those two...|I fear they may not survive this task.",-1,2)

	set_motion("Sturm", "ATTACK1", -1)
	MSG_EX("#S3#C3Sturm|#C0...Are not the knights of this era without power?|I hear tell they've fallen into ruin.",-1,2)
	MSG_EX("#S3#C3Sturm|#C0Will he truly be all right?",-1,2)

//	set_deg_ex("Beatrice","Sturm")
	set_deg("Beatrice",190)
	look_chr("Beatrice","Sturm")
//	SET_MOTION("Beatrice", "ATTACK1",-1)

	MSG_EX("#S3#C3Beatrice|#C0He has reclaimed the crowns from the ruins.|Surely you have seen him contend against the|creatures there.",-1,2)
	MSG_EX("#S3#C3Beatrice|#C0His strength grows with every battle.",-1,2)
	MSG_EX("#S3#C3Beatrice|#C0I have heard he fights to prolong his life,|but I feel he bears an even greater reason to fight.",-1,2)
	MSG_EX("#S3#C3Beatrice|#C0While I am unaware what reason that is...",-1,2)
	MSG_EX("#S3#C3Beatrice|#C0That man is the quintessential knight.",-1,2)
	wait(100)

//	cross_fade(60)
//	set_script_camera(2.56,17.00,0.99, -10.5,250.0,0.0, 10, 15.0)
//	rotate_script_camera(0,-5,0, 2000, 1)

	MSG_EX("#S3#C3Theobald|#C0...",-1,2)

	set_deg("Avatarlaha", 208)
	look_chr("Avatarlaha","Tiowald")
	wait(40)

	MSG_EX("#S3#C3Abhidharma|#C0Elder Theobald, what troubles you?",-1,2)

//	set_deg_ex("Tiowald","Avatarlaha")
	wait(20)
	set_deg_ex("Beatrice","Sturm")
	look_chr("Beatrice","Tiowald")

	wait(40)
	look_chr("Tiowald","Avatarlaha")
	MSG_EX("#S3#C3Theobald|#C0...I have something I feel|I must share with everyone.",-1,2)
	MSG_EX("#S3#C3Theobald|#C0Shortly before coming here,|I held palaver with the stars.",-1,2)
	wait(40)
	MSG_EX("#S3#C3Abhidharma|#C0Ooh, your astrology always was rather|famous around the castle, wasn't it?",-1,2)
	MSG_EX("#S3#C3Abhidharma|#C0What did you see?",-1,2)
	wait(40)
	MSG_EX("#S3#C3Theobald|#C0...It appears the three stars|have aligned themselves as one.",-1,2)

	wait(20)
//	SET_MOTION("Sturm", "ATTACK1",-1)
	set_deg("Sturm", 180)
	look_chr("Sturm","Tiowald")
	wait(20)
	MSG_EX("#S3#C3Sturm|#C0Three stars...",-1,2)
	MSG_EX("#S3#C3Sturm|#C0Are you referring to the Dragon's Fang?",-1,2)
	wait(40)
	look_chr("Tiowald","Gandaltua")
	MSG_EX("#S3#C3Theobald|#C0From what I have foreseen, all will|become clear with this battle.",-1,2)

	wait(40)
//	move_script_look_at(1,1,0, 200, 1)

	SET_MOTION("Gandaltua", "ATTACK1",-1)
	MSG_EX("#S3#C3Gandharva|#C0I wonder if we should reveal ourselves to him.",-1,2)
	MSG_EX("#S3#C3Gandharva|#C0Our history...",-1,2)
	wait(60)
	scale_script_camera(1.5, 220, 1)
	fade_out(180)

	MSG_EX("#S3#C3Gandharva|#C0...and about Lady Fleurette's destiny.",-1,2)

	wait_camera(0)

//　　画面フェードアウト抜けて、時の狭間マップ。
//　　操作フリーに。

	// ランダムマップにつなぐ

SKIP:
	wait(120)

	wait(2)
	SHOW_CHR("PC")
	game_flag_on(3725)

	ENTRY_RANDOM_MAP(0, 5,5, 3,4, "rndmap_0998")

//--------------------------------------------------------------------
EXIT:

	END
}



RES("CLICK")
{

	FOCUS_CHR("Gandaltua")
	SET_NAME("Gandaltua", "Gandharva")
	SET_MOTION("Gandaltua", "ATTACK1",-1)

//	check_room_flag(0)
//	on_jump TALK1_2

TALK1_1:
	MSG("Once you're out of the Time Crevice, I ask that|you release the barrier around Castle Strangerock.")
	MSG("I'm sure you will be of aid...|Your aura gives me great confidence.")
	room_flag_on(0)
	jump EXIT

////　　以降、繰り返し用メッセージ
//TALK1_2:
//	MSG("ドヴォルザークを助けてやってくれ。")
//	MSG("思うところは色々あるだろうが|ここは目的が同じもの同士、|協力し合おうじゃないか。")
//	MSG("あんたはきっと助けてくれる。|そんな気がするんだよな。")
	
EXIT:
	SET_MOTION("Gandaltua","STAND",-1)
	END
}
