// ----------------------------------------------------------------------------
// 初期状態                                                                    
// ----------------------------------------------------------------------------

DEF("MAP")
RES("INIT")
{
	// シネスコ時スペクタクルズON
	ROOM_FLAG_ON(254)

	HIDE_CHR("Sturm")
	HIDE_CHR("Tiowald")
	HIDE_CHR("Beatrice")
	HIDE_CHR("Avatarlaha")

	// EV C-7 ガンダルチュア
	check_game_flag(3725)
	off_jump NEXT2

	HIDE_CHR("Gandaltua")

NEXT2:
	// EV C-7c ガンダルチュアとシュトゥルムの会話イベント
	check_game_flag(3725)
	on_jump NEXT3
	// EV C-7b ガンダルチュアとの会話後、ランダムマップに飛んだ
	check_game_flag(3724)
	off_jump NEXT3
	// BGM異界イベント用
	BGM(22, 0, -1)

NEXT3:
	// 中ボスストッパー隠し
	INIT_SWITCH_ON("stop")

	CHECK_GAME_FLAG(936)
	OFF_JUMP next
	// ガーディアン
	put_monster("m00",332,14,0,0,0)
	put_monster("m01",332,14,0,0,1)
	put_monster("m02",332,14,0,0,2)
	put_monster("m03",332,14,0,0,3)
	put_monster("m04",332,14,0,0,4)
	put_monster("m05",332,14,0,0,5)
	put_monster("m06",332,14,0,0,6)
	put_monster("m07",332,14,0,0,7)
	HIDE_CHR("tbox2")
next:

	// カギ設定
	CHECK_GAME_FLAG(1915)
	ON_SKIP(2)
	KAGI("d1915",1)
	SKIP(1)
	INIT_SWITCH_ON("d1915")

	// カギ設定
	CHECK_GAME_FLAG(936)
	OFF_SKIP(5)
	CHECK_GAME_FLAG(1921)
	ON_SKIP(2)
	KAGI("d1921",1)
	SKIP(1)
	INIT_SWITCH_ON("d1921")

	// カギ設定
	CHECK_GAME_FLAG(1922)
	ON_SKIP(2)
	KAGI("d1922",1)
	SKIP(1)
	INIT_SWITCH_ON("d1922")

	// カギ設定
	CHECK_GAME_FLAG(1923)
	ON_SKIP(2)
	KAGI("d1923",1)
	SKIP(1)
	INIT_SWITCH_ON("d1923")

//	CHECK_ENTRY_GATE("09c2_09c3")
//	OFF_JUMP BGMCHK
//	CHECK_GAME_FLAG(936)
//	ON_JUMP BGMCHK
//	stop_bgm(0,2000)
//BGMCHK:

}

// ボス倒したぞ--------------------------------------------------------------
RES("WIN")
{
	CHECK_GAME_FLAG(936)
	ON_JUMP next

		STOP_PC(0)
		WAIT(60)
		SE("SE_STOPPER")
		CINEMA_ON(0)
		FOCUS_CHR("stop")
		SWITCH_ON("stop")

		// 宝箱消去
		SHOW_CHR("tbox1")
		SHOW_CHR("tbox3")
		SHOW_CHR("tbox4")
		EFC("EFC_ADD_TREASURE",-6.802379,0,-12.968599)
		EFC("EFC_ADD_TREASURE",12.821179,0,6.965584)
		EFC("EFC_ADD_TREASURE",0.024324,0,14.597500)

		WAIT(90)
		CINEMA_OFF(0)

		bgm(-1,0,-1)

	// カギ設定
	KAGI("d1921",1)

	GAME_FLAG_ON(936)

next:
}

