// ----------------------------------------------------------------------------
// 中ボスイベントトリガー
// ----------------------------------------------------------------------------

DEF("tbox2")
RES("CLICK")
{
	// 既に倒しているのでは
	CHECK_GAME_FLAG(936)
	ON_JUMP next

	// 二度目に踏んでも何も出ないよ
//	CHECK_ROOM_FLAG(1)
//	ON_JUMP next

	CINEMA_ON(0)
	STOP_PC(0)

	OPEN_BOX("CUR")
	WAIT(60)

	// イベント開始
	FOCUS_CHR("stop")
	QUAKE(0,10,60)
	SWITCH_OFF("stop")
	WAIT(60)
	FOCUS_CHR("null")

	// 小ボス曲
	BGM(14,0,-1)

	// 宝箱消去
	HIDE_CHR("tbox1")
	HIDE_CHR("tbox3")
	HIDE_CHR("tbox4")

	// ガーディアン
	put_monster("m00",332,14,2,0,0)
	put_monster("m01",332,14,2,0,1)
	put_monster("m02",332,14,2,0,2)
	put_monster("m03",332,14,2,0,3)
	put_monster("m04",332,14,2,0,4)
	put_monster("m05",332,14,2,0,5)
	put_monster("m06",332,14,2,0,6)
	put_monster("m07",332,14,2,0,7)
	QUAKE(0,10,60)

	WAIT(120)
	CINEMA_OFF(0)

//	ROOM_FLAG_ON(1)

next:
}


