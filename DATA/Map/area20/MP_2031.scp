// 扉 ////////////////////////////////////////////////////////////////////////

// 北 ------------------------------
DEF("door_N")
RES("CLICK")
{
	check_game_flag(1003)
	on_jump unlocked
	wait(0)
	end
unlocked:
}

// 西 ------------------------------
DEF("door_W")
