
// ----------------------------------------------------------------------------
// マップ初期状態                                                              
// ----------------------------------------------------------------------------

DEF("MAP")
RES("INIT")
{
	
// treasure -----------------------------------------
trs1:
	check_game_flag(1013)
	on_jump open_trs1
	set_treasure("trs1",1,228,"t1")
	jump trs2
open_trs1:
	hide_chr("trs1")

}

// どっきり /////////////////////////////////
DEF("trap1")
RES("KILL")
{
	kill_chr("trap1",0,0,-1)
	put_monster("skull1",	319,1,0,0,0)
}
DEF("trap2")
RES("KILL")
{
	kill_chr("trap2",0,0,-1)
	put_monster("bat1",		005,1,0,0,1)
}
DEF("trap3")
RES("KILL")
{
	kill_chr("trap3",0,0,-1)
	put_monster("jely1",	004,1,0,0,2)
}


// 中身 //////////////////////////////////////////////////////
DEF("t1")
RES("CATCH")
{
	game_flag_on(1013)
}
