
// ----------------------------------------------------------------------------
// マップ初期状態                                                              
// ----------------------------------------------------------------------------

DEF("MAP")
RES("INIT")
{
// treasure -----------------------------------------

trs1:
	check_game_flag(1015)
	on_jump open_trs1
	set_treasure("box1",0,100,"t1")
	set_treasure("box1",0,100,"t1")
	set_treasure("box1",0,100,"t1")
	set_treasure("box1",0,100,"t1")
	set_treasure("box1",1,060,"t1")
	set_treasure("box1",1,210,"t1")
	set_treasure("box1",1,226,"t1")
	set_treasure("box1",1,227,"t1")
	jump trs2
open_trs1:
	hide_chr("box1")
trs2:

// door(S) ------------------------------------------
	check_game_flag(1014)
	off_jump skip_S
	init_switch_on("map38_A")
skip_S:
}

// 中身 //////////////////////////////////////////////////////
DEF("t1")
RES("CATCH")
{
	game_flag_on(1015)
}
