//SE_KIMA_06 ,"XNSE542",0,0   // 死亡
//SE_KIMA_07 ,"XNSE543",0,0   // 攻撃：殴り
//SE_KIMA_08 ,"XNSE585",0,0   // 攻撃：炎ブレス吐く前の吸い込み
//SE_KIMA_09 ,"XNSE580",0,0   // 移動：足音
//SE_KIMA_10 ,"XNSE586",0,0   // 移動：足音（デカ）


// 基本SE
X1 1080 SE_KIMA_02

X2 1385 SE_KIMA_01
X3 1415 SE_KIMA_04
X4 1465 SE_KIMA_01

